				SendClientMessage(to_player, 0xFFFFFFFF, "รร รฆรฌรจรฒรฅ {00CC00}Y {FFFFFF}รทรฒรฎรกรป รงร รชรซรพรทรจรฒรผ รฑรครฅรซรชรณ รจรซรจ {FF6600}N {FFFFFF}รครซรฟ รฎรฒรชร รงร ");

				format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ %s รชรณรฏรจรฒรผ รร รธรณ รงร รฏรฐร รขรฎรทรญรณรพ รฑรฒร รญรถรจรพ \"%s\" รงร  %d รฐรณรก", GetPlayerNameEx(to_player), GetFuelStationData(value_1, FS_NAME), value_2);
				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
			case OFFER_TYPE_FILL_CAR:
