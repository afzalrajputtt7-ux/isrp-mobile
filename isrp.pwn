CMD:drugs(playerid, params[])
{
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /drugs [รชรฎรซ-รขรฎ รฃรฐร รฌรฌ]");
	
	extract params -> new drugs;
	
	if(!(1 <= drugs <= 3)) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรซรจรทรฅรฑรฒรขรฎ รฃรฐร รฌรฌ รฎรฒ 1 รครฎ 3");

	new fmt_msg[512];

	if(GetPlayerData(playerid, P_DRUGS) < drugs) return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฑรฒรฎรซรผรชรฎ รญร รฐรชรฎรฒรจรชรฎรข");

	AddPlayerData(playerid, P_DRUGS, -, drugs);

	new Float:health;
    ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0);
	GetPlayerHealth(playerid, health);
	SetPlayerHealthEx(playerid, health + (drugs*20.0));

	SetPlayerWeather(playerid, -68);

	SetTimerEx("DrugEffectGone", 40000, false, "i", playerid);

	Action(playerid, "รจรฑรฏรฎรซรผรงรฎรขร รซ รญร รฐรชรฎรฒรจรชรจ", _, false);

	format(fmt_msg, sizeof fmt_msg, "รรป รจรฑรฏรฎรซรผรงรฎรขร รซรจ %d รฃรฐร รฌรฌ(ร ) รญร รฐรชรฎรฒรจรชรฎรข. รร รธรฅ รงรครฎรฐรฎรขรผรฅ (%d)", drugs, GetPlayerData(playerid, P_HEALTH));
	SendClientMessage(playerid, 0x32a44bFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET drugs=%d WHERE id=%d", GetPlayerData(playerid, P_DRUGS), GetPlayerAccountID(playerid));
	mysql_query(mysql, fmt_msg, false);

	return 1;
}
