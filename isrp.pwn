alias:freeze("fz")
CMD:freeze(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1)
    return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
  
    if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unfreeze [id รจรฃรฐรฎรชร ]");

    extract params -> new to_player;
 
    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
    return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
   
	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");
 
    TogglePlayerControllable(to_player, 0); 
 
    new fmt_msg[999];
  
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รงร รฌรฎรฐรฎรงรจรซ %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);
  
    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รงร รฌรฎรฐรฎรงรจรซรจ %s[%d]", GetPlayerNameEx(to_player), to_player);
    SendClientMessage(playerid, -1, fmt_msg);
  
    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รงร รฌรฎรฐรฎรงรจรซ รร รธรฅรฃรฎ รฏรฅรฐรฑรฎรญร รฆร .", GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, -1, fmt_msg);
  
    return true;
}

alias:unfreeze("unfz")
CMD:unfreeze(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1)
    return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unfreeze [id รจรฃรฐรฎรชร ]");

    extract params -> new to_player;

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
    return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
 
    TogglePlayerControllable(to_player, 1); 
 
    new fmt_msg[999];
 
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฐร รงรฌรฎรฐรฎรงรจรซ %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF); 
 
    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รฐร รงรฌรฎรฐรฎรงรจรซรจ %s[%d]", GetPlayerNameEx(to_player), to_player);
    SendClientMessage(playerid, -1, fmt_msg);
 
    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฐร รงรฌรฎรฐรฎรงรจรซ รร รธรฅรฃรฎ รฏรฅรฐรฑรฎรญร รฆร .", GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, -1, fmt_msg);
 
    return true;
}

stock Showmenus(playerid,menus)
{
    new BitStream:bitstream = BS_New();
    BS_WriteValue(bitstream, PR_UINT8, PACKET_CUSTOMRPC);
    BS_WriteValue(bitstream, PR_UINT32, 0x84); 

    BS_WriteValue(bitstream, PR_INT32, menus);

    BS_Send(bitstream, playerid);

    BS_Delete(bitstream);

    return true;
}

CMD:menus(playerid)
{
 Showmenus(playerid,84);
}

