stock AntiSliv(playerid, action[])
{
    if(GetPlayerData(playerid, P_ANTISLIV) > gettime())
    {
        SendClientMessage(playerid, -1, "{FFFF00}[!]{FFFFFF} รรธรจรกรชร , รขร รธรจ ร รครฌรจรญ รครฅรฉรฑรฒรขรจรฟ รงร รกรซรฎรชรจรฐรฎรขร รญรป!");

      	format(sctring, sizeof(sctring), "{FFFF00}[!]{FFFFFF} %s [%d] รรฎรครฎรงรฐรฅรญรจรฅ รญร  รฑรซรจรข ร รชรชร รณรญรฒร  (รครฅรฉรฑรฒรขรจรฅ %s)", GetPlayerNameEx(playerid), playerid, action);
      	SendMessageToAdmins(sctring, 0x999999FF);
        return true;
    }
    g_player[playerid][P_ANTISLIV] = gettime() + 15;
    UpdatePlayerDatabaseInt(playerid, "antisliv", GetPlayerData(playerid, P_ANTISLIV));
    return false;
}

public: DonateQiwi(playerid, response_code, data[])
{
    if(response_code == 200)
    {
        SendClientMessage(playerid, -1, "รรฎรญร รฒ รญร รฉรครฅรญ!");
        if(strfind(data, "success", true) != -1)
        {
            SendClientMessage(playerid, -1, "รรฎรญร รฒ รฎรฏรซร รทรฅรญ!");

            new Cache:result;
            mysql_format(mysql, sctring, sizeof(sctring), "SELECT * FROM `payments` WHERE `user_id` = '%d' AND `status` = 1 LIMIT 1", GetPlayerAccountID(playerid));
            result = mysql_query(mysql, sctring, true);
            if(cache_num_rows())
            {

                new sum,id_pay;
                id_pay = cache_get_field_content_int(0, "id");
                sum = cache_get_field_content_int(0, "sum");

                mysql_format(mysql, sctring, sizeof(sctring), "UPDATE `payments` SET `status` = 2 WHERE `id` = '%d'", id_pay);
                mysql_query(mysql, sctring, false);

                format(sctring, sizeof(sctring), "{0099CC}รร รธ รกร รซร รญรฑ รณรฑรฏรฅรธรญรฎ รฏรฎรฏรฎรซรญรฅรญ รญร  {FFD700}%i รฐรณรกรซรฅรฉ! (QIWI)", sum);
                SendClientMessage(playerid, -1, sctring);

                if(Config[sDonPower] != 1)
                {
                    format(sctring, sizeof(sctring), "{0099CC}ร รณรทรฅรฒรฎรฌ ร รชรถรจรจ (X%d) รญร  ร รชรชร รณรญรฒ รงร รทรจรฑรซรฅรญรฎ {FFD700}%i รฐรณรกรซรฅรฉ!",Config[sDonPower], sum*Config[sDonPower]);
                    SendClientMessage(playerid, -1, sctring);
                }
                GivePlayerDonateRub(playerid, sum*Config[sDonPower], "รรฎรญร รฒ QIWI");
                cache_delete(result);
                return 1;
            }
        }
    }
    else
    {
    	format(sctring, sizeof(sctring), "รรฎรฏรฎรซรญรฅรญรจรฟ รฏรฎ QIWI รญรฅ รญร รฉรครฅรญรป: (code: %d)", response_code);
        SendClientMessage(playerid, 0x999999FF, sctring);
    }
    return 1;
}


stock PlayerTotalOnline(playerid, count)
{
	if(GetPlayerPremium(playerid) == 0)
	{
		if(GetPlayerData(playerid, P_TOTALHOUR) < count)
			return 0;
		else
			return 1;
	}
	return 1;
}

stock ShowVehicleImproveDialog(playerid = INVALID_PLAYER_ID, vehicle_type = 1) // VEHICLE_TYPE_OWNABLE_CAR)
{
	if(playerid == INVALID_PLAYER_ID)
	    return 0;

	if(!vehicle_type)
	    return 0;

	new vehicleid = GetPlayerOwnableCar(playerid);

	if(vehicleid == INVALID_VEHICLE_ID)
	    return 0;

	new index = GetVehicleData(vehicleid, V_ACTION_ID);

	new pt_engine = GetOwnableCarData(index, OC_PT_ENGINE),
	    pt_brake = GetOwnableCarData(index, OC_PT_BRAKE),
	    pt_stability = GetOwnableCarData(index, OC_PT_STABILITY);

	new fmt_text[128];

	format
	(
	    fmt_text,
	    sizeof fmt_text,
		"{FFFFFF}1. รรซรณรทรธรฅรญรจรฟ รครขรจรฃร รฒรฅรซรฟ [%d/5]\n"\
	    "2. รรซรณรทรธรฅรญรจรฟ รฒรฎรฐรฌรฎรงรญรฎรฉ รฑรจรฑรฒรฅรฌรป [%d/5]\n"\
	    "3. รรซรณรทรธรฅรญรจรฟ รณรฑรฒรฎรฉรทรจรขรฎรฑรฒรจ [%d/5]",
	    pt_engine, pt_brake, pt_stability
	);

	Dialog(playerid, DIALOG_OWNABLE_CAR_PT, DIALOG_STYLE_LIST, "Performance Tuning", fmt_text, "รรปรกรฐร รฒรผ", "รรฒรฌรฅรญร ");

	return 1;
}

stock ShowPerformanceItem(playerid, item_type = PT_ITEM_TYPE_NONE)
{
	if(item_type == PT_ITEM_TYPE_NONE)
		return 0;

    new vehicleid = GetPlayerOwnableCar(playerid);

	if(vehicleid == INVALID_VEHICLE_ID)
	    return 0;

	new index = GetVehicleData(vehicleid, V_ACTION_ID);

	new pt_engine = GetOwnableCarData(index, OC_PT_ENGINE),
	    pt_brake = GetOwnableCarData(index, OC_PT_BRAKE),
	    pt_stability = GetOwnableCarData(index, OC_PT_STABILITY);

	new fmt_text[128],
		fmt_dialog[128 * 5];

	for(new idx; idx < 5; idx ++)
	{
	    // if(GetOwnableCarData(index, OC_PT_ENGINE) > idx)

        format(fmt_text, sizeof fmt_text, "{FFFFFF}%d. ", idx + 1);

		new price,
		    item_level;

		switch(item_type)
		{
			case PT_ITEM_TYPE_ENGINE:
			{
				strcat(fmt_text, engine_ptune[idx]);

				price = engine_ptune_price[idx];
				item_level = pt_engine;
			}
			case PT_ITEM_TYPE_BRAKE:
			{
			    strcat(fmt_text, brake_ptune[idx]);

			    price = brake_ptune_price[idx];
			    item_level = pt_brake;
			}
			case PT_ITEM_TYPE_STABILITY:
			{
			    strcat(fmt_text, stability_ptune[idx]);

			    price = stability_ptune_price[idx];
			    item_level = pt_stability;
			}

			default:
			    return 0;
		}

		if(item_level > idx)
			format(fmt_text, sizeof fmt_text, "%s {FFCD00}[รรฑรฒร รญรฎรขรซรฅรญรฎ]", fmt_text);

		else
		    format(fmt_text, sizeof fmt_text, "%s {66CC33}[$%d]", fmt_text, price);

		if(idx > 2)
		    strcat(fmt_text, " {EC174F}[VIP Gold]\n");

		else
		    strcat(fmt_text, "\n");

		strcat(fmt_dialog, fmt_text);
	}

	new dialog_title[3][23] = {"รรซรณรทรธรฅรญรจรฟ รครขรจรฃร รฒรฅรซรฟ", "รรซรณรทรธรฅรญรจรฟ รฒรฎรฐรฌรฎรงรฎรข", "รรซรณรทรธรฅรญรจรฟ รณรฑรฒรฎรฉรทรจรขรฎรฑรฒรจ"};

	Dialog(playerid, DIALOG_OWNABLE_CAR_PT_ITEM, DIALOG_STYLE_LIST, dialog_title[item_type - 1], fmt_dialog, "รรปรกรฐร รฒรผ", "รรฒรฌรฅรญร ");

	SetPVarInt(playerid, "pt_item_type", item_type);

	return 1;
}

stock ShowPlayerBuyHelper(playerid)
{
    new price = Config[helper_price];


    if(GetPlayerDonateRub(playerid) > price)
	{
        GivePlayerDonateRub(playerid, -price, "รรฎรชรณรฏรชร  support-รฏรฐร รข");

		SetPlayerData(playerid, P_HELPER, 1);
		UpdatePlayerDatabaseInt(playerid, "helper", 1);

        SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ /shelp, รทรฒรฎรกรป รณรงรญร รฒรผ รฎ รญรฎรขรปรต รขรฎรงรฌรฎรฆรญรฎรฑรฒรฟรต");
	}
	else
	    return SendClientMessage(playerid, -1, "ร รร รฑ รญรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฐรณรกรซรฅรฉ, รฏรฎรฏรฎรซรญรจรฒรผ รจรต รฌรฎรฆรญรฎ รญร  รฑร รฉรฒรฅ {FFCD00}"SERVER_SITE" -> รรฎรญร รฒ");

	return 1;

}

CMD:fixcar(playerid)
{
	if(GetPlayerAdminEx(playerid) < 1) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	
	new vehicleid = GetPlayerVehicleID(playerid);

    if(vehicleid == 0)
    {
            SendClientMessage(playerid, -1, ""USC"รรป รครฎรซรฆรญรป รฑรจรครฅรฒรผ รข รฒรฐร รญรฑรฏรฎรฐรฒรฅ");
            return 0;
    }

    // รฏรฅรฐรฅรฌรฅรญรญรปรฅ รชรฎรฒรฎรฐรปรฅ รกรณรครณรฒ รตรฐร รญรจรฒรผ รฏรฎรงรจรถรจรพ รจ รณรฃรฎรซ รฏรฎรขรฎรฐรฎรฒร 
    new Float:x, Float:y, Float:z;
    new Float:angle;

    // รฏรฎรซรณรทร รฅรฌ รฏรฎรงรจรถรจรพ รจ รณรฃรฎรซ รฏรฎรขรฎรฐรฎรฒร 
    GetVehiclePos(vehicleid, x, y, z);
    GetVehicleZAngle(vehicleid, angle);

    // รณรฑรฒร รญร รขรซรจรขร รฅรฌ รฏรฎรงรจรถรจรพ รจ รณรฃรฎรซ รฏรฎรขรฎรฐรฎรฒร 
    SetVehiclePos(vehicleid, x, y, z + 1.5);
    SetVehicleZAngle(vehicleid, angle);

    SendClientMessage(playerid, -1, ""SC"รรป รณรฑรฏรฅรธรญรฎ รฏรฎรฑรฒร รขรจรซรจ รฒรฐร รญรฑรฏรฎรฐรฒ รญร  รชรฎรซยธรฑร  รจ รฏรฎรทรจรญรจรซรจ รฅรฃรฎ");
        
	RepairVehicle(vehicleid);
	SetVehicleHealth(vehicleid,1000);
	
	return 1;
}



CMD:setplayerhouse(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 7) return 1;

	extract params -> new to_player, health; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /setplayerhouse [id รจรฃรฐรฎรชร ] [id house]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	else if(!(-1 <= health <= 1000)) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฌรฅรฐ รครฎรฌร  รฎรฒ -1 รครฎ 1000 ( -1 รขรปรฑรฅรซรจรฒรผ )");

	SetPlayerData(to_player, P_HOUSE, health);
	SetPlayerData(playerid, P_HOUSE_ROOM, -1);
	SetPlayerData(playerid, P_HOUSE_TYPE, HOUSE_TYPE_HOME);
	if(health == -1)
	{
	    SetPlayerData(to_player, P_HOUSE, -1);
		SetPlayerData(playerid, P_HOUSE_ROOM, -1);
		SetPlayerData(playerid, P_HOUSE_TYPE, HOUSE_TYPE_NONE);
	}

	new fmt_msg[105];
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รจรงรฌรฅรญรจรซ รร รฌ รญรฎรฌรฅรฐ รครฎรฌร ", GetPlayerNameEx(playerid));
	SendClientMessage(to_player, -1, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรป รจรงรฌรฅรญรจรซรจ รจรฃรฐรฎรชรณ %s รญรฎรฌรฅรฐ รครฎรฌร  รญร  %d", GetPlayerNameEx(to_player),health);
	SendClientMessage(playerid, -1, fmt_msg);
	new query[90];

	format(query, sizeof query, "UPDATE accounts SET house_type=%d,house=%d, WHERE id=%d LIMIT 1", HOUSE_TYPE_HOME, health, GetPlayerAccountID(playerid));
	mysql_query(mysql, query, false);

	if(GetPlayerAdminEx(playerid) <= 5)
	{
		format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รจรงรฌรฅรญรจรซ รญรฎรฌรฅรฐ รครฎรฌรณ %s[%d] รญร  %d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, health);
		SendMessageToAdmins(fmt_msg, 0xCECECEFF);
	}

	format(fmt_msg, sizeof fmt_msg, "รรฑรฒร รญรฎรขรจรซ %s[acc:%d] รญรฎรฌรฅรฐ รครฎรฌร  %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), health);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}
