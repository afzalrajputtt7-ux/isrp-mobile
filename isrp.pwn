CMD:unjail(playerid, params[])
{
	if (TEST_SERVER == 1)
		return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");

	if (GetPlayerAdminEx(playerid) < 1)
		return 1;

	extract params -> new to_player, string:reason[30]; else
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unjail [id รจรฃรฐรฎรชร ] [รรฐรจรทรจรญร ]");

	if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new bool:isFsin = GetPlayerData(to_player, P_FJAIL) > 0;
	new bool:isJail = GetPlayerData(to_player, P_JAIL) > 0;

	if (!isFsin && !isJail)
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรจรครจรฒ รข รฒรพรฐรผรฌรฅ");

	new fmt_msg[128];
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรปรฏรณรฑรฒรจรซ รจรง รฒรพรฐรผรฌรป %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
	if (strlen(reason))
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);
	SendClientMessage(to_player, 0x66CC00FF, "รร รฑ รขรปรฏรณรฑรฒรจรซรจ รฑ รฒรพรฐรผรฌรป");

	format(fmt_msg, sizeof fmt_msg, "รรปรฏรณรฑรฒรจรซ รฑ รฒรพรฐรผรฌรป %s[acc:%d]. รรฐรจรทรจรญร : %s",
		GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);

	if (isFsin)
		FSinUnjailPlayer(to_player);
	else
		UnjailPlayer(to_player);

	format(fmt_msg, sizeof fmt_msg, "รรปรฏรณรฑรฒรจรซ รจรง รฒรพรฐรผรฌรป %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

CMD:getcam(playerid, params[])
{
						new
                        Float:fPX, Float:fPY, Float:fPZ,
                        Float:fVX, Float:fVY, Float:fVZ,
                        Float:object_x, Float:object_y, Float:object_z;

		                const
		                Float:fScale = 5.0;

		                GetPlayerCameraPos(playerid, fPX, fPY, fPZ);
		                GetPlayerCameraFrontVector(playerid, fVX, fVY, fVZ);

		                object_x = fPX + floatmul(fVX, fScale);
		                object_y = fPY + floatmul(fVY, fScale);
		                object_z = fPZ + floatmul(fVZ, fScale);

		                format(sctring, sizeof(sctring), "CameraPos: %f,%f,%f | LookAt: %f,%f,%f",fPX,fPY,fPZ,object_x,object_y,object_z);
		                print(sctring);
		                SendClientMessage(playerid, -1, sctring);
						return 1;
}
CMD:ban(playerid, params[])
{
	if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");

	if(GetPlayerAdminEx(playerid) < 7 ) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	
    
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /ban [id รจรฃรฐรฎรชร ] [รฑรฐรฎรช รข รครญรฟรฉ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, ban_time, string:reason[30];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
		
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	new max_days = GetPlayerAdminEx(playerid) > 4 ? 365 : 30;

	new fmt_msg[999];

	if(!(1 <= ban_time <= max_days))
	{
		format(fmt_msg, sizeof fmt_msg, ""SC"รรฐรฎรช รกร รญร  รฌรฎรฆรฅรฒ รกรปรฒรผ รฎรฒ 1 รครฎ %d รครญรฅรฉ", max_days);

		return SendClientMessage(playerid, 0xCECECEFF, fmt_msg);
	}

	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฅรซรผรงรฟ รงร รกร รญรจรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรปรธรฅ รฏรฎ รฐร รญรฃรณ");
	//if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฅรซรผรงรฟ รงร รกร รญรจรฒรผ รฑร รฌรฎรฃรฎ รฑรฅรกรฟ");

	if(AntiSliv(playerid, "/ban")) return true;
	
	AddAdminStat(playerid, "bans_total", P_BANS_TOTAL);
	AddAdminStat(playerid, "bans_today", P_BANS_TODAY);

	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รงร รกรซรฎรชรจรฐรฎรขร รซ รจรฃรฐรฎรชร  %s รญร  %d รครญรฅรฉ", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), ban_time);

	if(strlen(reason) > 0)
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);


	if(!strlen(reason)) reason = "None";

	format(fmt_msg, sizeof fmt_msg, "รร รกร รญรจรซ %s[acc:%d] รญร  %d รครญรฅรฉ. รรฐรจรทรจรญร  %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

	AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, reason, GetPlayerNameEx(playerid));
	return 1;
}

CMD:unban(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 4 ) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new string: player_name[21];

	if(!strlen(player_name)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unban [รญรจรช รจรฃรฐรฎรชร  รฏรฐรจรทรจรญร ]");

	new query[80],
		Cache: result,
		rows,
		uid,
		uip[16];

	mysql_format(mysql, query, sizeof query, "SELECT id, last_ip FROM accounts WHERE name='%s'", player_name);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	if(rows)
	{
		uid = cache_get_row_int(0, 0);
		cache_get_row(0, 1, uip);
	}

	cache_delete(result);

	if(!rows || !uid) return SendClientMessage(playerid, 0x999999FF, ""SC"รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");

	mysql_format(mysql, query, sizeof query, "SELECT * FROM ban_list WHERE user_id=%d", uid);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	cache_delete(result);

	if(!rows) return SendClientMessage(playerid, 0x999999FF, ""SC"รรชรชร รณรญรฒ รจรฃรฐรฎรชร  รญรฅ รงร รกรซรฎรชรจรฐรฎรขร รญ");

	mysql_format(mysql, query, sizeof query, "DELETE FROM ban_list WHERE user_id=%d", uid);
	mysql_query(mysql, query, false);

	format(query, sizeof query, "unbanip %s", uip);
	SendRconCommand(query);

	SendRconCommand("reloadbans");

	format(query, sizeof query, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รฐร รงรกรซรฎรชรจรฐรฎรขร รซ รจรฃรฐรฎรชร  %s", GetPlayerNameEx(playerid), player_name);
	

	SendClientMessageToAll(0xFF5533FF, query);

	format(query, sizeof query, "รร รงรกร รญรจรซ %s[acc:%d]", player_name, uid);
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, query);

	return 1;
}

CMD:setskin(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new to_player, skin_id; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /setskin [id รจรฃรฐรฎรชร ] [id รฑรชรจรญร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
	if(TEST_SERVER == 1)
	{
	    if(playerid != to_player) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญรณรพ รชรฎรฌร รญรครณ รฌรฎรฆรญรฎ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รญร  รรรร รรรรรรร รฒรฎรซรผรชรฎ รฏรฎ รฎรฒรญรฎรธรฅรญรจรพ รช รฑรฅรกรฅ!");
	}
	
	if(GetPlayerData(to_player, P_JAIL) > 0 || GetPlayerData(to_player, P_FJAIL) > 0)
{
	SendClientMessage(playerid, COLOR_GREY, "รรฅรซรผรงรฟ รฑรฌรฅรญรจรฒรผ รฎรครฅรฆรครณ รจรฃรฐรฎรชรณ, รญร รตรฎรครฟรนรฅรฌรณรฑรฟ รฏรฎรค รงร รชรซรพรทรฅรญรจรฅรฌ.");
	return 1;
}

	if(!(1 <= skin_id <= 20000)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"ID รฑรชรจรญร  รฎรฒ 1 รครฎ 20000");


	SetPlayerData(to_player, P_SKIN, skin_id);
	UpdatePlayerDatabaseInt(to_player, "skin", skin_id);

	SetPlayerSkinInit(to_player);

	new fmt_text[999];
	
    format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รขรปรคร รซรจ รฑรชรจรญ ยน%d รจรฃรฐรฎรชรณ %s[%d]", skin_id, GetPlayerNameEx(to_player), to_player);
	SendClientMessage(playerid, -1, fmt_text);
	
	format(fmt_text, sizeof fmt_text, "{1E90FF}รร รฌ รกรปรซ รขรปรคร รญ รฑรชรจรญ ยน%d ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ %s[%d]", skin_id, GetPlayerNameEx(playerid), playerid);
	SendClientMessage(to_player, -1, fmt_text);	
	
	format(fmt_text, sizeof fmt_text, "{FF5533}[A] %s[%d] รขรปรคร รซ %s[%d] รฑรชรจรญ ยน%d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, skin_id);
	SendMessageToAdmins(fmt_text, 0xCECECEFF);	

	format(fmt_text, sizeof fmt_text, "รรฑรฒร รญรฎรขรจรซ %s[acc:%d] รฑรชรจรญ %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), skin_id);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}


CMD:offban(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 3 ) return 1;

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /offban [รญรจรช รจรฃรฐรฎรชร ] [รชรฎรซ-รขรฎ รครญรฅรฉ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new string: player_name[21], days, string: reason[30];

	if(!(1 <= days <= 365)) return SendClientMessage(playerid, 0x999999FF, "รรฎรซรจรทรฅรฑรฒรขรฎ รครญรฅรฉ รฎรฒ 1 รครฎ 365");

	if(IsPlayerConnected(GetPlayerID(player_name))) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญร รตรฎรครจรฒรฑรฟ รญร  รฑรฅรฐรขรฅรฐรฅ");

	new query[144],
		Cache: result,
		rows,
		uid,
		admin,
		uip[16];

	mysql_format(mysql, query, sizeof query, "SELECT id, admin, last_ip FROM accounts WHERE name='%s'", player_name);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	if(rows)
	{
		uid = cache_get_row_int(0, 0);
		admin = cache_get_row_int(0, 1);
		cache_get_row(0, 2, uip);
	}

	cache_delete(result);

	if(!rows || !uid) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");

	if(GetPlayerAdminEx(playerid) < admin) return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รงร รกร รญรจรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรปรธรฅ รฏรฎ รฐร รญรฃรณ");

	mysql_format(mysql, query, sizeof query, "SELECT * FROM ban_list WHERE user_id=%d", uid);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	cache_delete(result);

	if(rows) return SendClientMessage(playerid, 0x999999FF, "รรชรชร รณรญรฒ รจรฃรฐรฎรชร  รณรฆรฅ รงร รกรซรฎรชรจรฐรฎรขร รญ");
	
	if(GetPlayerAdminEx(playerid) < admin)
    return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รงร รกร รญรจรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรปรธรฅ รร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	if(AntiSliv(playerid, "/offban")) return true;

	format(query, sizeof query, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รงร รกร รญรจรซ รฎรดรดรซร รฉรญ รจรฃรฐรฎรชร  %s รญร  %d รครญรฅรฉ", GetPlayerNameEx(playerid), player_name, days);

	if(strlen(reason) > 0)
		format(query, sizeof query, "%s. รรฐรจรทรจรญร : %s", query, reason);

	if(!strlen(reason)) reason = "None";

	SendClientMessageToAll(0xFF5533FF, query);

	format(query, sizeof query, "รรดรดรซร รฉรญ รงร รกร รญรจรซ %s[acc:%d] รญร  %d รครญรฅรฉ. รรฐรจรทรจรญร : %s", player_name, uid, days, reason);
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, query);

	format(reason, sizeof reason, "[OFFLINE]%s", reason);
	
	AddAdminStat(playerid, "bans_total", P_BANS_TOTAL);
	AddAdminStat(playerid, "bans_today", P_BANS_TODAY);

	AddBan(uid, gettime(), days, uip, reason, GetPlayerNameEx(playerid));

	return 1;
}

CMD:delacc(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 7) return 1;

	extract params -> new string:name[21], string:reason[30]; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /delacc [รจรฌรฟ รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");

	new query[128],
		Cache: result,
		admin,
		rows;

	mysql_format(mysql, query, sizeof query, "SELECT admin FROM accounts WHERE name='%s' LIMIT 1", name);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	if(rows)
	{
		admin = cache_get_row_int(0, 0);

		if(admin && GetPlayerAdminEx(playerid) < 5)
		{
			SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รณรคร รซรจรฒรผ ร รชรชร รณรญรฒ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรปรธรฅ รร รฑ รฐร รญรฃรฎรฌ");

			cache_delete(result);

			format(query, sizeof query, "รรฎรฏรปรฒร รซรฑรฟ รณรคร รซรจรฒรผ ร รชรชร รณรญรฒ %s", name);
			SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, query);

			return 1;
		}

		mysql_format(mysql, query, sizeof query, "DELETE FROM accounts WHERE name='%s' LIMIT 1", name);
		mysql_query(mysql, query, false);

		format(query, sizeof query, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รฎรกรญรณรซรจรซ รจรฌรณรนรฅรฑรฒรขรฎ รจรฃรฐรฎรชร  %s", GetPlayerNameEx(playerid), name);

		if(strlen(reason) > 0)
		{
			new fmt_text[45];

			format(fmt_text, sizeof fmt_text, ". รรฐรจรทรจรญร : %s", reason);
			strcat(query, fmt_text);
		}

		SendClientMessageToAll(0xFF5533FF, query);

		format(query, sizeof query, "รรคร รซรจรซ ร รชรชร รณรญรฒ %s. รรฐรจรทรจรญร : %s", name, reason);
		SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, query);
	}
	else SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");

	cache_delete(result);

	return 1;
}

CMD:skin(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new to_player, skin_id; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /skin [id รจรฃรฐรฎรชร ] [id รฑรชรจรญร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
	if(TEST_SERVER == 1)
	{
	    if(playerid != to_player) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญรณรพ รชรฎรฌร รญรครณ รฌรฎรฆรญรฎ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รญร  รรรร รรรรรรร รฒรฎรซรผรชรฎ รฏรฎ รฎรฒรญรฎรธรฅรญรจรพ รช รฑรฅรกรฅ!");
	}
	
	if(GetPlayerData(to_player, P_JAIL) > 0 || GetPlayerData(to_player, P_FJAIL) > 0)
{
	SendClientMessage(playerid, COLOR_GREY, "รรฅรซรผรงรฟ รฑรฌรฅรญรจรฒรผ รฎรครฅรฆรครณ รจรฃรฐรฎรชรณ, รญร รตรฎรครฟรนรฅรฌรณรฑรฟ รฏรฎรค รงร รชรซรพรทรฅรญรจรฅรฌ.");
	return 1;
}

	if(!(-1 <= skin_id <= 20000) || skin_id == 0) return SendClientMessage(playerid, 0x999999FF, ""SC"ID รฑรชรจรญร  รฎรฒ 1 รครฎ 20000");

	if(skin_id != -1)
		SetPlayerSkin(to_player, skin_id);
	else
		SetPlayerSkin(to_player, GetPlayerSkinEx(to_player));

	new fmt_text[999];

	format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รขรปรคร รซรจ รจรฃรฐรฎรชรณ %s[%d] รฑรชรจรญ %s", GetPlayerNameEx(to_player), to_player, skin_id != -1 ? "รขรฐรฅรฌรฅรญรญรปรฉ" : "รฏรฐรฅรฆรญรจรฉ");
	SendClientMessage(playerid, -1, fmt_text);
	
	format(fmt_text, sizeof fmt_text, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รขรปรคร รซ รร รฌ %s รฑรชรจรญ", GetPlayerNameEx(playerid), playerid, skin_id != -1 ? "รขรฐรฅรฌรฅรญรญรปรฉ" : "รฏรฐรฅรฆรญรจรฉ");
	SendClientMessage(to_player, -1, fmt_text);	

	if(skin_id != -1)
		format(fmt_text, sizeof fmt_text, "[A] %s[%d] รขรปรคร รซ %s[%d] รขรฐรฅรฌรฅรญรญรปรฉ รฑรชรจรญ ยน%d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, skin_id);
	else
		format(fmt_text, sizeof fmt_text, "[A] %s[%d] รขรปรคร รซ %s[%d] รฏรฐรฅรฆรญรจรฉ รฑรชรจรญ", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
	SendMessageToAdmins(fmt_text, 0x999999FF);

	format(fmt_text, sizeof fmt_text, "รรปรคร รซ %s[acc:%d] รฑรชรจรญ %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), skin_id);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:house(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4) return 1;

	extract params -> new house_id; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /house [รญรฎรฌรฅรฐ รครฎรฌร ]");

	if(!(0 <= house_id <= g_house_loaded-1)) return SendClientMessage(playerid, 0xCECECEFF, "รร รญรญรฎรฃรฎ รครฎรฌร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

	new Float: x,
		Float: y,
		Float: z,
		Float: angle;

	if(GetHouseData(house_id, H_ENTRACE) != -1)
	{
		EnterPlayerToEntrance(playerid, GetHouseData(house_id, H_ENTRACE));

		x = GetHouseData(house_id, H_POS_X);
		y = GetHouseData(house_id, H_POS_Y);
		z = GetHouseData(house_id, H_POS_Z);
	}
	else
	{
		x = GetHouseData(house_id, H_EXIT_POS_X);
		y = GetHouseData(house_id, H_EXIT_POS_Y);
		z = GetHouseData(house_id, H_EXIT_POS_Z);
		angle = GetHouseData(house_id, H_EXIT_ANGLE);
	}
	SetPlayerPosEx(playerid, x, y, z, angle);

	new fmt_text[35];

	format(fmt_text, sizeof fmt_text, "รรป รฒรฅรซรฅรฏรฎรฐรฒรจรฐรฎรขร รซรจรฑรผ รช รครฎรฌรณ ยน%d", house_id);
	SendClientMessage(playerid, -1, fmt_text);

	format(fmt_text, sizeof fmt_text, " รช รครฎรฌรณ %d", house_id);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

