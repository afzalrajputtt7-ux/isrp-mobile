    new string[512];
    format(string, sizeof(string), "{E0584B}#1{ffffff} รรชรฒรจรขรญรปรฅ รดรฎรฐรฌรป ({FFFF00}%d{FFFFFF}) {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n{E0584B}#2{ffffff} รรฎรคร รฒรผ รดรฎรฐรฌรณ       {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ", GetPendingFormsCount());
    
    ShowPlayerDialog(playerid, DIALOG_AF, DIALOG_STYLE_LIST, "{ff4a4a}"SERVER_NAME"{ffffff} | รรฎรฐรฌรป ร รครฌรจรญรจรฑรฒรฐร รถรจรจ", string, "รร รซรฅรฅ", "รรปรฉรฒรจ");
    return 1;
}

