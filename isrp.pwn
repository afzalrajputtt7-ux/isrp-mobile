CMD:changecolor(playerid, params[])
{
    if(!IsPlayerInAnyVehicle(playerid))
  return SendClientMessage(playerid, -1, ""USC"รรป รครฎรซรฆรญรป รกรปรฒรผ รงร  รฐรณรซรฅรฌ!");

  extract params -> new color; else return SendClientMessage(playerid, 0xCECECEFF, "{ffff00}|{ffffff} รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /changecolor [id รถรขรฅรฒร ]");

    if(!(0 <= color <= 126)) return SendClientMessage(playerid, 0xCECECEFF, "{ffff00}|{ffffff}รรฑรฏรฎรซรผรงรณรฉรฒรฅ id รถรขรฅรฒร  รฎรฒ 0 รครฎ 126");

    new vehicleid = GetPlayerVehicleID(playerid);

    ChangeVehicleColor(vehicleid, color);

   SendClientMessage(playerid, COLOR_WHITE, "รรขรฅรฒ รขรธร รฅรฃรฎ ร รขรฒรฎรฌรฎรกรจรซรฟ รณรฑรฏรฅรธรญรฎ รจรงรฌรฅรญรฅรญ!");

    return 1;
}



