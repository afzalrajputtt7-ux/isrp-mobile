	if(!(-1 <= weather <= 20))
	{
		SendClientMessage(playerid, 0x999999FF, ""SC"รรฎรฃรฎรคร  รฎรฒ 0 รครฎ 20");
		SendClientMessage(playerid, 0x999999FF, ""SC"รรฅรชรฎรฌรฅรญรครฎรขร รญรฎ: 1, 3, 8, 9, 18");

		return 1;
	}
	
	if(weather != -1)
		SetWeather(weather);	

