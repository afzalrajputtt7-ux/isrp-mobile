CMD:delveh(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 4) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
    if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, ""USC"รรป รครฎรซรฆรญรป รกรปรฒรผ รงร  รฐรณรซรฅรฌ ร รขรฒรฎรฌรฎรกรจรซรฟ");
    if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
    if(GetVehicleData(GetPlayerVehicleID(playerid), V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_ADMIN_CAR)
    {
	    RemovePlayerFromVehicle(playerid);
	    n_veh_DestroyVehicle(GetPlayerVehicleID(playerid));
	    SendClientMessage(playerid, 0xCECECEFF, ""SC"รรป รณรคร รซรจรซรจ รฑรฎรงรคร รญรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ");
	
	    new fmt_msg[999];
	
    	format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รณรคร รซรจรซ รฑรฎรงรคร รญรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ", GetPlayerNameEx(playerid), playerid);
    	SendMessageToAdmins(fmt_msg, 0x999999FF);
	}
	return true;
}

CMD:reset_cash(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	//else if(admin_logged[playerid] == false) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ ร รขรฒรฎรฐรจรงรจรฐรฎรขร รญรป, รครซรฟ รฝรฒรฎรฃรฎ รจรฑรฏรฎรซรผรงรณรฉรฒรฅ /alogin");

	extract params -> new to_player, cash; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /reset_cash [ID รจรฃรฐรฎรชร ] [cรณรฌรฌร ]");
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
		
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	new reason[999];
	new fmt_msg[999];
	format(reason, sizeof reason, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฎรกรญรณรซรจรซ รขร รฌ รครฅรญรผรฃรจ", GetPlayerNameEx(playerid), playerid);
	GivePlayerMoneyEx(to_player, -cash, reason, true, true);
	SendClientMessage(to_player, 0x66CC00FF, reason);
	
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฎรกรญรณรซรจรซ รครฅรญรผรฃรจ รจรฃรฐรฎรชรณ %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);	

	format(reason, sizeof reason, "{1E90FF}รรป รฎรกรญรณรซรจรซรจ %s %d รฐรณรกรซรฅรฉ", GetPlayerNameEx(to_player), cash);
	SendClientMessage(playerid, 0x66CC00FF, reason);

	format(reason, sizeof reason, "รรกรญรณรซรจรซ %s[%d] %d รฐรณรก", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), cash);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, reason);
	return 1;
}

CMD:reset_donate(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	//else if(admin_logged[playerid] == false) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ ร รขรฒรฎรฐรจรงรจรฐรฎรขร รญรป, รครซรฟ รฝรฒรฎรฃรฎ รจรฑรฏรฎรซรผรงรณรฉรฒรฅ /alogin");

	extract params -> new to_player, donate; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /reset_donate [ID รจรฃรฐรฎรชร ] [cรณรฌรฌร ]");
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
		
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	new reason[999];
	new fmt_msg[999];
	format(reason, sizeof reason, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฎรกรญรณรซรจรซ รขร รฌ รครฎรญร รฒ", GetPlayerNameEx(playerid), playerid);
	GivePlayerDonateRub(to_player, -donate, reason, true, true);
	SendClientMessage(to_player, 0x66CC00FF, reason);
	
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฎรกรญรณรซรจรซ รครฎรญร รฒ รจรฃรฐรฎรชรณ %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);		

	format(reason, sizeof reason, "{1E90FF}รรป รฎรกรญรณรซรจรซรจ %s %d รครฎรญร รฒร ", GetPlayerNameEx(to_player), donate);
	SendClientMessage(playerid, 0x66CC00FF, reason);

	format(reason, sizeof reason, "รรกรญรณรซรจรซ %s[%d] %d รครฎรญร รฒร ", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), donate);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, reason);
	return 1;
}

CMD:givevip(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	extract params -> new to_player, premium, days; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givevip [ID รจรฃรฐรฎรชร ] [รณรฐรฎรขรฅรญรผ รฏรฐรฅรฌรจรณรฌ-ร รชรชร รณรญรฒร ] [รขรฐรฅรฌรฟ (รข รครญรฟรต)]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");

	if(!(1 <= premium <= 3)) return SendClientMessage(playerid, 0x999999FF, "รรฐรฎรขรฅรญรผ รฏรฐรฅรฌรจรณรฌ-ร รชรชร รณรญรฒร  รฎรฒ 1 รครฎ 3 (รทรฒรฎรกรป รฎรฒรฎรกรฐร รฒรผ, รจรฑรฏรฎรซรผรงรณรฉรฒรฅ รชรฎรซ-รขรฎ รครญรฅรฉ: 0)");

	if(!(0 <= days <= 30)) return SendClientMessage(playerid, 0x999999FF, "รรฎรซรจรทรฅรฑรฒรขรฎ รครญรฅรฉ รฎรฒ 0 รครฎ 30");

	new fmt_msg[999];

	new premium_rank[3][17] =
	{
		"{C0C0C0}Silver",
		"{FFD700}Gold",
		"{E5E4E2}Platinum"
	};

	SetPlayerData(to_player, P_PREMIUM, premium);
	SetPlayerData(to_player, P_PREMIUM_TIME, gettime() + days * 86400);

	UpdatePlayerDatabaseInt(to_player, "premium", premium);
	UpdatePlayerDatabaseInt(to_player, "premium_time", gettime() + days * 86400);

	format(fmt_msg, sizeof fmt_msg, "%s รขรปรคร รซ รร รฌ %s {3399FF}รฏรฐรฅรฌรจรณรฌ-ร รชรชร รณรญรฒ รญร  %d รครญ.", GetPlayerNameEx(playerid), premium_rank[premium - 1], days);
	SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรป รขรปรคร รซรจ %s %s {3399FF}รฏรฐรฅรฌรจรณรฌ-ร รชรชร รณรญรฒ รญร  %d รครญ.", GetPlayerNameEx(to_player), premium_rank[premium - 1], days);
	SendClientMessage(playerid, 0x3399FFFF, fmt_msg);


	return 1;
}

CMD:epoints(playerid)
{
	if(GetPlayerAdminEx(playerid) < 1) return 0;

	new fmt_str[300];

	format(str, sizeof str, "{ff4a4a}"SERVER_NAME"{ffffff} | รร รซรซรฎรข: {E0584B}%d", GetPlayerData(playerid, P_ACOINS));
	 
	Dialog
		(
			playerid, DIALOG_ADMSHOP, DIALOG_STYLE_LIST, 
			str, 		
			"{E0584B} #1 {FFFFFF}รรจรฐรฒรณร รซรผรญร รฟ รร รซรพรฒร \t\t\t\t\t {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n"\
			"{E0584B} #2 {FFFFFF}รรฎรญร รฒรญร รฟ รร รซรพรฒร \t\t\t\t\t {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n"\
			"{E0584B} #3 {FFFFFF}รรจรฏ รฑรฒร รฒรณรฑรป\t\t\t\t\t {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n"\
			"{E0584B} #4 {FFFFFF}รรฅรฉรฑรป\t\t\t\t\t {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n"\
			"{E0584B} #5 {FFFFFF}รรญรจรชร รซรผรญรปรฅ ร รชรฑรฅรฑรฑรณร รฐรป(รข รฐร รงรฐร รกรฎรฒรชรฅ)\t\t\t\t\t {888888} รญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ",
			"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
		);
}
CMD:giveepoints(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return 1;

	extract params -> new to_player, acoins; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /giveepoints [id รจรฃรฐรฎรชร ] [cรณรฌรฌร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(-1 <= acoins <= 100_000)) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฆรญรฎ รขรปรคร รขร รฒรผ รฎรฒ 1 รครฎ 10000 รร รซรซรฎรข รงร  รฎรครจรญ รฐร รง");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, -1, ""USC" รรฃรฐรฎรช รญรฅ รข รฑรฅรฒรจ!");
		
	new fmt_text[999];
	
    format(fmt_text, sizeof fmt_text, "{FFFFFF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ {ffff00}%s {FFFFFF}รขรปรคร รซ รร รฌ {ffff00}%d {FFFFFF}รกร รซรซร (-รฎรข) รฎรกรฌรฅรญร .", GetPlayerNameEx(playerid), acoins);
	SendClientMessage(to_player, -1, fmt_text);
	
	format(fmt_text, sizeof fmt_text, "{FFFFFF}รรฒรฎรกรป รฏรฎรฒรฐร รฒรจรฒรผ รกร รซรซรป รขรฎรฑรฏรฎรซรผรงรณรฉรฒรฅรฑรผ รฑรฏรฅรถรจร รซรผรญรฎรฉ รชรฎรฌร รญรครฎรฉ: {ffff00}/epoints");
	SendClientMessage(to_player, -1, fmt_text);	
	
	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รขรปรคร รซ รกร รซรซรป รครซรฟ รฎรกรฌรฅรญร  %s[%d] รชรฎรซ-รขรฎ %d รกร รซรซรฎรข, รข รจรฒรฎรฃรฅ รณ รจรฃรฐรฎรชร  %d รกร รซรซรฎรข", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, acoins, GetPlayerMoneyEx(to_player));
	SendMessageToAdmins(fmt_text, 0xCECECEFF);	

    AddPlayerData(playerid, P_ACOINS, +, acoins);
	UpdatePlayerDatabaseInt(playerid, "acoins", GetPlayerData(to_player, P_ACOINS) - 450);
	return 1;
}

stock GivePlayerCar(playerid, modelid, color_1, color_2)
{

		if((GetPlayerOwnableCars(playerid) + 1) > GetPlayerCarSlots(playerid))
		{
			SendClientMessage(playerid, 0x3399FFFF, "รรฑรฅ รฑรซรฎรฒรป รครซรฟ รฒรฐร รญรฑรฏรฎรฐรฒร  รงร รญรฟรฒรป. รรป รฌรฎรฆรฅรฒรฅ รณรขรฅรซรจรทรจรฒรผ รจรต: {FFFF00}/menu > รรฎรฏรฎรซรญรจรฒรฅรซรผรญรฎ");
			return -1;
		}
		
		if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
		{
			SendClientMessage(playerid, 0x999999FF, "รรซรฟ รฏรฎรชรณรฏรชรจ รฒรฐร รญรฑรฏรฎรฐรฒร  รญรณรฆรญรฎ รขรปรฃรฐรณรงรจรฒรผ รณรฆรฅ รงร รฃรฐรณรฆรฅรญรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รฑรฅรฐรขรฅรฐร ");
			return -1;
		}

		new buy_cars_count = cars_after_purchase_count[2]++;

		if(buy_cars_count >= 4)
			cars_after_purchase_count[2] = 0;

		new Float: pos_x = cars_pos_after_purchase[2][buy_cars_count][0];
		new Float: pos_y = cars_pos_after_purchase[2][buy_cars_count][1];
		new Float: pos_z = cars_pos_after_purchase[2][buy_cars_count][2];
		new Float: angle = cars_pos_after_purchase[2][buy_cars_count][3];

		new query[220],
			Cache: result,
			idx;

		idx = GetFreeOwnableCarID();

		SetOwnableCarData(idx, OC_OWNER_ID, 	GetPlayerAccountID(playerid));

		SetOwnableCarData(idx, OC_MODEL_ID, 	modelid);
		SetOwnableCarData(idx, OC_COLOR_1, 		color_1);
		SetOwnableCarData(idx, OC_COLOR_2, 		color_2);

		SetOwnableCarData(idx, OC_POS_X, 		pos_x);
		SetOwnableCarData(idx, OC_POS_Y, 		pos_y);
		SetOwnableCarData(idx, OC_POS_Z, 		pos_z);
		SetOwnableCarData(idx, OC_ANGLE, 		angle);

		strmid(g_ownable_car[idx][OC_NUMBER], "------", 0, 8, 8);

		SetOwnableCarData(idx, OC_ALARM, 		false);
		SetOwnableCarData(idx, OC_KEY_IN, 		false);

		SetOwnableCarData(idx, OC_CREATE, 		gettime());

		format(g_ownable_car[idx][OC_OWNER_NAME], 21, GetPlayerNameEx(playerid));
		// ----------------------------------------------------------------------------------------

		new vehicleid = CreateVehicle
		(
			GetOwnableCarData(idx, OC_MODEL_ID),
			GetOwnableCarData(idx, OC_POS_X),
			GetOwnableCarData(idx, OC_POS_Y),
			GetOwnableCarData(idx, OC_POS_Z),
			GetOwnableCarData(idx, OC_ANGLE),
			GetOwnableCarData(idx, OC_COLOR_1),
			GetOwnableCarData(idx, OC_COLOR_2),
			-1,
			0,
			VEHICLE_ACTION_TYPE_OWNABLE_CAR,
			idx
		);
		if(vehicleid != INVALID_VEHICLE_ID)
		{
			//CreateVehicleLabel(vehicleid, GetOwnableCarData(idx, OC_NUMBER), 0xFFFF00EE, 0.0, 0.0, 1.3, 20.0);
			//index = GetVehicleData(vehicleid, V_ACTION_ID);
			format(g_ownable_car[idx][OC_NUMBER], 12, g_ownable_car[idx][OC_NUMBER]);
			SetVehicleRuNumberPlate(vehicleid, g_ownable_car[idx][OC_NUMBER], "17");
			SetVehicleParam(vehicleid, V_LOCK, false);

			SetVehicleData(vehicleid, V_MILEAGE, 0.0);
		}

		SetPlayerData(playerid, P_OWNABLE_CAR, vehicleid);

		format
		(
			query, sizeof query,
			"INSERT INTO ownable_cars \
			(owner_id,model_id,color_1,color_2,pos_x,pos_y,pos_z,angle,create_time) \
			VALUES \
			('%d','%d','%d','%d','%f','%f','%f','%f','%d')",
			GetPlayerAccountID(playerid),
			modelid,
			color_1,
			color_2,
			pos_x,
			pos_y,
			pos_z,
			angle,
			gettime()
		);
		result = mysql_query(mysql, query, true);

		SetOwnableCarData(idx, OC_SQL_ID, cache_insert_id());

		cache_delete(result);
		
		launch[playerid] = 0;
		diski[playerid] = 0;
		fars[playerid] = 0;
		nitro[playerid] = 0;
		SendClientMessage(playerid, 0x66CC00FF, "{FFFFFF}รรซรฟ รงร รฃรฐรณรงรชรจ รฒรฐร รญรฑรฏรฎรฐรฒร  รขรฎรฑรฏรฎรซรผรงรณรฉรฒรฅรฑรผ{ffff00} รรฅรญรพ - รรฐร รญรฑรฏรฎรฐรฒ.");
	    SendClientMessage(playerid, 0x66CC00FF, "{FFFFFF}รรซรจ รขรฎรฑรฏรฎรซรผรงรณรฉรฒรฅรฑรผ{ffff00} รฏร รฐรชรฎรขรชรฎรฉ.");
		UnloadPlayerOwnableCar(playerid);

		return 1;
}

