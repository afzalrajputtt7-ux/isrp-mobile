    if (sscanf(params, "iii", prisonerid, visitorid, minutes))
        return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ /startmeettest [id รงร รชรซรพรทรฅรญรญรฎรฃรฎ] [id รฏรฎรฑรฅรฒรจรฒรฅรซรฟ] [รขรฐรฅรฌรฟ รข รฌรจรญรณรฒร รต]");

    if (!IsPlayerConnected(prisonerid) || !IsPlayerConnected(visitorid))
        return SendClientMessage(playerid, COLOR_GREY, "รรครจรญ รจรง รณรชร รงร รญรญรปรต รจรฃรฐรฎรชรฎรข รญรฅ รข รฑรฅรฒรจ");

    if (prisonerid == visitorid)
        return SendClientMessage(playerid, COLOR_GREY, "รร รชรซรพรทยธรญรญรปรฉ รจ รฏรฎรฑรฅรฒรจรฒรฅรซรผ รญรฅ รฌรฎรฃรณรฒ รกรปรฒรผ รฎรครญรจรฌ รจ รฒรฅรฌ รฆรฅ รจรฃรฐรฎรชรฎรฌ");

    if (GetPlayerData(prisonerid, P_FJAIL) <= 0)
        return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ รงร รชรซรพรทยธรญรญรปรฌ");

    if (GetPlayerDistanceFromPlayer(playerid, prisonerid) > 5.0 || GetPlayerDistanceFromPlayer(playerid, visitorid) > 5.0)
        return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรชรจ รครฎรซรฆรญรป รกรปรฒรผ รฐรฟรครฎรฌ รฑ รขร รฌรจ");

    if (!IsPlayerInRangeOfPoint(playerid, 20.0, -2023.11, -1799.98, 1501.18))
        return SendClientMessage(playerid, COLOR_GREY, "รรป รครฎรซรฆรญรป รกรปรฒรผ รข รชรฎรฌรญร รฒรฅ รครซรฟ รฑรขรจรคร รญรจรฉ");

    if (minutes < 5 || minutes > 15)
        return SendClientMessage(playerid, COLOR_GREY, "รรฐรฅรฌรฟ รครฎรซรฆรญรฎ รกรปรฒรผ รฎรฒ 5 รครฎ 15 รฌรจรญรณรฒ");

    new roomid = -1;
    for (new i = 0; i < sizeof g_fsinRooms; i++)
    {
        if (!g_fsinRooms[i][isBusy])
        {
            roomid = i;
            break;
        }
    }

    if (roomid == -1)
        return SendClientMessage(playerid, COLOR_GREY, "รรฅรฒ รฑรขรฎรกรฎรครญรปรต รชรฎรฌรญร รฒ รครซรฟ รฑรขรจรคร รญรจรฉ");

    StartMeetFSIN(prisonerid, visitorid, roomid, minutes);

    new fmt_msg[144];
    format(fmt_msg, sizeof fmt_msg, "[รรรร] %s %s รญร รทร รซ รฑรขรจรคร รญรจรฅ รครซรฟ รงร รชรซรพรทรฅรญรญรฎรฃรฎ %s รจ รฏรฎรฑรฅรฒรจรฒรฅรซรฟ %s รข รชรฎรฌรญร รฒรฅ ยน%d รญร  %d รฌรจรญรณรฒ.",
