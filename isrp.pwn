CMD:quest(playerid)
{
	ShowPlayerQuestMenu(playerid);
}

CMD:vleave(playerid, params[])
{
	if(GetPlayerData(playerid, P_IMPROVEMENTS) < 2) return SendClientMessage(playerid, 0x999999FF, "รรฐรจรฎรกรฐรฅรฒรจรฒรฅ รณรซรณรทรธรฅรญรจรฅ \"รรฅรธรจรฒรฅรซรผรญรฎรฑรฒรผ\", รทรฒรฎรกรป รณรขรฎรซรจรฒรผรฑรฟ รฏรฎ รฑรฎรกรฑรฒรขรฅรญรญรฎรฌรณ รฆรฅรซร รญรจรพ");

	if(!GetPlayerTeamEx(playerid)) return ShowNotificationDefault(playerid, 2, 5, 2, 1, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฎรฐรฃร รญรจรงร รถรจรจ");

	new fmt_text[999];

	format
	(
		fmt_text, sizeof fmt_text,
		""SC"รร รธร  รฎรฐรฃร รญรจรงร รถรจรฟ{ffff00}: \"%s\".\n\n"\
		"{ffffff}รรป รครฅรฉรฑรฒรขรจรฒรฅรซรผรญรฎ รตรฎรฒรจรฒรฅ รฏรฎรชรจรญรณรฒรผ รคร รญรญรณรพ รฎรฐรฃร รญรจรงร รถรจรพ รฏรฎ\n"\
		"{ffffff}รฑรฎรกรฑรฒรขรฅรญรญรฎรฌรณ รฆรฅรซร รญรจรพ?",
		GetTeamName(GetPlayerTeamEx(playerid))
	);

	Dialog(playerid, DIALOG_TEAM_LEAVE, DIALOG_STYLE_MSGBOX, "{FF6347}"SERVER_NAME" {ffffff}| รรฎรครฒรขรฅรฐรฆรครฅรญรจรฅ", fmt_text, "รร รซรฅรฅ", "รรฒรฌรฅรญร ");

	return 1;
}

CMD:unj(playerid)
{
	if(!GetPlayerPremium(playerid) || GetPlayerData(playerid, P_UNJ)) return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ VIP, รจรซรจ รขรป รณรฆรฅ รขรฎรฑรฏรฎรซรผรงรฎรขร รซรจรฑรผ รชรฎรฌร รญรครฎรฉ รฐร รญรฅรฅ");
    if(GetPlayerPremium(playerid) == 2)
	{
		SetPlayerData(playerid, P_JAIL ,GetPlayerData(playerid, P_JAIL) / 2);
	}
	else if(GetPlayerPremium(playerid) == 3)
	{
		SetPlayerData(playerid, P_JAIL ,GetPlayerData(playerid, P_JAIL) / 3);
	}
    SetPlayerData(playerid, P_UNJ, 1);
    UpdatePlayerDatabaseInt(playerid, "unj", GetPlayerData(playerid, P_UNJ));
    SendClientMessage(playerid, 0xCECECEFF, "รรป รณรฌรฅรญรผรธรจรซรจ รฑรฐรฎรช รฒรพรฐรผรฌรป!");
	return 1;
}


CMD:togphone(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร . รรฃรฎ รฌรฎรฆรญรฎ รชรณรฏรจรฒรผ รข รฑรฎรฒรฎรขรฎรฌ รฑร รซรฎรญรฅ");
	if(!GetPlayerPremium(playerid))
	    return   SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ VIP ร รชรชร รณรญรฒร .");

	if(GetPlayerPhoneCall(playerid, PC_INCOMING_PLAYER) != INVALID_PLAYER_ID || GetPlayerPhoneCall(playerid, PC_OUTCOMING_PLAYER) != INVALID_PLAYER_ID)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรญรทรจรฒรฅ รฒรฅรชรณรนรจรฉ รฐร รงรฃรฎรขรฎรฐ");

	if(GetPlayerPhoneCall(playerid, PC_ENABLED))
	{
		SetPlayerPhoneCall(playerid, PC_ENABLED, false);
		SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรฅรดรฎรญ รฎรฒรชรซรพรทรฅรญ");
	}
	else
	{
		SetPlayerPhoneCall(playerid, PC_ENABLED, true);
		SendClientMessage(playerid, 0x32a44bFF, "รรฅรซรฅรดรฎรญ รขรชรซรพรทรฅรญ");
	}
	return 1;
}

CMD:v(playerid, params[])
{
	if(GetPlayerPremium(playerid) < 1) return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ VIP ร รชรชร รณรญรฒร  ");
	else if(IsPlayerMuted(playerid) > 0) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฑรฒรณรฏ รข รทร รฒ รงร รกรซรฎรชรจรฐรฎรขร รญ. รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ: {66CC33}/time");
	else if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /v [รฒรฅรชรฑรฒ]");

	new fmt_msg[144];



	format(fmt_msg, sizeof fmt_msg, "[VIP Platinum] %s[%d]: %s", GetPlayerNameEx(playerid), playerid, params);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(!GetPlayerPremium(i)) continue;
        if(!GetPlayerData(i, P_PREMIUM_CHAT)) continue;

		SendClientMessage(i, COLOR_YELLOW , fmt_msg);
	}
	return 1;
}

CMD:voff(playerid, params[])
{
	if(GetPlayerPremium(playerid) < 1) return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ VIP ร รชรชร รณรญรฒร  ");
	if(GetPlayerData(playerid, P_PREMIUM_CHAT))
	{
		SendClientMessage(playerid,-1,"รรป รฎรฒรชรซรพรทรจรซรจ VIP รทร รฒ");
		SetPlayerData(playerid, P_PREMIUM_CHAT, 0);
		return 1;
	}
	if(!GetPlayerData(playerid, P_PREMIUM_CHAT))
	{
		SendClientMessage(playerid,-1,"รรป รขรชรซรพรทรจรซรจ VIP รทร รฒ");
		SetPlayerData(playerid, P_PREMIUM_CHAT, 1);
		return 1;
	}
	return 1;
}

stock SendMessageToYouTubers(message[], color, y_level = 1)
{
    if(y_level < 1)
        y_level = 1;

    new count;
    foreach(new playerid : Player)
    {
        if(!IsPlayerLogged(playerid)) continue;
        if(GetPlayerYouTubeEx(playerid) < y_level) continue;

        SendClientMessage(playerid, color, message);
        count ++;
    }
    return count;
}

CMD:yhelp(playerid, params[])
{
	if(GetPlayerYouTubeEx(playerid) < 1) return 1;

	new fmt_str[350 + 1];

	format
	(
		fmt_str, sizeof fmt_str,
		"{6666CC}/yz -{FFFFFF} รฒรฅรซรฅรฏรฎรฐรฒ รข รพรฒรณรกรฅรฐรฑรชรณรพ-รงรฎรญรณ{6666CC}\n\
		/yre -{FFFFFF} รฑรซรฅรฆรชร  รงร  รจรฃรฐรฎรชรฎรฌ{6666CC}\n\
		/yreoff -{FFFFFF} รงร รชรฎรญรทรจรฒรผ รฑรซรฅรฆรชรณ รงร  รจรฃรฐรฎรชรฎรฌ{6666CC}\n\
		/y -{FFFFFF}  รพรฒรณรกรฅรฐรฑรชรจรฉ รทร รฒ{6666CC}\n\
		/yhp -{FFFFFF} รขรฎรฑรฑรฒร รญรฎรขรจรฒรผ รฑรฅรกรฅ รตรฏ{6666CC}\n\
		/yveh -{FFFFFF} รงร รฑรฏร รขรญรจรฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ{6666CC}\n\
		/yskin -{FFFFFF} รขรปรคร รฒรผ รฑรฅรกรฅ รขรฐรฅรฌรฅรญรญรปรฉ รฑรชรจรญ{6666CC}\n\
		/sptext -{FFFFFF} รฏรจรฑร รฒรผ รฒรฅรชรฑรฒ รงร  รจรฃรฐรฎรชร {6666CC}\n\
		\n\
		รรฎรฑรฒรณรฏ รฒรฅรซรฅรฏรฎรฐรฒร  รฏรฎ รฌรฅรฒรชรฅ รญร  รชร รฐรฒรฅ");

	Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "รรฎรฌร รญรครป รพรฒรณรกรฅรฐรฎรข", fmt_str, "รร รชรฐรปรฒรผ", "");
	return 1;
}

