CMD:ears(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 3) return 1;

	g_admin_ears = g_admin_ears ^ true;

	new fmt_text[70];

	format(fmt_text, sizeof fmt_text, "รรป %s รฏรฐรฎรฑรซรณรธรชรณ SMS", g_admin_ears ? "รขรชรซรพรทรจรซรจ" : "รขรปรชรซรพรทรจรซรจ");
	SendClientMessage(playerid, 0x3399FFFF, fmt_text);

	if(GetPlayerAdminEx(playerid) <= 5)
	{
		format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s รฏรฐรฎรฑรซรณรธรชรณ SMS", GetPlayerNameEx(playerid), playerid, g_admin_ears ? "รขรชรซรพรทรจรซ" : "รขรปรชรซรพรทรจรซ");
		SendMessageToAdmins(fmt_text, 0x999999FF);
	}

	format(fmt_text, sizeof fmt_text, "%s รฏรฐรฎรฑรซรณรธรชรณ SMS", g_admin_ears ? "รรชรซรพรทรจรซ" : "รรปรชรซรพรทรจรซ");

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

