							    MoveOwnableCar(playerid, vehicleid, fam_id);
							}
							default:
								return 1;
						}
						//callcmd::car(playerid, "");
					}
				}
			}

			case DIALOG_OWNABLE_CAR_LOAD_BAT:
			{
				if(response)
				{
					new idx = GetPVarInt(playerid, "ownablecar_id"),
						Float: x,
						Float: y,
						Float: z,
						Cache: result,
						query[100];

					mysql_format(mysql, query, sizeof query, "SELECT pos_x, pos_y, pos_z FROM ownable_cars WHERE id='%d'", idx);
					result = mysql_query(mysql, query, true);

					if(cache_num_rows())
					{
						x = cache_get_row_float(0, 0);
						y = cache_get_row_float(0, 1);
						z = cache_get_row_float(0, 2);
					}

					cache_delete(result);

					switch(listitem + 1)
					{
						case 1:
						{
	
								if(GetPlayerMoneyEx(playerid) >= 300)
								{
									GivePlayerMoneyEx(playerid, -300, "รรฅรฒรชร  รร รญร  GPS", true, true);

									EnablePlayerGPS(playerid, x, y, z);
         
									return 1;
								}
								else SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ");

						}
						case 2:
						{
							if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
							{
								SendClientMessage(playerid, 0x999999FF, "รรจรฑรฒรฅรฌรญร รฟ รฎรธรจรกรชร . รรฐร รญรฑรฏรฎรฐรฒ รณรฆรฅ รงร รฃรฐรณรฆรฅรญ.");
								return 1;
							}
							else
							{
								if(GetPVarInt(playerid, "rent_true") != 1)
								{
									if(LoadOwnableCar(idx) != -1)
									{
										PlayerOwnableCarInit(playerid);
										//LoadTun(playerid);
										SendClientMessage(playerid, 0x66CC33FF, "รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รณรฑรฏรฅรธรญรฎ รงร รฃรฐรณรฆรฅรญ!");
									}
									else SendClientMessage(playerid, 0x999999FF, "รรธรจรกรชร  รฏรฐรจ รงร รฃรฐรณรงรชรฅ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
								}
								else 
								{
									if(GetPlayerMoneyEx(playerid) >= GetPVarInt(playerid, "price_rent"))
									{
										if(LoadOwnableCarRentBat(playerid, idx) != -1)
										{
											PlayerOwnableCarInit(playerid);
											//LoadTun(playerid);
											PutPlayerInVehicle(playerid, GetPlayerData(playerid, P_OWNABLE_CAR), 0);
											SendClientMessage(playerid, 0x66CC33FF, "รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รณรฑรฏรฅรธรญรฎ รงร รฃรฐรณรฆรฅรญ!");

											GivePlayerMoneyEx(playerid, -GetPVarInt(playerid, "price_rent"));

											DeletePVar(playerid, "price_rent");
											DeletePVar(playerid, "rent_true");
										}
										else SendClientMessage(playerid, 0x999999FF, "รรธรจรกรชร  รฏรฐรจ รงร รฃรฐรณรงรชรฅ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
									}
								}
							}
						}
					}
				}
				else
				{
					if(GetPVarInt(playerid, "show_menu"))
					{
						DeletePVar(playerid, "show_menu");
						callcmd::car(playerid, "");
					}
				}
				
				return 1;
			}
			
case DIALOG_OWNABLE_CAR_LOAD_LUT:
{
    if(response)
    {
        new idx = GetPVarInt(playerid, "ownablecar_id"),
            Float:x,
            Float:y,
            Float:z,
            Cache:result,
            query[100];

        mysql_format(mysql, query, sizeof query,
            "SELECT pos_x, pos_y, pos_z FROM ownable_cars WHERE id='%d'", idx);
        result = mysql_query(mysql, query, true);

        if(cache_num_rows())
        {
            x = cache_get_row_float(0, 0);
            y = cache_get_row_float(0, 1);
            z = cache_get_row_float(0, 2);
        }
        cache_delete(result);

        switch(listitem + 1)
        {
            // ================= GPS =================
            case 1:
            {
                    if(GetPlayerMoneyEx(playerid) >= 300)
                    {
                        GivePlayerMoneyEx(playerid, -300, "รรฅรฒรชร  รร รญร  GPS", true, true);
                        EnablePlayerGPS(playerid, x, y, z);
                    }
                    else SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ");
            }

            // ================= รรรรรรรร =================
            case 2:
            {
                if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
                    return SendClientMessage(playerid, 0x999999FF,
                        "รรจรฑรฒรฅรฌรญร รฟ รฎรธรจรกรชร . รรฐร รญรฑรฏรฎรฐรฒ รณรฆรฅ รงร รฃรฐรณรฆรฅรญ.");

                // ===== รรรรรร =====
                if(GetPVarInt(playerid, "rent_true") == 1)
                {
                    if(GetPlayerMoneyEx(playerid) < GetPVarInt(playerid, "price_rent"))
                        return SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ");

                    // รซรฎรชร รซรผรญรปรฉ รฌร รฑรฑรจรข รชรฎรฎรฐรครจรญร รฒ
                    new Float:spawnPos[6][4] =
                    {
                        {-2460.224, 197.344, 25.740, 1.000},
                        {-2464.279, 197.418, 25.740, 1.000},
                        {-2466.615, 197.365, 25.740, 1.000},
                        {-2469.888, 197.623, 25.735, 1.000},
                        {-2473.203, 197.334, 25.742, 1.000},
                        {-2475.766, 197.582, 25.746, 1.000}
                    };

                    new r = random(sizeof(spawnPos));

                    SetPVarFloat(playerid, "rent_x", spawnPos[r][0]);
                    SetPVarFloat(playerid, "rent_y", spawnPos[r][1]);
                    SetPVarFloat(playerid, "rent_z", spawnPos[r][2]);
                    SetPVarFloat(playerid, "rent_a", spawnPos[r][3]);

                    if(LoadOwnableCarRentLut(playerid, idx) != -1)
                    {
                        PlayerOwnableCarInit(playerid);
                        PutPlayerInVehicle(playerid,
                            GetPlayerData(playerid, P_OWNABLE_CAR), 0);

                        GivePlayerMoneyEx(playerid,
                            -GetPVarInt(playerid, "price_rent"));

                        DeletePVar(playerid, "price_rent");
                        DeletePVar(playerid, "rent_true");

                        SendClientMessage(playerid, 0x66CC33FF,
                            "รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รณรฑรฏรฅรธรญรฎ รงร รฃรฐรณรฆรฅรญ!");
                    }
                    else SendClientMessage(playerid, 0x999999FF,
                        "รรธรจรกรชร  รฏรฐรจ รงร รฃรฐรณรงรชรฅ รฒรฐร รญรฑรฏรฎรฐรฒร ");

                    return 1;
                }

                // ===== รรรรรรร รรรรรรรร =====
                if(LoadOwnableCar(idx) != -1)
                {
                    PlayerOwnableCarInit(playerid);
                    SendClientMessage(playerid, 0x66CC33FF,
