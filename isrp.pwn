case DIALOG_GPS_MISTS:
{
	if(response)
	{
		switch(listitem)
		{
		    case 0: // รรร
			{
				new fmt_str[128];
				new stationid = GetNearestFuelStation(playerid, 0.0);

				// รรรรรรรรร รรรรรรรร
				if(stationid == -1)
				{
					SendClientMessage(playerid, 0xFF0000AA, "รรซรจรฆร รฉรธร รฟ รรร รญรฅ รญร รฉรครฅรญร !");
					return 1;
				}

				new Float:dist = GetPlayerDistanceFromPoint(playerid,
					GetFuelStationData(stationid, FS_POS_X),
					GetFuelStationData(stationid, FS_POS_Y),
					GetFuelStationData(stationid, FS_POS_Z)
				);

				SetGPSMarker(
					playerid,
					GetFuelStationData(stationid, FS_POS_X),
					GetFuelStationData(stationid, FS_POS_Y),
					GetFuelStationData(stationid, FS_POS_Z)
				);

				format(fmt_str, sizeof fmt_str, "รรซรจรฆรฅ รขรฑรฅรฃรฎ รช รร รฌ รญร รตรฎรครจรฒรฑรฟ รรร ยน%d \"%s\" (รฐร รฑรฑรฒรฎรฟรญรจรฅ %.1f รฌ)",
					stationid, GetFuelStationData(stationid, FS_NAME), dist);
				SendClientMessage(playerid, 0xFFFF00AA, fmt_str);
			}
			case 1: // รร รฃร รงรจรญ 24/7
			{
				new fmt_str[128];
