stock IsComfortPartInstalled(current_value, part_digit)
{
    new s_val[12];
    format(s_val, sizeof(s_val), "%d", current_value);
    new char_digit = part_digit + '0';
    for(new i = 0; i < strlen(s_val); i++) {
        if(s_val[i] == char_digit) return 1;
    }
    return 0;
}

stock IsAllComfortPartsInstalled(value)
{
    if(IsComfortPartInstalled(value, 1) &&
       IsComfortPartInstalled(value, 2) &&
       IsComfortPartInstalled(value, 3) &&
       IsComfortPartInstalled(value, 4) &&
       IsComfortPartInstalled(value, 5))
    {
        return 1;
    }
    return 0;
}

