        return SendClientMessage(playerid, COLOR_GREY, "ร รร รฑ รญรฅรฒ รขรฎรฅรญรญรฎรฃรฎ รกรจรซรฅรฒร .");

    if(!strlen(params)) return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /showvb [id รจรฃรฐรฎรชร ]");

    extract params -> new to_player;

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player)) return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ ร รขรฒรฎรฐรจรงรฎรขร รญ.");
    if(!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0)) return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ.");

    SendClientMessage(playerid, COLOR_BLUE, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ รฏรฎรชร รงร รฒรผ รขรฎรฅรญรญรปรฉ รกรจรซรฅรฒ.");
    SendPlayerOffer(playerid, to_player, OFFER_TYPE_SHOWVB);
