			GetFuelStationData(stationid, FS_PRICE),
			GetFuelStationData(stationid, FS_RENT_PRICE)
		);
		Dialog(playerid, DIALOG_FUEL_STATION_BUY, DIALOG_STYLE_MSGBOX, "{33AACC}รรฎรชรณรฏรชร  รงร รฏรฐร รขรฎรทรญรฎรฉ รฑรฒร รญรถรจรจ", fmt_str, "รร ", "รรฅรฒ");
	}
