CMD:makestore(playerid, params[])
{
	new houseid = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);
	if(houseid != -1)
	{
		if(GetHouseData(houseid, H_IMPROVEMENTS) >= 5)
		{
			if(GetPlayerInHouse(playerid) == houseid)
			{
				new type = GetHouseData(houseid, H_TYPE);
				if(IsPlayerInRangeOfPoint(playerid, 50.0, GetHouseTypeInfo(type, HT_ENTER_POS_X), GetHouseTypeInfo(type, HT_ENTER_POS_Y), GetHouseTypeInfo(type, HT_ENTER_POS_Z)))
				{
					Dialog
					(
						playerid, DIALOG_HOUSE_MOVE_STORE, DIALOG_STYLE_MSGBOX,
						"{FFCD00}รรชร รด",
						"{FFFFFF}รรป รตรฎรฒรจรฒรฅ รฐร รงรฌรฅรฑรฒรจรฒรผ รธรชร รด รข รฝรฒรฎรฌ รฌรฅรฑรฒรฅ?",
						"รร ", "รรฅรฒ"
					);
				}
				else SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรฅรกรฟ รข รครฎรฌรฅ");
			}
			else SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรฅรกรฟ รข รครฎรฌรฅ");
		}
		else SendClientMessage(playerid, 0x999999FF, "รรฅรฎรกรตรฎรครจรฌ 5 รณรฐรฎรขรฅรญรผ รณรซรณรทรธรฅรญรจรฉ รครซรฟ รครฎรฌร ");
	}
	else SendClientMessage(playerid, 0x999999FF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รขรซร รครฅรซรผรถร รฌ รญรฅรครขรจรฆรจรฌรฎรฑรฒรจ");

	return 1;
}

CMD:use(playerid, params[])
{
	new house_id = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);

	if(house_id == -1) return SendClientMessage(playerid, 0x999999FF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รขรซร รครฅรซรผรถร รฌ รญรฅรครขรจรฆรจรฌรฎรฑรฒรจ");

	if(GetPlayerInHouse(playerid) != house_id) return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รฑรขรฎยธรฌ รครฎรฌรฅ");

	if(GetHouseData(house_id, H_IMPROVEMENTS) < 5) return SendClientMessage(playerid, 0x999999FF, "รรฅรฎรกรตรฎรครจรฌ 5 รณรฐรฎรขรฅรญรผ รณรซรณรทรธรฅรญรจรฉ รครซรฟ รครฎรฌร ");

	if(!IsPlayerInRangeOfPoint(playerid, 3.0, GetHouseData(house_id, H_STORE_X), GetHouseData(house_id, H_STORE_Y), GetHouseData(house_id, H_STORE_Z)))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรขรฎรฅรฃรฎ รธรชร รดร ");

	Dialog
	(
		playerid, DIALOG_HOUSE_STORE, DIALOG_STYLE_LIST,
		"{FFCC00}รรชร รด",
		"1. รรฎรซรฎรฆรจรฒรผ รร รฒรฅรฐรจร รซรป\n\
		2. รรฎรซรฎรฆรจรฒรผ รญร รฐรชรฎรฒรจรชรจ\n\
		3. รรฎรซรฎรฆรจรฒรผ รฎรฐรณรฆรจรฅ\n\
		4. รรฎรซรฎรฆรจรฒรผ รฎรครฅรฆรครณ\n\
		{99FF99}5. รรงรฟรฒรผ รร รฒรฅรฐรจร รซรป\n\
		{99FF99}6. รรงรฟรฒรผ รญร รฐรชรฎรฒรจรชรจ\n\
		{99FF99}7. รรงรฟรฒรผ รฎรฐรณรฆรจรฅ\n\
		{99FF99}8. รรงรฟรฒรผ รฎรครฅรฆรครณ",
		"รร รซรฅรฅ", "รร รชรฐรปรฒรผ"
	);

	return 1;
}

CMD:homelock(playerid, params[])
{
	new hotel_id = GetPlayerHouse(playerid, HOUSE_TYPE_HOTEL);
	new room_id = GetPlayerData(playerid, P_HOUSE_ROOM);

	if(hotel_id != -1)
	{
		if(GetHotelData(hotel_id, room_id, H_STATUS))
		{
			SetHotelData(hotel_id, room_id, H_STATUS, false);

			GameTextForPlayer(playerid, "~g~~h~OยKPโยO", 2000, 4);
			SendClientMessage(playerid, 0x66CC00FF, "รรฎรฌรฅรฐ รฎรฒรชรฐรปรฒ");
		}
		else
		{
			SetHotelData(hotel_id, room_id, H_STATUS, true);

			GameTextForPlayer(playerid, "~r~~h~หAKPโยO", 2000, 4);
			SendClientMessage(playerid, 0xFF6600FF, "รรฎรฌรฅรฐ รงร รชรฐรปรฒ");
		}

		new query[64];
		format(query, sizeof query, "UPDATE hotels SET status=%d WHERE id=%d LIMIT 1", GetHotelData(hotel_id, room_id, H_STATUS), GetHotelData(hotel_id, room_id, H_SQL_ID));
		mysql_query(mysql, query, false);
	}
	else SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฑรญรจรฌร รฅรฒรฅ รญรฎรฌรฅรฐ รข รฃรฎรฑรฒรจรญรจรถรฅ");

	return 1;
}

CMD:exit(playerid, params[])
{
	if(GetPlayerInHouse(playerid) != -1)
	{
		new houseid = GetPlayerInHouse(playerid);
		if(GetHouseData(houseid, H_IMPROVEMENTS) > 5)
		{
			Dialog
			(
				playerid, DIALOG_ACTION_EXIT_HOUSE, DIALOG_STYLE_LIST,
				"{FFCC00}รรปรตรฎรค",
				"1. รรซรจรถร \n\
				2. รร รฐร รฆ",
				"รร รซรฅรฅ", "รร รชรฐรปรฒรผ"
			);
		}
		else
			ExitPlayerFromHouse(playerid, 3.0);
	}
	else if(GetPlayerData(playerid, P_IN_HOTEL_ROOM) != -1)
	{
		ExitPlayerFromHotelRoom(playerid);
	}
	else if(!GetPlayerInterior(playerid))
	{
		SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รข รฏรฎรฌรฅรนรฅรญรจรจ");
	}

	return 1;
}

CMD:lift(playerid, params[])
{
	new entranceid = GetPlayerInEntrance(playerid);
	if(entranceid != -1)
	{
		new floor = GetPlayerInEntranceFloor(playerid);
		if(floor != -1)
		{
			if(!floor)
			{
				if(!IsPlayerInRangeOfPoint(playerid, 1.5, 30.5405, 1403.6593, 1508.4163))
					return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฎรชรฎรซรฎ รซรจรดรฒร ");
			}
			else
			{
				if(!IsPlayerInRangeOfPoint(playerid, 1.5, 11.1776, 1377.5216, 1508.4163))
					return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฎรชรฎรซรฎ รซรจรดรฒร ");
			}
			ShowPlayerEntranceFloorsLift(playerid, entranceid, floor);
		}
	}
	else SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รข รฏรฎรครบรฅรงรครฅ");

	return 1;
}

CMD:lock(playerid, params[])
{
if(player_sell_ownable_car[playerid] == false)
                         	{
    if(GetPlayerOwnableCar(playerid) == INVALID_VEHICLE_ID)
    {
        if(GetPlayerOwnableCars(playerid) == 0)
        return SendClientMessage(playerid, 0x999999FF, ""USC"ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
        else
        return SendClientMessage(playerid, 0x999999FF, ""USC"รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
    }
    new Float: x, Float: y, Float: z;
    GetVehiclePos(GetPlayerOwnableCar(playerid), x, y, z);

    if(IsPlayerInRangeOfPoint(playerid, 10.0, x, y, z))
    {
        ToggleLock(playerid, GetPlayerOwnableCar(playerid));
    }
    else SendClientMessage(playerid, 0x999999FF, ""USC"รรป รครฎรซรฆรญรป รฑรฒรฎรฟรฒรผ รฐรฟรครฎรฌ รฑ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ");
    return true;
    }
    else return 1;
}
alias:lock("lk")

CMD:key(playerid, params[])
{
	if(IsPlayerInAnyVehicle(playerid))
	{
		if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID || GetPlayerAllowedCar(playerid) != INVALID_VEHICLE_ID)
		{
			new vehicleid = GetPlayerVehicleID(playerid);
			if(!IsABike(vehicleid))
			{
				if(vehicleid == GetPlayerOwnableCar(playerid) || vehicleid == GetPlayerAllowedCar(playerid))
				{
					new index = GetVehicleData(vehicleid, V_ACTION_ID);
					new bool: status = GetOwnableCarData(index, OC_KEY_IN);

					if(status)
					{
						if(GetVehicleParam(vehicleid, V_ENGINE) == VEHICLE_PARAM_ON)
						{
							SetVehicleParam(vehicleid, V_ENGINE, VEHICLE_PARAM_OFF);
						}
						Action(playerid, "รขรปรฒร รนรจรซ รชรซรพรท รจรง รงร รฌรชร  รงร รฆรจรฃร รญรจรฟ", _, false);
					}
					else Action(playerid, "รขรฑรฒร รขรจรซ รชรซรพรท รข รงร รฌรฎรช รงร รฆรจรฃร รญรจรฟ", _, false);

					SetOwnableCarData(index, OC_KEY_IN, status ^ true);
				//	SpeedometrKeyStatusInit(playerid, vehicleid);
				}
				else SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รซรจรทรญรฎรฌ/รครฎรขรฅรฐรฅรญรญรฎรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");
			}
		}
		else
		{
			if(GetPlayerOwnableCars(playerid) == 0)
				SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ/รครฎรขรฅรฐรฅรญรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
			else
				SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
		}
	}
	else SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	return 1;
}

CMD:getmycar(playerid, params[])
{
	new vehicleid = GetPlayerOwnableCar(playerid);
	if(vehicleid != INVALID_VEHICLE_ID)
	{
		new price = 300;
		new i_have_home = (GetPlayerHouse(playerid, HOUSE_TYPE_HOME) != -1 || GetPlayerHouse(playerid, HOUSE_TYPE_HOTEL) != -1);

			if(GetPlayerMoneyEx(playerid) >= price || i_have_home)
			{
				if(!i_have_home)
					GivePlayerMoneyEx(playerid, -price, "รรฅรฒรชร  รร รญร  GPS", true, true);

				new Float: x, Float: y, Float: z;
				GetVehiclePos(vehicleid, x, y, z);

				EnablePlayerGPS(playerid, x, y, z);
    
				return 1;
			}
			else SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ");
	}
	else
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
		else
			SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
	}

	return 0;
}

CMD:sellcar(playerid, params[])
{
	new vehicleid = GetPlayerOwnableCar(playerid);
	if(vehicleid != INVALID_VEHICLE_ID)
	{
		new model_id = GetVehicleData(vehicleid, V_MODELID);
		if(model_id)
		{
			new fmt_str[999];

			new price = GetVehicleInfo(model_id-400, VI_PRICE);
			new percent = price * 50 / 100;

			format
			(
				fmt_str, sizeof fmt_str,
				""SC"รรฐร รญรฑรฏรฎรฐรฒรญรฎรฅ รฑรฐรฅรครฑรฒรขรฎ:\t{ffff00}%s (ยน%d)\n"\
				""SC"รรฒรฎรจรฌรฎรฑรฒรผ รฏรฐรฎรคร รฆรจ:\t{ffff00}%d\n\n"\
				"{FFFFFF}รรป รฌรฎรฆรฅรฒรฅ รฏรฐรฎรคร รฒรผ รฑรขรฎรฅ รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฅ รฑรฐรฅรครฑรฒรขรฎ รครฐรณรฃรจรฌ\n"\
				"รจรฃรฐรฎรชร รฌ รฑ รฏรฎรฌรฎรนรผรพ รชรฎรฌร รญรครป: {ffff00}\"/sellmycar\".\n\n"\
				"{FFFFFF}รรป รณรขรฅรฐรฅรญรป, รทรฒรฎ รตรฎรฒรจรฒรฅ รฌรฎรฌรฅรญรฒร รซรผรญรฎ รฏรฐรฎรคร รฒรผ รฑรขรฎรฅ\n"\
				"รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฅ รฑรฐรฅรครฑรฒรขรฎ?",
				GetVehicleName(vehicleid),
				model_id,
				price,
				price - percent
			);
			Dialog(playerid, DIALOG_OWNABLE_CAR_SELL, DIALOG_STYLE_MSGBOX, "{FF6347}"SERVER_NAME" -> {ffffff}รรฐรฎรคร รฆร  รฒรฐร รญรฑรฏรฎรฐรฒร ", fmt_str, "รร ", "รรฒรฌรฅรญร ");
		}
	}
	else
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			ShowNotificationDefault(playerid, 2, 5, 2, 1, "ร รขร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
		else
			ShowNotificationDefault(playerid, 2, 5, 2, 1, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐรฅ");
	}

	return 1;
}

CMD:sellmycar(playerid, params[])
{
	new vehicleid = GetPlayerOwnableCar(playerid);
	if(vehicleid != INVALID_VEHICLE_ID)
	{
		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellmycar [id รจรฃรฐรฎรชร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

		extract params -> new to_player, price;

		new model_id = GetVehicleData(vehicleid, V_MODELID);
		if(model_id)
		{
			new car_price = GetVehicleInfo(model_id-400, VI_PRICE);

			if(!IsPlayerConnected(to_player) || to_player == playerid)
				return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

			if((GetPlayerOwnableCars(to_player) + 1) > GetPlayerCarSlots(to_player))
				return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฑรขรฎรกรฎรครญรปรต รฑรซรฎรฒรฎรข รครซรฟ รฒรฐร รญรฑรฏรฎรฐรฒร ");

			if(GetPlayerOwnableCar(to_player) != INVALID_VEHICLE_ID)
				return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รครฎรซรฆรฅรญ รขรปรฃรฐรณรงรจรฒรผ รฅรฃรฎ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รฑรฅรฐรขรฅรฐร  {888888}(/car > 7)");

			if(!(3000 <= price <= (car_price * 2)))
				return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รครฎรซรฆร  รกรปรฒรผ รฎรฒ 3000 รฐรณรกรซรฅรฉ รจ รญรฅ รครฎรฐรฎรฆรฅ รข 2 รฐร รงร  รฃรฎรฑ. รฑรฒรฎรจรฌรฎรฑรฒรจ รร");

			if(GetPlayerMoneyEx(to_player) < price)
				return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฒร รชรฎรฉ รฑรณรฌรฌรป");

			new  Float: car_x, Float: car_y, Float: car_z;
			GetVehiclePos(vehicleid, car_x, car_y, car_z);

			if(IsPlayerInRangeOfPoint(playerid, 15.0, car_x, car_y, car_z) && IsPlayerInRangeOfPoint(to_player, 15.0, car_x, car_y, car_z))
			{
				SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_OWNABLE_CAR, price, vehicleid);
			}
			else SendClientMessage(playerid, 0xCECECEFF, "รรป รจ รฏรฎรชรณรฏร รฒรฅรซรผ รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฎรชรฎรซรฎ รร");
		}
	}
	else
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
		else
			SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
	}

	return 1;
}

CMD:allow(playerid, params[])
{
	new vehicleid = GetPlayerOwnableCar(playerid);
	if(vehicleid == INVALID_VEHICLE_ID)
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
		else
			return SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
	}

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /allow [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new fmt_text[71];

	if(GetPlayerAllowedCar(to_player) == vehicleid)
	{
		format(fmt_text, sizeof fmt_text, "รรป รงร รกรฐร รซรจ รณ %s รชรซรพรทรจ รฎรฒ รร รธรฅรฃรฎ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ", GetPlayerNameEx(to_player));
		SendClientMessage(playerid, 0x3399FFFF, fmt_text);

		format(fmt_text, sizeof fmt_text, "%s รงร รกรฐร รซ รณ รร รฑ รชรซรพรทรจ รฎรฒ รฑรขรฎรฅรฃรฎ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ", GetPlayerNameEx(playerid));
		SendClientMessage(to_player, 0xFF5533FF, fmt_text);

		SetPlayerData(to_player, P_ALLOWED_CAR, INVALID_VEHICLE_ID);
	}
	else
	{
		if(!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0)) return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

		SendPlayerOffer(playerid, to_player, OFFER_TYPE_GIVE_CAR_KEY);
	}

	return 1;
}

CMD:park(playerid, params[])
{
	if(!IsPlayerInAnyVehicle(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	new vehicleid = GetPlayerOwnableCar(playerid);
	if(vehicleid == INVALID_VEHICLE_ID)
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
		else
			return SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
	}

	if(vehicleid != GetPlayerVehicleID(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รซรจรทรญรฎรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	new green_zone_id = GetPVarInt(playerid, "player_in_green_zone") - 1;

	if(green_zone_id != -1)
	{
		if(!g_green_zones[green_zone_id][GZ_ALLOW_PARK])
		{
			new fmt_text[144];

			format(fmt_text, sizeof fmt_text, "รร  รฒรฅรฐรฐรจรฒรฎรฐรจรจ {FFFF00}'%s' {3399FF}รฏร รฐรชรฎรขรชร  รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  รงร รฏรฐรฅรนรฅรญร . รรปรกรฅรฐรจรฒรฅ รครฐรณรฃรฎรฅ รฌรฅรฑรฒรฎ รครซรฟ รฏร รฐรชรฎรขรชรจ", g_green_zones[green_zone_id][GZ_NAME]);
			SendClientMessage(playerid, 0x3399FFFF, fmt_text);

			return 1;
		}
	}

	new index = GetVehicleData(vehicleid, V_ACTION_ID);

	GetVehiclePos(vehicleid, GetOwnableCarData(index, OC_POS_X), GetOwnableCarData(index, OC_POS_Y), GetOwnableCarData(index, OC_POS_Z));
	GetVehicleZAngle(vehicleid, GetOwnableCarData(index, OC_ANGLE));

	SaveOwnableCar(vehicleid);
	return SendClientMessage(playerid, 0x66CC00FF, "รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รณรฑรฏรฅรธรญรฎ รฏรฐรจรฏร รฐรชรฎรขร รญ");
}

CMD:car(playerid, params[])
{
	if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
	{
		Dialog
		(
			playerid, DIALOG_OWNABLE_CAR, DIALOG_STYLE_LIST,
			"{FFCD00}รรจรฑรฒรฅรฌร  รณรฏรฐร รขรซรฅรญรจรฟ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ",
			"1. {669900}รรฒรชรฐรปรฒรผ {FFFFFF}รจรซรจ {FF3300}รงร รชรฐรปรฒรผ {FFFFFF}รฒรฐร รญรฑรฏรฎรฐรฒ\n"\
			"2. รรฒรฌรฅรฒรจรฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ รญร  GPS {FF6600}(300 รฐรณรก)\n"\
			"3. รรฎรครฅรฐรฆรจรฌรฎรฅ รกร รฃร รฆรญรจรชร \n"\
			"4. รรฎรชรณรฌรฅรญรฒรป รญร  รฒรฐร รญรฑรฏรฎรฐรฒ\n"\
			"5. รรญรฟรฒรผ รญรฎรฌรฅรฐรญรปรฅ รงรญร รชรจ\n"\
			"6. รร รฑรฒรฐรฎรฉรชร  ร รขรฒรฎรฌรฎรกรจรซรฟ\n"\
			"{888888}7. รรปรฃรฐรณรงรจรฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รฑรฅรฐรขรฅรฐร \n"\
			"8. รรซรณรทรธรจรฒรผ ร รขรฒรฎ\n"\
			"9. รรฎรกร รขรจรฒรผ ร รขรฒรฎ รข รฑรฅรฌรผรพ",
			"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
		);
	}
	else
	{
		new fmt_text[740],
			Cache: result,
			id;

		mysql_format(mysql, fmt_text, sizeof fmt_text, "SELECT * FROM ownable_cars WHERE owner_id='%d'", GetPlayerAccountID(playerid));
		result = mysql_query(mysql, fmt_text, true);

		new rows = cache_num_rows();

		if(!rows)
			SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");

		else
		{
			if(rows == 1)
			{
				id = cache_get_field_content_int(0, "id");

				ShowOwnableCarLoadDialog(playerid, id);
			}
			else
			{
				new query[60],
					model_id,
					car_number[7], count_rows;

				if(rows >= 11)
				{
					count_rows = 10;
				}
				else count_rows = rows;

				format(fmt_text, sizeof fmt_text, "");

				for(new i = 0; i < count_rows; i ++)
				{
					id = cache_get_field_content_int(i, "id");
					model_id = cache_get_field_content_int(i, "model_id") - 400;
					cache_get_field_content(i, "number", car_number);

					format(query, sizeof query, "{FFFFFF}%d. %s {888888}[%s]\n", i + 1, GetVehicleInfo(model_id, VI_NAME), car_number);
					strcat(fmt_text, query);
					SetPlayerListitemValue(playerid, i, id);
				}


				if(rows >= 11)
				{
					new buttom[21], buttom_1[21];
					format(buttom, sizeof buttom, "รรซรฅรครณรพรนร รฟ รฑรฒรฐร รญรจรถร ");
					strcat(fmt_text, buttom);
					SetPVarInt(playerid, "count_list", 1);
                    SetPVarInt(playerid, "up_count", 10);
					SetPVarInt(playerid, "down_count", 11);
				}


				Dialog
				(
					playerid, DIALOG_OWNABLE_CAR_LIST, DIALOG_STYLE_LIST,
					"{FFCD00}รรปรกรฅรฐรจรฒรฅ รฒรฐร รญรฑรฏรฎรฐรฒ",
					fmt_text,
					"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
				);
			}
		}

		cache_delete(result);
	}
	return 1;
}

CMD:trunk(playerid, params[])
{
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
	{
		new vehicleid;
		new Float: x, Float: y, Float: z;
		new Float: angle, Float: distance;

		while((++vehicleid) < MAX_VEHICLES)
		{
			if(!GetVehicleData(vehicleid, V_MODELID)) continue;

			GetCoordVehicle(vehicleid, VEHICLE_COORD_TYPE_BOOT, x, y, z, angle, distance);
			if(!IsPlayerInRangeOfPoint(playerid, 1.0, x, y, z)) continue;

			ShowTrunkDialog(playerid, vehicleid, false);
			break;
		}
	}
	return 1;
}


CMD:delvehall(playerid)
{
    if(GetPlayerAdminEx(playerid) < 4) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    new total_car = 0;
    for(new i = 0; i < MAX_VEHICLES; i++)
    {
        if(GetVehicleData(i, V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_ADMIN_CAR)
        {
            DestroyDeliveryVehicle(i);
            total_car ++;
        }

    }

    format(sctring, sizeof(sctring), ""SC"รรป รณรคร รซรจรซรจ {00ff00}%i {FFFFFF}ร รขรฒรฎรฌรฎรกรจรซรฅรฉ รฑรฎรงรคร รญรญรปรต รญร  รฑรฅรฐรขรฅรฐรฅ!", total_car);
    SendClientMessage(playerid, -1, sctring);
    format(sctring, sizeof(sctring), "[A] %s[%d] รณรคร รซรจรซ รขรฅรฑรผ รฑรฎรงรคร รญรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญร  รฑรฅรฐรขรฅรฐรฅ. (%i รธรฒ)",GetPlayerNameEx(playerid), playerid, total_car);
    SendMessageToAdmins(sctring, 0x999999FF);
    return 1;
}

CMD:veh(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 4)
        return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    extract params -> new model_id, color_1, color_2; else return SendClientMessage(playerid, 0xCECECEFF, "| รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /veh [id รฌรฎรครฅรซรจ] [รถรขรฅรฒ 1] [รถรขรฅรฒ 2] [รครฎรฑรฒรณรฏ รครซรฟ รจรฃรฐรฎรชรฎรข (รญรฅ รฎรกรฟรงร รฒรฅรซรผรญรฎ)]");
    if(!(400 <= model_id && model_id <= 30000))
        return SendClientMessage(playerid, 0xCECECEFF, "| รรฑรฏรฎรซรผรงรณรฉรฒรฅ รฌรฎรครฅรซรผ รฎรฒ 400 รครฎ 30000");

    new status;
    sscanf(params, "{d}{d}{d}d", status);
    if(!(0 <= status && status <= 1))
        status = 0;

    new Float: x, Float: y, Float: z, Float: a;
    GetPlayerPos(playerid, x, y, z);
    GetPlayerFacingAngle(playerid, a);

    new vehicleid = CreateVehicle(model_id, x, y, z, a, color_1, color_2, -1, 0, VEHICLE_ACTION_TYPE_ADMIN_CAR, status);
    PutPlayerInVehicle(playerid, vehicleid, 0);
    SetTimerEx("ShowEngineNotification", 1000, false, "i", playerid);

    new plate_number[7];
    new plate_region[3];
    GenerateRandomPlateAlt(plate_number, plate_region);
    SetVehicleNumberPlateEx(vehicleid, 1, plate_number, plate_region);

    new fmt_text[256];
    format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฑรฎรงรคร รซ รฒรฐร รญรฑรฏรฎรฐรฒ (%d, %d, %d)",
        GetPlayerNameEx(playerid), playerid, model_id, color_1, color_2, plate_number, plate_region);
    SendMessageToAdmins(fmt_text, 0x999999FF);

    format(fmt_text, sizeof fmt_text, "รรฎรงรคร รซ รฒรฐร รญรฑรฏรฎรฐรฒ (%d, %d, %d)", model_id, color_1, color_2);
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

    return 1;
}

stock GenerateRandomPlateAlt(number[7], region[3])
{
    static const letters[] = "aBCEHKMOPTXY";
    number[0] = letters[random(sizeof(letters) - 1)];
    number[1] = '0' + random(10);
    number[2] = '0' + random(10);
    number[3] = '0' + random(10);
    number[4] = letters[random(sizeof(letters) - 1)];
    number[5] = letters[random(sizeof(letters) - 1)];
    number[6] = '\0';

    region[0] = '0' + random(10);
    region[1] = '0' + random(10);
    region[2] = '\0';
}

