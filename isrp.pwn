					else { GivePlayerMoneyEx(BlackJackLobby[lobby][Table2Id], -pBJInfo[BlackJackLobby[lobby][Table2Id]][pBJBet]); format(str, sizeof str, "%d รฐรณb", playermoney(BlackJackLobby[lobby][Table2Id])); PlayerTextDrawSetString(BlackJackLobby[lobby][Table2Id], bj_money[BlackJackLobby[lobby][Table2Id]], str); }
				}
