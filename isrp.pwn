}

CMD:fvig(playerid, params[])
{
	if(!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG)) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	if(!(9 <= GetPlayerJob(playerid) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /fvig [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");


	extract params -> new to_player, string:reason[32];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(1 <= strlen(reason) <= 32))
		return SendClientMessage(playerid, 0xCECECEFF, "รรขรฅรครจรฒรฅ รฏรฐรจรทรจรญรณ รขรปรฃรฎรขรฎรฐร ");

	if(GetPlayerTeamEx(to_player) != GetPlayerTeamEx(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฎรฐรฃร รญรจรงร รถรจรจ");

	if(GetPlayerJob(to_player) >= GetPlayerJob(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รขรปรฃรฎรขรฎรฐ. รงร รฌรฅรฑรฒรจรฒรฅรซรพ/รซรจรครฅรฐรณ รฎรฐรฃร รญรจรงร รถรจรจ");
		
		
    AddPlayerData(to_player, P_OWARN, +, 1);

	new fmt_msg[128];

    format(fmt_msg, sizeof fmt_msg, "[ORG]: "c_b"%s[%d] รขรปรคร รซ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รจรฃรฐรฎรชรณ %s [%d/3]. รรฐรจรทรจรญร : %s",GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), GetPlayerData(to_player, P_OWARN), reason);

	SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, 0x33CC66FF);

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_OWARN);

	if(warns >= 3)
	{
		EndWorkDayUval(to_player);
		SendClientMessage(to_player, 0xFF5533FF, "รรป รกรปรซรจ รจรฑรชรซรพรทรฅรญรป รจรง รฎรฐรฃร รญรจรงร รถรจรจ. รรฐรจรทรจรญร : 3/3 รขรปรฃรฎรขรฎรฐร .");

		format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET owarn=0,team=0,job=0 WHERE id=%d", uid);
		mysql_query(mysql, fmt_msg, false);
		
		SetPlayerData(to_player, P_OWARN, 0);
		SetPlayerData(to_player, P_TEAM, 0);
		SetPlayerData(to_player, P_JOB, 0);
	}

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET owarn=%d WHERE id=%d", warns, uid);
	mysql_query(mysql, fmt_msg, false);


	return 1;
}

CMD:funvig(playerid, params[])
{
	if(!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG)) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	if(!(9 <= GetPlayerJob(playerid) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /funvig [id รจรฃรฐรฎรชร ]");


	extract params -> new to_player;

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
		
    if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รฑรญรฟรฒรผ รขร รฐรญ รฑ รฑร รฌรฎรฃรฎ รฑรฅรกรฟ");


	if(GetPlayerTeamEx(to_player) != GetPlayerTeamEx(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฎรฐรฃร รญรจรงร รถรจรจ");


    AddPlayerData(to_player, P_OWARN, -, 1);

	new fmt_msg[128];

    format(fmt_msg, sizeof fmt_msg, "[ORG]: "c_b"%s[%d] รฑรญรฟรซ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รจรฃรฐรฎรชรณ %s [%d/3].",GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), GetPlayerData(to_player, P_OWARN));

	SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, 0x33CC66FF);

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_OWARN);

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET owarn=%d WHERE id=%d", warns, uid);
	mysql_query(mysql, fmt_msg, false);


	return 1;
}


CMD:fwarn(playerid, params[])
{
    new fam_id = fam_id = GetPlayerData(playerid, P_FAMILY),
	    rang_id = GetPlayerData(playerid, P_FAMILY_RANK);

    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_WARN);

    if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รขรปรคร รขร รฒรผ รฑรฅรฌรฅรฉรญรฎรฅ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ.");


	if(GetPlayerAdminEx(playerid) < 2) return 1;
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /fwarn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, string:reason[66];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");

	if(GetPlayerData(to_player, P_FAMILY_RANK) >= GetPlayerData(playerid, P_FAMILY_RANK))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รฌรณรฒ รงร รฌรฅรฑรฒรจรฒรฅรซรพ/รซรจรครฅรฐรณ รฑรฅรฌรผรจ");

	//if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รฑร รฌรฎรฌรณ รฑรฅรกรฅ");

	AddPlayerData(to_player, P_FWARN, +, 1);

	new fmt_msg[128];

    format(fmt_msg, sizeof fmt_msg, "{%06x}[F] %s %s[%d] รขรปรคร รซ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รจรฃรฐรฎรชรณ %s [%d|3]. รรฐรจรทรจรญร : %s", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyRang(fam_id, rang_id), GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), GetPlayerData(to_player, P_FWARN), reason);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_FWARN);

	if(warns >= 3)
	{
		SendClientMessage(to_player, 0xFF5533FF, "รรป รกรปรซรจ รจรฑรชรซรพรทรฅรญรป รจรง รฑรฅรฌรผรจ. รรฐรจรทรจรญร : 3 รขร รฐรญร .");

		format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET fwarn=0,family=0,family_rank=1 WHERE id=%d", uid);
		mysql_query(mysql, fmt_msg, false);
		
		SetPlayerData(to_player, P_FWARN, 0);
		SetPlayerData(to_player, P_FAMILY, 0);
	}

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET fwarn=%d WHERE id=%d", warns, uid);
	mysql_query(mysql, fmt_msg, false);

	return 1;
}

CMD:funwarn(playerid, params[])
{
    new fam_id = fam_id = GetPlayerData(playerid, P_FAMILY),
	    rang_id = GetPlayerData(playerid, P_FAMILY_RANK);

    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_UNWARN);

    if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รฑรญรจรฌร รฒรผ รฑรฅรฌรฅรฉรญรฎรฅ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ.");


	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /warn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, string: reason[66];
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");

    if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รฑรญรฟรฒรผ รขร รฐรญ รฑ รฑร รฌรฎรฃรฎ รฑรฅรกรฟ");

	SetPlayerData(to_player, P_FWARN, 		0);
	UpdatePlayerDatabaseInt(to_player, "fwarn", 		0);

	new fmt_msg[128];

    format(fmt_msg, sizeof fmt_msg, "{%06x}[F] %s %s[%d] รฑรญรฟรซ รขรฑรฅ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฟ รฑ รจรฃรฐรฎรชร  %s. รรฐรจรทรจรญร : %s", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyRang(fam_id, rang_id), GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), reason);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}

	return 1;
}

CMD:fmute(playerid, params[])
{
	new fam_id = fam_id = GetPlayerData(playerid, P_FAMILY),
	    rang_id = GetPlayerData(playerid, P_FAMILY_RANK);

    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_MUTE);

    if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รขรปรคร รขร รฒรผ รกร รญ รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร .");


	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /fmute [id รจรฃรฐรฎรชร ] [รขรฐรฅรฌรฟ รข รฌรจรญรณรฒร รต] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, mute_time, string: reason[30];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");

	if(GetPlayerData(to_player, P_FAMILY_RANK) >= GetPlayerData(playerid, P_FAMILY_RANK))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รฌรณรฒ รงร รฌรฅรฑรฒรจรฒรฅรซรพ/รซรจรครฅรฐรณ รฑรฅรฌรผรจ");

	if(!(1 <= mute_time <= 360)) return SendClientMessage(playerid, 0xCECECEFF, "รรฐรฅรฌรฟ รครฎรซรฆรญรฎ รกรปรฒรผ รญรฅ รฌรฅรญรผรธรฅ 1 รจ รญรฅ รกรฎรซรผรธรฅ 360 รฌรจรญรณรฒ");
	if(GetPlayerData(to_player, P_FMUTE) > 0) return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รณรฆรฅ รฅรฑรฒรผ รฌรณรฒ");
//	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รฏรฎรฑรฒร รขรจรฒรผ รงร รฒรปรทรชรณ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรณ รขรปรธรฅ รฏรฎ รฐร รญรฃรณ");
	//else if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รฏรฎรฑรฒร รขรจรฒรผ รงร รฒรปรทรชรณ รฑร รฌรฎรฌรณ รฑรฅรกรฅ");

	new fmt_msg[150];

	format(fmt_msg, sizeof fmt_msg, "{%06x}[F] %s %s[%d] รฏรฎรฑรฒร รขรจรซ รงร รฒรปรทรชรณ รจรฃรฐรฎรชรณ %s รญร  %d รฌรจรญรณรฒ. รรฐรจรทรจรญร : %s", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyRang(fam_id, rang_id), GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), mute_time, reason);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}

	SetPlayerData(to_player, P_FMUTE, mute_time * 60);
	UpdatePlayerDatabaseInt(to_player, "fmute", mute_time * 60);

	SendClientMessage(to_player, 0xCECECEFF, "รรฐรฅรฌรฟ รครฎ รฎรชรฎรญรทร รญรจรฟ รกร รญร  รทร รฒร  รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร : {CCCC00}/time");

	return 1;
}

CMD:funmute(playerid, params[])
{
    new fam_id = fam_id = GetPlayerData(playerid, P_FAMILY),
        rang_id = GetPlayerData(playerid, P_FAMILY_RANK);

    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_UNMUTE);

    if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รฑรญรจรฌร รฒรผ รกร รญ รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร .");


	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /funmute [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");

    if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รฑรญรฟรฒรผ รงร รฒรปรทรชรณ รฑ รฑร รฌรฎรฃรฎ รฑรฅรกรฟ");

	else if(GetPlayerData(to_player, P_FMUTE) <= 0) return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฌรณรฒร ");

	new fmt_msg[100];

	format(fmt_msg, sizeof fmt_msg, "{%06x}[F] %s %s[%d] รฑรญรฟรซ รงร รฒรปรทรชรณ รฑ รจรฃรฐรฎรชร  %s", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyRang(fam_id, rang_id), GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player));

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}

	SetPlayerData(to_player, P_FMUTE, 0);
	UpdatePlayerDatabaseInt(to_player, "fmute", 0);

	SendClientMessage(to_player, 0x32a44bFF, "รรฎรฑรฒรณรฏ รข รทร รฒ รขรฎรฑรฑรฒร รญรฎรขรซรฅรญ");

	return 1;
}

CMD:finvite(playerid, params[])
{
    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_INV);

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รฏรฐรจรฃรซร รธร รฒรผ รซรพรครฅรฉ รข รฑรฅรฌรผรพ.");

	if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
//	if(!(9 <= GetPlayerData(playerid, P_FAMILY_RANK) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รฑรฎรฒรงรคร รฒรฅรซรพ รฑรฅรฌรผรจ รจ รฅรฃรฎ รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /finvite [id รจรฃรฐรฎรชร ]");

	extract params -> new to_player;
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(GetPlayerData(to_player, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รณรฆรฅ รฑรฎรฑรฒรฎรจรฒ รข รฑรฅรฌรผรฅ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0)) return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_FINVITE);
	return 1;
}

CMD:funinvite(playerid, params[])
{
    new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_UNINV);

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รณรขรฎรซรผรญรฟรฒรผ รซรพรครฅรฉ รฑ รฑรฅรฌรผรจ.");

	if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
//	if(!(9 <= GetPlayerData(playerid, P_FAMILY_RANK) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รฑรฎรฒรงรคร รฒรฅรซรพ รฑรฅรฌรผรจ รจ รฅรฃรฎ รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /funinvite [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");

	extract params -> new to_player, string:reason[32];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(1 <= strlen(reason) <= 32))
		return SendClientMessage(playerid, 0xCECECEFF, "รรขรฅรครจรฒรฅ รฏรฐรจรทรจรญรณ รณรขรฎรซรผรญรฅรญรจรฟ");

	if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");

	if(GetPlayerData(to_player, P_FAMILY_RANK) >= GetPlayerData(playerid, P_FAMILY_RANK))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รณรขรฎรซรจรฒรผ รณรขรฎรซรจรฒรผ รงร รฌรฅรฑรฒรจรฒรฅรซรฟ/รซรจรครฅรฐร  รฎรฐรฃร รญรจรงร รถรจรจ");

	FUnInvite(playerid, to_player, reason);

	return 1;
}

CMD:frang(playerid, params[])
{
	if(!GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

	new rank = GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_RANG_GIVER);

	if(GetPlayerData(playerid, P_FAMILY_RANK) < rank) return Send(playerid, COR_RED, "[รรธรจรกรชร ]: "c_b" ร รขร รฑ รญรฅ รครฎรฑรฒร รฒรฎรทรญรฎ รญรณรฆรญรปรฉ รฐร รญรฃ รข รฑรฅรฌรผรฅ, รทรฒรฎรกรป รจรงรฌรฅรญรฟรฒรผ รฐร รญรฃรจ รข รฑรฅรฌรผรฅ.");

	//if(!(9 <= GetPlayerData(playerid, P_FAMILY_RANK) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รฑรฎรฒรงรคร รฒรฅรซรพ รฑรฅรฌรผรจ รจ รฅรฃรฎ รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /frang [id รจรฃรฐรฎรชร ] [รฐร รญรฃ]");
	extract params -> new to_player, give_rang;
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(GetPlayerData(to_player, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฑรฅรฌรผรฅ");
	if(GetPlayerData(to_player, P_FAMILY_RANK) >= GetPlayerData(playerid, P_FAMILY_RANK)) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รณรขรฎรซรจรฒรผ รณรขรฎรซรจรฒรผ รงร รฌรฅรฑรฒรจรฒรฅรซรฟ/รซรจรครฅรฐร  รฎรฐรฃร รญรจรงร รถรจรจ");
	if(1 < give_rang > 9) return SendClientMessage(playerid, 0xCECECEFF, "รร รญรฃ รฎรฒ 1 รครฎ 9");

	new fmt_msg[512];

	SetPlayerData(to_player, P_FAMILY_RANK, give_rang);
	format(fmt_msg, sizeof fmt_msg, "รร รธ รฐร รญรฃ รข รฑรฅรฌรผรฅ รกรปรซ รจรงรฌรฅรญรฅรญ รญร  %d (%s)", GetPlayerData(to_player, P_FAMILY_RANK), GetFamilyRang(GetPlayerData(to_player, P_FAMILY), GetPlayerData(to_player, P_FAMILY_RANK)));
	SendClientMessage(to_player, 0x1E90FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรป รจรงรฌรฅรญรจรซรจ รฐร รญรฃ %s[%d] รครฎ %d (%s)",  GetPlayerNameEx(to_player), to_player, GetPlayerData(to_player, P_FAMILY_RANK), GetFamilyRang(GetPlayerData(to_player, P_FAMILY), GetPlayerData(to_player, P_FAMILY_RANK)));
	SendClientMessage(playerid, 0x1E90FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET family_rank=%d WHERE id=%d", GetPlayerData(to_player, P_FAMILY_RANK), GetPlayerAccountID(to_player));
	mysql_query(mysql, fmt_msg, false);

	return 1;
}
CMD:sellmyskin(playerid, params[])
{
	new skinid = GetPlayerData(playerid, P_SKIN);
	if(skinid == 252) return false;
	if(GetPlayerSkin(playerid) == 252) return SendClientMessage(playerid, -1, "{FFFF00}[รรญรดรฎรฐรฌร รถรจรฟ]{FFFFFF} รรป รญรฅ รฌรฎรฆรฅรฒรฅ รฏรฐรฎรคร รฒรผ รฑรชรจรญ!");
	if(!strlen(params))
	return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellmyskin [id รจรฃรฐรฎรชร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

	extract params -> new to_player, price;
	if(price == 0) return false;
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

   	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รคร รซรฅรชรฎ รฎรฒ รร รฑ");

	if(GetPlayerMoneyEx(to_player) < price)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฒร รชรฎรฉ รฑรณรฌรฌรป");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_SKIN, skinid, price);
	return 1;
}

CMD:f(playerid, params[])
{
	if(GetPlayerData(playerid, P_FAMILY) == 0) return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฑรฅรฌรผรฅ");
	if(IsPlayerFMuted(playerid) > 0) return Send(playerid, -1, "ร รขร รฑ รกร รญ รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร ");
	if(IsPlayerMuted(playerid) > 0) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฑรฒรณรฏ รข รทร รฒ รงร รกรซรฎรชรจรฐรฎรขร รญ. รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ: {66CC33}/time");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /f [รฒรฅรชรฑรฒ]");

	new fmt_msg[144],
		fam_id = GetPlayerData(playerid, P_FAMILY),
		rang_id = GetPlayerData(playerid, P_FAMILY_RANK) + 1;

	format(fmt_msg, sizeof fmt_msg, "{%06x}[%s] %s %s[%d]: %s", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyData(fam_id, F_NAME), GetFamilyRang(fam_id + 1, rang_id), GetPlayerNameEx(playerid), playerid, params);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}
	return 1;
}
alias:f("fam")

CMD:fn(playerid, params[])
{
	if(GetPlayerData(playerid, P_FAMILY) == 0) return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฑรฅรฌรผรฅ");
	if(IsPlayerMuted(playerid) > 0) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฑรฒรณรฏ รข รทร รฒ รงร รกรซรฎรชรจรฐรฎรขร รญ. รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ: {66CC33}/time");
	if(IsPlayerFMuted(playerid) > 0) return Send(playerid, -1, "ร รขร รฑ รกร รญ รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร ");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /fn [รฒรฅรชรฑรฒ]");

	new fmt_msg[144],
		fam_id = GetPlayerData(playerid, P_FAMILY) + 1,
		rang_id = GetPlayerData(playerid, P_FAMILY_RANK);

	format(fmt_msg, sizeof fmt_msg, "(( {%06x}OOC: [F] %s %s[%d]: %s ))", family_colors[GetFamilyData(GetPlayerData(playerid, P_FAMILY), F_COLOR)] >>> 8, GetFamilyRang(fam_id + 1, rang_id), GetPlayerNameEx(playerid), playerid, params);

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(GetPlayerData(i, P_FAMILY) == 0) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		if(GetPlayerData(i, P_FAMILY) != GetPlayerData(playerid, P_FAMILY)) continue;

		SendClientMessage(i, 0x6699CCFF, fmt_msg);
	}
	return 1;
}

