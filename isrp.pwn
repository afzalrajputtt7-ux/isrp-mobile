CMD:aaks(playerid, params[]) 
{
        extract params -> new to_player, modelid, bone, index; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /aaks [id รจรฃรฐรฎรชร ] [ร รฉรครจ ร รชรฑร ] [รทร รฑรฒรผ รฒรฅรซร /bones] [ร รฉรครจ รฑรซรฎรฒร ]");
        SetPlayerAttachedObject(to_player, index, modelid, bone);
        return 1;
}



CMD:setvinil(playerid, params[]) 
{

    extract params -> new idvinila; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /setvinil [id รรจรญรจรซร ]");

    new vehicleid = GetPlayerVehicleID(playerid);
    if (vehicleid == 0)
        return SendClientMessage(playerid, -1, "รรธรจรกรชร : รรป รญรฅ รขรญรณรฒรฐรจ รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฃรฎ รฑรฐรฅรครฑรฒรขร .");
        
     // รรฎรซรณรทรจรฌ รครฎรฑรฒรณรฏรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รฐร รฑรชรฐร รฑรฎรช รครซรฟ รฒรฅรชรณรนรฅรฃรฎ รร, รจรฑรฏรฎรซรผรงรณรฟ รฑรฎรกรฑรฒรขรฅรญรญรณรพ รดรณรญรชรถรจรพ (รฑรฌ. รญรจรฆรฅ).
    new num_paintjobs = GetNumberOfPaintjobsForVehicle(GetVehicleModel(vehicleid));
    if (num_paintjobs == 0)
        return SendClientMessage(playerid, -1, "รรธรจรกรชร : รรซรฟ รฒรฅรชรณรนรฅรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฃรฎ รฑรฐรฅรครฑรฒรขร  รญรฅรฒ รครฎรฑรฒรณรฏรญรปรต รฐร รฑรชรฐร รฑรฎรช.");
    
    ChangeVehiclePaintjob(vehicleid, idvinila);
    

}


stock GetNumberOfPaintjobsForVehicle(vehiclemodel)
{
    switch(vehiclemodel)
    {
        case 483:
            return 1;
        case 575:
            return 2;
        case 534, 535, 536, 558, 559, 560, 561, 562, 565, 567, 576,611,612,613:
            return 3;
    }
    return 0;
}


