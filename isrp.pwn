CMD:setap(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
    if(GetPlayerAdminEx(playerid) < 7) return 1;

    extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sethelper [id รจรฃรฐรฎรชร ]");

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
        return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(GetPlayerHelperEx(to_player))
        return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รณรฆรฅ รฑรฒรฎรจรฒ รญร  รฏรฎรฑรฒรณ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ");

    SetPlayerData(to_player, P_HELPER, 2);
    UpdatePlayerDatabaseInt(to_player, "helper", 2);

    new fmt_text[128];

    format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รกรปรซรจ รญร รงรญร รทรฅรญรป รญร  รฏรฎรฑรฒ รรซร รขรญรฎรฃรฎ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ", GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, 0xFF5533FF, fmt_text);

    format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรฑรฒร รขรจรซ %s[%d] รญร  รฏรฎรฑรฒ รฑรซรฅรครฟรนรฅรฃรฎ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ",
    GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);

    SendMessageToAdmins(fmt_text, 0xFF5533FF);

    format(fmt_text, sizeof fmt_text, "รรฎรฑรฒร รขรจรซ %s[acc:%d] รญร  รฏรฎรฑรฒ รฑรซรฅรครฟรนรฅรฃรฎ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
    SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

    return 1;
}

CMD:hc(playerid, params[])
{
    new level = GetPlayerHelperEx(playerid);
    if(level >= 1)
    {
        if(!strlen(params))
            return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /hc [รฒรฅรชรฑรฒ]");

        new fmt_str[128], rank_text[32];
        rank_text = (level == 1) ? "รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจ (1)" : "รรฒ. รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจ (2)";

        format(fmt_str, sizeof fmt_str, "{009933}*%s {FFFFFF}%s[%d]: %s", rank_text, GetPlayerNameEx(playerid), playerid, params);
        SendMessageToHelpers(fmt_str, 0x99CC00FF);
    }

    return 1;
}

