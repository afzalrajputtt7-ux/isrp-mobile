								    launch[playerid] = 0;
								    diski[playerid] = 0;
								    fars[playerid] = 0;
								    nitro[playerid] = 0;
									SendClientMessage(playerid, 0xFFFFFFFF, "{ffff00}| {ffffff}รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รณรฑรฏรฅรธรญรฎ รขรปรฃรฐรณรฆรฅรญ!");
								}
								//else SendClientMessage(playerid, 0x999999FF, "ร รฌรฎรฌรฅรญรฒร  รงร รฃรฐรณรงรชรจ รคร รญรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  รฅรนรฅ รญรฅ รฏรฐรฎรธรซรฎ 5 รฌรจรญรณรฒ");
       						}
								case 8:
							{
							    ShowVehicleImproveDialog(playerid);
							}
							case 9:
