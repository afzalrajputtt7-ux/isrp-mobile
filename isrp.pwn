			case DIALOG_ADMIN_LOGIN:
{
	new fmt_text[999];

	if(!response || !strlen(inputtext))
	{
		SendClientMessage(playerid, 0xFF0000FF, "รรป รญรฅ รขรขรฅรซรจ รฏร รฐรฎรซรผ. รรฎรฏรฐรฎรกรณรฉรฒรฅ รฑรญรฎรขร .");
		AdminAuthorization(playerid);
		return true;
	}

	if(strval(inputtext) != GetPlayerData(playerid, P_APASS))
	{
		format(fmt_text, sizeof fmt_text,
			"[A] %s[%d] รฎรฒรชรซรพรทรจรซรฑรฟ รฎรฒ รฑรฅรฐรขรฅรฐร  (รญรฅรขรฅรฐรญรปรฉ ร รครฌรจรญ รฏร รฐรฎรซรผ). IP: %s",
			GetPlayerNameEx(playerid), playerid, GetPlayerIpEx(playerid));
		SendMessageToAdmins(fmt_text, 0x999999FF);
		SendClientMessage(playerid, COLOR_GREY, "รรป รขรขรฅรซรจ รญรฅรขรฅรฐรญรปรฉ รฏร รฐรฎรซรผ รจ รกรปรซรจ รฎรฒรชรซรพรทรฅรญรป รฎรฒ รฑรฅรฐรขรฅรฐร , รฏรฅรฐรฅรงร รฉรครจรฒรฅ. ");
		Kick(playerid);
		return true;
	}

	format(fmt_text, sizeof fmt_text,
	    "{8B0000}[A-LOGIN]: {ff4a4a}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ {FFFFFF}%s [%d] {ff4a4a}ร รขรฒรฎรฐรจรงรฎรขร รซรฑรฟ รข รฑรจรฑรฒรฅรฌรฅ ร รครฌรจรญรจรฑรฒรฐรจรฐรฎรขร รญรจรฟ รชร รช: {FFFFFF}%s",
	    GetPlayerNameEx(playerid), playerid, GetPlayerData(playerid, P_PREFIX));
	SendMessageToAdmins(fmt_text, 0xff4a4aAA);

	format(fmt_text, sizeof fmt_text,
 	  "{8B0000}[A-LOGIN]: {ff4a4a}รรป ร รขรฒรฎรฐรจรงรฎรขร รซรจรฑรผ รข รฑรจรฑรฒรฅรฌรฅ ร รครฌรจรญรจรฑรฒรฐรจรฐรฎรขร รญรจรฟ รชร รช: {FFFFFF}%s",
  	 GetPlayerData(playerid, P_PREFIX));
	SendClientMessage(playerid, 0xff4a4aAA, fmt_text);

	SetPlayerData(playerid, P_ADMIN_LOGGED, 1);


	return true;
}
			case DIALOG_ADMIN_REG:
