stock IsPlayerInArea(playerid,Float:minx,Float:miny,Float:maxx,Float:maxy)
{
	new Float:X,Float:Z,Float:Y;
 	GetPlayerPos(playerid,X,Y,Z);
	if(X > minx && X < maxx && Y > miny && maxy > Y) return 1;
	return 0;
}

CMD:sv(playerid, params[])
{
    if (GetPlayerAdminEx(playerid) < 6)
        return SendClientMessage(playerid, -1, "ร รขร รฑ รญรฅรฒ รฏรฐร รข รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรณ รชรฎรฌร รญรครณ.");

    new name[32];
    if (sscanf(params, "s[32]", name))
        return SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /sv [รญร รงรขร รญรจรฅ รฒรฎรทรชรจ]");

    new Float:x, Float:y, Float:z, Float:a;
    GetPlayerPos(playerid, x, y, z);

    if (IsPlayerInAnyVehicle(playerid))
        GetVehicleZAngle(GetPlayerVehicleID(playerid), a);
    else
        GetPlayerFacingAngle(playerid, a);

    new File:my_file = fopen("savedpositions.txt", io_append);
    if (!my_file)
        return SendClientMessage(playerid, -1, "รรธรจรกรชร  รฏรฐรจ รฑรฎรตรฐร รญรฅรญรจรจ รฏรฎรงรจรถรจรจ.");

    new saveStr[128];
    format(saveStr, sizeof(saveStr), "%s: %.2f, %.2f, %.2f, %.2f, %d, %d\r\n",
        name, x, y, z, a, GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid));
    fwrite(my_file, saveStr);
    fclose(my_file);

    SendClientMessage(playerid, -1, "รรฎรงรจรถรจรฟ รฑรฎรตรฐร รญรฅรญร .");
    return 1;
}

