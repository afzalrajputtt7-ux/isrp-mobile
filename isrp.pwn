	if(GetPlayerTeamEx(playerid) != TEAM_RADIO) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	
