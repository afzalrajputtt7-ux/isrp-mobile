            strcat(dialogStr, "/get โ รจรญรดรฎรฐรฌร รถรจรฟ รฎ รจรฃรฐรฎรชรฅ\n");
            strcat(dialogStr, "/gethere (/gh) โ รฒรฅรซรฅรฏรฎรฐรฒ รจรฃรฐรฎรชร  รช รฑรฅรกรฅ\n");
            strcat(dialogStr, "/warn โ รขรปรคร รฒรผ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ\n");
            strcat(dialogStr, "/unwarn โ รฑรญรฟรฒรผ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ\n");
            strcat(dialogStr, "/weap โ รฏรฎรฑรฌรฎรฒรฐรฅรฒรผ รฎรฐรณรฆรจรฅ\n");
            strcat(dialogStr, "/goto (/g) โ รฒรฅรซรฅรฏรฎรฐรฒ รช รจรฃรฐรฎรชรณ\n");
            strcat(dialogStr, "/event โ รฑรฎรงรคร รฒรผ รฌรฅรฐรฎรฏรฐรจรฟรฒรจรฅ\n");
            strcat(dialogStr, "/hp โ รขรปรคร รฒรผ HP\n");
            strcat(dialogStr, "/skick โ รฒรจรตรฎ รชรจรชรญรณรฒรผ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/fonline โ รฑรฒร รฒรจรฑรฒรจรชร  รฎรญรซร รฉรญร  รฎรฐรฃร รญรจรงร รถรจรฉ\n");
        }
        case 3:
        {
            strcat(dialogStr, "/sethelper โ รญร รงรญร รทรจรฒรผ รตรฅรซรฏรฅรฐร \n");
            strcat(dialogStr, "/delhelper โ รฑรญรฟรฒรผ รตรฅรซรฏรฅรฐร \n");
            strcat(dialogStr, "/offdelhelper โ รฑรญรฟรฒรผ รตรฅรซรฏรฅรฐร  รฎรดรดรซร รฉรญ\n");
            strcat(dialogStr, "/templeader โ รขรฐรฅรฌรฅรญรญรฎรฅ รซรจรครฅรฐรฑรฒรขรฎ\n");
            strcat(dialogStr, "/setleader โ รฏรฎรฑรฒร รขรจรฒรผ รญร  รซรจรครฅรฐร \n");
            strcat(dialogStr, "/offban โ รกร รญ รฎรดรดรซร รฉรญ\n");
            strcat(dialogStr, "/ban โ รกร รญ รฎรญรซร รฉรญ\n");
            strcat(dialogStr, "/money โ รณรงรญร รฒรผ รครฅรญรผรฃรจ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/ears โ รฏรฐรฎรฑรซรณรธรชร  SMS\n");
            strcat(dialogStr, "/getvehspeed โ รฑรชรฎรฐรฎรฑรฒรผ ร รขรฒรฎ\n");
        }
        case 4:
        {
            strcat(dialogStr, "/permban โ รกร รญ รญร รขรฑรฅรฃรคร \n");
            strcat(dialogStr, "/inter โ รณรฑรฒร รญรฎรขรจรฒรผ รจรญรฒรฅรฐรผรฅรฐ\n");
            strcat(dialogStr, "/world โ รณรฑรฒร รญรฎรขรจรฒรผ รขรจรฐรฒรณร รซรผรญรปรฉ รฌรจรฐ\n");
            strcat(dialogStr, "/house โ รฒรฅรซรฅรฏรฎรฐรฒ รช รครฎรฌรณ\n");
            strcat(dialogStr, "/biz โ รฒรฅรซรฅรฏรฎรฐรฒ รช รกรจรงรญรฅรฑรณ\n");
            strcat(dialogStr, "/fuelstation โ รฒรฅรซรฅรฏรฎรฐรฒ รช รรร\n");
            strcat(dialogStr, "/veh โ รฑรฎรงรคร รฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ\n");
            strcat(dialogStr, "/skin โ รขรฐรฅรฌรฅรญรญรปรฉ รฑรชรจรญ\n");
            strcat(dialogStr, "/o โ รฑรฎรฎรกรนรฅรญรจรฅ รข รฎรกรนรจรฉ รทร รฒ\n");
            strcat(dialogStr, "/skin โ รขรปรคร รฒรผ รขรฐรฅรฌรฅรญรญรปรฉ รฑรชรจรญ\n");
            strcat(dialogStr, "/spcars โ รฎรทรจรฑรฒรชร  ร รขรฒรฎ\n");
            strcat(dialogStr, "/cc โ รฎรทรจรฑรฒรชร  รทร รฒร \n");
            strcat(dialogStr, "/delvehall โ รณรคร รซรจรฒรผ รขรฅรฑรผ รฒรฐร รญรฑรฏรฎรฐรฒ\n");
            strcat(dialogStr, "/delveh โ รณรคร รซรจรฒรผ รฒรฅรชรณรนรฅรฅ ร รขรฒรฎ\n");
        }
        case 5:
        {
            strcat(dialogStr, "/shablon โ รขรปรคร รฒรผ รธร รกรซรฎรญ\n");
            strcat(dialogStr, "/deladmin โ รฑรญรฟรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร \n");
            strcat(dialogStr, "/offdeladmin โ รฑรญรฟรฒรผ รฎรดรดรซร รฉรญ\n");
            strcat(dialogStr, "/admup โ รฏรฎรขรปรฑรจรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร \n");
            strcat(dialogStr, "/admdown โ รฏรฎรญรจรงรจรฒรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร \n");
            strcat(dialogStr, "/awarn โ รขรปรฃรฎรขรฎรฐ\n");
            strcat(dialogStr, "/unawarn โ รฑรญรฟรฒรผ รขรปรฃรฎรขรฎรฐ\n");
            strcat(dialogStr, "/admlist โ รฑรฏรจรฑรฎรช ร รครฌรจรญรจรฑรฒรฐร รถรจรจ\n");
            strcat(dialogStr, "/setyt โ รขรปรคร รฒรผ รพรฒรณรกรฅรฐรชรณ\n");
