							case 6: // รรปรฑรฅรซรจรฒรผรฑรฟ รจรง รฎรฒรฅรซรฟ
							{
								Dialog
								(
									playerid, DIALOG_HOTEL_OUT, DIALOG_STYLE_MSGBOX,
									"{66CC99}รรปรฑรฅรซรฅรญรจรฅ",
									"{FFFFFF}รรป รณรขรฅรฐรฅรญรป รทรฒรฎ รตรฎรฒรจรฒรฅ รขรปรฑรฅรซรจรฒรผรฑรฟ รจรง รฎรฒรฅรซรฟ?",
									"รร ", "รรฅรฒ"
								);
