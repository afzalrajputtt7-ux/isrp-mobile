CMD:aban(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7)
        return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    if(!strlen(params))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /aban [id ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร ]");

    new adminid = strval(params);

    if(!IsPlayerConnected(adminid) || !IsPlayerLogged(adminid))
        return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ.");

    if(GetPlayerAdminEx(adminid) < 1)
        return SendClientMessage(playerid, 0xFF5533FF, "รร รญรญรปรฉ รจรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ");

    if(GetPlayerAdminEx(adminid) >= GetPlayerAdminEx(playerid))
        return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

    if(adminid == playerid)
        return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

    // รรฐรฅรฌรฅรญรญรฎ รฑรญรจรฌร รฅรฌ รฏรฐร รขร 
    g_player[adminid][P_ADMIN] = 0;

    new fmt_msg[256];
    format(fmt_msg, sizeof fmt_msg, "รรซร รขรญรปรฉ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรฐรฅรฌรฅรญรญรฎ รงร รกรซรฎรชรจรฐรฎรขร รซ รฏรฐร รขร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s",
        GetPlayerNameEx(playerid), GetPlayerNameEx(adminid));

    SendClientMessageToAll(0xFF5533FF, fmt_msg);

    // รรฎรฎรกรนรฅรญรจรฅ รงร รกรซรฎรชรจรฐรฎรขร รญรญรฎรฌรณ ร รครฌรจรญรณ
    SendClientMessage(adminid, 0xFF5533FF, "รร รธรจ รฏรฐร รขร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรฐรฅรฌรฅรญรญรฎ รงร รกรซรฎรชรจรฐรฎรขร รญรป รฏรฎ รฐรฅรธรฅรญรจรพ รฃรซร รขรญรฎรฃรฎ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร ");

    // รรฎรฃรจรฐรฎรขร รญรจรฅ
    format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฅรญรญรฎ รงร รกรซรฎรชรจรฐรฎรขร รซ รฏรฐร รขร  %s[acc:%d]",
        GetPlayerNameEx(adminid), GetPlayerAccountID(adminid));

    SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

    return 1;
}

CMD:unaban(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7)
        return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    if(!strlen(params))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unaban [id รจรฃรฐรฎรชร ] [รณรฐรฎรขรฅรญรผ ร รครฌรจรญร ]");

    extract params -> new targetid, level;

    if(!IsPlayerConnected(targetid) || !IsPlayerLogged(targetid))
        return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ.");

    if(level < 1 || level > 7)
        return SendClientMessage(playerid, 0xFF5533FF, "รรฐรฎรขรฅรญรผ ร รครฌรจรญร  รครฎรซรฆรฅรญ รกรปรฒรผ รฎรฒ 1 รครฎ 7");

    // รรฎรฑรฑรฒร รญร รขรซรจรขร รฅรฌ รฏรฐร รขร 
    g_player[targetid][P_ADMIN] = level;

    new fmt_msg[128];
    format(fmt_msg, sizeof fmt_msg, "รรซร รขรญรปรฉ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรฎรฑรฑรฒร รญรฎรขรจรซ รฏรฐร รขร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s (รณรฐรฎรขรฅรญรผ %d)",
        GetPlayerNameEx(playerid), GetPlayerNameEx(targetid), level);

    SendClientMessageToAll(0x00FF00FF, fmt_msg);
    SendClientMessage(targetid, 0x00FF00FF, "รร รธรจ รฏรฐร รขร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รขรฎรฑรฑรฒร รญรฎรขรซรฅรญรป!");

    return 1;
}

stock InteractionNPC(playerid)
{
    new Node:JSONObject = JSON_Object();

    JSON_SetInt(JSONObject, "o", 1);
    JSON_SetInt(JSONObject, "m", 122);
    JSON_SetString(JSONObject, "n", "รรฅรฒรฐรฎรขรจรท");
    JSON_SetString(JSONObject, "d", "รรป รทรฅ รฑรณรชร  รญรฅ รณรขร รฆร รฅรธ Death Of Coder'a?");
    JSON_SetInt(JSONObject, "ts", 3);

    // รรฎรงรคร รฅรฌ รฌร รฑรฑรจรข รชรญรฎรฏรฎรช
    new Node:button1 = JSON_Object();
    JSON_SetString(button1, "bn", "รร , รณรขร รฆร รพ!");
    JSON_SetInt(button1, "bt", 1);  // ID รชรญรฎรฏรชรจ
    JSON_SetInt(button1, "bk", 1);  // รรจรฏ รชรญรฎรฏรชรจ (1 = รงรฅรซรฅรญร รฟ)

    new Node:button2 = JSON_Object();
    JSON_SetString(button2, "bn", "รรฅรฒ, รญรฅ รณรขร รฆร รพ!");
    JSON_SetInt(button2, "bt", 2);  // ID รชรญรฎรฏรชรจ
    JSON_SetInt(button2, "bk", 3);  // รรจรฏ รชรญรฎรฏรชรจ (3 = รชรฐร รฑรญร รฟ)

    new Node:button3 = JSON_Object();
    JSON_SetString(button3, "bn", "รรฎรฆรฅรฒ รกรปรฒรผ...");
    JSON_SetInt(button3, "bt", 3);  // ID รชรญรฎรฏรชรจ
    JSON_SetInt(button3, "bk", 2);  // รรจรฏ รชรญรฎรฏรชรจ (2 = รฑรฅรฐร รฟ)

    // รรฎรงรคร รฅรฌ รฌร รฑรฑรจรข รจรง รชรญรฎรฏรฎรช
    new Node:buttonsArray = JSON_Array(button1, button2, button3);

    // รรฎรกร รขรซรฟรฅรฌ รฌร รฑรฑรจรข รชรญรฎรฏรฎรช รข รฎรฑรญรฎรขรญรฎรฉ รฎรกรบรฅรชรฒ
    JSON_SetArray(JSONObject, "b", buttonsArray);

    // รรทรจรนร รฅรฌ รขรฐรฅรฌรฅรญรญรปรฅ รณรงรซรป
    JSON_Cleanup(button1);
    JSON_Cleanup(button2);
    JSON_Cleanup(button3);
    JSON_Cleanup(buttonsArray);

    ShowPlayerGUI(playerid, 63, JSONObject);

    // รรทรจรนร รฅรฌ รฎรฑรญรฎรขรญรฎรฉ รฎรกรบรฅรชรฒ
    JSON_Cleanup(JSONObject);
}

CMD:interr(playerid)
{
    InteractionNPC(playerid);
    return 1;
}

stock ShowCustomAdminConnectDialog(playerid)
{
    new string[512];
    strcat(string, "{B8860B}รญรฎรฌรฅรฐ\tรญร รจรฌรฅรญรฎรขร รญรจรฅ\tรครฎรฑรฒรณรฏรญรฎรฅ รครฅรฉรฑรฒรขรจรฅ\n");
    strcat(string, "{FF6347}#1{FFFFFF}\tรรขรฟรงรผ รฑ ร รครฌรจรญรจรฑรฒรฐร รถรจรฅรฉ {FF6347}(รฆร รซรฎรกร ){FFFFFF}\tรญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\n");
    strcat(string, "{FF6347}#2{FFFFFF}\tรรขรฟรงรผ รฑ รฏรฎรฌรฎรนรญรจรชร รฌรจ {FF6347}(รขรฎรฏรฐรฎรฑ){FFFFFF}\tรญร รฆรฌรจรฒรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ");

    ShowPlayerDialog(playerid, DIALOG_REPORT_SELECTOR, DIALOG_STYLE_TABLIST_HEADERS,
        "{FF6347}KRANIN STUDIO {FFFFFF}| รรขรฟรงรผ รฑ ร รครฌรจรญรจรฑรฒรฐร รถรจรฅรฉ",
        string,
        "รรปรกรฐร รฒรผ", "รร รงร รค");
}

public BonusMessagesTimer()
{
    // รรฅรฐรฅรกรจรฐร รฅรฌ รขรฑรฅรต รขรฎรงรฌรฎรฆรญรปรต รจรฃรฐรฎรชรฎรข รฎรฒ 0 รครฎ MAX_PLAYERS
    for (new i = 0; i < MAX_PLAYERS; i++)
    {
        // รรฐรฎรขรฅรฐรฟรฅรฌ, รฏรฎรครชรซรพรทรฅรญ รซรจ รจรฃรฐรฎรช รช รฑรฅรฐรขรฅรฐรณ (ร รชรฒรจรขรฅรญ รซรจ รฅรฃรฎ รฑรซรฎรฒ)
        if (IsPlayerConnected(i))
        {
            // รรปรงรปรขร รฅรฌ รขร รธ stock รครซรฟ รฎรฒรฏรฐร รขรชรจ รฑรฎรฎรกรนรฅรญรจรฉ รฝรฒรฎรฌรณ รจรฃรฐรฎรชรณ
            SendWelcomeBonusMessages(i);
        }
    }
    return 1;
}

stock SendWelcomeBonusMessages(playerid)
{
// รรฎรฎรกรนรฅรญรจรฅ 1: รร รฐรฏรซร รฒร 
SendClientMessage(playerid, 0xFFFFFFFF, "{FF6347}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป{FFFFFF} | {FFDEAD}รรฐรจ รฏรฎรซรณรทรฅรญรจรจ รงร รฐรฏรซร รฒรป รญร  รชร รฆรครฎรฉ รจรง รครฎรฑรฒรณรฏรญรปรต รฐร รกรฎรฒ รฎรญร  รกรณรครฅรฒ รณรฌรญรฎรฆร รฒรผรฑรฟ รข {FF6347}ร2 รฐร รงร .{FFFFFF}");

// รรฎรฎรกรนรฅรญรจรฅ 2: PayDay/รรฏรปรฒ
SendClientMessage(playerid, 0xFFFFFFFF, "{FF6347}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป{FFFFFF} | {FFDEAD}รร รฆรครปรฉ PayDay รญร  รฑรฅรฐรขรฅรฐรฅ รรป รกรณรครฅรฒรฅ รฏรฎรซรณรทร รฒรผ รข {FF6347}ร2 รฐร รงร  รกรฎรซรผรธรฅ รฎรทรชรฎรข รรฏรปรฒร  (EXP)!{FFFFFF}");

// รรฎรฎรกรนรฅรญรจรฅ 3: รรฎรญร รฒ/Black Coin
SendClientMessage(playerid, 0xFFFFFFFF, "{FF6347}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป{FFFFFF} | {FFDEAD}รรฐรจ รฏรฎรฏรฎรซรญรฅรญรจรจ รกร รซร รญรฑร  ร รชรชร รณรญรฒร  {FFFFFF}[Black Coin]{FFDEAD} - รฑรณรฌรฌร  รฏรฎรฏรฎรซรญรฅรญรจรฟ รกรณรครฅรฒ รณรฌรญรฎรฆร รฒรผรฑรฟ รข {FF6347}ร2 รฐร รงร !{FFFFFF}");

// รรฎรฎรกรนรฅรญรจรฅ 4: รรฏรฎรฑรฎรกรป รฏรฎรฏรฎรซรญรฅรญรจรฟ
SendClientMessage(playerid, 0xFFFFFFFF, "{FF6347}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป{FFFFFF} | {FFDEAD}รรฎรฏรฎรซรญรจรฒรผ รฑรทรฅรฒ รฑรขรฎรฅรฃรฎ รจรฃรฐรฎรขรฎรฃรฎ ร รชรชร รณรญรฒร  รฌรฎรฆรญรฎ รฏรฐรฟรฌรฎ รข รซร รณรญรทรฅรฐรฅ, รจรซรจ - รทรฅรฐรฅรง รฑร รฉรฒ: {FF6347}none.online{FFFFFF}");

    return 1;
}

stock ShowRentBikeDialogLYT(playerid)
{
    new Cache:result;
    new header[96];
    new stringer[2048];
    new sctring[256];
    new query[128];

    format(
        header, sizeof header,
        "{E03131}%s{FFFFFF} | รรฏรฐร รขรซรฅรญรจรฅ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ",
        SERVER_NAME
    );

    stringer[0] = EOS;
    strcat(stringer, "{FFFFFF}#\tรร รงรขร รญรจรฅ\tรรฎรฌรฅรฐ\tรรฅรฉรฑรฒรขรจรฅ\n");

    // 1 โ รรชรณรฒรฅรฐ
    format(
        sctring, sizeof sctring,
        "{E0584B}1.\t{FFFFFF}รรชรณรฒรฅรฐ\t{888888}[-----]\t{E0584B}รรฐรฅรญรครฎรขร รฒรผ\n"
    );
    strcat(stringer, sctring);

    mysql_format(
        mysql, query, sizeof query,
        "SELECT id, model_id, number FROM ownable_cars WHERE owner_id='%d'",
        GetPlayerAccountID(playerid)
    );
    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows();
    new model_id, car_id;
    new number[8];

    for(new i; i < rows; i++)
    {
        car_id   = cache_get_field_content_int(i, "id");
        model_id = cache_get_field_content_int(i, "model_id") - 400;
        cache_get_field_content(i, "number", number);

        format(
            sctring, sizeof sctring,
            "{FFFFFF}%d.\t%s\t{888888}[%s]\t{FFFFFF}รรฎรฑรฒร รขรจรฒรผ รร\n",
            i + 2,
            GetVehicleInfo(model_id, VI_NAME),
            number
        );
        strcat(stringer, sctring);

        SetPlayerListitemValue(playerid, i + 1, car_id);
    }

    cache_delete(result);

    Dialog(
        playerid,
        DIALOG_RENT_BIKE_LUT,
        DIALOG_STYLE_TABLIST_HEADERS,
        header,
        stringer,
        "รรปรกรฐร รฒรผ",
        "รร รชรฐรปรฒรผ"
    );
}

