            "{E0584B}11. {ffffff}รรฎรชรณรฏรชร  VIP รฏรฐรจรขรฅรซรฅรฃรจรฉ\n"\
            "{E0584B}12. {ffffff}รรณรฌรกรฎรชรฑ\t\t{99cc00}100 รฐรณรกรซรฅรฉ",
            GetDonatePrice(DONATE_PRICE_SKILLS)
        );

        format(fmt_description, sizeof fmt_description, "{E0584B}BLACK RUSSIA %d รฐรณรก", GetPlayerDonateRub(playerid));
    }

    Dialog(playerid, DIALOG_DRUB_MENU, DIALOG_STYLE_LIST, fmt_description, fmt_text, "รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ");
    return 1;
}

stock ShowPlayerDonations(playerid, name)
{
	new query[256],
		fmt_text[1400],
		Cache: result;

	mysql_format(mysql, query, sizeof query, "SELECT * FROM `unitpay_payments` WHERE `account`='%s' AND `status`=0", name);
	result = mysql_query(mysql, query, true);

	if(!cache_num_rows())
	{
			format
			(
				fmt_text, sizeof fmt_text,
				"{FFFFFF}\
				รรป รฅรนรฅ รญรจ รฐร รงรณ รญรฅ รฏรฎรฏรฎรซรญรฟรซรจ รฑรขรฎรฉ ร รชรชร รณรญรฒ.\n\
				รรฒรฎ รฌรฎรฆรญรฎ รฑรครฅรซร รฒรผ รญร  รฑร รฉรฒรฅ {33cc66}"#SERVER_SITE" {FFFFFF}รข รฐร รงรครฅรซรฅ {6699cc}\"รรฎรญร รฒ\".\
				"
			);


			Dialog
			(
				playerid, DIALOG_DONATIONS, DIALOG_STYLE_MSGBOX,
				"{FFCC00}รรฎรฑรซรฅรครญรจรฅ รฏรฎรฏรฎรซรญรฅรญรจรฟ",
				fmt_text,
				"รร รงร รค", ""
			);

			cache_delete(result);
			return 1;
	}

	format(fmt_text, sizeof(fmt_text), "รร รฒร  รจ รขรฐรฅรฌรฟ\t\t\tรรณรฌรฌร \n{FFFFFF}");

	for(new i = 0; i < cache_num_rows(); i++)
	{
	    new tmp_text[128], tmp_date[16];

	    cache_get_field_content(i, "dateComplete", tmp_date);
	    format(tmp_text, sizeof tmp_text, "\n%s\t\t%d.00 รฐรณรก.", tmp_date, cache_get_field_content_int(i, "sum"));

	    strcat(fmt_text, tmp_text);
	}

	Dialog
	(
	    playerid,
	    DIALOG_DONATIONS,
	    DIALOG_STYLE_MSGBOX,
	    "{FFCC00}20 รฏรฎรฑรซรฅรครญรจรต รฎรฏรฅรฐร รถรจรฉ รฏรฎรฏรฎรซรญรฅรญรจรฟ",
	    fmt_text,
	    "รร รงร รค", ""
	);
	cache_delete(result);
	return 1;
}

