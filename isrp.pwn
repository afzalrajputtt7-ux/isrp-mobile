                format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รฏรฎรฑรฌรฎรฒรฐรฅรฒรผ รฅรฃรฎ รฏร รฑรฑรฏรฎรฐรฒ.", GetPlayerNameEx(playerid));
                SendClientMessage(to_player, 0x3399FFFF, fmt_str);
                ShowNotificationNew(to_player, 4, 10, notifcmdyes, 0, "รรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ รจรฃรฐรฎรชร ", ">");
            }
            case OFFER_TYPE_SHOWMED:
			{
			   new fmt_str[128];
			   format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รฏรฎรฑรฌรฎรฒรฐรฅรฒรผ รฅรฃรฎ รฌรฅรครจรถรจรญรฑรชรณรพ รชร รฐรฒรณ.", GetPlayerNameEx(playerid));
			   SendClientMessage(to_player, 0x3399FFFF, fmt_str);
			   ShowNotificationNew(to_player, 4, 10, notifcmdyes, 0, "รรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ รจรฃรฐรฎรชร ", ">");
