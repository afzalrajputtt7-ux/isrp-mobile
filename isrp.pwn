				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
			case OFFER_TYPE_JAIL_FREE:
			{
				format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รฏรฅรฐรฅรฑรฌรฎรฒรฐรฅรฒรผ รร รธรฅ รครฅรซรฎ รงร  %d รฐรณรก.", GetPlayerNameEx(playerid), value_1);
				SendClientMessage(to_player, 0x3399FFFF, fmt_str);

				ShowNotificationNew(to_player, 4, 10, notifcmdyes, 0, "รรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ รจรฃรฐรฎรชร ", ">");

				format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ %s รฏรฅรฐรฅรฑรฌรฎรฒรฐรฅรฒรผ รฅรฃรฎ รครฅรซรฎ รงร  %d รฐรณรก.", GetPlayerNameEx(to_player), value_1);
				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
	
			default: return 1;
		}

		SetPlayerOfferInfo(playerid, O_OUTCOMIG_PLAYER, to_player);

		SetPlayerOfferInfo(to_player, O_INCOMING_PLAYER, playerid);
		SetPlayerOfferInfo(to_player, O_INCOMING_TYPE, type);

		SetPlayerOfferValue(to_player, 0, value_1);
		SetPlayerOfferValue(to_player, 1, value_2);
	}
	else SendClientMessage(playerid, 0xFFFFFFFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {FF9900}/cancel {FFFFFF}รทรฒรฎรกรป รฎรฒรฎรงรขร รฒรผ รฏรฐรฅรครปรครณรนรฅรฅ รฏรฐรฅรครซรฎรฆรฅรญรจรฅ");

	return 1;
}

// ------------------------------------------
CMD:yes(playerid, params[])
{
	new offer_id = GetPlayerOfferInfo(playerid, O_INCOMING_PLAYER);
	new offer_type = GetPlayerOfferInfo(playerid, O_INCOMING_TYPE);

	new value_1 = GetPlayerOfferInfo(playerid, O_INCOMING_VALUE)[0];
	new value_2 = GetPlayerOfferInfo(playerid, O_INCOMING_VALUE)[1];

	if(offer_id != INVALID_PLAYER_ID)
	{
		if(IsPlayerConnected(offer_id) && IsPlayerLogged(offer_id))
		{
			if(GetPlayerOfferInfo(offer_id, O_OUTCOMIG_PLAYER) == playerid)
			{
				ClearPlayerOffer(offer_id);
			}
			else offer_type = -1;

			new Float: x, Float: y, Float: z;
			new Float: dist;

			GetPlayerPos(offer_id, x, y, z);

			if(offer_type != OFFER_TYPE_GETHERE)
				dist = GetPlayerDistanceFromPoint(playerid, x, y, z);

			else dist = 5.0;

			if(dist <= 10.0)
			{
				new fmt_str[144];

				switch(offer_type)
				{
					case OFFER_TYPE_SHOW_SKILL:
					{
						ShowPlayerSkills(offer_id, playerid);
						Action(offer_id, "รฏรฎรชร รงร รซ รฑรขรฎรจ รญร รขรปรชรจ รขรซร รครฅรญรจรฟ รฎรฐรณรฆรจรฅรฌ", _, false);
					}

					case OFFER_TYPE_INVITE:
					{
						new team_id = GetPlayerTeamEx(offer_id);

						if((1 <= team_id < MAX_ORG) || !(1 <= GetPlayerTeamEx(playerid) < MAX_ORG))
						{
							InvitePlayer(playerid, team_id, 1, true);

							new fmt_msg[144];
							format(fmt_msg, sizeof fmt_msg, "[R] %s %s รรฐรจรญรฟรซ รจรฃรฐรฎรชร  %s[%d] รข รฎรฐรฃร รญรจรงร รถรจรพ", GetPlayerJobAndRankName(offer_id), GetPlayerNameEx(offer_id), GetPlayerNameEx(playerid), playerid);

							if(!GetPlayerTeamEx(playerid))
							{
								SendMessageToJob(GetPlayerJob(playerid), fmt_msg);
								SendClientMessage(playerid, -1, "รร รกรฎรฒร รจรฒ");
							}
							else
							{
								SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, 0x33CC66FF);
							}

							new join_msg[120];
							format(join_msg, sizeof join_msg, "{FFFFFF}รรป รฏรฐรจรญรฟรซรจ รฏรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ{ffff00} %s {FFFFFF}รขรฑรฒรณรฏรจรฒรผ รข รฎรฐรฃร รญรจรงร รถรจรพ{ffff00} \"%s\"", GetPlayerNameEx(offer_id), GetPlayerTeamName(offer_id));
							SendClientMessage(playerid, 0x66CC00FF, join_msg);
							SendClientMessage(playerid, 0x3399FFFF, "{FFFFFF}รรฎรฑรฏรฎรซรผรงรณรฉรฒรฅรฑรผ {ffff00}/menu {FFFFFF}รครซรฟ รครฎรฑรฒรณรฏร  รช รชรฎรฌร รญรคร รฌ รฎรฐรฃร รญรจรงร รถรจรจ.");

							format(join_msg, sizeof join_msg, "%s รฏรฐรจรญรฟรซ รร รธรฅ รฏรฐรฅรครซรฎรฆรฅรญรจรฅ รขรฑรฒรณรฏรจรฒรผ รข รฎรฐรฃร รญรจรงร รถรจรพ", GetPlayerNameEx(playerid));
							SendClientMessage(offer_id, 0x66CC00FF, join_msg);

							format(join_msg, sizeof join_msg, "รรฐรจรญรฟรซ %s[acc:%d] รข รฎรฐรฃร รญรจรงร รถรจรพ %s", GetPlayerNameEx(playerid), GetPlayerAccountID(playerid), GetPlayerTeamName(offer_id));
							SendLog(offer_id, LOG_TYPE_FRACTION, join_msg);

							AddPlayerData(playerid, P_QUEST_EXP_8, +, 1);
							UpdatePlayerDatabaseInt(playerid, "quest_exp_8", GetPlayerData(playerid, P_QUEST_EXP_8));

							if(GetPlayerData(playerid, P_QUEST_EXP_8) == 1)
							{
								SendClientMessage(playerid, COR_SERVER, "{ffffff}รรป รณรฑรฏรฅรธรญรฎ รขรปรฏรฎรซรญรจรซรจ รชรขรฅรฑรฒ {009900}'รรฑรฒรณรฏรจรฒรผ รขรฎ รดรฐร รชรถรจรพ'. {ffffff}รร รธร  รญร รฃรฐร รคร : {009900}5000 รฐรณรก, 1exp");
								SendClientMessage(playerid, COR_SERVER, "{ffffff}รรขรฅรครจรฒรฅ {009900}/quest{ffffff}, รทรฒรฎรกรป รณรงรญร รฒรผ รฏรฎรครฐรฎรกรญรฎรฑรฒรจ.");
								GivePlayerMoneyEx(playerid, 10000, "รรปรฏรฎรซรญรฅรญรจรฅ รชรขรฅรฑรฒร ");

								SetPlayerData(playerid, P_QUEST_8, 1);
								UpdatePlayerDatabaseInt(playerid, "quest_8", 1);

								AddPlayerData(playerid, P_TOP_5, +, 1);
								UpdatePlayerDatabaseInt(playerid, "TOP_Quest", GetPlayerData(playerid, P_TOP_5));
							}
						}
						else SendClientMessage(playerid, 0xCECECEFF, "รรฐรจ รขรฑรฒรณรฏรซรฅรญรจรจ รข รฎรฐรฃร รญรจรงร รถรจรพ รฏรฐรฎรจรงรฎรธรซร  รฎรธรจรกรชร ");
					}
					case OFFER_TYPE_SHOWVB:
					{
 					  if (!IsPlayerConnected(offer_id) || !IsPlayerLogged(offer_id))
 					      return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅรครฎรฑรฒรณรฏรฅรญ.");

					    new nomer = GetPlayerData(offer_id, P_VOENBILET_NUM);

					    new kemdanvb[32];
					    format(kemdanvb, sizeof kemdanvb, "%s", GetPlayerData(offer_id, P_VOENBILET_KEM));

  					 new zvanie[32];
					    format(zvanie, sizeof zvanie, "%s", GetPlayerData(offer_id, P_VOENBILET_ZVANIE));

					    new data[16];
					   format(data, sizeof data, "%s", GetPlayerData(offer_id, P_VOENBILET_DATE));

					   new name_offer[MAX_PLAYER_NAME];
					    GetPlayerName(offer_id, name_offer, sizeof name_offer);

					   new action_show[128];
					    format(action_show, sizeof action_show, "รรฎรชร รงร รซ รขรฎรฅรญรญรปรฉ รกรจรซรฅรฒ %s", GetPlayerNameEx(playerid));
					   Action(offer_id, action_show, _, false);

					    new action_view[128];
					    format(action_view, sizeof action_view, "รรฐรฎรฑรฌร รฒรฐรจรขร รฅรฒ รขรฎรฅรญรญรปรฉ รกรจรซรฅรฒ %s", GetPlayerNameEx(offer_id));
					    Action(playerid, action_view, _, false);

					    ShowMilitaryCardDialog(playerid, nomer, name_offer, data, kemdanvb, zvanie);
					    ClearPlayerOffer(playerid);
					}
					case OFFER_TYPE_SHOWLIC:
					{
						if (!IsPlayerConnected(offer_id) || !IsPlayerLogged(offer_id))
							return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅรครฎรฑรฒรณรฏรฅรญ.");

						new action_show[64];
						format(action_show, sizeof action_show, "รรฎรชร รงร รซ รซรจรถรฅรญรงรจรจ %s", GetPlayerNameEx(playerid));
						Action(offer_id, action_show, _, false);

						new action_view[64];
						format(action_view, sizeof action_view, "รรฐรฎรฑรฌร รฒรฐรจรขร รฅรฒ รซรจรถรฅรญรงรจรจ %s", GetPlayerNameEx(offer_id));
						Action(playerid, action_view, _, false);

						ShowLicenseDialog(playerid, offer_id);
						ClearPlayerOffer(playerid);
					}
					case OFFER_TYPE_SHOWPASS:
					{
   					if (!IsPlayerConnected(offer_id) || !IsPlayerLogged(offer_id))
   					    return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅรครฎรฑรฒรณรฏรฅรญ.");

					   new name[MAX_PLAYER_NAME];
  					 GetPlayerName(offer_id, name, sizeof name);

					   new sex[16];
 					  format(sex, sizeof sex, "%s", GetPlayerSexName(offer_id));

					    new house[32];
  					 format(house, sizeof house, "%s", GetPlayerHouseName(offer_id));

					   new org[32];
   					format(org, sizeof org, "%s", GetPlayerTeamName(offer_id));

					   new rank[32];
					    format(rank, sizeof rank, "%s", GetPlayerJobAndRankName(offer_id));

					   new fmt_text[512];
 					  format(fmt_text, sizeof fmt_text,
  					    "{FFFFFF}รรฌรฟ:{FF6600}\t\t\t\t\t\t\t\t%s\n"\
  					     "{FFFFFF}รรฎรงรฐร รฑรฒ:{FF6600}\t\t\t\t\t\t%d\n"\
  					     "{FFFFFF}รรฎรซ:{FF6600}\t\t\t\t\t\t\t\t%s\n"\
 					      "{FFFFFF}รรฐรฎรฆรจรขร รญรจรฅ:{FF6600}\t\t\t%s\n"\
					       "-----------         -----------\n"\
  					     "{FFFFFF}รรฐรฃร รญรจรงร รถรจรฟ:{FF6600}\t%s\n"\
   					    "{FFFFFF}รรฎรซรฆรญรฎรฑรฒรผ:{FF6600}\t\t\t\t\t%s\n"\
  					     "-----------         -----------\n"\
  					     "{FFFFFF}รรฅรซรฅรดรฎรญ:{FF6600}\t\t\t%d\n"\
  					     "{FFFFFF}รรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร :{FF6600}\t\t\t%d\n"\
   					    "{FFFFFF}รร รชรฎรญรฎรฏรฎรฑรซรณรธรญรฎรฑรฒรผ:{FF6600}\t\t%d",
    					   name,
   					    GetPlayerLevel(offer_id),
 					      sex,
 					      house,
 					      org,
 					      rank,
   					    GetPlayerPhone(offer_id),
   					    GetPlayerSuspect(offer_id),
   					    GetPlayerData(offer_id, P_LAW_ABIDING)
 					  );

 					  Dialog(playerid, DIALOG_PASSPORT, DIALOG_STYLE_LIST, "{ff4a4a}"SERVER_NAME"{FFFFFF} | รร รฑรฏรฎรฐรฒ", fmt_text, "รร รชรฐรปรฒรผ", "");

 					  Action(offer_id, "รฏรฎรชร รงร รซ รฑรขรฎรฉ รฏร รฑรฏรฎรฐรฒ", _, false);
					    Action(playerid, "รฏรฐรฎรฑรฌร รฒรฐรจรขร รฅรฒ รฏร รฑรฏรฎรฐรฒ", _, false);

					   ClearPlayerOffer(playerid);
					}
					case OFFER_TYPE_MEDCARD:
					{
 					  new doctor = GetPVarInt(playerid, "med_offer_from");
					   new price = GetPVarInt(playerid, "med_offer_price");

  					 if (GetPlayerMoney(playerid) < price)
   					    return SCM(playerid, COLOR_GREY, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฑรฐรฅรครฑรฒรข.");

 					  GivePlayerMoneyEx(playerid, -price);
  					 SetPlayerData(playerid, P_MEDCARD_STATE, 1);
  					 SetTimerEx("FinishMedcardTimer", 600000, false, "i", playerid);

  					 new action_show[128];
   					format(action_show, sizeof action_show, "รร รทร รซ รฎรกรฑรซรฅรครฎรขร รญรจรฅ %s", GetPlayerNameEx(playerid));
 					  Action(doctor, action_show, _, false);

   					new action_view[128];
   					format(action_view, sizeof action_view, "รรฐรฎรตรฎรครจรฒ รฎรกรฑรซรฅรครฎรขร รญรจรฅ รณ %s", GetPlayerNameEx(doctor));
 					  Action(playerid, action_view, _, false);

   					new fmt_doc[128];
  					 format(fmt_doc, sizeof fmt_doc, "%s รฑรฎรฃรซร รฑรจรซรฑรฟ รฏรฐรฎรฉรฒรจ รฎรกรฑรซรฅรครฎรขร รญรจรฅ รงร  %d รฐรณรกรซรฅรฉ.", GetPlayerNameEx(playerid), price);
   					SCM(doctor, COLOR_BLUE, fmt_doc);

 					  SCM(playerid, COLOR_WHITE, "รรป รฎรฏรซร รฒรจรซรจ รฎรกรฑรซรฅรครฎรขร รญรจรฅ. รรฅรครชร รฐรฒร  รกรณรครฅรฒ รฃรฎรฒรฎรขร  รทรฅรฐรฅรง 10 รฌรจรญรณรฒ.");

  					 DeletePVar(playerid, "med_offer_from");
  					 DeletePVar(playerid, "med_offer_price");
					}
					case OFFER_TYPE_SHOWMED:
					{
					    if (!IsPlayerConnected(offer_id) || !IsPlayerLogged(offer_id))
					       return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅรครฎรฑรฒรณรฏรฅรญ.");

					   if (GetPlayerData(offer_id, P_MEDCARD) != 1)
  					     return SCM(playerid, COLOR_GREY, "ร รจรฃรฐรฎรชร  รญรฅรฒ รฌรฅรครจรถรจรญรฑรชรฎรฉ รชร รฐรฒรป.");

					    new date[16];
					    format(date, sizeof date, "%s", GetPlayerData(offer_id, P_MEDCARD_DATE));
					    if (!strlen(date) || strlen(date) < 4)
  					     format(date, sizeof date, "รญรฅ รณรชร รงร รญร ");

 					  new Float:raw_health;
					    GetPlayerHealth(offer_id, raw_health);
					    if (raw_health <= 0.0 || raw_health > 100.0)
  					     raw_health = 100.0;

					    new health = floatround(raw_health, floatround_floor);

					   new name_offer[MAX_PLAYER_NAME];
					    GetPlayerName(offer_id, name_offer, sizeof name_offer);

					   ShowMedicalCardDialog(playerid, offer_id, name_offer, health, date);
					    ClearPlayerOffer(playerid);
					}
					case OFFER_TYPE_ACCESSORY:
					{
						new price = GetPVarInt(offer_id, "owner_accept_price"),
						acs = GetPVarInt(offer_id, "acs_id"), sql = GetPVarInt(offer_id, "owner_accept_acs_sql"), string[124];

						if(price <= GetPlayerMoneyEx(playerid))
						{

							mysql_format(mysql, string, sizeof string, "UPDATE accessory_inventory SET player = %d WHERE id = %d", GetPlayerAccountID(playerid), sql);
							mysql_query(mysql, string, false);

							if(!mysql_errno())
							{
								GivePlayerMoneyEx(playerid, -price);
								GivePlayerMoneyEx(offer_id, price);

								format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฎรคร รซรจ/รฏรฅรฐรฅรคร รซรจ %s ร รชรฑรฅรฑรฑรณร รฐ %s รงร  %d รฐรณรก.", GetPlayerNameEx(playerid), accessory[acs][NAME_ACCESSORY], price);
								SendClientMessage(offer_id, 0x3399FFFF, fmt_str);
							
								format(fmt_str, sizeof fmt_str, "%s รฏรฐรฎรคร รซ รร รฌ %s รงร  %d รฐรณรก.", GetPlayerNameEx(offer_id), accessory[acs][NAME_ACCESSORY], price);
								SendClientMessage(playerid, 0x3399FFFF, fmt_str);
							}
						}
						else
						{
							SendClientMessage(playerid, -1, ""USC" ร รร รฑ รญรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฑรฐรฅรครฑรฒรข");
							SendClientMessage(offer_id, -1, ""USC" ร รรฃรฐรฎรชร  รญรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฑรฐรฅรครฑรฒรข");
						}
					}
                    case OFFER_TYPE_FINVITE:
                    {
                        new fam_id = GetPlayerData(offer_id, P_FAMILY);

                        FInvitePlayer(playerid, fam_id, 1, true);

                        new fmt_msg[120];
                        format(fmt_msg, sizeof fmt_msg, "รรฎรงรครฐร รขรซรฟรฅรฌ! รรป รขรฑรฒรณรฏรจรซรจ รข รฑรฅรฌรผรพ \"%s\"", GetFamilyData(fam_id, F_NAME));

                        SendClientMessage(playerid, 0x32a44bFF, fmt_msg);
                        SendClientMessage(playerid, 0x1E90FFFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {d8284c}/fmenu > รฏรฎรฌรฎรนรผ รฏรฎ รฑรฅรฌรผรฅ{1E90FF}, รทรฒรฎรกรป รณรงรญร รฒรผ รฎ รญรฎรขรปรต รขรฎรงรฌรฎรฆรญรฎรฑรฒรฟรต");

                        format(fmt_msg, sizeof fmt_msg, "%s รฏรฐรจรญรฟรซ รร รธรฅ รฏรฐรฅรครซรฎรฆรฅรญรจรฅ รขรฑรฒรณรฏรจรฒรผ รข รฑรฅรฌรผรพ", GetPlayerNameEx(playerid), value_1);
                        SendClientMessage(offer_id, 0x32a44bFF, fmt_msg);

                        format(fmt_msg, sizeof fmt_msg, "รรฐรจรญรฟรซ %s[acc:%d] รข รฑรฅรฌรผรพ %s", GetPlayerNameEx(playerid), GetPlayerAccountID(playerid), GetPlayerTeamName(offer_id));
                        SendLog(offer_id, LOG_TYPE_FRACTION, fmt_msg);

                        AddPlayerData(playerid, P_QUEST_EXP_7, +, 1);
						UpdatePlayerDatabaseInt(playerid, "quest_exp_7", GetPlayerData(playerid, P_QUEST_EXP_7));

						if(GetPlayerData(playerid, P_QUEST_EXP_7) == 1)
