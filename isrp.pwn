							case 4: // รรฎรชรณรฌรฅรญรฒรป รญร  รฒรฐร รญรฑรฏรฎรฐรฒ
							{
								ShowOwnableCarPass(playerid, vehicleid);
							}
							case 5: // รรญรฟรฒรผ รญรฎรฌรฅรฐรญรปรฅ รงรญร รชรจ
