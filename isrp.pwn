	SendClientMessage(playerid, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "รรฃรฐรฎรช %s รฏรฅรฐรฅรคร รซ รร รฌ รร รฒรฐรฎรญรป (%d รธรฒ.)", GetPlayerNameEx(playerid), give_ammo_count);
