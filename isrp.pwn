stock ShowPlayerDrivingExam(playerid, step)
{
	if(0 <= step <= sizeof driving_exam - 1)
	{
		Dialog
		(
			playerid, DIALOG_DRIVING_EXAM, DIALOG_STYLE_LIST,
			driving_exam[step][DE_TITLE],
			driving_exam[step][DE_LIST_ITEMS],
			"รรฒรขรฅรฒรจรฒรผ", ""
		);
		SetPlayerDrivingExamInfo(playerid, DE_EXAM_STEP, step);
	}
	else if(step >= sizeof driving_exam)
	{
		new points = GetPlayerDrivingExamInfo(playerid, DE_POINTS);
		SetPlayerDrivingExamInfo(playerid, DE_EXAM_STEP, 0);
		SetPlayerDrivingExamInfo(playerid, DE_ROUTE_STEP, 0);

		if(points >= 9)
			SetPlayerData(playerid, P_DRIVING_LIC, 1);

		new fmt_str[256];
		format(fmt_str, sizeof fmt_str, "{FFFFFF}รรฎรซรจรทรฅรฑรฒรขรฎ รฏรฐร รขรจรซรผรญรปรต รฎรฒรขรฅรฒรฎรข: {66CC00}%d\n\n", points);

		if(points == 9)
		{
			strcat
			(
				fmt_str,
				"{6699FF}รรฎรงรครฐร รขรซรฟรฅรฌ!\n"\
				"รรป รญร รกรฐร รซรจ รฌรจรญรจรฌร รซรผรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รกร รซรซรฎรข, รทรฒรฎรกรป รฏรฐรจรฑรฒรณรฏรจรฒรผ รชรฎ รขรฒรฎรฐรฎรฉ รทร รฑรฒรจ รฝรชรงร รฌรฅรญร !"
			);
		}
		else if(points >= 10)
		{
			static const
				medal_name[3][12] = {"รกรฐรฎรญรงรฎรขรณรพ", "รฑรฅรฐรฅรกรฐรฟรญรญรณรพ", "รงรฎรซรฎรฒรณรพ"};

			format(fmt_str, sizeof fmt_str, "%s{6699FF}รรฎรงรครฐร รขรซรฟรฅรฌ!\nรรป รฏรฎรซรณรทร รฅรฒรฅ %s รฌรฅรคร รซรผ รงร  รฒรฅรฎรฐรฅรฒรจรทรฅรฑรชรณรพ รทร รฑรฒรผ รฝรชรงร รฌรฅรญร !", fmt_str, medal_name[points - 10]);
		}
		else
		{
			ClearPlayerDrivingExamInfo(playerid);
			strcat
			(
				fmt_str,
				"{FF6600}ร รฑรฎรฆร รซรฅรญรจรพ รขรป รญรฅ รญร รกรฐร รซรจ รญรฅรฎรกรตรฎรครจรฌรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รกร รซรซรฎรข\n"\
				"ร รฑรซรฅรครณรพรนรจรฉ รฐร รง รขรญรจรฌร รฒรฅรซรผรญรฎ รฏรฐรฎรทรจรฒร รฉรฒรฅ รฎรกรณรทร รพรนรจรฉ รฐร รงรครฅรซ\n"\
				"รรครฅรฌ รขร รฑ รญร  รฏรฅรฐรฅรฑรคร รทรฅ!"
			);
		}

		Dialog
		(
			playerid, DIALOG_DRIVING_EXAM_RESULT, DIALOG_STYLE_MSGBOX,
			"{FFFF00}รรฅรงรณรซรผรฒร รฒรป รฒรฅรฎรฐรฅรฒรจรทรฅรฑรชรฎรฉ รทร รฑรฒรจ",
			fmt_str,
			"รรช", ""
		);
	}
	return 1;
}

stock NextDrivingExamRouteCP(playerid)
{
	new step = GetPlayerDrivingExamInfo(playerid, DE_ROUTE_STEP);

	SetPlayerRaceCheckpoint
	(
