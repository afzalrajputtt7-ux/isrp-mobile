CMD:inter(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 1 ) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new to_player, interior; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /inter [id รจรฃรฐรฎรชร ] [รจรญรฒรฅรฐรผรฅรฐ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
	if(TEST_SERVER == 1)
	{
	    if(playerid != to_player) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญรณรพ รชรฎรฌร รญรครณ รฌรฎรฆรญรฎ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รญร  รรรร รรรรรรร รฒรฎรซรผรชรฎ รฏรฎ รฎรฒรญรฎรธรฅรญรจรพ รช รฑรฅรกรฅ!");
	}

	SetPlayerInterior(to_player, interior);

	new fmt_msg[999];
	
	new fmt_text[999];
	
	format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รณรฑรฒร รญรฎรขรจรซ %s[%d] รจรญรฒรฅรฐรผรฅรฐ %d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, interior);
	SendMessageToAdmins(fmt_msg, 0x999999FF);
		
    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รณรฑรฒร รญรฎรขรจรซรจ %s[%d] รจรญรฒรฅรฐรผรฅรฐ %d", GetPlayerNameEx(to_player), to_player, interior);
    SendClientMessage(playerid, 0x66CC00FF, fmt_msg);	

	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รณรฑรฒร รญรฎรขรจรซ รขร รฌ รจรญรฒรฅรฐรผรฅรฐ %d", GetPlayerNameEx(playerid), playerid, interior);
	SendClientMessage(to_player, 0x66CC00FF, fmt_msg);	

	LinkVehicleToInterior(GetPlayerData(to_player, P_BUY_CAR), interior);

	format(fmt_text, sizeof fmt_text, "รรฑรฒร รญรฎรขรจรซ %s[acc:%d] รจรญรฒรฅรฐรผรฅรฐ %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), interior);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:world(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4 ) return 1;

	extract params -> new to_player, world; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /world [id รจรฃรฐรฎรชร ] [รขรจรฐรฒ.รฌรจรฐ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(TEST_SERVER == 1)
	{
	    if(playerid != to_player) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญรณรพ รชรฎรฌร รญรครณ รฌรฎรฆรญรฎ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รญร  รรรร รรรรรรร รฒรฎรซรผรชรฎ รฏรฎ รฎรฒรญรฎรธรฅรญรจรพ รช รฑรฅรกรฅ!");
	}

	SetPlayerVirtualWorld(to_player, world);

	new fmt_text[110];

	format(fmt_text, sizeof fmt_text, "รรป รณรฑรฒร รญรฎรขรจรซรจ %s[%d] รขรจรฐรฒ.รฌรจรฐ %d", GetPlayerNameEx(to_player), to_player, world);
	SendClientMessage(playerid, -1, fmt_text);

	format(fmt_text, sizeof fmt_text, "%s[%d] รณรฑรฒร รญรฎรขรจรซ รร รฌ รขรจรฐรฒ.รฌรจรฐ %d", GetPlayerNameEx(playerid), playerid, world);
	SendClientMessage(to_player, -1, fmt_text);

	if(GetPlayerAdminEx(playerid) <= 5)
	{
		format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รณรฑรฒร รญรฎรขรจรซ %s[%d] รขรจรฐรฒ.รฌรจรฐ ยน%d", GetPlayerNameEx(playerid), playerid,
		GetPlayerNameEx(to_player), to_player, world);
		SendMessageToAdmins(fmt_text, 0x999999FF);
	}

	format(fmt_text, sizeof fmt_text, "รรฑรฒร รญรฎรขรจรซ %s[acc:%d] รขรจรฐรฒ.รฌรจรฐ %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), world);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:warn(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 7) return 1;
	
    
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /warn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, string:reason[66];

	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	//if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รฑร รฌรฎรฌรณ รฑรฅรกรฅ");

	if(AntiSliv(playerid, "/warn")) return true;
	
	AddAdminStat(playerid, "warns_total", P_WARNS_TOTAL);
	AddAdminStat(playerid, "warns_today", P_WARNS_TODAY);

	AddPlayerData(to_player, P_WARN, +, 1);
	SetPlayerData(to_player, P_WARN_TIME, gettime() + (86400 * 10));

	new fmt_msg[128];
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรปรคร รซ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ รจรฃรฐรฎรชรณ %s [%d|3]", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), GetPlayerData(to_player, P_WARN));

	if(strlen(reason) > 0)
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	InvitePlayer(to_player, 0, 0, true);

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_WARN);
	new warns_time = GetPlayerData(to_player, P_WARN_TIME);

	format(fmt_msg, sizeof fmt_msg, "รรปรคร รซ รขร รฐรญ %s[acc:%d] (%d/3). รรฐรจรทรจรญร : %d", GetPlayerNameEx(to_player), uid, warns, reason);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	if(warns >= 3)
	{
		SendClientMessage(to_player, 0xFF5533FF, "รรชรชร รณรญรฒ รงร รกรซรฎรชรจรฐรฎรขร รญ รญร  10 รครญรฅรฉ");

		warns =
		warns_time = 0;

		AddBan(uid, gettime(), 10, GetPlayerIpEx(to_player), "รฏรฎรซรณรทรฅรญรฎ 3 รขร รฐรญร ", GetPlayerNameEx(playerid));
	}
	else Kick:(to_player);

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET warn=%d,warn_time=%d WHERE id=%d", warns, warns_time, uid);
	mysql_query(mysql, fmt_msg, false);

	return 1;
}

CMD:unwarn(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 2) return 1;
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /warn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, string: reason[66];
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	SetPlayerData(to_player, P_WARN, 		0);
	SetPlayerData(to_player, P_WARN_TIME, 	0);

	UpdatePlayerDatabaseInt(to_player, "warn", 		0);
	UpdatePlayerDatabaseInt(to_player, "warn_time", 	0);

	new fmt_msg[128];
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รฑรญรฟรซ รขรฑรฅ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฟ รฑ รจรฃรฐรฎรชร  %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

	if(strlen(reason) > 0)
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรญรฟรซ รขรฑรฅ รขร รฐรญรป %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

CMD:spawn(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 7) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	
	extract params -> new to_player, string: reason[30]; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /spawn [id รจรฃรฐรฎรชร ] [รรฐรจรทรจรญร ]");
	
	if(TEST_SERVER == 1)
	{
	    if(playerid != to_player) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร  รรรร รรรรรรร รคร รญรญรณรพ รชรฎรฌร รญรครณ รฌรฎรฆรญรฎ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฒรฎรซรผรชรฎ รฏรฎ รฎรฒรญรฎรธรฅรญรจรพ รช รฑรฅรกรฅ!");
	}
	
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player)) return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	SpawnPlayer(to_player);

	AddAdminStat(playerid, "spawns_total", P_SPAWNS_TOTAL);
	AddAdminStat(playerid, "spawns_today", P_SPAWNS_TODAY);

	new fmt_msg[999];
	//format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รงร รฑรฏร รขรญรจรซ %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

	if(strlen(reason))
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);
	
		format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รงร รฑรฏร รขรญรจรซ %s[%d]. รรฐรจรทรจรญร : %s ", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, reason);
		SendMessageToAdmins(fmt_msg, 0x999999FF);
		
    	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รงร รฑรฏร รขรญรจรซรจ %s[%d]. รรฐรจรทรจรญร : %s ", GetPlayerNameEx(to_player), to_player, reason);
    	SendClientMessage(playerid, 0x66CC00FF, fmt_msg);	

	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รกรปรซรจ รงร รฑรฏร รขรญรฅรญรป ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ %s[%d]. รรฐรจรทรจรญร : %s ", GetPlayerNameEx(playerid), playerid, reason);
	SendClientMessage(to_player, 0x66CC00FF, fmt_msg);
	
	InfoAstats[3] += 1;

	format(fmt_msg, sizeof fmt_msg, "รร รฑรฏร รขรญรจรซ %s[acc:%d]. รรฐรจรทรจรญร : %s",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);
	return 1;
}

CMD:spcar(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 3) return 1;

	extract params -> new vehicleid; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /spcar [id ร รขรฒรฎ]");

	if(IsPlayerInAnyVehicle(playerid) && vehicleid == 0) vehicleid = GetPlayerVehicleID(playerid);

	if(!IsValidVehicle(vehicleid)) return SendClientMessage(playerid, 0xCECECEFF, "รร รญรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

	SetVehicleToRespawn(vehicleid);

	new fmt_msg[100];

	if(GetPlayerAdminEx(playerid) <= 5)
	{
		format(fmt_msg, sizeof fmt_msg, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รงร รฐรฅรฑรฏร รขรญรจรซ ร รขรฒรฎ [ยน%d]", GetPlayerNameEx(playerid), playerid, vehicleid);
		SendMessageToAdmins(fmt_msg, 0x999999FF);
	}

	format(fmt_msg, sizeof fmt_msg, "รร รฐรฅรฑรฏร รขรญรจรซ ร รขรฒรฎ ยน%d", vehicleid);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

