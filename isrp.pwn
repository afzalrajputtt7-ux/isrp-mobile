forward CloseGate(gateid);
public CloseGate(gateid)
{
    switch(gateid)
    {
        case 0: // vorotki
        {
            MoveObject(vorotki, -1820.49, -2651.36, 10.9, 3.0, 0.0, 0.0, 99.5);
            gateOpened[0] = false;
            return 1;
        }

        case 1: // vorotafsinkpp
        {
            MoveObject(vorotafsinkpp, -1820.11, -2632.95, 8.58, 3.0, 0.0, 0.0, -80.5);
            gateOpened[1] = false;
            return 1;
        }

        case 2: // vorotafsinkpp1
        {
            MoveObject(vorotafsinkpp1, -1827.21, -2634.129, 8.61, 3.0, 0.0, 0.0, 99.4);
            gateOpened[2] = false;
            return 1;
        }

        case 3: // vorotamo1
        {
            MoveObject(vorotamo1, 1909.95, 1725.28, 15.6666, 3.0, 0.0, 0.0, 0.0);
            gateOpened[3] = false;
            return 1;
        }

        case 4: // vorotamo
        {
            MoveObject(vorotamo, 1891.1486, 1721.5555, 16.4444, 3.0, 0.0, 0.0, 0.0);
            gateOpened[4] = false;
            return 1;
        }
        case 5: // barrier1 รรร
		{
 		  MoveObject(barrier1, 2579.94, -2434.11, 21.79, 3.0, 0.0, 0.0, 0.0);
  		 gateOpened[5] = false;
		   return 1;
		}
		case 6: // barrier2 รรร
		{
  		 MoveObject(barrier2, -2345.66, -381.10, 29.06, 4.0, -180.0, 0.0, 90.0);
 		  gateOpened[6] = false;
 		  return 1;
		}
    }
    return 1;
}

stock ShowArmyKPPDialog(playerid)
{
    new status_barrier[32], status_gate[32];
    new action_barrier[32], action_gate[32];
    new dialog[512];

    format(status_barrier, sizeof status_barrier, gateOpened[3] ? "{00FF00}รฎรฒรชรฐรปรฒ" : "{FF5555}รงร รชรฐรปรฒ");
    format(status_gate, sizeof status_gate, gateOpened[4] ? "{00FF00}รฎรฒรชรฐรปรฒรป" : "{FF5555}รงร รชรฐรปรฒรป");

    format(action_barrier, sizeof action_barrier, gateOpened[3] ? "{FF5555}รงร รชรฐรปรฒรจรฟ" : "{FF5555}รฎรฒรชรฐรปรฒรจรฟ");
    format(action_gate, sizeof action_gate, gateOpened[4] ? "{FF5555}รงร รชรฐรปรฒรจรฟ" : "{FF5555}รฎรฒรชรฐรปรฒรจรฟ");
    
    strcat(dialog, "{FF5555}รรฎรฌรฅรฐ\t{FF5555}รร รจรฌรฅรญรฎรขร รญรจรฅ\t{FF5555}รรฒร รฒรณรฑ\t{FF5555}รรฎรฑรฒรณรฏรญรฎรฅ รครฅรฉรฑรฒรขรจรฅ\n");

    new line1[128], line2[128];
    format(line1, sizeof line1, "{FFFFFF}1.\tรรซร รฃรกร รณรฌ\t%s\t{FF5555}รร รฆรฌรจรฒรฅ รครซรฟ %s\n", status_barrier, action_barrier);
    format(line2, sizeof line2, "{FFFFFF}2.\tรรฎรฐรฎรฒร \t%s\t{FF5555}รร รฆรฌรจรฒรฅ รครซรฟ %s", status_gate, action_gate);

    strcat(dialog, line1);
    strcat(dialog, line2);

    ShowPlayerDialog(playerid, DIALOG_KPP_ARMY, DIALOG_STYLE_TABLIST_HEADERS, "{FF5555}KRANIN STUDIO RolePlay{FFFFFF} | รรฏรฐร รขรซรฅรญรจรฅ รรร", dialog, "รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ");
}

stock StartKPPHack(playerid)
{
    if(!IsPlayerInRangeOfPoint(playerid, 5.0, 1910.61, 1728.09, 16.73))
        return SendClientMessage(playerid, COLOR_GREY, "รรป รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ รฎรฒ รรร.");

    SetPVarInt(playerid, "KPPHackProgress", 0);
    kpp_hack_timer = SetTimerEx("KPPHackProgress", 1000, true, "d", playerid);
}

forward KPPHackProgress(playerid);
public KPPHackProgress(playerid)
{
    if(!IsPlayerInRangeOfPoint(playerid, 5.0, 1910.61, 1728.09, 16.73))
    {
        KillTimer(kpp_hack_timer);
        kpp_hack_timer = -1;
        SendClientMessage(playerid, COLOR_GREY, "รรงรซรฎรฌ รฏรฐรฅรฐรขร รญ. รรป รฏรฎรชรจรญรณรซรจ รงรฎรญรณ.");
        return;
    }

    new progress = GetPVarInt(playerid, "KPPHackProgress");
    progress += 10;
    SetPVarInt(playerid, "KPPHackProgress", progress);

    new msg[64];
    format(msg, sizeof msg, "รรงรซรฎรฌ รรร: %d", progress);
	strcat(msg, "%%"); // รครฎรกร รขรซรฟรฅรฌ รงรญร รช รฏรฐรฎรถรฅรญรฒร  รขรฐรณรทรญรณรพ
    SendClientMessage(playerid, COLOR_RADIO, msg);

    if(progress >= 100)
    {
        KillTimer(kpp_hack_timer);
        kpp_hack_timer = -1;
        kpp_hacked = true;
        gateOpened[3] = true;
        gateOpened[4] = true;

        MoveObject(vorotamo, 1891.1486, 1714.2531, 16.4444, 3.0);
        MoveObject(vorotamo1, 1909.95, 1725.28, 15.6666, 3.0, -90.0, 0.0, 0.0);

        SendClientMessage(playerid, COLOR_GREY, "รรร รรฐรฌรจรจ รขรงรซรฎรฌร รญ! รรฎรฐรฎรฒร  รจ รธรซร รฃรกร รณรฌ รฎรฒรชรฐรปรฒรป รญร  10 รฌรจรญรณรฒ.");
        SendMessageToTeam(TEAM_ARMY, "[R] รรร รขรงรซรฎรฌร รญ, รชรฒรฎ-รฒรฎ รฏรฐรฎรกรฐร รซรฑรฟ รญร  รฒรฅรฐรฐรจรฒรฎรฐรจรพ รขรฎรจรญรฑรชรฎรฉ รทร รฑรฒรจ! ", COLOR_RADIO);
        SetTimer("ResetKPPHack", 600000, false);
    }
}

public ResetKPPHack()
{
    kpp_hacked = false;
    gateOpened[3] = false;
    gateOpened[4] = false;

    MoveObject(vorotamo, 1891.1486, 1721.5555, 16.4444, 3.0, 0.0, 0.0, 0.0);
    MoveObject(vorotamo1, 1909.95, 1725.28, 15.6666, 3.0, 0.0, 0.0, 0.0);

    SendClientMessageToAll(COLOR_GREY, "รรร รรฐรฌรจรจ รขรฎรฑรฑรฒร รญรฎรขรซรฅรญ. รรฏรฐร รขรซรฅรญรจรฅ รฑรญรฎรขร  รครฎรฑรฒรณรฏรญรฎ.");
    SendMessageToTeam(TEAM_ARMY, "[R] รรจรฑรฒรฅรฌร  รรร รขรฎรฑรฑรฒร รญรฎรขรซรฅรญร , รขรฎรฐรฎรฒร  รจ รธรซร รฃรกร รณรฌ รงร รชรฐรปรฒรป. ", COLOR_RADIO);
}

CMD:lsklad(playerid)
{
	if (GetPlayerJob(playerid) < 9)
		return SendClientMessage(playerid, -1, "รรฅรครฎรฑรฒร รฒรฎรทรญรปรฉ รฐร รญรฃ.");

	new idx = GetNearestArmory(playerid);
	if (idx == -1)
		return SendClientMessage(playerid, -1, "รรป รญรฅ รฐรฟรครฎรฌ รฑรฎ รฑรชรซร รครฎรฌ.");

	switch (g_armory[idx][A_TYPE])
	{
		case ARMORY_TYPE_ARMOR:
		{
			if (GetPlayerTeamEx(playerid) != TEAM_ARMY)
				return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฎรฒ 9 รฐร รญรฃร  รรฐรฌรจรจ.");
		}
		case ARMORY_TYPE_FSIN:
		{
			if (GetPlayerTeamEx(playerid) != TEAM_FSIN)
				return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฎรฒ 9 รฐร รญรฃร  รรรร.");
		}
		case ARMORY_TYPE_SECURITY:
		{
			if (GetPlayerTeamEx(playerid) != TEAM_GOVERNMENT)
				return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฎรฒ 9 รฐร รญรฃร  รรฐร รขรจรฒรฅรซรผรฑรฒรขร .");
		}
		case ARMORY_TYPE_POLICE:
		{
			new team = GetPlayerTeamEx(playerid);
			if (team != TEAM_DPS && team != TEAM_PPS)
				return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฎรฒ 9 รฐร รญรฃร  รรรร/รรรรร.");
		}
		case ARMORY_TYPE_FSB:
		{
			new team = GetPlayerTeamEx(playerid);
			if (team != TEAM_FBI)
				return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฎรฒ 9 รฐร รญรฃร  รรร.");
		}
		default:
		{
			return SendClientMessage(playerid, -1, "รรจรฏ รฑรชรซร รคร  รญรฅ รฐร รฑรฏรฎรงรญร รญ.");
		}
	}

	// รฒรฅรฏรฅรฐรผ รฑรชรซร รค รฏรฅรฐรฅรชรซรพรทร รฅรฒรฑรฟ
	g_armory[idx][A_IS_OPEN] = !g_armory[idx][A_IS_OPEN];
	UpdateArmoryLabel(idx);

	SendClientMessage(playerid, -1, g_armory[idx][A_IS_OPEN] ? "รรป รฎรฒรชรฐรปรซรจ รฑรชรซร รค." : "รรป รงร รชรฐรปรซรจ รฑรชรซร รค.");
	return 1;
}

CMD:addmaterials(playerid, params[])
{
	new amount;
	if (sscanf(params, "d", amount))
		return SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรณรฉ: /addmaterials [รชรฎรซ-รขรฎ]");

	new idx = GetNearestArmory(playerid);
	if (idx == -1) return SendClientMessage(playerid, -1, "รรป รญรฅ รฐรฟรครฎรฌ รฑรฎ รฑรชรซร รครฎรฌ.");

	g_armory[idx][A_MATERIALS] += amount;
	if (g_armory[idx][A_MATERIALS] > 100000) g_armory[idx][A_MATERIALS] = 100000;

	UpdateArmoryDatabaseInt(idx, "materials", g_armory[idx][A_MATERIALS]);

	UpdateArmoryLabel(idx);
	SendClientMessage(playerid, -1, "รร รฒรฅรฐรจร รซรป รครฎรกร รขรซรฅรญรป.");
	return 1;
}

stock UpdateArmoryLabel(idx)
{
	if (g_armory[idx][A_LABEL] == 0) return;

	new label[256];
	new status[32];

	if (g_armory[idx][A_IS_OPEN])
		format(status, sizeof(status), "{00FF00}รฎรฒรชรฐรปรฒ");
	else
		format(status, sizeof(status), "{FF0000}รงร รชรฐรปรฒ");

	format(label, sizeof(label),
		"{FFFF00} << รรฐรณรฆรฅรฉรญรปรฉ รฑรชรซร รค >>\n\n\
		{FFFF00}|{FFFFFF} รรฎรฑรฒรฎรฟรญรจรฅ{FFFF00}: %d {FFFFFF} รจรง {FFFF00} 100000\n\
		{FFFF00}|{FFFFFF} รรฒร รฒรณรฑ{FFFF00}: รฑรชรซร รค %s",
		g_armory[idx][A_MATERIALS],
		status);

	UpdateDynamic3DTextLabelText(g_armory[idx][A_LABEL], 0xFFD700FF, label);

    UpdateArmoryZagruzkaLabel();
}

stock GetNearestArmory(playerid)
{
	new Float:x, Float:y, Float:z;
	GetPlayerPos(playerid, x, y, z);

	for (new i = 0; i < sizeof g_armory; i++)
	{
		if (IsPlayerInRangeOfPoint(playerid, 5.0, g_armory[i][A_POS_X], g_armory[i][A_POS_Y], g_armory[i][A_POS_Z]))
			return i;
	}
	return -1;
}

forward StartCarryAnimation(playerid);
public StartCarryAnimation(playerid)
{
    ApplyAnimation(playerid, "CARRY", "crry_prtial", 4.1, 1, 1, 1, 1, 1, 0);
    return 1;
}

CMD:adelivery(playerid)
{
    if (GetPlayerTeamEx(playerid) != TEAM_ARMY)
        return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑรฎรซรคร รฒร รฌ รรฐรฌรจรจ.");
       
    if(!IsWorkDayStarted(playerid)) return 1;

    new vehicleid = GetPlayerVehicleID(playerid);
    if (vehicleid == INVALID_VEHICLE_ID || GetVehicleModel(vehicleid) != VEHICLE_MODEL_SUPPLY_TRUCK)
        return SendClientMessage(playerid, COLOR_GREY, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข ร รขรฒรฎรฌรฎรกรจรซรฅ {FFFF00}รรรรร 54115.");

    if (g_delivery_vehicle[vehicleid])
    {
        Dialog(playerid, DIALOG_ADELIVERY_CONFIRM, DIALOG_STYLE_MSGBOX,
            "{FF6666}KRANIN STUDIO RolePlay {FFFFFF}| รรฎรฑรฒร รขรชร  รณรฆรฅ ร รชรฒรจรขรญร ",
            "{FFFFFF}ร รขร รฑ รณรฆรฅ รฅรฑรฒรผ ร รชรฒรจรขรญร รฟ รฏรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข.\nรรป รครฅรฉรฑรฒรขรจรฒรฅรซรผรญรฎ รตรฎรฒรจรฒรฅ รงร รขรฅรฐรธรจรฒรผ รฒรฅรชรณรนรณรพ รฏรฎรฑรฒร รขรชรณ?",
            "รร ", "รรฅรฒ");
        return 1;
    }

    new dialog[4096], buffer[256];
    strcat(dialog, "{FF6666}#รรฎรฌรฅรฐ\t{FF6666}รร รจรฌรฅรญรฎรขร รญรจรฅ\t{FF6666}รรฎรฑรฒรฎรฟรญรจรฅ รฑรชรซร รคร \t{FF6666}รรฎรฑรฒรณรฏรญรฎรฅ รครฅรฉรฑรฒรขรจรฅ\n");

    format(buffer, sizeof(buffer),
        "{FF6666}#1\t{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข รข รรฎรฅรญรญรณรพ รทร รฑรฒรผ\t{FFFF00} %d {FFFFFF}รจรง {FFFF00}100000\t{FF6666}รร รฆรฌรจรฒรฅ, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฑรฒร รขรชรณ\n",
        g_armory[ARMORY_TYPE_ARMOR][A_MATERIALS]); strcat(dialog, buffer);

    format(buffer, sizeof(buffer),
        "{FF6666}#2\t{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข รข รรร\t{FFFF00} %d {FFFFFF}รจรง {FFFF00}100000\t{FF6666}รร รฆรฌรจรฒรฅ, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฑรฒร รขรชรณ\n",
        g_armory[ARMORY_TYPE_FSB][A_MATERIALS]); strcat(dialog, buffer);

    format(buffer, sizeof(buffer),
        "{FF6666}#3\t{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข รข รรจรซรจรถรจรพ\t{FFFF00} %d {FFFFFF}รจรง {FFFF00}100000\t{FF6666}รร รฆรฌรจรฒรฅ, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฑรฒร รขรชรณ\n",
        g_armory[ARMORY_TYPE_POLICE][A_MATERIALS]); strcat(dialog, buffer);

    format(buffer, sizeof(buffer),
        "{FF6666}#4\t{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข รข รรฐร รขรจรฒรฅรซรผรฑรฒรขรฎ\t{FFFF00} %d {FFFFFF}รจรง {FFFF00}100000\t{FF6666}รร รฆรฌรจรฒรฅ, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฑรฒร รขรชรณ\n",
        g_armory[ARMORY_TYPE_SECURITY][A_MATERIALS]); strcat(dialog, buffer);

    format(buffer, sizeof(buffer),
        "{FF6666}#5\t{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข รข รรรร\t{FFFF00} %d {FFFFFF}รจรง {FFFF00}100000\t{FF6666}รร รฆรฌรจรฒรฅ, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฑรฒร รขรชรณ",
        g_armory[ARMORY_TYPE_FSIN][A_MATERIALS]); strcat(dialog, buffer);

    Dialog(playerid, DIALOG_ADELIVERY_SELECT, DIALOG_STYLE_TABLIST_HEADERS,
        "{FF6666}KRANIN STUDIO RolePlay {FFFFFF}| รร รฒรฅรฐรจร รซรป", dialog, "รรปรกรฐร รฒรผ", "รรปรฉรฒรจ");

    return 1;
}

stock CreateDeliveryVehicleLabel(vehicleid, target_type)
{
    if (!IsValidVehicle(vehicleid)) return;

    new label[256], org_name[64];

    switch (target_type)
    {
        case ARMORY_TYPE_ARMOR:        org_name = "{FFFF00}\"รรฎรฅรญรญร รฟ รทร รฑรฒรผ\"";
        case ARMORY_TYPE_FSB:          org_name = "{FFFF00}\"รรร\"";
        case ARMORY_TYPE_POLICE:       org_name = "{FFFF00}\"รรจรซรจรถรจรฟ\"";
        case ARMORY_TYPE_SECURITY:     org_name = "{FFFF00}\"รรฐร รขรจรฒรฅรซรผรฑรฒรขรฎ\"";
        case ARMORY_TYPE_FSIN:         org_name = "{FFFF00}\"รรรร\"";
        default:                       org_name = "{FF0000}\"รรฅรจรงรขรฅรฑรฒรญรฎ\"";
    }

    format(label, sizeof(label),
        "{FFFF00}<<{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข{FFFF00}>>\n\n\
| {FFFFFF}รร รงรญร รทรฅรญรจรฅ{FFFF00}: %s\n\
{FFFF00}| {FFFFFF}รร รฃรฐรณรฆรฅรญรฎ รฟรนรจรชรฎรข รฑ รฌร รฒรฅรฐรจร รซร รฌรจ{FFFF00}: 0 {FFFFFF}รจรง {FFFF00}10",
        org_name);

    CreateVehicleLabel(vehicleid, label, 0xFFD700FF, 0.0, 0.0, 2.8, 20.0);
}

stock UpdateDeliveryLabel(vehicleid, target_type)
{
    if (!IsValidVehicle(vehicleid)) return;

    new label[256], org_name[64];

    switch (target_type)
    {
        case ARMORY_TYPE_ARMOR:        org_name = "{FFFF00}\"รรฎรฅรญรญร รฟ รทร รฑรฒรผ\"";
        case ARMORY_TYPE_FSB:          org_name = "{FFFF00}\"รรร\"";
        case ARMORY_TYPE_POLICE:       org_name = "{FFFF00}\"รรจรซรจรถรจรฟ\"";
        case ARMORY_TYPE_SECURITY:     org_name = "{FFFF00}\"รรฐร รขรจรฒรฅรซรผรฑรฒรขรฎ\"";
        case ARMORY_TYPE_FSIN:         org_name = "{FFFF00}\"รรรร\"";
        default:                       org_name = "{FF0000}\"รรฅรจรงรขรฅรฑรฒรญรฎ\"";
    }

    format(label, sizeof(label),
        "{FFFF00}<<{FFFFFF}รรฎรฑรฒร รขรชร  รฌร รฒรฅรฐรจร รซรฎรข{FFFF00}>>\n\n\
| {FFFFFF}รร รงรญร รทรฅรญรจรฅ{FFFF00}: %s\n\
{FFFF00}| {FFFFFF}รร รฃรฐรณรฆรฅรญรฎ รฟรนรจรชรฎรข รฑ รฌร รฒรฅรฐรจร รซร รฌรจ{FFFF00}: %d {FFFFFF}รจรง {FFFF00}10",
        org_name, g_delivery_boxes[vehicleid]);

    UpdateVehicleLabel(vehicleid, 0xFFD700FF, label);
}

stock AbortDeliveryByVehicle(vehicleid)
{
    if (!IsValidVehicle(vehicleid)) return;
    if (!g_delivery_vehicle[vehicleid]) return;
    if (GetVehicleModel(vehicleid) != VEHICLE_MODEL_SUPPLY_TRUCK) return;

    DestroyVehicleLabel(vehicleid);

    if (g_delivery_load_pickup[vehicleid] != -1)
    {
        DestroyDynamicPickup(g_delivery_load_pickup[vehicleid]);
        g_delivery_load_pickup[vehicleid] = -1;
    }

    if (g_delivery_load_area[vehicleid] != -1)
    {
        DestroyDynamicArea(g_delivery_load_area[vehicleid]);
        g_delivery_load_area[vehicleid] = -1;
    }

    if (g_delivery_unload_pickup[vehicleid] != -1)
    {
        DestroyDynamicPickup(g_delivery_unload_pickup[vehicleid]);
        g_delivery_unload_pickup[vehicleid] = -1;
    }

    if (g_delivery_unload_area[vehicleid] != -1)
    {
        DestroyDynamicArea(g_delivery_unload_area[vehicleid]);
        g_delivery_unload_area[vehicleid] = -1;
    }

    g_delivery_vehicle[vehicleid] = false;
    g_delivery_boxes[vehicleid] = 0;
    g_delivery_target[vehicleid] = -1;
    g_delivery_target_name[vehicleid][0] = EOS;

}

stock DestroyDeliveryVehicle(vehicleid)
{
    AbortDeliveryByVehicle(vehicleid);
    DestroyVehicle(vehicleid);
}

stock ArmoryZagruzkaLabel()
{
    g_armory_zagruzka_label = CreateDynamic3DTextLabel(
        "", 0xFFD700FF,
        1584.39, 1636.23, 18.10, // Z + 0.5
        10.0,
        .streamdistance = 20.0
    );

    UpdateArmoryZagruzkaLabel();
}

stock UpdateArmoryZagruzkaLabel()
{
    if (g_armory_zagruzka_label == 0) return;

    new label[256], status[32];

    if (g_armory[ARMORY_TYPE_ARMOR][A_IS_OPEN])
        format(status, sizeof(status), "{00FF00}รฎรฒรชรฐรปรฒ");
    else
        format(status, sizeof(status), "{FF0000}รงร รชรฐรปรฒ");

    format(label, sizeof(label),
        "{FFFF00}<<รรฐรณรฆรฅรฉรญรปรฉ รฑรชรซร รค>>\n\n\
{FFFF00}|{FFFFFF} รร รฒรฅรฐรจร รซรฎรข: {FFFF00}%d {FFFFFF}รจรง {FFFF00}100000\n\
{FFFF00}|{FFFFFF} รรฒร รฒรณรฑ: รฑรชรซร รค %s",
        g_armory[ARMORY_TYPE_ARMOR][A_MATERIALS],
        status);

    UpdateDynamic3DTextLabelText(g_armory_zagruzka_label, 0xFFD700FF, label);
}

forward StopPlayerAnimation(playerid);
