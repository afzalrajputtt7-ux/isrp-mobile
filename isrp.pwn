CMD:cuff(playerid, params[])
{
	if(!(TEAM_DPS <= GetPlayerTeamEx(playerid) <= TEAM_FSIN)) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฏรฐร รขรฎรฎรตรฐร รญรจรฒรฅรซรผรญรปรต รฎรฐรฃร รญรฎรข");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /cuff [id รจรฃรฐรฎรชร ]");


	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(GetPlayerData(to_player, P_CUFFED)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รณรฆรฅ รงร รชรฎรขร รญ รข รญร รฐรณรทรญรจรชรจ");
	
	if(GetPlayerData(to_player, P_SUSPECT) == 0 && GetPlayerData(to_player, P_FJAIL) == 0)
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ รฏรฐรฅรฑรฒรณรฏรญรจรชรฎรฌ");

	SetPlayerSpecialAction(to_player, SPECIAL_ACTION_CUFFED);
	SetPlayerAttachedObject(to_player, A_OBJECT_SLOT_HAND, 19418, A_OBJECT_BONE_RIGHT_HAND, -0.011, 0.028, -0.022, -15.600012, -33.699977, -81.700035, 0.891999, 1.00, 1.168);
	SetPlayerData(to_player, P_CUFFED, true);
	
	TogglePlayerControllable(to_player, false);
	
	SetPVarInt(playerid, "cufferid", 1);

	new fmt_str[90];

	format(fmt_str, sizeof fmt_str, "%s %s รญร รครฅรซ รญร  %s รญร รฐรณรทรญรจรชรจ", GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
	SendMessageInLocal(playerid, fmt_str, 0xDD90FFFF, 25.0);

	return 1;
}

CMD:uncuff(playerid, params[])
{
	if((GetPlayerTeamEx(playerid) < TEAM_DPS || GetPlayerTeamEx(playerid) > TEAM_FSIN))
	return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฏรฐร รขรฎรฎรตรฐร รญรจรฒรฅรซรผรญรปรต รฎรฐรฃร รญรฎรข");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /uncuff [id รจรฃรฐรฎรชร ]");


	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player)) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(!GetPlayerData(to_player, P_CUFFED)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญรฅ รงร รชรฎรขร รญ รข รญร รฐรณรทรญรจรชรจ");

	SetPlayerSpecialAction(to_player, SPECIAL_ACTION_NONE);
	RemovePlayerAttachedObject(to_player, A_OBJECT_SLOT_HAND);
	SetPlayerData(to_player, P_CUFFED, false);
	
	TogglePlayerControllable(to_player, true);
	
	DeletePVar(playerid, "cufferid");

	new fmt_str[90];

	format(fmt_str, sizeof fmt_str, "%s %s รฑรญรฟรซ รฑ %s รญร รฐรณรทรญรจรชรจ", GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
	SendMessageInLocal(playerid, fmt_str, 0xDD90FFFF, 25.0);

	return 1;
}

CMD:putpl(playerid, params[])
{
    if(!IsPlayerInPoliceTeam(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฏรฐร รขรฎรฎรตรฐร รญรจรฒรฅรซรผรญรปรต รฎรฐรฃร รญรฎรข");
    if(!IsWorkDayStarted(playerid)) return 1;

    extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /putpl [id รจรฃรฐรฎรชร ]");

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player)) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
    if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");
    if(!GetPlayerData(to_player, P_CUFFED)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญรฅ รงร รชรฎรขร รญ รข รญร รฐรณรทรญรจรชรจ");

    new vehicle_id = GetPlayerVehicleID(playerid);
    if(!vehicle_id) return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข ร รขรฒรฎรฌรฎรกรจรซรฅ");

    new bool:is_there_some_free_places;
    for(new i = 2; i <= 3; i++) // รงร รครญรจรฅ รฌรฅรฑรฒร 
    {
        if(IsVehicleSeatOccupied(vehicle_id, i)) continue;
        PutPlayerInVehicle(to_player, vehicle_id, i);
        is_there_some_free_places = true;
        break;
    }
    if(!is_there_some_free_places) return SendClientMessage(playerid, 0x999999FF, "รร รครญรจรฅ รฌรฅรฑรฒร  รร รธรฅรฃรฎ ร รขรฒรฎรฌรฎรกรจรซรฟ รงร รญรฟรฒรป");

    // รรฑรฒร รญรฎรขรชร  รฑรซรฅรครฎรขร รญรจรฟ
    if(g_IsFollowing[to_player]) StopFollowing(to_player);

    new fmt_str[90];
    format(fmt_str, sizeof fmt_str, "%s %s รฏรฎรฑร รครจรซ %s รข รฌร รธรจรญรณ", GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
    SendMessageInLocal(playerid, fmt_str, 0xDD90FFFF, 25.0);

    return 1;
}


CMD:search(playerid, params[])
{
	if(!IsPlayerInPoliceTeam(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฏรฐร รขรฎรฎรตรฐร รญรจรฒรฅรซรผรญรปรต รฎรฐรฃร รญรฎรข");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /search [id รจรฃรฐรฎรชร ]");


	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	new fmt_text[110],
		bool: some_is_found;

	format(fmt_text, sizeof fmt_text, "%s %s รฏรฐรฎรจรงรขยธรซ รฎรกรปรฑรช รณ %s", GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
	SendMessageInLocal(playerid, fmt_text, 0xDD90FFFF, 25.0);

	if(GetPlayerData(to_player, P_DRUGS))
	{
		format(fmt_text, sizeof fmt_text, "ร %s[%d] รฎรกรญร รฐรณรฆรฅรญรฎ %d รฃ รญร รฐรชรฎรฒรจรชรฎรข", GetPlayerData(to_player, P_DRUGS));
		SendClientMessage(playerid, 0xFFFF00FF, fmt_text);

		some_is_found = true;
	}
	if(GetPlayerData(to_player, P_AMMO))
	{
		format(fmt_text, sizeof fmt_text, "ร %s[%d] รฎรกรญร รฐรณรฆรฅรญรฎ %d รฏร รฒรฐรฎรญรฎรข", GetPlayerData(to_player, P_AMMO));
		SendClientMessage(playerid, 0xFFFF00FF, fmt_text);

		some_is_found = true;
	}

	if(!some_is_found) SendClientMessage(playerid, 0xFFFF00FF, "รรจรทรฅรฃรฎ รญรฅ รญร รฉรครฅรญรฎ");

	return 1;
}

CMD:su(playerid, params[])
{
    if(!IsPlayerInPoliceTeam(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฏรฐร รขรฎรฎรตรฐร รญรจรฒรฅรซรผรญรปรต รฎรฐรฃร รญรฎรข");
    if(GetPlayerJob(playerid) < 6) return SendClientMessage(playerid, COLOR_GREY, "รรฎรฌร รญรคร  รครฎรฑรฒรณรฏรญร  รฒรฎรซรผรชรฎ รฑ 6-รฃรฎ รฐร รญรฃร .");
    if(!IsWorkDayStarted(playerid)) return 1;

    new criminalid, wanted_level;
    new message[66];
    if(sscanf(params, "dds[66]", criminalid, wanted_level, message))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /su [id] [รณรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร ] [รฏรฐรจรทรจรญร ]");

    if(!IsPlayerConnected(criminalid) || !IsPlayerLogged(criminalid) || criminalid == playerid)
        return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(!strlen(message))
        return SendClientMessage(playerid, 0x999999FF, "รรขรฅรครจรฒรฅ รฏรฐรจรทรจรญรณ");
       
    if(GetPlayerData(criminalid, P_JAIL) > 0 || GetPlayerData(criminalid, P_FJAIL) > 0)
        return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฏรฎรค รงร รชรซรพรทรฅรญรจรฅรฌ. รรปรคร รทร  รฐรฎรงรปรฑรชร  รญรฅรขรฎรงรฌรฎรฆรญร ");

    if(wanted_level < 1 || wanted_level > 6)
        return SendClientMessage(playerid, 0x999999FF, "รรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร  รครฎรซรฆรฅรญ รกรปรฒรผ รฎรฒ 1 รครฎ 6");

    new current_wanted = GetPlayerSuspect(criminalid);
    if(current_wanted >= 6)
        return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รจรฌรฅรฅรฒ รฌร รชรฑรจรฌร รซรผรญรปรฉ รณรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร ");

    new final_wanted = current_wanted + wanted_level;
    if(final_wanted > 6) final_wanted = 6;

    SetPlayerData(criminalid, P_SUSPECT, final_wanted);
    SetPlayerSuspectInit(criminalid);
    UpdatePlayerDatabaseInt(criminalid, "suspect", final_wanted);

    new fmt_text[255];
    format(fmt_text, sizeof fmt_text, "%s รฎรกรบรฟรขรจรซ รร รฑ รข รฐรฎรงรปรฑรช. รรฐรจรทรจรญร : %s. รรฅรชรณรนรจรฉ รณรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร  %d",
        GetPlayerNameEx(playerid), message, final_wanted);
    SendClientMessage(criminalid, 0x3399FFFF, fmt_text);

    format(fmt_text, sizeof fmt_text, "รรป รฎรกรบรฟรขรจรซรจ %s รข รฐรฎรงรปรฑรช. รรฐรจรทรจรญร : %s. รรฅรชรณรนรจรฉ รณรฐรฎรขรฅรญรผ รฐรฎรงรปรฑรชร  %d",
        GetPlayerNameEx(criminalid), message, final_wanted);
    SendClientMessage(playerid, 0x3399FFFF, fmt_text);

    format(fmt_text, sizeof fmt_text, "%s %s[%d] รฎรกรบรฟรขรจรซ %s[%d] รข รฐรฎรงรปรฑรช [%d/6], รฏรฐรจรทรจรญร : %s",
        GetPlayerJobAndRankName(playerid),
        GetPlayerNameEx(playerid),
        playerid,
        GetPlayerNameEx(criminalid),
        criminalid,
        final_wanted,
        message);
    SendMessageToPoliceTeam(fmt_text, COLOR_GOLD);

    AddPlayerData(playerid, P_PROGRESS_EXP_3, +, 1);
    UpdatePlayerDatabaseInt(playerid, "ProgressExp3", GetPlayerData(playerid, P_PROGRESS_EXP_3));

    if(GetPlayerData(playerid, P_PROGRESS_EXP_3) == 500)
    {
        SendClientMessage(playerid, COR_QUEST, "[รรฎรฑรฒรจรฆรฅรญรจรฟ]: "c_b"รรป รณรฑรฏรฅรธรญรฎ รขรปรฏรฎรซรญรจรซรจ รครฎรฑรฒรจรฆรฅรญรจรฅ "c_i"'รรฎรซรจรถรจรฟ ยน2'. "c_b"รร รฃรฐร รคร : "c_s"100 DONATE-RUB");
        GivePlayerDonateRub(playerid, 100, "รรปรฏรฎรซรญรฅรญรจรฅ รครฎรฑรฒรจรฆรฅรญรจรฟ / รดรฐร รชรถรจรฟ");
        SetPlayerData(playerid, P_PROGRESS_3, 1);
        UpdatePlayerDatabaseInt(playerid, "Progress3", 1);
        AddPlayerData(playerid, P_TOP_4, +, 1);
        UpdatePlayerDatabaseInt(playerid, "TOP_Progress", GetPlayerData(playerid, P_TOP_4));
    }

    return 1;
}

