							else
								SendClientMessage(playerid, 0x999999FF, "รรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รจรฃรฐรฎรชร  รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
						}
