    else
        strcat(dialogText, "รรฐร รชรถรจรฟ\t{CC6666}รรฅรครฎรฑรฒรณรฏรญรฎ\t{999999}รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฎรฐรฃร รญรจรงร รถรจรจ\n");

    if (GetPlayerHouse(playerid, HOUSE_TYPE_HOME) != -1)
        strcat(dialogText, "รรฎรฌ\t{00AA00}รรฎรฑรฒรณรฏรญรฎ\t{999999}รร รฆรฌรจรฒรฅ รครซรฟ รขรปรกรฎรฐร \n");
    else
        strcat(dialogText, "รรฎรฌ\t{CC6666}รรฅรครฎรฑรฒรณรฏรญรฎ\t{999999}ร รร รฑ รญรฅรฒ รครฎรฌร \n");

    if (GetPlayerHouse(playerid, HOUSE_TYPE_ROOM) != -1)
        strcat(dialogText, "รรฎรฑรฒรฅรขร รฟ\t{00AA00}รรฎรฑรฒรณรฏรญรฎ\t{999999}รร รฆรฌรจรฒรฅ รครซรฟ รขรปรกรฎรฐร \n");
    else
        strcat(dialogText, "รรฎรฑรฒรฅรขร รฟ\t{CC6666}รรฅรครฎรฑรฒรณรฏรญรฎ\t{999999}รรป รญรฅ รฏรฐรฎรฆรจรขร รฅรฒรฅ รณ รชรฎรฃรฎ-รซรจรกรฎ\n");

    new fam_id = GetPlayerIdFamily(playerid);
