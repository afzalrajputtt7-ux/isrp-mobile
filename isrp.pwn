CMD:mr(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_FSIN)
		return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฒรฐรณรครญรจรช รรรร");

	if(GetPlayerJob(playerid) < 5)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร !");
		
	if(gettime() - g_last_mr[playerid] < 600)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรครฎรฆรครจรฒรฅ, รขรปรฃรฎรขรฎรฐร  รฌรฎรฆรญรฎ รขรปรคร รขร รฒรผ รฒรฎรซรผรชรฎ รฐร รง รข 10 รฌรจรญรณรฒ. ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	new targetid, reason[64];
	if(sscanf(params, "us[64]", targetid, reason))
		return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /mr [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");


	if(!IsPlayerConnected(targetid) || !IsPlayerLogged(targetid))
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ รญร รฉรครฅรญ");

	if(GetPlayerData(targetid, P_FJAIL) <= 0)
		return SendClientMessage(playerid, COLOR_GREY, "รรปรฃรฎรขรฎรฐ รฌรฎรฆรญรฎ รขรปรคร รขร รฒรผ รฒรฎรซรผรชรฎ รงร รชรซรพรทยธรญรญรปรฌ รรรร.");

	if(GetPlayerData(targetid, P_MR) >= 3)
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รณรฆรฅ รจรฌรฅรฅรฒ รฌร รชรฑรจรฌร รซรผรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รขรปรฃรฎรขรฎรฐรฎรข.");

	SetPlayerData(targetid, P_MR, GetPlayerData(targetid, P_MR) + 1);
	UpdatePlayerDatabaseInt(targetid, "mr", GetPlayerData(targetid, P_MR));
	
	AddPlayerData(targetid, P_FJAIL, +, 300);
	UpdatePlayerDatabaseInt(targetid, "fjail", GetPlayerData(targetid, P_FJAIL));

	new msg[144];
	format(msg, sizeof msg, "รรฎรฒรฐรณรครญรจรช รรรร %s[%d] รขรปรคร รซ รขร รฌ รขรปรฃรฎรขรฎรฐ รฏรฎ รฏรฐรจรทรจรญรฅ: %s. รรฅรชรณรนรฅรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รขรปรฃรฎรขรฎรฐรฎรข: %d/3.", GetPlayerNameEx(playerid), playerid, reason, GetPlayerData(targetid, P_MR));
	SendClientMessage(targetid, COLOR_BLUE, msg);

	new fmt_msg[144];
	format(fmt_msg, sizeof fmt_msg, "[R] %s %s[%d] รขรปรคร รซ รขรปรฃรฎรขรฎรฐ รงร รชรซรพรทรฅรญรญรฎรฌรณ %s[%d] รฏรฎ รฏรฐรจรทรจรญรฅ: %s",
		GetPlayerJobAndRankName(playerid),
		GetPlayerNameEx(playerid),
		playerid,
		GetPlayerNameEx(targetid),
		targetid,
		reason);
		
	
	SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, COLOR_RADIO);
		
	if(GetPlayerData(targetid, P_MR) == 3)
{
	SetPlayerData(targetid, P_KARCER, 1);
	UpdatePlayerDatabaseInt(targetid, "karcer", 1);

	new pos = random(sizeof g_karcer_positions);
	new world = 98 + pos;

	SetPlayerVirtualWorld(targetid, world);
	SetPlayerPosEx(targetid,
		g_karcer_positions[pos][0],
		g_karcer_positions[pos][1],
		g_karcer_positions[pos][2],
		1,
		g_karcer_positions[pos][4]);

	SetPlayerFacingAngle(targetid, g_karcer_positions[pos][3]);
	SetPlayerInterior(targetid, 1);
	SetPlayerSkin(targetid, FSIN_SKIN_ID);

	SendClientMessage(targetid, COLOR_BLUE, "รรป รกรปรซรจ ร รขรฒรฎรฌร รฒรจรทรฅรฑรชรจ รฏรฅรฐรฅรญรฅรฑรฅรญรป รข รชร รฐรถรฅรฐ รครฎ รชรฎรญรถร  รฑรฐรฎรชร , รฒร รช รชร รช รณ รขร รฑ 3/3 รขรปรฃรฎรขรฎรฐรฎรข.");

	new name[MAX_PLAYER_NAME];
	GetPlayerName(targetid, name, sizeof name);

	new msg[128];
	format(msg, sizeof msg, "[R] รร รชรซรพรทยธรญรญรปรฉ %s[%d] รกรปรซ ร รขรฒรฎรฌร รฒรจรทรฅรฑรชรจ รฏรฎรฌรฅรนยธรญ รข รชร รฐรถรฅรฐ รจรง-รงร  3/3 รขรปรฃรฎรขรฎรฐรฎรข.", name, targetid);
	SendMessageToTeam(GetPlayerTeamEx(playerid), msg, COLOR_RADIO);
}
	
	g_last_mr[playerid] = gettime();
	return 1;
}

