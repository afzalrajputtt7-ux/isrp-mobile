	SendMessageToAdmins(fmt_text, 0x999999FF);
	
	format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รณรฑรฏรฅรธรญรฎ รณรฑรฒร รญรฎรขรจรซรจ รฏรฎรฃรฎรครณ รญร  รฑรฅรฐรขรฅรฐรฅ รญร  %d", weather);
	SendClientMessage(playerid, -1, fmt_text);

	return 1;
}

