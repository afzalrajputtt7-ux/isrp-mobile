        SetVehicleData(GetFamilyCarData(idx, F_CAR_ID), V_FUEL, 50.0);
    }
    format
    (
        query, sizeof query,
        "INSERT INTO family_cars \
        (owner_id,model_id,color_1,color_2,pos_x,pos_y,pos_z,angle,create_time) \
