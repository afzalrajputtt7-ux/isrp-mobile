CMD:lic(playerid, params[])
{
	if(!strlen(params))
		return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /lic [id รจรฃรฐรฎรชร ]");

	extract params -> new to_player;

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ ร รขรฒรฎรฐรจรงรฎรขร รญ.");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0))
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ.");

	SendClientMessage(playerid, COLOR_BLUE, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ รฏรฎรชร รงร รฒรผ รฑรขรฎรจ รซรจรถรฅรญรงรจรจ.");
	SendPlayerOffer(playerid, to_player, OFFER_TYPE_SHOWLIC);
	return 1;
}


CMD:pass(playerid, params[])
{
    extract params -> new to_player; else return SCM(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /pass [id รจรฃรฐรฎรชร ]");
    if (!IsPlayerConnected(to_player))
        return SCM(playerid, COLOR_GREY, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if (!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0))
        return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

    SendPlayerOffer(playerid, to_player, OFFER_TYPE_SHOWPASS);
    SCM(playerid, COLOR_BLUE, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ รฏรฎรชร รงร รฒรผ รฏร รฑรฏรฎรฐรฒ.");
    return 1;
}

CMD:restart(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 6) return 1;

	server_restart = true;

	return GameModeExit();
}

