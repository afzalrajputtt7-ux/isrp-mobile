	SetPlayerData(playerid, P_LAST_MP, 1);

	return 1;
}

CMD:namelist(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) >= 4)
	{
		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉ: /namelist [id รจรฃรฐรฎรชร ]");

		extract params -> new to_player;

		if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
			return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

		if(!GetPVarInt(to_player, "change_name_status"))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญรฅ รฏรฎรคร รขร รซ รงร รฏรฐรฎรฑ รญร  รฑรฌรฅรญรณ รญรจรชร ");

		new player_name[20 + 1];
		GetPVarString(to_player, "change_name", player_name, sizeof(player_name));

		if(ChangePlayerName(to_player, player_name, true))
		{
			Dialog
			(
				to_player, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX,
				"{FFCD00}รรฌรฟ รจรงรฌรฅรญรฅรญรฎ",
				"{66FF00}รร รฟรขรชร  รญร  รจรงรฌรฅรญรฅรญรจรฅ รจรฌรฅรญรจ รฎรครฎรกรฐรฅรญร , รญรฎรขรฎรฅ รจรฌรฟ รณรฑรฒร รญรฎรขรซรฅรญรฎ.\n\n"\
				"{FFFFFF}ร รฑรซรฅรครณรพรนรจรฉ รฐร รง รฏรฐรจ รขรตรฎรครฅ รข รจรฃรฐรณ รจรฑรฏรฎรซรผรงรณรฉรฒรฅ รฑรขรฎรฅ รญรฎรขรฎรฅ รจรฌรฟ. รรซรฟ\n"\
				"รฝรฒรฎรฃรฎ รญรณรฆรญรฎ รจรงรฌรฅรญรจรฒรผ รฅรฃรฎ รข รฎรชรญรฅ รชรซรจรฅรญรฒร  CRMP. รรฅรชรฎรฌรฅรญรครณรฅรฌ รฏรฐรฟรฌรฎ\n"\
				"รฑรฅรฉรทร รฑ รฑรขรฅรฐรญรณรฒรผ รจรฃรฐรณ รจ รฑรครฅรซร รฒรผ รฝรฒรฎ.",
				"รรช", ""
			);
		}
		else SendClientMessage(playerid, 0xFF6600FF, "รรฐรจ รฑรฌรฅรญรฅ รญรจรชร  รฏรฐรฎรจรงรฎรธรซร  รฎรธรจรกรชร ");

		new fmt_text[75];

		format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฎรครฎรกรฐรจรซ รงร รฟรขรชรณ รญร  รฑรฌรฅรญรณ รญรจรชรญรฅรฉรฌร ", GetPlayerNameEx(playerid), playerid);
		SendMessageToAdmins(fmt_text, 0x999999FF);

		DeletePVar(to_player, "change_name");
		DeletePVar(to_player, "change_name_status");

		format(fmt_text, sizeof fmt_text, "รรครฎรกรฐรจรซ รงร รฟรขรชรณ รฑรฌรฅรญรป รญรจรชรญรฅรฉรฌร  รครซรฟ %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
		SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);
	}

	return 1;
}

CMD:cc(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 4) return 1;

	for(new i = 0; i < 20; i++)
	{
		SendClientMessageToAll(-1, "");
	}
	SendClientMessageToAll(0xFFCD00FF, "รร รฒ รกรปรซ รฎรทรจรนรฅรญ ร รครฌรจรญรจรฑรฒรฐร รถรจรฅรฉ");

	new fmt_text[65];
	format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฎรทรจรฑรฒรจรซ รทร รฒ", GetPlayerNameEx(playerid), playerid);
	SendMessageToAdmins(fmt_text, 0x999999FF);

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, "รรทรจรฑรฒรจรซ รทร รฒ");

	return 1;
}

CMD:leave(playerid, params[])
{
	if(GetPlayerData(playerid, P_IMPROVEMENTS) < 2) return SendClientMessage(playerid, 0x999999FF, "รรฐรจรฎรกรฐรฅรฒรจรฒรฅ รณรซรณรทรธรฅรญรจรฅ \"รรฅรธรจรฒรฅรซรผรญรฎรฑรฒรผ\", รทรฒรฎรกรป รณรขรฎรซรจรฒรผรฑรฟ รฏรฎ รฑรฎรกรฑรฒรขรฅรญรญรฎรฌรณ รฆรฅรซร รญรจรพ");

	if(!GetPlayerTeamEx(playerid)) return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฎรฐรฃร รญรจรงร รถรจรจ! ");

	new fmt_text[999];

	format
	(
		fmt_text, sizeof fmt_text,
		""SC"รร รธร  รฎรฐรฃร รญรจรงร รถรจรฟ{ffff00}: \"%s\".\n\n"\
		"{ffffff}รรป รครฅรฉรฑรฒรขรจรฒรฅรซรผรญรฎ รตรฎรฒรจรฒรฅ รฏรฎรชรจรญรณรฒรผ รคร รญรญรณรพ รฎรฐรฃร รญรจรงร รถรจรพ รฏรฎ\n"\
		"{ffffff}รฑรฎรกรฑรฒรขรฅรญรญรฎรฌรณ รฆรฅรซร รญรจรพ?",
		GetTeamName(GetPlayerTeamEx(playerid))
	);

	Dialog(playerid, DIALOG_TEAM_LEAVE, DIALOG_STYLE_MSGBOX, "{FF6347}"SERVER_NAME" {ffffff}| รรฎรครฒรขรฅรฐรฆรครฅรญรจรฅ", fmt_text, "รร รซรฅรฅ", "รรฒรฌรฅรญร ");

	return 1;
}

CMD:awarn(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 5) return 1;
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /awarn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, string:reason[66];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!GetPlayerAdminEx(to_player))
	    return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ");

	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	AddPlayerData(to_player, P_ADMIN_WARN, +, 1);

	new fmt_msg[144];
	format(fmt_msg, sizeof fmt_msg, "[A] %s รขรปรคร รซ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฅ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรณ %s [%d|3]. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), GetPlayerData(to_player, P_ADMIN_WARN), reason);

	SendMessageToAdmins(fmt_msg, 0xFF5533FF);

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_ADMIN_WARN);

	format(fmt_msg, sizeof fmt_msg, "รรปรคร รซ ร รขร รฐรญ %s[acc:%d] (%d/3). รรฐรจรทรจรญร : %d", GetPlayerNameEx(to_player), uid, warns, reason);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	if(warns >= 3)
	{
		SendClientMessage(to_player, 0xFF5533FF, "รร รธ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฑรชรจรฉ รณรฐรฎรขรฅรญรผ ร รญรญรณรซรจรฐรฎรขร รญ");

		warns = 0;

		SetPlayerData(to_player, P_ADMIN, 0);
		UpdatePlayerDatabaseInt(to_player, "admin", 0);
	}
	else SendClientMessage(to_player, 0xFF5533FF, "รรฐรจ รฏรฎรซรณรทรฅรญรจรจ 3-ยธรต รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฉ รรป รกรณรครฅรฒรฅ รฑรญรฟรฒรป รฑ รฏรฎรฑรฒร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร ");

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET admin_warn=%d WHERE id=%d", warns, uid);
	mysql_query(mysql, fmt_msg, false);

	return 1;
}
CMD:unawarn(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 5) return 1;
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /unawarn [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");

	extract params -> new to_player, string: reason[66];
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(!GetPlayerAdminEx(to_player))
	    return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ");

	SetPlayerData(to_player, P_ADMIN_WARN, 				0);

	UpdatePlayerDatabaseInt(to_player, "admin_warn", 	0);

	
	new fmt_msg[144];
	format(fmt_msg, sizeof fmt_msg, "[A] %s รฑรญรฟรซ รขรฑรฅ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฟ รฑ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player),reason);

	SendMessageToAdmins(fmt_msg, 0xFF5533FF);

	format(fmt_msg, sizeof fmt_msg, "รรญรฟรซ รขรฑรฅ ร รขร รฐรญรป %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

