				BlackJackLobby[lobby][StartedLobby] = true; BlackJackLobby[lobby][StageLobby] = 1; SCMBJL(lobby, CLRED, "รรรร รรรรรรรร...");

				printf("รรฒรฎรซ 1: %d", BlackJackLobby[lobby][Table1Id]);
				printf("รรฒรฎรซ 2: %d", BlackJackLobby[lobby][Table2Id]);
