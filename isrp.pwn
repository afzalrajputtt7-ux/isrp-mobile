		         new query[200], rows,
			    Cache: result;
			
			    mysql_format(mysql, query, sizeof(query), "SELECT * FROM whitelist WHERE name='%e'", GetPlayerNameEx(i));
			    result = mysql_query(mysql, query, true);
			
			    rows = bool: cache_num_rows();
			    cache_delete(result);
			
			    if (rows) {
			        SCM(i, -1, "รร รธ ร รชรชร รณรญรฒ รกรปรซ รญร รฉรครฅรญ รข รขร รฉรฒ-รซรจรฑรฒรฅ. รรฎรฑรฒรณรฏ รช รฑรฅรฐรขรฅรฐรณ รฎรฒรชรฐรปรฒ"); 
			    } else {
			        ShowPlayerDialog(i, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "รร รฉรฒ-รซรจรฑรฒ", "รร รธ รญรจรช รญรฅ รญร รฉรครฅรญ รข รขร รฉรฒ-รซรจรฑรฒรฅ. รรป รกรปรซรจ รชรจรชรญรณรฒรป รฑ รฑรฅรฐรขรฅรฐร ", "รรช");
