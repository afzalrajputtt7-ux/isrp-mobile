CMD:askin(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1)
        return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    if(!strcmp(params, "1", true))
    {
        SetPlayerSkin(playerid, 122); // รฌรณรฆรฑรชรฎรฉ รฑรชรจรญ
        SendClientMessage(playerid, 0x00FF00FF, ""SC"รรป รณรฑรฏรฅรธรญรฎ {FFFF00}รญร รครฅรซรจ {FFFFFF}รฌรณรฆรฑรชรฎรฉ {FFFF00}รฑรชรจรญ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร .");
        return 1;
    }
    else if(!strcmp(params, "2", true))
    {
        SetPlayerSkin(playerid, 11943); // รฆรฅรญรฑรชรจรฉ รฑรชรจรญ
        SendClientMessage(playerid, 0x00FF00FF, ""SC"รรป รณรฑรฏรฅรธรญรฎ {FFFF00}รญร รครฅรซรจ {FFFFFF}รฑรชรจรญ {FFFF00}ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร .");
        return 1;
    }
    else if(!strcmp(params, "3", true))
    {
        SetPlayerSkin(playerid, GetPlayerSkinEx(playerid)); // รขรฎรงรขรฐร รฒ รฏรฐรฅรฆรญรฅรฃรฎ รฑรชรจรญร 
        SendClientMessage(playerid, 0x00FF00FF, ""SC"รรป รณรฑรฏรฅรธรญรฎ {FFFF00}รญร รครฅรซรจ {FFFFFF}รฑรชรจรญ {FFFF00}ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร .");
        return 1;
    }
    else
    {
        SendClientMessage(playerid, COLOR_RED, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /askin [1 - รฌรณรฆรฑรชรฎรฉ, 2 - รฆรฅรญรฑรชรจรฉ, 3 - รฑรญรฟรฒรผ]");
        return 1;
    }
}

