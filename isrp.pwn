CMD:time(playerid, params[])
{
    new
		hour, minute, second,
		year, month, day;
		
    gettime(hour, minute, second);
	getdate(year, month, day);

	//new fmt_str[999];
	
    //format(fmt_str, sizeof fmt_str, "~y~%d:%02d:%02d~n~~b~~h~%02d.%02d.%d", hour, minute, second, day, month, year);
	//GameTextForPlayer(playerid, fmt_str, 3000, 1);

	new fmt_msg[999];
	if(GetPlayerData(playerid, P_WARN_TIME) > 0)
	{
		format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฟ รครฎ รฑรญรฟรฒรจรฟ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฟ: %d รครญรฅรฉ", ((GetPlayerData(playerid, P_WARN_TIME) - gettime()) / 86400) + 1);
		SendClientMessage(playerid, 0x66CC00FF, fmt_msg);
	}
    if(GetPlayerData(playerid, P_FMUTE) > 0)
	{
		format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ รฑรฅรฌรฅรฉรญรฎรฃรฎ รทร รฒร : %d:%02d", floatround(GetPlayerData(playerid, P_FMUTE) / 60) /* % 60 */, (GetPlayerData(playerid, P_FMUTE) % 60));
		SendClientMessage(playerid, 0x32a44bFF, fmt_msg);
	}
	if(GetPlayerData(playerid, P_MUTE) > 0)
	{
		format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ รทร รฒร : %d:%02d", floatround(GetPlayerData(playerid, P_MUTE) / 60) /* % 60 */, (GetPlayerData(playerid, P_MUTE) % 60));
		SendClientMessage(playerid, 0x66CC00FF, fmt_msg);
	}

	if(GetPlayerData(playerid, P_JAIL) > 0)
	{
		format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฟ รครฎ รชรฎรญรถร  รงร รชรซรพรทรฅรญรจรฟ: %d:%02d", floatround(GetPlayerData(playerid, P_JAIL) / 60) /* % 60 */, (GetPlayerData(playerid, P_JAIL) % 60));
		SendClientMessage(playerid, 0x66CC00FF, fmt_msg);
	}
	
	if(GetPlayerData(playerid, P_FJAIL) > 0)
	{
		format(fmt_msg, sizeof fmt_msg, "รรฐรฅรฌรฟ รครฎ รชรฎรญรถร  รงร รชรซรพรทรฅรญรจรฟ: %d:%02d", floatround(GetPlayerData(playerid, P_FJAIL) / 60) /* % 60 */, (GetPlayerData(playerid, P_FJAIL) % 60));
		SendClientMessage(playerid, 0x66CC00FF, fmt_msg);
	}
	
	ShowTime(playerid);
	ShowCurrentTime(playerid);

	return 1;
}

CMD:id(playerid, params[])
{
	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /id [รจรฌรฟ รจรซรจ รทร รฑรฒรผ รจรฌรฅรญรจ รจรฃรฐรฎรชร ]");

	new fmt_str[64];
	new count;

	foreach(new idx : Player)
	{
		if(!IsPlayerLogged(idx)) continue;

		if(strfind(GetPlayerNameEx(idx), params, true) != -1)
		{
			count ++;

			format(fmt_str, sizeof fmt_str, "%d. %s {66CC66}id %d", count, GetPlayerNameEx(idx), idx);
			SendClientMessage(playerid, 0xFFFFFFFF, fmt_str);

			if(count >= 5)
			{
				SendClientMessage(playerid, 0x999999FF, "รรฎรชร รงร รญรป รฏรฅรฐรขรปรฅ 5 รฑรฎรขรฏร รครฅรญรจรฉ");
				break;
			}
		}
	}
	if(!count)
		SendClientMessage(playerid, 0x999999FF, "รรฎรขรฏร รครฅรญรจรฉ รญรฅ รญร รฉรครฅรญรฎ");

	return 1;
}

CMD:buyf(playerid, params[])
{
	new factory_fuels = GetRepositoryData(REPOSITORY_TYPE_OIL_FACTORY, REPOSITORY_ACTION_OIL_FACTORY_F, R_AMOUNT);

	if(!IsPlayerInAnyVehicle(playerid))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รญร  รญรฅรดรฒรฅรงร รขรฎรครฅ รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	new modelid;
	new vehicleid = GetPlayerJobCar(playerid);

	if(vehicleid != INVALID_VEHICLE_ID)
		modelid = GetVehicleData(vehicleid, V_MODELID);

	if(IsPlayerInRangeOfPoint(playerid, 20.0, 2710.3369,-2383.5164,17.9063))  // รครซรฟ รงร รขรฎรคร 
	{
		if(GetPlayerTempJob(playerid) != TEMP_JOB_FACTORY_TRUCKER || modelid != 514)
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฐร รกรฎรฒร รฅรฒรฅ รข รฎรฒรครฅรซรฅ รครฎรฑรฒร รขรชรจ รงร รขรฎรคร  รจรซรจ รงร รญรฟรซรจ รญรฅ รฒรณ รซรจรญรจรพ");
	}
	else if(IsPlayerInRangeOfPoint(playerid, 20.0, 2738.3379,-2273.0725,17.9063))  // รครซรฟ ร รงรฑ
	{
		if(GetPlayerJob(playerid) != JOB_TRUCKER || modelid != 514)
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฐร รกรฎรฒร รฅรฒรฅ รฐร รงรขรฎรงรทรจรชรฎรฌ รฒรฎรฏรซรจรขร  รจรซรจ รงร รญรฟรซรจ รญรฅ รฒรณ รซรจรญรจรพ");
	}
	else
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รญร  รญรฅรดรฒรฅรงร รขรฎรครฅ");

	new total_litres = GetPlayerJobLoadItems(playerid);

	if(!IsPlayerInVehicle(playerid, vehicleid))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รญร  รญรฅรดรฒรฅรงร รขรฎรครฅ รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	if(!strlen(params))
		return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /buyf [รชรฎรซ-รขรฎ รข รซรจรฒรฐร รต]");

	if(!IsTrailerAttachedToVehicle(vehicleid))
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รธรฅรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  รฎรฒรฑรณรฒรฑรฒรขรณรฅรฒ รถรจรฑรฒรฅรฐรญร  รครซรฟ รฒรฎรฏรซรจรขร ");

	extract params -> new load_fuel;

	if(!(1 <= load_fuel <= 8000))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรฆรญรฎ รงร รฃรฐรณรงรจรฒรผ รฎรฒ 1 รครฎ 8000 รซ รฒรฎรฏรซรจรขร ");

	if(factory_fuels < load_fuel)
		return SendClientMessage(playerid, 0x999999FF, "รร  รญรฅรดรฒรฅรงร รขรฎรครฅ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฒรฎรฏรซรจรขร ");

	if((total_litres + load_fuel) > 8000)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รถรจรฑรฒรฅรฐรญรณ รฑรฒรฎรซรผรชรฎ รญรฅ รฏรฎรฌรฅรฑรฒรจรฒรฑรฟ");

	if(GetPlayerMoneyEx(playerid) < (load_fuel * 10))
		return SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ รครซรฟ รฏรฎรชรณรฏรชรจ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฒรฎรฏรซรจรขร ");

	GivePlayerMoneyEx(playerid, -(load_fuel * 10), "รรฎรชรณรฏรชร  รฒรฎรฏรซรจรขร  (รญรฅรดรฒรฅรงร รขรฎรค)", true, false);

	SetRepositoryData(REPOSITORY_TYPE_OIL_FACTORY, REPOSITORY_ACTION_OIL_FACTORY_F, R_AMOUNT, factory_fuels - load_fuel);
	UpdateRepository(REPOSITORY_TYPE_OIL_FACTORY, REPOSITORY_ACTION_OIL_FACTORY_F);

	SetPlayerJobLoadItems(playerid, total_litres + load_fuel);

	new fmt_str[64];

	format(fmt_str, sizeof fmt_str, "รรป รงร รฃรฐรณรงรจรซรจ %d รซ รฒรฎรฏรซรจรขร  รฎรกรนรฅรฉ รฑรฒรฎรจรฌรฎรฑรฒรผรพ %d รฐรณรก", load_fuel, load_fuel * 10);
	SendClientMessage(playerid, 0xFFFF00FF, fmt_str);

	format(fmt_str, sizeof fmt_str, "~g~+ %d litres~n~~b~total %d litres", load_fuel, total_litres + load_fuel);
	GameTextForPlayer(playerid, fmt_str, 2000, 6);

	format(fmt_str, sizeof fmt_str, "รรฎรฑรฒร รขรชร  รฒรฎรฏรซรจรขร \n{FFFFFF}รร รฃรฐรณรงรชร  %d / 8000 รซ", total_litres + load_fuel);
	UpdateVehicleLabel(vehicleid, 0xFF6600FF, fmt_str);

	return 1;
}

CMD:sellf(playerid, params[])
{
	new modelid;
	new vehicleid = GetPlayerJobCar(playerid);

	if(vehicleid != INVALID_VEHICLE_ID)
		modelid = GetVehicleData(vehicleid, V_MODELID);

	if(GetPlayerTempJob(playerid) != TEMP_JOB_FACTORY_TRUCKER || modelid != 514)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฐร รกรฎรฒร รฅรฒรฅ รข รฑรซรณรฆรกรฅ รครฎรฑรฒร รขรชรจ รงร รขรฎรคร ");

	if(!IsPlayerInRangeOfPoint(playerid, 10.0, -1120.4103,2175.6133,38.0294))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รฒรฎรฏรซรจรขร  รงร รขรฎรคร ");

	new total_litres = GetPlayerJobLoadItems(playerid);

	new factory_fuels = GetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_FUEL, R_AMOUNT);

	if(!strlen(params))
		return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellf [รชรฎรซ-รขรฎ รข รซรจรฒรฐร รต]");

	extract params -> new sell_fuels;

	if(!(1 <= sell_fuels <= 8000))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรฆรญรฎ รฏรฐรฎรคร รฒรผ รฎรฒ 1 รครฎ 8000 รซ รฒรฎรฏรซรจรขร ");

	if(vehicleid == INVALID_VEHICLE_ID || !IsTrailerAttachedToVehicle(vehicleid) || total_litres < sell_fuels)
		return SendClientMessage(playerid, 0x999999FF, "ร รร รธรฅรฉ รดรณรฐรฅ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฒรฎรฏรซรจรขร  รจรซรจ รถรจรฑรฒรฅรฐรญร  รญรฅ รฏรฐรจรถรฅรฏรซรฅรญร ");

	if((factory_fuels + sell_fuels) > 1000000)
		return SendClientMessage(playerid, 0x999999FF, "รรชรซร รค รฒรฎรฏรซรจรขร  รงร รขรฎรคร  รงร รฏรฎรซรญรฅรญ");

	GivePlayerMoneyEx(playerid, (sell_fuels * 12), "รรฐรฎรคร รฆร  รฒรฎรฏรซรจรขร  (รงร รขรฎรค)", true, true);

	SetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_FUEL, R_AMOUNT, factory_fuels + sell_fuels);
	UpdateRepository(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_FUEL);

	SetPlayerJobLoadItems(playerid, total_litres - sell_fuels);
	AddPlayerData(playerid, P_JOB_WAGE, +, sell_fuels * 2);

	new fmt_str[64];

	format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฎรคร รซรจ รงร รขรฎรครณ %d รซ รฒรฎรฏรซรจรขร  รญร  รฑรณรฌรฌรณ %d รฐรณรก", sell_fuels, sell_fuels * 12);
	SendClientMessage(playerid, 0x66CC00FF, fmt_str);

	format(fmt_str, sizeof fmt_str, "รร รธร  รทรจรฑรฒร รฟ รขรปรฐรณรทรชร  รฑรฎรฑรฒร รขรซรฟรฅรฒ {FF9900}%d รฐรณรก", sell_fuels * 2);
	SendClientMessage(playerid, 0x66CC00FF, fmt_str);

	format(fmt_str, sizeof fmt_str, "รรฎรฑรฒร รขรชร  รฒรฎรฏรซรจรขร \n{FFFFFF}รร รฃรฐรณรงรชร  %d / 8000 รซ", total_litres - sell_fuels);
	UpdateVehicleLabel(vehicleid, 0xFF6600FF, fmt_str);

	return 1;
}

CMD:buyprod(playerid, params[])
{
	if(!(GetPlayerJob(playerid) == JOB_TRUCKER && IsPlayerInJob(playerid)))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รฐร รกรฎรฒร รฒรผ รคร รซรผรญรฎรกรฎรฉรนรจรชรฎรฌ");

	extract params -> new buy_prod_count; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /buyprod [รชรฎรซ-รขรฎ]. รรฒรฎรจรฌรฎรฑรฒรผ 1 รฏรฐรฎรครณรชรฒร  24 รฐรณรก.");

	if(!IsPlayerInRangeOfPoint(playerid, 20.0, -1046.5460,2203.9644,38.2055))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รจรฑรตรฎรครญรปรต รฌร รฒรฅรฐรจร รซรฎรข รงร รขรฎรคร ");

	else if(!IsPlayerInVehicle(playerid, GetPlayerJobCar(playerid)))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รจรฑรตรฎรครญรปรต รฌร รฒรฅรฐรจร รซรฎรข รงร รขรฎรคร  รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	else if(!(1 <= buy_prod_count <= 10000))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรฆรญรฎ รงร รฃรฐรณรงรจรฒรผ รฎรฒ 1 รครฎ 10000 รธรฒ. รฏรฐรฎรครณรชรฒรฎรข");

	else if(GetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_PROD, R_AMOUNT) < buy_prod_count)
		return SendClientMessage(playerid, 0x999999FF, "รร  รฑรชรซร รครฅ รจรฑรตรฎรครญรปรต รฌร รฒรฅรฐรจร รซรฎรข รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฏรฐรฎรครณรชรฒรฎรข");

	else if((buy_prod_count + GetPlayerJobLoadItems(playerid)) > 10000)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รดรณรฐรฃรฎรญ รฑรฒรฎรซรผรชรฎ รญรฅ รฏรฎรฌรฅรฑรฒรจรฒรฑรฟ, รฌร รชรฑรจรฌรณรฌ 10000 รธรฒ.");

	if(GetPlayerMoneyEx(playerid) < (buy_prod_count * 24))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ รครซรฟ รฏรฎรชรณรฏรชรจ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฏรฐรฎรครณรชรฒรฎรข");

	GivePlayerMoneyEx(playerid, -(buy_prod_count * 24), "รรฎรชรณรฏรชร  รฏรฐรฎรครณรชรฒรฎรข (รฐร รงรข. รฏรฐรฎรครณรชรฒรฎรข)", true, true);

	SetPlayerJobLoadItems(playerid, GetPlayerJobLoadItems(playerid) + buy_prod_count);

	SetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_PROD, R_AMOUNT, GetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_PROD, R_AMOUNT) - buy_prod_count);
	UpdateRepository(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_PROD);

	new fmt_msg[64];

	format(fmt_msg, sizeof fmt_msg, "รรป รชรณรฏรจรซรจ %d รฏรฐรฎรครณรชรฒรฎรข รญร  รฑรณรฌรฌรณ %d รฐรณรก.", buy_prod_count, buy_prod_count * 24);
	SendClientMessage(playerid, 0x66CC00FF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรฅรชรณรนรฅรฅ รชรฎรซ-รขรฎ รงร รฃรฐรณรฆรฅรญรญรปรต รฏรฐรฎรครณรชรฒรฎรข: %d รจรง 10000", GetPlayerJobLoadItems(playerid));
	SendClientMessage(playerid, 0xFFFF00FF, fmt_msg);

	return 1;
}

CMD:buym(playerid, params[])
{
	new modelid;
	new vehicleid = GetPlayerJobCar(playerid);

	if(vehicleid != INVALID_VEHICLE_ID)
		modelid = GetVehicleData(vehicleid, V_MODELID);

	if(GetPlayerTempJob(playerid) != TEMP_JOB_FACTORY_TRUCKER || modelid != 406)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฐร รกรฎรฒรญรจรช รฑรซรณรฆรกรป รครฎรฑรฒร รขรชรจ รงร รขรฎรคร ");

	if(!strlen(params))
		return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /buym [รชรฎรซ-รขรฎ รข รชรฃ]");

	extract params -> new buy_metal_count;

	new metall_loaded_count = GetPlayerJobLoadItems(playerid);
	new miner_metal = GetRepositoryData(REPOSITORY_TYPE_MINER, REPOSITORY_ACTION_MINER_METAL, R_AMOUNT);

	if(!IsPlayerInRangeOfPoint(playerid, 15.0, 2424.5317,1765.6780,-0.2507) || !IsPlayerInVehicle(playerid, vehicleid))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รธร รตรฒรป รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	if(!(1 <= buy_metal_count <= 500))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรฆรญรฎ รงร รฃรฐรณรงรจรฒรผ รฎรฒ 1 รครฎ 500 รชรฃ รร รฒรฅรฐรจร รซรปร ");

	if(miner_metal < buy_metal_count)
		return SendClientMessage(playerid, 0x999999FF, "รร  รฑรชรซร รครฅ รธร รตรฒรป รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

	if((metall_loaded_count + buy_metal_count) > 500)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รดรณรฐรฃรฎรญ รฑรฒรฎรซรผรชรฎ รญรฅ รฏรฎรฌรฅรฑรฒรจรฒรฑรฟ");

	if(GetPlayerMoneyEx(playerid) < (buy_metal_count * 15))
		return SendClientMessage(playerid, 0x999999FF, "รรฅรครฎรฑรฒร รฒรฎรทรญรฎ รครฅรญรฅรฃ รครซรฟ รฏรฎรชรณรฏรชรจ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

	GivePlayerMoneyEx(playerid, -(buy_metal_count * 15), "รรฎรชรณรฏรชร  รร รฒรฅรฐรจร รซรปร  (รฐร รงรขรฎรงรทรจรช)", true, true);

	SetRepositoryData(REPOSITORY_TYPE_MINER, REPOSITORY_ACTION_MINER_METAL, R_AMOUNT, miner_metal - buy_metal_count);
	UpdateRepository(REPOSITORY_TYPE_MINER, REPOSITORY_ACTION_MINER_METAL);

	SetPlayerJobLoadItems(playerid, metall_loaded_count + buy_metal_count);

	new fmt_str[64];

	format(fmt_str, sizeof fmt_str, "รรป รงร รฃรฐรณรงรจรซรจ %d รชรฃ รร รฒรฅรฐรจร รซรปร  รฎรกรนรฅรฉ รฑรฒรฎรจรฌรฎรฑรฒรผรพ %d รฐรณรก", buy_metal_count, buy_metal_count * 15);
	SendClientMessage(playerid, 0xFFFF00FF, fmt_str);

	format(fmt_str, sizeof fmt_str, "รรฎรฑรฒร รขรชร  รร รฒรฅรฐรจร รซรปร \n{FFFFFF}รร รฃรฐรณรงรชร  %d / 500 รชรฃ", metall_loaded_count + buy_metal_count);
	UpdateVehicleLabel(vehicleid, 0x3399FFFF, fmt_str);

	return 1;
}

CMD:sellm(playerid, params[])
{
	if(!strlen(params))
		return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellm [รชรฎรซ-รขรฎ รข รชรฃ]");

	extract params -> new sell_metal_count;

	if(!IsPlayerInRangeOfPoint(playerid, 20.0, -1043.8157,2205.5217,38.1195))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รร รฒรฅรฐรจร รซรปร  รงร รขรฎรคร ");

	if(!(1 <= sell_metal_count <= 500))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรฆรญรฎ รฏรฐรฎรคร รฒรผ รฎรฒ 1 รครฎ 500 รชรฃ รร รฒรฅรฐรจร รซรปร ");

	new factory_metal = GetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_METAL, R_AMOUNT);

	if((factory_metal + sell_metal_count) > 1_000_000)
		return SendClientMessage(playerid, 0xCECECEFF, "รรชรซร รค รร รฒรฅรฐรจร รซรปร  รงร รขรฎรคร  รงร รฏรฎรซรญรฅรญ");

	new fmt_str[90];

	new modelid;
	new vehicleid = GetPlayerJobCar(playerid);

	if(vehicleid != INVALID_VEHICLE_ID)
		modelid = GetVehicleData(vehicleid, V_MODELID);

	if(GetPlayerTempJob(playerid) == TEMP_JOB_FACTORY_TRUCKER && IsPlayerInVehicle(playerid, vehicleid) && modelid == 406)
	{
		new metall_loaded_count = GetPlayerJobLoadItems(playerid);

		if(metall_loaded_count < sell_metal_count)
			return SendClientMessage(playerid, 0x999999FF, "ร รร รธรฅรฌ รดรณรฐรฃรฎรญรฅ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

		metall_loaded_count -= sell_metal_count;
		SetPlayerJobLoadItems(playerid, metall_loaded_count);

		format(fmt_str, sizeof fmt_str, "รรฎรฑรฒร รขรชร  รร รฒรฅรฐรจร รซรปร \n{FFFFFF}รร รฃรฐรณรงรชร  %d / 500 รชรฃ", metall_loaded_count);
		UpdateVehicleLabel(vehicleid, 0x3399FFFF, fmt_str);

		AddPlayerData(playerid, P_JOB_WAGE, +, sell_metal_count * 3);
		GivePlayerMoneyEx(playerid, (sell_metal_count * 18), "รรฐรฎรคร รฆร  รร รฒรฅรฐรจร รซรปร  รงร รขรฎรครณ (รฐร รงรขรฎรงรทรจรช)", true, true);
	}
	else
	{
		if(GetPlayerData(playerid, P_METALL) < sell_metal_count)
			return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รฑ รฑรฎรกรฎรฉ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

		format(fmt_str, sizeof fmt_str, "UPDATE accounts SET money=%d,metall=%d WHERE id=%d LIMIT 1", GetPlayerMoneyEx(playerid) + (sell_metal_count * 18), GetPlayerData(playerid, P_METALL), GetPlayerAccountID(playerid));
		mysql_query(mysql, fmt_str, false);

		if(!mysql_errno())
		{
			AddPlayerData(playerid, P_METALL, -, sell_metal_count);
			GivePlayerMoneyEx(playerid, (sell_metal_count * 18), "รรฐรฎรคร รฆร  รร รฒรฅรฐรจร รซรปร  รงร รขรฎรครณ", false, true);
		}
		else
			return SendClientMessage(playerid, 0xFF6600FF, "รรธรจรกรชร  รฑรฎรตรฐร รญรฅรญรจรฟ, รฏรฎรขรฒรฎรฐรจรฒรฅ รฏรฎรฏรปรฒรชรณ {FF0000}(equ-code 13)");

	}
	format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฎรคร รซรจ รงร รขรฎรครณ %d รชรฃ รร รฒรฅรฐรจร รซรปร  รญร  รฑรณรฌรฌรณ %d รฐรณรก", sell_metal_count, sell_metal_count * 18);
	SendClientMessage(playerid, 0x66CC00FF, fmt_str);

	format(fmt_str, sizeof fmt_str, "รร รธร  รทรจรฑรฒร รฟ รขรปรฐรณรทรชร  รฑรฎรฑรฒร รขรซรฟรฅรฒ {FF9900}%d รฐรณรก", sell_metal_count * 3);
	SendClientMessage(playerid, 0x66CC00FF, fmt_str);

	SetRepositoryData(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_METAL, R_AMOUNT, factory_metal + sell_metal_count);
	UpdateRepository(REPOSITORY_TYPE_FACTORY, REPOSITORY_ACTION_FACTORY_METAL);

	return 1;
}

CMD:takem(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_ARMY) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รขรฎรฅรญรญรฎรฑรซรณรฆร รนรจรฉ");

	extract params -> new take_metal_count; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /takem [รชรฎรซ-รขรฎ รข รชรฃ]");

	if(take_metal_count <= 0) return SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รร รฒรฅรฐรจร รซรปร ");

	new army_metal = GetRepositoryData(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL, R_AMOUNT);

	if(!IsPlayerInRangeOfPoint(playerid, 15.0, 2883.7095,1447.6533,1050.9984))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รขรฎรจรญรฑรชรฎรฉ รทร รฑรฒรจ");

	if(army_metal < take_metal_count)
		return SendClientMessage(playerid, 0x999999FF, "รร  รฑรชรซร รครฅ รขรฎรจรญรฑรชรฎรฉ รทร รฑรฒรจ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

	if((GetPlayerData(playerid, P_METALL) + take_metal_count) > GetPlayerMaxStorage(playerid, STORAGE_METALL))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รณรญรฅรฑรฒรจ รฑ รฑรฎรกรฎรฉ รฑรฒรฎรซรผรชรฎ รร รฒรฅรฐรจร รซรปร  (รฌร รชรฑรจรฌรณรฌ 20 รชรฃ)");

	AddPlayerData(playerid, P_METALL, +, take_metal_count);
	UpdatePlayerDatabaseInt(playerid, "metall", GetPlayerData(playerid, P_METALL));

	SetRepositoryData(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL, R_AMOUNT, army_metal - take_metal_count);
	UpdateRepository(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL);

	new fmt_str[128];

	format(fmt_str, sizeof fmt_str, "%s[%d] รขรงรฟรซ(ร ) รญร  รขรฎรฅรญรญรฎรฌ รฑรชรซร รครฅ {00cc33}%d รชรฃ รร รฒรฅรฐรจร รซรปร ", GetPlayerNameEx(playerid), playerid, take_metal_count);
	SendMessageToTeam(TEAM_ARMY, fmt_str, 0x3399FFFF);

	return 1;
}

CMD:putm(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_ARMY) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รขรฎรฅรญรญรฎรฑรซรณรฆร รนรจรฉ");

	extract params -> new put_metal_count; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /putm [รชรฎรซ-รขรฎ รข รชรฃ]");

	if(put_metal_count <= 0) return SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รร รฒรฅรฐรจร รซรปร ");

	new army_metal = GetRepositoryData(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL, R_AMOUNT);

	if(!IsPlayerInRangeOfPoint(playerid, 15.0, 2883.7095,1447.6533,1050.9984))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รณ รฑรชรซร รคร  รขรฎรจรญรฑรชรฎรฉ รทร รฑรฒรจ");

	if(GetPlayerData(playerid, P_METALL) < put_metal_count)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

	AddPlayerData(playerid, P_METALL, -, put_metal_count);
	UpdatePlayerDatabaseInt(playerid, "metall", GetPlayerData(playerid, P_METALL));

	SetRepositoryData(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL, R_AMOUNT, army_metal + put_metal_count);
	UpdateRepository(REPOSITORY_TYPE_ARMY, REPOSITORY_ACTION_ARMY_METAL);

	new fmt_str[128];

	format(fmt_str, sizeof fmt_str, "%s[%d] รฏรฎรซรฎรฆรจรซ(ร ) รญร  รขรฎรฅรญรญรปรฉ รฑรชรซร รค {00cc33}%d รชรฃ รร รฒรฅรฐรจร รซรฎรข", GetPlayerNameEx(playerid), playerid, put_metal_count);
	SendMessageToTeam(TEAM_ARMY, fmt_str, 0x3399FFFF);

	return 1;
}

CMD:givemet(playerid, params[])
{
	extract params -> new to_player, give_metall_count; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givemet [id รจรฃรฐรฎรชร ] [รชรฎรซ-รขรฎ รข รชรฃ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(give_metall_count <= 0) return SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รร รฒรฅรฐรจร รซรปร ");

	if(give_metall_count > GetPlayerData(playerid, P_METALL))
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รร รฒรฅรฐรจร รซรปร ");

	new fmt_text[80];

	if((GetPlayerData(to_player, P_METALL) + give_metall_count) > GetPlayerMaxStorage(to_player, STORAGE_METALL))
	{
		format(fmt_text, sizeof fmt_text, "รรฃรฐรฎรช รญรฅ รฌรฎรฆรฅรฒ รณรญรฅรฑรฒรจ รฑ รฑรฎรกรฎรฉ รฑรฒรฎรซรผรชรฎ รร รฒรฅรฐรจร รซรปร  (รฌร รชรฑรจรฌรณรฌ %d รชรฃ)", GetPlayerMaxStorage(to_player, STORAGE_METALL));
		SendClientMessage(playerid, 0xCECECEFF, fmt_text);
	}

	AddPlayerData(playerid, P_METALL, -, give_metall_count);
	UpdatePlayerDatabaseInt(playerid, "metall", GetPlayerData(playerid, P_METALL));

	AddPlayerData(to_player, P_METALL, +, give_metall_count);
	UpdatePlayerDatabaseInt(to_player, "metall", GetPlayerData(to_player, P_METALL));

	format(fmt_text, sizeof fmt_text, "~b~-%d metall", give_metall_count);
	GameTextForPlayer(playerid, fmt_text, 4000, 1);

	format(fmt_text, sizeof fmt_text, "~b~+%d metall", give_metall_count);
	GameTextForPlayer(to_player, fmt_text, 4000, 1);

	format(fmt_text, sizeof fmt_text, "รรป รฏรฅรฐรฅรคร รซรจ รร รฒรฅรฐรจร รซรป รจรฃรฐรฎรชรณ %s (%d รชรฃ.)", GetPlayerNameEx(to_player), give_metall_count);
	SendClientMessage(playerid, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "รรฃรฐรฎรช %s รฏรฅรฐรฅรคร รซ รร รฌ รร รฒรฅรฐรจร รซรป (%d รชรฃ.)", GetPlayerNameEx(playerid), give_metall_count);
	SendClientMessage(to_player, 0x3399FFFF, fmt_text);

	return 1;
}


CMD:givemycoins(playerid, params[])
{
	if (GetPlayerData(playerid, P_TOTALHOUR) < 30) {
		SendClientMessage(playerid, 0x999999FF, "รรณรฆรญรฎ รฎรฒรปรฃรฐร รฒรผ 30 รทร รฑรฎรข, รทรฒรฎรกรป รฏรฅรฐรฅรคร รขร รฒรผ รชรฎรจรญรป");
		return 1;
	}

	extract params -> new to_player, give; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givemycoins [id รจรฃรฐรฎรชร ] [รชรฎรซ-รขรฎ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(give <= 0) return SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ");

	if(give > GetPlayerData(playerid, P_COINS))
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รชรฎรจรญรฎรข");

	new fmt_text[80];

	AddPlayerData(playerid, P_COINS, -, give);
	UpdatePlayerDatabaseInt(playerid, "coins", GetPlayerData(playerid, P_COINS));

	AddPlayerData(to_player, P_COINS, +, give);
	UpdatePlayerDatabaseInt(to_player, "coins", GetPlayerData(to_player, P_COINS));

	format(fmt_text, sizeof fmt_text, "~b~-%d coin", give);
	GameTextForPlayer(playerid, fmt_text, 4000, 1);

	format(fmt_text, sizeof fmt_text, "~b~+%d coin", give);
	GameTextForPlayer(to_player, fmt_text, 4000, 1);

	format(fmt_text, sizeof fmt_text, "รรป รฏรฅรฐรฅรคร รซรจ รฌรฎรญรฅรฒรป รจรฃรฐรฎรชรณ %s รข รชรฎรซรจรทรฅรฑรฒรขรฅ %d", GetPlayerNameEx(to_player), give);
	SendClientMessage(playerid, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "รรฃรฐรฎรช %s รฏรฅรฐรฅรคร รซ รร รฌ รฌรฎรญรฅรฒรป รข รชรฎรซรจรทรฅรฑรฒรขรฅ %d", GetPlayerNameEx(playerid), give);
	SendClientMessage(to_player, 0x3399FFFF, fmt_text);

	return 1;
}

CMD:givepatr(playerid, params[])
{
	extract params -> new to_player, give_ammo_count; else return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givepatr [id รจรฃรฐรฎรชร ] [รชรฎรซ-รขรฎ รฏร รฒรฐรฎรญรฎรข]");

