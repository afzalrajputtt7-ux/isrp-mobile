	CreateDynamic3DTextLabel("รร รฏรฐร รขรฎ\n\n{FFFFFF}รรฐรฎรคร รฆร  รฒรฎรฏรซรจรขร  รครซรฟ รงร รขรฎรคร ", 0xFF6600FF, 977.3191, 635.4105, 12.1154 - 0.5, 20.0);

