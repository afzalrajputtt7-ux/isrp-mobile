    Action(targetid, action_show, _, false);

    new action_view[128];
    format(action_view, sizeof action_view, "รรฐรฎรฑรฌร รฒรฐรจรขร รฅรฒ รฌรฅรครจรถรจรญรฑรชรณรพ รชร รฐรฒรณ %s", name_target);
    Action(viewerid, action_view, _, false);

    return 1;
}

