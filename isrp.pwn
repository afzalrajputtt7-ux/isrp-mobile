#define COLOR_LIGHT_BLUE 0xAAEEFFFF

CMD:giveroulette(playerid, params[])
{
    if (GetPlayerAdminEx(playerid) < 7) 
        return SendClientMessage(playerid, COLOR_RED, "รรฎรฌร รญรคร  รญรฅรครฎรฑรฒรณรฏรญร . รรฐรฅรกรณรฅรฒรฑรฟ รณรฐรฎรขรฅรญรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  7 รจรซรจ รขรปรธรฅ.");

    new targetid, amount;
    if (sscanf(params, "ui", targetid, amount)) 
        return SendClientMessage(playerid, COLOR_RED, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /giveroulette [ID รจรฃรฐรฎรชร ] [รชรฎรซรจรทรฅรฑรฒรขรฎ]");

    if (!IsPlayerConnected(targetid)) 
        return SendClientMessage(playerid, COLOR_RED, "รรฃรฐรฎรช รญรฅ รญร รฉรครฅรญ.");

    if (amount <= 0) 
        return SendClientMessage(playerid, COLOR_RED, "รรฎรซรจรทรฅรฑรฒรขรฎ รครฎรซรฆรญรฎ รกรปรฒรผ รกรฎรซรผรธรฅ รญรณรซรฟ.");

    player_roulette_bronz[targetid] += amount;
    UpdatePlayerDatabaseInt(targetid, "roulette_bronz", player_roulette_bronz[targetid]);

    new adminName[MAX_PLAYER_NAME], targetName[MAX_PLAYER_NAME], msg[160];
    GetPlayerName(playerid, adminName, sizeof(adminName));
    GetPlayerName(targetid, targetName, sizeof(targetName));

    format(msg, sizeof(msg), "รรป รขรปรคร รซรจ %d รกรฐรฎรญรง. รฐรณรซรฅรฒรฎรช รจรฃรฐรฎรชรณ %s [%d].", amount, targetName, targetid);
    SendClientMessage(playerid, COLOR_LIGHT_BLUE, msg);

    format(msg, sizeof(msg), "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s [%d] รขรปรคร รซ รขร รฌ %d รกรฐรฎรญรง. รฐรณรซรฅรฒรฎรช!", adminName, playerid, amount);
    SendClientMessage(targetid, COLOR_LIGHT_BLUE, msg);

    format(msg, sizeof(msg), "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s [%d] รขรปรคร รซ %d รกรฐรฎรญรง. รฐรณรซรฅรฒรฎรช รจรฃรฐรฎรชรณ %s [%d].", adminName, playerid, amount, targetName, targetid);
    SendMessageToAdmins(msg, 0xA9A9A9FF); // รฒยธรฌรญรฎ-รฑรฅรฐรปรฉ

    new logMessage[128];
    format(logMessage, sizeof(logMessage), "รรปรคร รซ รกรฐรฎรญรงรฎรขรปรฅ รฐรณรซรฅรฒรชรจ รจรฃรฐรฎรชรณ %s รข รชรฎรซรจรทรฅรฑรฒรขรฅ %d.", targetName, amount);
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, logMessage);

    return 1;
}

CMD:ask(playerid, params[])
{
	if(GetPlayerHelperEx(playerid) == 0) return SendClientMessage(playerid, 0xFFFFFFFF, "{FF0000}| {FFFFFF}รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รรฃรฅรญรฒร รฌ รฏรฎรครครฅรฐรฆรชรจ!");

	if(!g_ask_created) return SendClientMessage(playerid, 0xCECECEFF, "{FF0000}| {FFFFFF}รรฅรฒ รฎรกรฐร รนรฅรญรจรฉ รครซรฟ รฏรฐรฎรขรฅรฐรชรจ!");

	new fmt_text[360],
		bool: ask_is_found;

	for(new idx; idx < g_ask_created; idx ++)
	{
		if(GetAskData(idx, ASK_EDIT) || GetAskData(idx, ASK_CREATOR) == INVALID_PLAYER_ID) continue;

		format
		(
			fmt_text, sizeof fmt_text,
			"{FFFFFF}รรป รฑรฎรกรจรฐร รฅรฒรฅรฑรผ รฎรฒรขรฅรฒรจรฒรผ รญร  รขรฎรฏรฐรฎรฑ รจรฃรฐรฎรชร : {FFFF00}%s[%d]\n\n"\
			"{FFFF00}|{FFFFFF}รรฅรชรฑรฒ: {FFFF00}%s\n\n"\
			"",
			GetPlayerNameEx(GetAskData(idx, ASK_CREATOR)), GetAskData(idx, ASK_CREATOR), GetAskData(idx, ASK_TEXT)
		);

		Dialog(playerid, DIALOG_ASK_EDIT, DIALOG_STYLE_INPUT, "{00FFFF}"SERVER_NAME" | รรฎรฏรฐรฎรฑ", fmt_text, "รรฒรฏรฐร รขรจรฒรผ", "รรฒรชรซรฎรญรจรฒรผ");
		
		format(fmt_text, sizeof fmt_text, "{FFFFFF}รรฃรฅรญรฒ รฏรฎรครครฅรฐรฆรชรจ {FFFF00}%s {FFFFFF}รขรงรฟรซรฑรฟ รงร  รร รธ รขรฎรฏรฐรฎรฑ.", GetPlayerNameEx(playerid));
		SendClientMessage(GetAskData(idx, ASK_CREATOR), -1, fmt_text);

		SetAskData(idx, ASK_EDIT, true);

		SetPVarInt(playerid, "ask_id", idx);

		ask_is_found = true;

		break;
	}

	if(!ask_is_found) return SendClientMessage(playerid, 0xCECECEFF, "{FF0000}| {FFFFFF}รรฅรฒ ร รชรฒรณร รซรผรญรปรต รฎรกรฐร รนรฅรญรจรฉ รครซรฟ รฐร รฑรฑรฌรฎรฒรฐรฅรญรจรฟ!");

	return 1;
}

