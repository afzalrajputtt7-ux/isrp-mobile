	factory_store_label[1] = CreateDynamic3DTextLabel("รร  รฑรชรซร รครฅ:\n{FF9900}รร รฒรฅรฐรจร รซรป: 0 / 1000000 รชรฃ\n\n{6699FF}/sellm", 0xFFFFFFFF, -1043.8157,2205.5217,38.1195, 20.0); // รฌรฅรฒร รซ

	CreateDynamic3DTextLabel("รรชรซร รค\nรฏรฐรฎรจรงรขรฎรครฑรฒรขรฅรญรญรฎรฃรฎ\nรถรฅรตร \n\n{6699FF}/sellf\n/sellm\n{33CC00}/buyprod", 0xFFFFFFFF, -1046.6550, 2208.5771, 42.0, 25.0, INVALID_PLAYER_ID, INVALID_VEHICLE_ID, _, _, _, _, 50.0);
