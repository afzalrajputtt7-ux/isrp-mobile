	return 1;
}

CMD:slap(playerid, params[])
{
    if (GetPlayerAdminEx(playerid) < 7)
        return SendClientMessage(playerid, 0xFF5533FF, "รรธรจรกรชร : ร รขร รฑ รญรฅรฒ รฏรฐร รข รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรณ รชรฎรฌร รญรครณ");

    extract params -> new to_player, set_code, string:reason[30]; else {
        SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /slap [id รจรฃรฐรฎรชร ] [0 - รขรขรฅรฐรต, 1 - รขรญรจรง] [รฏรฐรจรทรจรญร ]");
        return 1;
    }

    if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ.");

    if (GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
        return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

    new Float:x, Float:y, Float:z;
    GetPlayerPos(to_player, x, y, z);

    new fmt_text[999], fmt_msg[999];

    switch (set_code)
    {
        case 0: // รขรขรฅรฐรต
        {
            SetPlayerPos(to_player, x, y, z + 5.0);
            PlayerPlaySound(to_player, 1130, 0.0, 0.0, 0.0);

            format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฏรฎรครกรฐรฎรฑรจรซ รจรฃรฐรฎรชร  %s[%d]. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, reason);
            SendMessageToAdmins(fmt_text, 0x999999FF);

            format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รฏรฎรครกรฐรฎรฑรจรซรจ รจรฃรฐรฎรชร  %s[%d]. รรฐรจรทรจรญร : %s", GetPlayerNameEx(to_player), to_player, reason);
            SendClientMessage(playerid, -1, fmt_msg);

            format(fmt_text, sizeof fmt_text, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรครกรฐรฎรฑรจรซ รร รฑ. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), playerid, reason);
            SendClientMessage(to_player, -1, fmt_text);
        }
        case 1: // รขรญรจรง
        {
            SetPlayerPos(to_player, x, y, z - 5.0);
            PlayerPlaySound(to_player, 1130, 0.0, 0.0, 0.0);

            format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฎรฏรณรฑรฒรจรซ รจรฃรฐรฎรชร  %s[%d]. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, reason);
            SendMessageToAdmins(fmt_text, 0x999999FF);

            format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รฎรฏรณรฑรฒรจรซรจ รจรฃรฐรฎรชร  %s[%d]. รรฐรจรทรจรญร : %s", GetPlayerNameEx(to_player), to_player, reason);
            SendClientMessage(playerid, -1, fmt_msg);

            format(fmt_text, sizeof fmt_text, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฎรฏรณรฑรฒรจรซ รร รฑ. รรฐรจรทรจรญร : %s", GetPlayerNameEx(playerid), playerid, reason);
            SendClientMessage(to_player, -1, fmt_text);
        }
        default:
            return SendClientMessage(playerid, 0xFF6600FF, "รรธรจรกรชร : รรฅรขรฅรฐรญรฎ รขรขรฅรครฅรญ รชรฎรค (0 - รขรขรฅรฐรต, 1 - รขรญรจรง)");
    }

    return 1;
}

CMD:hp(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 2) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new to_player, health; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /hp [id รจรฃรฐรฎรชร ] [รชรฎรซรจรทรฅรฑรฒรขรฎ รงรครฎรฐรฎรขรผรฟ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");

	else if(GetPlayerAdminEx(playerid) == 1 && to_player != playerid)
		return SendClientMessage(playerid, 0x999999FF, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐร รฌ 1-รฃรฎ รณรฐรฎรขรญรฟ รครฎรฑรฒรณรฏรญรฎ รจรงรฌรฅรญรฅรญรจรฅ รฒรฎรซรผรชรฎ รฑรขรฎรฅรฃรฎ รณรฐรฎรขรญรฟ รงรครฎรฐรฎรขรผรฟ");
	
	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	else if(!(0 <= health <= 100)) return SendClientMessage(playerid, 0x999999FF, ""SC"รรฐรฎรขรฅรญรผ รงรครฎรฐรฎรขรผรฟ รฎรฒ 0 รครฎ 100");

	SetPlayerData(to_player, P_HEALTH, health);
	SetPlayerHealthEx(to_player, health);

	if(GetPlayerData(to_player, P_HOSPITAL))
		SetPlayerData(to_player, P_HOSPITAL, false);

	new fmt_msg[999];
	format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รจรงรฌรฅรญรจรซ รณรฐรฎรขรฅรญรผ รงรครฎรฐรฎรขรผรฟ %s[%d] รญร  %d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, health);
	SendMessageToAdmins(fmt_msg, 0x999999FF);
	
	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รจรงรฌรฅรญรจรซรจ %s[%d] รณรฐรฎรขรฅรญรผ รงรครฎรฐรฎรขรผรฟ", GetPlayerNameEx(to_player), to_player);
	SendClientMessage(playerid, -1, fmt_msg);	
	
	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รจรงรฌรฅรญรจรซ รร รฌ รณรฐรฎรขรฅรญรผ รงรครฎรฐรฎรขรผรฟ", GetPlayerNameEx(playerid), playerid);
	SendClientMessage(to_player, -1, fmt_msg);	

	format(fmt_msg, sizeof fmt_msg, "รรฑรฒร รญรฎรขรจรซ %s[acc:%d] รณรฐรฎรขรฅรญรผ รงรครฎรฐรฎรขรผรฟ รญร  %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), health);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

CMD:spcars(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4) return 1;

	new delay;
	if(sscanf(params, "d", delay))
	    return SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /spcars [รขรฐรฅรฌรฟ รข รฑรฅรชรณรญรคร รต: 10-60]");

	if(delay < 10 || delay > 60)
	    return SendClientMessage(playerid, -1, "รรฐรฅรฌรฟ รครฎรซรฆรญรฎ รกรปรฒรผ รฎรฒ 10 รครฎ 60 รฑรฅรชรณรญรค.");

	new fmt_text[128];
	format(fmt_text, sizeof fmt_text,
	    "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รจรญรจรถรจรจรฐรฎรขร รซ รฐรฅรฑรฏร รขรญ รญรฅรงร รญรฟรฒรฎรฃรฎ ร รขรฒรฎ. รรฅรฑรผ รญรฅรงร รญรฟรฒรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รจรฑรทรฅรงรญรฅรฒ รทรฅรฐรฅรง %d รฑรฅรชรณรญรค.",
	    GetPlayerNameEx(playerid), delay);
	SendClientMessageToAll(0xFFCC00FF, fmt_text);

	format(fmt_text, sizeof fmt_text,
	    "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รงร รฏรณรฑรฒรจรซ รฒร รฉรฌรฅรฐ รฐรฅรฑรฏร รขรญร  รญรฅรงร รญรฟรฒรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  (%d รฑรฅรช)",
	    GetPlayerNameEx(playerid), playerid, delay);
	SendMessageToAdmins(fmt_text, 0x999999FF);


	new admin_id = playerid; // รรฎรชร รซรผรญร รฟ รฏรฅรฐรฅรฌรฅรญรญร รฟ, รทรฒรฎรกรป รญรฅ รขรปรงรปรขร รฒรผ รขรญรณรฒรฐรจ รฒร รฉรฌรฅรฐร  GetPlayerNameEx

	SetTimerEx("spcars_respawn", delay * 1000, false, "i", admin_id);
	return 1;
}

forward spcars_respawn(admin_id);
public spcars_respawn(admin_id)
{
	new vehicles_count = 0;

	for(new i = 1; i < MAX_VEHICLES; i++)
	{
	    if(!IsValidVehicle(i)) continue;
	    if(IsVehicleOccupied(i)) continue;
	    if(IsTrailerAttachedToAnyVehicle(i)) continue;

	    SetVehicleToRespawn(i);
	    vehicles_count++;
	}

	new fmt_text[128];
	format(fmt_text, sizeof fmt_text,
	    ""SC"รรฅรฑรผ รญรฅรงร รญรฟรฒรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รกรปรซ รงร รฐรฅรฑรฏร รขรญรฅรญ ร รครฌรจรญรจรฑรฒรฐร รถรจรฅรฉ. รรฑรฅรฃรฎ: %d รธรฒ.",
	    vehicles_count);
	SendClientMessageToAll(0x33AAFFFF, fmt_text);

	format(fmt_text, sizeof fmt_text,
	    "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รงร รขรฅรฐรธรจรซ รฐรฅรฑรฏร รขรญ รญรฅรงร รญรฟรฒรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  (%d ร รขรฒรฎ)",
	    GetPlayerNameEx(admin_id), admin_id, vehicles_count);
	SendMessageToAdmins(fmt_text, 0x999999FF);

	SendLog(admin_id, LOG_TYPE_ADMIN_ACTION, "รร รฐรฅรฑรฏร รขรญรจรซ รขรฅรฑรผ รญรฅรงร รญรฟรฒรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ (/spcars) ");
}

CMD:givegun(playerid, params[])
{
    if (GetPlayerAdminEx(playerid) < 3) return 1;
    if (TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");

    new to_player, weapon_id, weapon_ammo;
    if (sscanf(params, "iii", to_player, weapon_id, weapon_ammo))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givegun [id รจรฃรฐรฎรชร ] [id รฎรฐรณรฆรจรฟ] [รชรฎรซ-รขรฎ รฏร รฒรฐรฎรญรฎรข]");

    if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if (weapon_id < 1 || weapon_id > 46 || (weapon_id >= 19 && weapon_id <= 21))
        return SendClientMessage(playerid, 0x999999FF, "ID รฎรฐรณรฆรจรฟ รฎรฒ 1 รครฎ 46, รชรฐรฎรฌรฅ 19โ21");

    if (weapon_ammo < 1 || weapon_ammo > 1000)
        return SendClientMessage(playerid, 0x999999FF, "รรฎรซรจรทรฅรฑรฒรขรฎ รฏร รฒรฐรฎรญรฎรข รฎรฒ 1 รครฎ 1000");

    // รรปรคร รทร  รฎรฐรณรฆรจรฟ
    GivePlayerWeapon(to_player, weapon_id, weapon_ammo);
    SetPlayerArmedWeapon(to_player, weapon_id);

    //รรจรชรฑ: รรฐรจรญรณรครจรฒรฅรซรผรญรฎ รณรฑรฒร รญร รขรซรจรขร รฅรฌ รฏร รฒรฐรฎรญรป
    SetPlayerAmmo(to_player, weapon_id, weapon_ammo);

    // รรขรฅรครฎรฌรซรฅรญรจรฟ
    new fmt_text[128];
    format(fmt_text, sizeof fmt_text, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รขรปรคร รซ รร รฌ %s รจ %d รฏร รฒรฐ.", GetPlayerNameEx(playerid), playerid, GetWeaponName(weapon_id), weapon_ammo);
    SendClientMessage(to_player, -1, fmt_text);

    format(fmt_text, sizeof fmt_text, "รรป รขรปรคร รซรจ รจรฃรฐรฎรชรณ %s[%d] %s รจ %d รฏร รฒรฐ.", GetPlayerNameEx(to_player), to_player, GetWeaponName(weapon_id), weapon_ammo);
    SendClientMessage(playerid, -1, fmt_text);

    if (GetPlayerAdminEx(playerid) <= 5)
    {
        format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รขรปรคร รซ %s[%d] %s [%d รฏร รฒรฐ]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, GetWeaponName(weapon_id), weapon_ammo);
        SendMessageToAdmins(fmt_text, 0x999999FF);
    }

    format(fmt_text, sizeof fmt_text, "รรปรคร รซ %s[acc:%d] %s[%d รฏร รฒรฐ]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), GetWeaponName(weapon_id), weapon_ammo);
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

    return 1;
}

CMD:agivelic(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 5) return 1;

	extract params -> new to_player, license; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /agivelic [id รจรฃรฐรฎรชร ] [รฒรจรฏ] (1-รร รงรฎรขรปรฉ รณรฐรฎรขรฅรญรผ 2-รรฐรฎรดรฅรฑรฑรจรฎรญร รซรผรญรปรฉ รณรฐรฎรขรฅรญรผ 3-รร  รฎรฐรณรฆรจรฅ)");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new fmt_text[144];

	switch(license)
	{
		case 1:
		{
			SetPlayerData(to_player, P_DRIVING_LIC, GetPlayerData(to_player, P_DRIVING_LIC) ^ 1);
			UpdatePlayerDatabaseInt(to_player, "driving_lic", GetPlayerData(to_player, P_DRIVING_LIC));

			format(fmt_text, sizeof fmt_text, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รร รงรฎรขรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_DRIVING_LIC) ? "รขรปรคร รซ รร รฌ" : "รงร รกรฐร รซ รณ รร รฑ");
			SendClientMessage(to_player, 0x3399FFFF, fmt_text);

			format(fmt_text, sizeof fmt_text, "รรป %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รร รงรฎรขรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerData(to_player, P_DRIVING_LIC) ? "รขรปรคร รซรจ" : "รงร รกรฐร รซรจ รณ", GetPlayerNameEx(to_player), to_player);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);

			format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รร รงรฎรขรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_DRIVING_LIC) ? "รขรปรคร รซ" : "รงร รกรฐร รซ รณ", GetPlayerNameEx(to_player), to_player);
			SendMessageToAdmins(fmt_text, 0x999999FF);
		}
		case 2:
		{
			SetPlayerData(to_player, P_DRIVING_LIC, GetPlayerData(to_player, P_DRIVING_LIC) == 2 ? 0 : 2);
			UpdatePlayerDatabaseInt(to_player, "driving_lic", GetPlayerData(to_player, P_DRIVING_LIC));

			format(fmt_text, sizeof fmt_text, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รรฐรฎรดรฅรฑรฑรจรฎรญร รซรผรญรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_DRIVING_LIC) == 2 ? "รขรปรคร รซ รร รฌ" : "รงร รกรฐร รซ รณ รร รฑ");
			SendClientMessage(to_player, 0x3399FFFF, fmt_text);

			format(fmt_text, sizeof fmt_text, "รรป %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รรฐรฎรดรฅรฑรฑรจรฎรญร รซรผรญรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerData(to_player, P_DRIVING_LIC) == 2 ? "รขรปรคร รซรจ" : "รงร รกรฐร รซรจ รณ", GetPlayerNameEx(to_player), to_player);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);

			format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รขรฎรฆรครฅรญรจรฅ รรฐรฎรดรฅรฑรฑรจรฎรญร รซรผรญรฎรฃรฎ รณรฐรฎรขรญรฟ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_DRIVING_LIC) == 2 ? "รขรปรคร รซ" : "รงร รกรฐร รซ รณ", GetPlayerNameEx(to_player), to_player);
			SendMessageToAdmins(fmt_text, 0x999999FF);
		}
		case 3:
		{
			SetPlayerData(to_player, P_WEAPON_LIC, GetPlayerData(to_player, P_WEAPON_LIC) ^ 1);
			UpdatePlayerDatabaseInt(to_player, "weapon_lic", GetPlayerData(to_player, P_WEAPON_LIC));

			format(fmt_text, sizeof fmt_text, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s รซรจรถรฅรญรงรจรพ รญร  รฎรฐรณรฆรจรฅ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_WEAPON_LIC) ? "รขรปรคร รซ รร รฌ" : "รงร รกรฐร รซ รณ รร รฑ");
			SendClientMessage(to_player, 0x3399FFFF, fmt_text);

			format(fmt_text, sizeof fmt_text, "รรป %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รฎรฐรณรฆรจรฅ", GetPlayerData(to_player, P_WEAPON_LIC) ? "รขรปรคร รซรจ" : "รงร รกรฐร รซรจ รณ", GetPlayerNameEx(to_player), to_player);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);

			format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] %s %s[%d] รซรจรถรฅรญรงรจรพ รญร  รฎรฐรณรฆรจรฅ", GetPlayerNameEx(playerid), playerid, GetPlayerData(to_player, P_WEAPON_LIC) ? "รขรปรคร รซ" : "รงร รกรฐร รซ รณ", GetPlayerNameEx(to_player), to_player);
			SendMessageToAdmins(fmt_text, 0x999999FF);
		}
		default: return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /agivelic [id รจรฃรฐรฎรชร ] [รฒรจรฏ] (1-รร รงรฎรขรปรฉ รณรฐรฎรขรฅรญรผ 2-รรฐรฎรดรฅรฑรฑรจรฎรญร รซรผรญรปรฉ รณรฐรฎรขรฅรญรผ 3-รร  รฎรฐรณรฆรจรฅ)");
	}

	format(fmt_text, sizeof fmt_text, "รรปรคร รซ %s[acc:%d] รซรจรถรฅรญรงรจรพ %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), license);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:setskills(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7) return 1;

	extract params -> new to_player, set_code, set_value; else {

	    SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /setskills [id รจรฃรฐรฎรชร ] [รญร รขรปรช] [รงรญร รทรฅรญรจรฅ]");
	    SendClientMessage(playerid, 0xCECECEFF, "รรฎรครป รญร รขรปรชรฎรข:");
		SendClientMessage(playerid, 0xCECECEFF, "1 - Colt 45");
	    SendClientMessage(playerid, 0xCECECEFF, "2 - SD Pistol");
	    SendClientMessage(playerid, 0xCECECEFF, "3 - Desert Eagle");
	    SendClientMessage(playerid, 0xCECECEFF, "4 - Shotgun");
	    SendClientMessage(playerid, 0xCECECEFF, "5 - MP5");
	    SendClientMessage(playerid, 0xCECECEFF, "6 - AK47");
	    SendClientMessage(playerid, 0xCECECEFF, "7 - M4");
	    SendClientMessage(playerid, 0xCECECEFF, "8 - Sniper Rifle");
		SendClientMessage(playerid, 0xCECECEFF, "9 - Sawnoff");
		SendClientMessage(playerid, 0xCECECEFF, "10 - Combat SG");
		SendClientMessage(playerid, 0xCECECEFF, "11 - Micro Uzi");
	    SendClientMessage(playerid, 0x999999FF, "12 - รรจรซร ");
	    return 1;
	}

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(0 <= set_value <= 100)) return SendClientMessage(playerid, 0x999999FF, "รรญร รทรฅรญรจรฅ รญร รขรปรชร  รฎรฒ 0 รครฎ 100");

	new tmp_skill_name[32], query[128];

	switch(set_code)
	{
		case 1:
	    {
	        SetPlayerData(to_player, P_SKILL_COLT, set_value);
			tmp_skill_name = "Colt 45";
			UpdatePlayerDatabaseInt(to_player, "skill_colt", set_value);
	    }
	    case 2:
	    {
	        SetPlayerData(to_player, P_SKILL_SDPISTOL, set_value);
			tmp_skill_name = "SD Pistol";
			UpdatePlayerDatabaseInt(to_player, "skill_sdpistol", set_value);
	    }
	    case 3:
	    {
	        SetPlayerData(to_player, P_SKILL_DEAGLE, set_value);
			tmp_skill_name = "Desert Eagle";
			UpdatePlayerDatabaseInt(to_player, "skill_deagle", set_value);
	    }
	    case 4:
	    {
	        SetPlayerData(to_player, P_SKILL_SHOTGUN, set_value);
			tmp_skill_name = "Shotgun";
			UpdatePlayerDatabaseInt(to_player, "skill_shotgun", set_value);
	    }
	    case 5:
	    {
	        SetPlayerData(to_player, P_SKILL_MP5, set_value);
			tmp_skill_name = "MP5";
			UpdatePlayerDatabaseInt(to_player, "skill_mp5", set_value);
	    }
	    case 6:
	    {
	        SetPlayerData(to_player, P_SKILL_AK47, set_value);
			tmp_skill_name = "AK47";
			UpdatePlayerDatabaseInt(to_player, "skill_ak47", set_value);
	    }
	    case 7:
	    {
	        SetPlayerData(to_player, P_SKILL_M4, set_value);
			tmp_skill_name = "M4";
			UpdatePlayerDatabaseInt(to_player, "skill_m4", set_value);
	    }
	    case 8:
	    {
	        SetPlayerData(to_player, P_SKILL_SNIPER_RIFLE, set_value);
			tmp_skill_name = "Sniper Rifle";
			UpdatePlayerDatabaseInt(to_player, "skill_sniper_rifle", set_value);
	    }
		case 9:
	    {
	        SetPlayerData(to_player, P_SKILL_SAWNOFF, set_value);
			tmp_skill_name = "Sawnoff";
			UpdatePlayerDatabaseInt(to_player, "skill_sawnoff", set_value);
	    }
		case 10:
	    {
	        SetPlayerData(to_player, P_SKILL_COMBAT_SG, set_value);
			tmp_skill_name = "Combat SG";
			UpdatePlayerDatabaseInt(to_player, "skill_combat_sg", set_value);
	    }
		case 11:
	    {
	        SetPlayerData(to_player, P_SKILL_MICRO_UZI, set_value);
			tmp_skill_name = "Micro Uzi";
			UpdatePlayerDatabaseInt(to_player, "skill_micro_uzi", set_value);
	    }
	    case 12:
	    {
	        SetPlayerData(to_player, P_POWER, set_value);
			tmp_skill_name = "รรจรซร ";
			UpdatePlayerDatabaseInt(to_player, "power", set_value);
	    }
	    default: return SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรฎ รขรขรฅรครฅรญ รชรฎรค รญร รขรปรชร ");
	}

	SetPlayerSkillsInit(to_player);

	format(query, sizeof query, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รจรงรฌรฅรญรจรซ รร รฌ รณรฐรฎรขรฅรญรผ รญร รขรปรชร  %s รญร  %d", GetPlayerNameEx(playerid), tmp_skill_name, set_value);
	SendClientMessage(to_player, 0x3399FFFF, query);

	format(query, sizeof query, "รรป รจรงรฌรฅรญรจรซรจ รจรฃรฐรฎรชรณ %s รณรฐรฎรขรฅรญรผ รญร รขรปรชร  %s รญร  %d", GetPlayerNameEx(to_player), tmp_skill_name, set_value);
	SendClientMessage(playerid, 0x66CC00FF, query);

	if(GetPlayerAdminEx(playerid) <= 5)
	{
		format(query, sizeof query, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รจรงรฌรฅรญรจรซ %s[%d] รณรฐรฎรขรฅรญรผ รญร รขรปรชร  %s รญร  %d", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, tmp_skill_name, set_value);
		SendMessageToAdmins(query, 0x999999FF);
	}

	format(query, sizeof query, "รรงรฌรฅรญรจรซ %s[acc:%d] รณรฐรฎรขรฅรญรผ รญร รขรปรชร  %s รญร  %d", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), tmp_skill_name, set_value);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, query);

	return 1;
}

CMD:admdown(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 5) return 1;

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /admdown [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!GetPlayerAdminEx(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญรฅ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ");

	if(GetPlayerAdminEx(to_player) == 1)
		return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รฏรฎรญรจรงรจรฒรผ รครฎ 0 รณรฐรฎรขรญรฟ. รรฑรฏรฎรซรผรงรณรฉรฒรฅ /deladmin รครซรฟ รฑรญรฟรฒรจรฟ");

	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	AddPlayerData(to_player, P_ADMIN, -, 1);
	UpdatePlayerDatabaseInt(to_player, "admin", GetPlayerAdminEx(to_player));

	new fmt_text[128];

	format(fmt_text, sizeof fmt_text, "รรซร รขรญรปรฉ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรญรจรงรจรซ รร รธ รณรฐรฎรขรฅรญรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รครฎ %d",
	GetPlayerNameEx(playerid), playerid, GetPlayerAdminEx(to_player));

	SendClientMessage(to_player, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรญรจรงรจรซ รณรฐรฎรขรฅรญรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s[%d] รครฎ %d",
	GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, GetPlayerAdminEx(to_player));

	SendMessageToAdmins(fmt_text, 0xFF5533FF);

	format(fmt_text, sizeof fmt_text, "รรฎรญรจรงรจรซ %s[acc:%d] รครฎ ร รครฌ. รณรฐรฎรขรญรฟ %d",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), GetPlayerAdminEx(to_player));

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

	return 1;
}

CMD:admup(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 5) return 1;

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /admup [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!GetPlayerAdminEx(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญรฅ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ");

	if(GetPlayerAdminEx(to_player) > 4)
		return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รฏรฎรขรปรฑรจรฒรผ รจรฃรฐรฎรชร  รขรปรธรฅ รครฎ 4 รณรฐรฎรขรญรฟ");

	if(GetPlayerAdminEx(to_player) >= GetPlayerAdminEx(playerid))
		return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รฏรฎรขรปรฑรจรฒรผ รณรฐรฎรขรฅรญรผ รณ รฃรซร รขรญรฎรฃรฎ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร ");

	AddPlayerData(to_player, P_ADMIN, +, 1);
	UpdatePlayerDatabaseInt(to_player, "admin", GetPlayerAdminEx(to_player));

	new fmt_text[128];

	format(fmt_text, sizeof fmt_text, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรขรปรฑรจรซ รร รธ รณรฐรฎรขรฅรญรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  รครฎ %d",
	GetPlayerNameEx(playerid), playerid, GetPlayerAdminEx(to_player));

	SendClientMessage(to_player, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฏรฎรขรปรฑรจรซ รณรฐรฎรขรฅรญรผ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s[%d] รครฎ %d",
	GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, GetPlayerAdminEx(to_player));

	SendMessageToAdmins(fmt_text, 0xFF5533FF);

	format(fmt_text, sizeof fmt_text, "รรฎรขรปรฑรจรซ %s[acc:%d] รครฎ ร รครฌ. รณรฐรฎรขรญรฟ %d",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), GetPlayerAdminEx(to_player));

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

	return 1;
}

