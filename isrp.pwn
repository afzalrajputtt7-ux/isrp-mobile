    if (GetPlayerData(playerid, P_MEDCARD) != 1)
        return SCM(playerid, COLOR_GREY, "ร รร รฑ รญรฅรฒ รฌรฅรครจรถรจรญรฑรชรฎรฉ รชร รฐรฒรป.");

    if (!strlen(params))
        return SCM(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /med [id รจรฃรฐรฎรชร ]");

    extract params -> new to_player;

    if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ ร รขรฒรฎรฐรจรงรฎรขร รญ.");

    if (!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0))
        return SCM(playerid, COLOR_GREY, "รรฃรฐรฎรช รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ.");

    SCM(playerid, COLOR_BLUE, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ รฏรฎรชร รงร รฒรผ รฌรฅรครจรถรจรญรฑรชรณรพ รชร รฐรฒรณ.");
    SendPlayerOffer(playerid, to_player, OFFER_TYPE_SHOWMED);
