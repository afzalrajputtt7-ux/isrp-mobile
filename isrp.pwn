stock ShowRentBikeDialogARZ(playerid)
{
    new Cache:result;
    new header[96];
    new stringer[2048];
    new sctring[256];
    new query[128];

    format(
        header, sizeof header,
        "{E03131}%s{FFFFFF} | รรฏรฐร รขรซรฅรญรจรฅ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ",
        SERVER_NAME
    );

    stringer[0] = EOS;
    strcat(stringer, "{FFFFFF}#\tรร รงรขร รญรจรฅ\tรรฎรฌรฅรฐ\tรรฅรฉรฑรฒรขรจรฅ\n");

    // 1 โ รรชรณรฒรฅรฐ
    format(
        sctring, sizeof sctring,
        "{E0584B}1.\t{FFFFFF}รรชรณรฒรฅรฐ\t{888888}[-----]\t{E0584B}รรฐรฅรญรครฎรขร รฒรผ\n"
    );
    strcat(stringer, sctring);

    mysql_format(
        mysql, query, sizeof query,
        "SELECT id, model_id, number FROM ownable_cars WHERE owner_id='%d'",
        GetPlayerAccountID(playerid)
    );
    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows();
    new model_id, car_id;
    new number[8];

    for(new i; i < rows; i++)
    {
        car_id   = cache_get_field_content_int(i, "id");
        model_id = cache_get_field_content_int(i, "model_id") - 400;
        cache_get_field_content(i, "number", number);

        format(
            sctring, sizeof sctring,
            "{FFFFFF}%d.\t%s\t{888888}[%s]\t{FFFFFF}รรฎรฑรฒร รขรจรฒรผ รร\n",
            i + 2,
            GetVehicleInfo(model_id, VI_NAME),
            number
        );
        strcat(stringer, sctring);

        SetPlayerListitemValue(playerid, i + 1, car_id);
    }

    cache_delete(result);

    Dialog(
        playerid,
        DIALOG_RENT_BIKE_ARZ,
        DIALOG_STYLE_TABLIST_HEADERS,
        header,
        stringer,
        "รรปรกรฐร รฒรผ",
        "รร รชรฐรปรฒรผ"
    );
}
