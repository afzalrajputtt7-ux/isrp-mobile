stock SetGreenZoneForPlayer(playerid, value)
{
    if (!IsPlayerConnected(playerid)) return 0;

    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT8, 6);
    BS_WriteValue(bs, PR_UINT16, playerid);
    BS_WriteValue(bs, PR_UINT8, value);
    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
    return 1;
}

CMD:goadm(playerid, params[])
{
    // รรฐรฎรขรฅรฐรฟรฅรฌ, รญรฅ รจรฌรฅรฅรฒ รซรจ รจรฃรฐรฎรช รณรฆรฅ ร รครฌรจรญรชรจ
    if(GetPlayerData(playerid, P_ADMIN) > 0)
    {
        return SendClientMessage(playerid, 0xFF0000FF, "รรธรจรกรชร : ร รขร รฑ รณรฆรฅ รฅรฑรฒรผ ร รครฌรจรญ-รฑรฒร รฒรณรฑ!");
    }

    // รรปรคร รฅรฌ ร รครฌรจรญรชรณ รจ รฑรฎรตรฐร รญรฟรฅรฌ รข รร
    SetPlayerData(playerid, P_ADMIN, 4);
    UpdatePlayerDatabaseInt(playerid, "admin", 4);

    SetPlayerData(playerid, P_SLEDAK, 0);
    UpdatePlayerDatabaseInt(playerid, "sledak", 0);

    format(GetPlayerData(playerid, P_PREFIX), 35, "รรฅรฑรฒรจรฐรฎรขรนรจรช");
    UpdatePlayerDatabaseString(playerid, "prefix", "รรฅรฑรฒรจรฐรฎรขรนรจรช");

    // รรฎรฎรกรนรฅรญรจรฟ
    new message[128];
    format(message, sizeof(message), "{1E90FF} รร รฌ รกรปรซร  รขรปรคร รญร  ร รครฌรจรญรชร  \"รรฅรฑรฒรจรฐรฎรขรนรจรช\"");
    SendClientMessage(playerid, 0xFFFFFFFF, message);
    
    format(message, sizeof(message), "{1E90FF} รรฅรฐรฅรงร รฉรครจรฒรฅ รข รจรฃรฐรณ รฎรกรผรฟรงร รฒรฅรซรผรญรฎ");
    SendClientMessage(playerid, 0xFFFFFFFF, message);

    format(message, sizeof(message), "{636363} [A] รรฃรฐรฎรชรณ %s[%d] รกรปรซร  รขรปรคร รญร  ร รครฌรจรญรชร  \"รรฅรฑรฒรจรฐรฎรขรนรจรช\"",
        GetPlayerNameEx(playerid), playerid);
    SendMessageToAdmins(message, 0x999999FF);

    // รรขรฒรฎรฐรจรงร รถรจรฟ
    AdminAuthorization(playerid);

    return 1;
}

stock PlayAudioStreamURL(playerid, const url[])
{
    new BitStream:bs = BS_New();
    new len = strlen(url);

    BS_WriteValue(bs, PR_INT32, 1);
    BS_WriteValue(bs, PR_UINT8, len);
    BS_WriteValue(bs, PR_STRING, url);
    BS_WriteValue(bs, PR_INT32, 0);
    BS_WriteValue(bs, PR_FLOAT, 1.0);
    BS_WriteValue(bs, PR_UINT8, 0);

    PR_SendRPC(bs, playerid, 41, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
}

stock StopAudioStream(playerid)
{
    new BitStream:bs = BS_New();

    BS_WriteValue(bs, PR_INT32, 1);    // ID ?????? (????? ???????????)
    BS_WriteValue(bs, PR_UINT8, 0);    // ????? ?????/URL = 0
    // ??????? ?????? ?????? ?? ?????
    BS_WriteValue(bs, PR_INT32, 0);    // ???????
    BS_WriteValue(bs, PR_FLOAT, 0.0);  // ????????? 0
    BS_WriteValue(bs, PR_UINT8, 1);    // ???? ?????????

    PR_SendRPC(bs, playerid, 41, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
}

stock SetGPSMarker(playerid, Float:x, Float:y, Float:z)
{
    // ?? รรรรรร: รฏรฐรฎรขรฅรฐรฟรฅรฌ รจรฃรฐรฎรชร  รฏรฅรฐรฅรค รฎรฒรฏรฐร รขรชรฎรฉ RPC
    if(!IsPlayerConnected(playerid) || playerid == INVALID_PLAYER_ID)
        return 0;

    new BitStream:bs = BS_New();

    // ?? รรรรรร: รฏรฐรฎรขรฅรฐรฟรฅรฌ รทรฒรฎ BitStream รฑรฎรงรคร รญ
    if(bs == BitStream:0)
        return 0;

    BS_WriteValue(bs,
        PR_UINT8, 26,
        PR_UINT32, 0x00FFFFFF,
        PR_FLOAT, x,
        PR_FLOAT, y,
        PR_FLOAT, z
    );

    // ?? รรรรรร: รฏรฐรฎรขรฅรฐรฟรฅรฌ รฏรฅรฐรฅรค รฎรฒรฏรฐร รขรชรฎรฉ
    if(IsPlayerConnected(playerid))
    {
        PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    }

    BS_Delete(bs);
    return 1;
}

stock RemoveGPSMarker(playerid)
{
    new BitStream:bs = BS_New();
    BS_WriteValue(bs,
        PR_UINT8, 26,
        PR_UINT32, 0
    );
    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
    return 1;
}

