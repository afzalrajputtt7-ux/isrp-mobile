CMD:flip(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    extract params -> new target_player; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /flip [id รจรฃรฐรฎรชร ]");

    if(!IsPlayerConnected(target_player) || !IsPlayerLogged(target_player))
        return ShowNotificationNew(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ.");

    if(!IsPlayerInAnyVehicle(target_player))
        return ShowNotificationNew(playerid, 2, 5, 2, 0, "รรฃรฐรฎรช รญรฅ รข รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฌ รฑรฐรฅรครฑรฒรขรฅ.");

    new vehicleid = GetPlayerVehicleID(target_player);
    new Float:angle;

    GetVehicleZAngle(vehicleid, angle);
    SetVehicleZAngle(vehicleid, angle);

    new Float:x, Float:y, Float:z;
    GetVehiclePos(vehicleid, x, y, z);
    SetVehiclePos(vehicleid, x, y, z + 0.5);

    new fmt_msg[128];
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฏรฅรฐรฅรขรฅรฐรญรณรซ รฒรฐร รญรฑรฏรฎรฐรฒ %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(target_player), target_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);

    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รฏรฅรฐรฅรขรฅรฐรญรณรซรจ รฒรฐร รญรฑรฏรฎรฐรฒ รจรฃรฐรฎรชร  %s[%d]", GetPlayerNameEx(target_player), target_player);
    SendClientMessage(playerid, -1, fmt_msg);

    format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฅรฐรฅรขรฅรฐรญรณรซ รขร รธ รฒรฐร รญรฑรฏรฎรฐรฒ", GetPlayerNameEx(playerid), playerid);
    SendClientMessage(target_player, 0x66CC00FF, fmt_msg);

    format(fmt_msg, sizeof fmt_msg, "รรฅรฐรฅรขรฅรฐรญรณรซ รฒรฐร รญรฑรฏรฎรฐรฒ %s[acc:%d]", GetPlayerNameEx(target_player), GetPlayerAccountID(target_player));
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

    return 1;
}

CMD:setfuel(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 3) return 1;

	extract params -> new vehicleid, fuel; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /setfuel [id รฒรฐร รญรฑรฏรฎรฐรฒร ] [รชรฎรซ-รขรฎ รฒรฎรฏรซรจรขร ]");

	if(!IsValidVehicle(vehicleid)) return SendClientMessage(playerid, 0xCECECEFF, "รร รญรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

	if(!(0 <= fuel <= 150)) return SendClientMessage(playerid, 0x999999FF, "รรฎรซรจรทรฅรฑรฒรขรฎ รฒรฎรฏรซรจรขร  รฎรฒ 0 รครฎ 150");

	SetVehicleData(vehicleid, V_FUEL, fuel);

	new fmt_text[80];

	format(fmt_text, sizeof fmt_text, "รรป รณรฑรฒร รญรฎรขรจรซรจ %d รฒรฎรฏรซรจรขร  รข รร ยน%d", fuel, vehicleid);
	SendClientMessage(playerid, -1, fmt_text);

	if(GetPlayerAdminEx(playerid) >= 5)
	{
		format(fmt_text, sizeof fmt_text, "[A] %s[%d] รณรฑรฒร รญรฎรขรจรซ %d รฒรฎรฏรซรจรขร  รข รร ยน%d", GetPlayerNameEx(playerid), playerid, fuel, vehicleid);
		SendMessageToAdmins(fmt_text, 0x999999FF);
	}

	format(fmt_text, sizeof fmt_text, "รรฑรฒร รญรฎรขรจรซ %d รฒรฎรฏรซรจรขร  รข ร รขรฒรฎ ยน%d", fuel, vehicleid);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:settime(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 7) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new time; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /settime [รขรฐรฅรฌรฟ (0-23)]");

	if(!(0 <= time <= 23)) return SendClientMessage(playerid, 0x999999FF, ""SC"รรฐรฅรฌรฟ รฎรฒ 0 รครฎ 23 รทร รฑรฎรข");

	SetWorldTime(time);

	new fmt_text[999];

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รณรฑรฒร รญรฎรขรจรซ รขรฐรฅรฌรฟ รญร  รฑรฅรฐรขรฅรฐรฅ รญร  %02d:00", GetPlayerNameEx(playerid), playerid, time);
	SendMessageToAdmins(fmt_text, 0x999999FF);
	
	format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รณรฑรฏรฅรธรญรฎ รณรฑรฒร รญรฎรขรจรซรจ รขรฐรฅรฌรฟ รญร  รฑรฅรฐรขรฅรฐรฅ รญร  %02d:00", time);
	SendClientMessage(playerid, -1, fmt_text);	

	return 1;
}

CMD:setweather(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 2) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

