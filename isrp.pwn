	extract params -> new user_id; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /getname [รญรฎรฌรฅรฐ ร รชรชร รณรญรฒร ]");

	new name[21],
		fmt_text[120];

	format(name, sizeof name, "%s", GetPlayerNameBySqlID(user_id));

	if(strcmp(name, "none", true))
	{
		format(fmt_text, sizeof fmt_text, "รรฌรฟ: %s / รรฎรฌรฅรฐ ร รชรชร รณรญรฒร : %d", name, user_id);

		SendClientMessage(playerid, 0x3399FFFF, fmt_text);
