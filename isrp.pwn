        GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, 0x3399FFFF, query);

    format(query, sizeof query, "รรป รจรงรฌรฅรญรจรซรจ รขรญรฅรธรญรฎรฑรฒรผ %s[%d]", GetPlayerNameEx(to_player), to_player);
