CMD:buycar(playerid) 
{
if(player_sell_ownable_car[playerid] == true)
                         	{
                         SendClientMessage(playerid, 0xCECECEFF, "รรญร รทร รซร  รฏรฐรฎรคร รฉรฒรฅ รจรซรจ รณรกรฅรฐรจรฒรฅ รฑรขรฎรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รฏรฐรฎรคร รฆรจ");
                         return 1;
                         }
                         else {
new vehicleid = GetNearestVehicleID(playerid, 5.0);

if(vehicleid != -1)	
{
	     if(ownable_car_sell_status[vehicleid] == true)
                         	{
	        new model_id = GetVehicleData(vehicleid, V_MODELID);
            new to_player = GetOwnableCarData(vehicleid, OC_LAST_OWNER_GAME_ID);
            new price = GetOwnableCarData(vehicleid, OC_LAST_PRICE);
            
			if((GetPlayerOwnableCars(playerid) + 1) > GetPlayerCarSlots(playerid))
				return SendClientMessage(playerid, 0xCECECEFF, "ร รขร รฑ รญรฅรฒ รฑรขรฎรกรฎรครญรปรต รฑรซรฎรฒรฎรข รครซรฟ รฒรฐร รญรฑรฏรฎรฐรฒร ");

			if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
				return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รขรปรฃรฐรณรงรจรฒรผ รฑรขรฎรฉ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รฑรฅรฐรขรฅรฐร  {888888}(/car > 7)");

			if(GetPlayerMoneyEx(playerid) < GetOwnableCarData(vehicleid, OC_LAST_PRICE))
				return SendClientMessage(playerid, 0xCECECEFF, "ร รขร รฑ รญรฅรฒ รครฅรญรฅรฃ รทรฒรฎรกรป รชรณรฏรจรฒรผ รฝรฒรฎรฒ รฒรฐร รญรฑรฏรฎรฐรฒ");
                
                SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_OWNABLE_CAR2, price, vehicleid);
            }
            else  SendClientMessage(playerid, 0xCECECEFF, "รรฒร  รฌร รธรจรญร  รญรฅ รฏรฐรฎรคร รฅรฒรฑรฟ");
    }
    else SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรฑรฟ รฐรฟรครฎรฌ รฑ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ รชรฎรฒรฎรฐรปรฉ รตรฎรฒรจรฒรฅ รชรณรฏรจรฒรผ");
}
}


