				SendClientMessage(to_player, 0x3399FFFF, fmt_str);

				SendClientMessage(to_player, 0xFFFFFFFF, "รร รฆรฌรจรฒรฅ {00CC00}Y {FFFFFF}รทรฒรฎรกรป รฑรฎรฃรซร รฑรจรฒรผรฑรฟ รจรซรจ {FF6600}N {FFFFFF}รครซรฟ รฎรฒรชร รงร ");

				format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ %s รงร รฏรฐร รขรชรณ รฒรฐร รญรฑรฏรฎรฐรฒร  รญร  %d รซ รงร  %d รฐรณรก", GetPlayerNameEx(to_player), value_1, value_2);
				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
			case OFFER_TYPE_REPAIR_CAR:
			{
				format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รฏรฎรทรจรญรจรฒรผ รร รธ รฒรฐร รญรฑรฏรฎรฐรฒ รงร  %d รฐรณรก", GetPlayerNameEx(playerid), value_1);
				SendClientMessage(to_player, 0x3399FFFF, fmt_str);

				ShowNotificationNew(to_player, 4, 10, notifcmdyes, 0, "รรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ รจรฃรฐรฎรชร ", ">");

				format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ %s รฑรครฅรซร รฒรผ รฐรฅรฌรฎรญรฒ รฒรฐร รญรฑรฏรฎรฐรฒร  รงร  %d รฐรณรก", GetPlayerNameEx(to_player), value_1);
				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
			case OFFER_TYPE_SELL_BUSINESS:
			{
				format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รชรณรฏรจรฒรผ รกรจรงรญรฅรฑ ยน%d \"%s\" รฏรฎ รถรฅรญรฅ %d รฐรณรก", GetPlayerNameEx(playerid), value_1, GetBusinessData(value_1, B_NAME), value_2);
				SendClientMessage(to_player, 0x3399FFFF, fmt_str);

				ShowNotificationNew(to_player, 4, 10, notifcmdyes, 0, "รรฐรฅรครซรฎรฆรฅรญรจรฅ รฎรฒ รจรฃรฐรฎรชร ", ">");

				format(fmt_str, sizeof fmt_str, "รรป รฏรฐรฅรครซรฎรฆรจรซรจ %s รชรณรฏรจรฒรผ รร รธ รกรจรงรญรฅรฑ \"%s\" รงร  %d รฐรณรก", GetPlayerNameEx(to_player), GetBusinessData(value_1, B_NAME), value_2);
				SendClientMessage(playerid, 0x3399FFFF, fmt_str);
			}
			case OFFER_TYPE_BUSINESS_MANAGER:
			{
				format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รฑรฒร รฒรผ รฑรฎรฒรฐรณรครญรจรชรฎรฌ รฅรฃรฎ รฏรฐรฅรครฏรฐรจรฟรฒรจรฟ (%s)", GetPlayerNameEx(playerid), GetBusinessData(value_1, B_NAME));
