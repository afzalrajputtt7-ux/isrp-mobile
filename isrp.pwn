stock IsAllSportPartsInstalled(value)
{
    if(IsSportPartInstalled(value, 1) &&
       IsSportPartInstalled(value, 2) &&
       IsSportPartInstalled(value, 3) &&
       IsSportPartInstalled(value, 4) &&
       IsSportPartInstalled(value, 5))
    {
        return 1;
    }
    return 0;
}

CMD:sporttest(playerid)
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return SendClientMessage(playerid, -1, "รรป รญรฅ รข รฌร รธรจรญรฅ!");

    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == -1) return SendClientMessage(playerid, -1, "รรฒรฎ รญรฅ รซรจรทรญรฎรฅ ร รขรฒรฎ!");

    new current_val = GetOwnableCarData(index, OC_SPORT);

    if(IsAllSportPartsInstalled(current_val))
    {
        SendClientMessage(playerid, -1, "{00FF00}[รรฅรฑรฒ] {FFFFFF}รร  รฝรฒรฎรฌ ร รขรฒรฎ รณรฑรฒร รญรฎรขรซรฅรญรป รรร 5 รฑรฏรฎรฐรฒรจรขรญรปรต รครฅรฒร รซรฅรฉ!");
    }
    else
    {
        new string[128], missing[64];
        // รรฎรกรจรฐร รฅรฌ รฑรฏรจรฑรฎรช รฒรฎรฃรฎ, รทรฅรฃรฎ รญรฅรฒ
        if(!IsSportPartInstalled(current_val, 1)) strcat(missing, "1, ");
        if(!IsSportPartInstalled(current_val, 2)) strcat(missing, "2, ");
        if(!IsSportPartInstalled(current_val, 3)) strcat(missing, "3, ");
        if(!IsSportPartInstalled(current_val, 4)) strcat(missing, "4, ");
        if(!IsSportPartInstalled(current_val, 5)) strcat(missing, "5, ");

        format(string, sizeof(string), "{FF0000}[รรฅรฑรฒ] {FFFFFF}รรฑรฒร รญรฎรขรซรฅรญรป รญรฅ รขรฑรฅ รครฅรฒร รซรจ. รรฒรฑรณรฒรฑรฒรขรณรพรฒ: %s", missing);
        SendClientMessage(playerid, -1, string);
    }

    new info[64];
    format(info, sizeof(info), "รรฅรชรณรนรฅรฅ รงรญร รทรฅรญรจรฅ รข รร: {FFFF00}%d", current_val);
    SendClientMessage(playerid, -1, info);

    return 1;
}

CMD:sporton(playerid)
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รรป รครฎรซรฆรญรป รกรปรฒรผ รงร  รฐรณรซรฅรฌ!");

    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == -1) return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รรฒรฎ รญรฅ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ.");

    if(!IsAllSportPartsInstalled(GetOwnableCarData(index, OC_SPORT)))
        return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รรซรฟ ร รชรฒรจรขร รถรจรจ รฏรฐรฎรธรจรขรชรจ รญรณรฆรญรป รขรฑรฅ 5 รครฅรฒร รซรฅรฉ รฒรพรญรจรญรฃร !");

    if(vInfo[vehicleid][vAccel] == 33.0)
        return SendClientMessage(playerid, -1, "{FFFF00}[รรญรดรฎ] {FFFFFF}รรฏรฎรฐรฒ-รฐรฅรฆรจรฌ รณรฆรฅ ร รชรฒรจรขรจรฐรฎรขร รญ.");

    SetVehicleAcceleration(vehicleid, 33.0, 1);
    SendClientMessage(playerid, -1, "{00FF00}[รรฏรฎรฐรฒ] {FFFFFF}รรฏรฎรฐรฒ รฏรฐรฎรธรจรขรชร  รขรชรซรพรทรฅรญร .");
    return 1;
}

CMD:sportoff(playerid)
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รรป รครฎรซรฆรญรป รกรปรฒรผ รข ร รขรฒรฎ!");

    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == -1) return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รรฒรฎ รญรฅ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ.");

    if(!IsAllSportPartsInstalled(GetOwnableCarData(index, OC_SPORT)))
        return SendClientMessage(playerid, -1, "{FF0000}[รรธรจรกรชร ] {FFFFFF}รร  รฝรฒรฎรฌ ร รขรฒรฎ รญรฅรฒ รฑรฏรฎรฐรฒรจรขรญรฎรฉ รฏรฐรฎรธรจรขรชรจ.");

    SetVehicleAcceleration(vehicleid, 0, 1);
    SendClientMessage(playerid, -1, "{FFFF00}[รรฏรฎรฐรฒ] {FFFFFF}รรฏรฎรฐรฒ รฏรฐรฎรธรจรขรชร  รฎรฒรชรซรพรทรฅรญร .");
    return 1;
}

stock IsDriftPartInstalled(current_value, part_digit)
{
    new s_val[12];
    format(s_val, sizeof(s_val), "%d", current_value);
    new char_digit = part_digit + '0';
    for(new i = 0; i < strlen(s_val); i++) {
        if(s_val[i] == char_digit) return 1;
    }
    return 0;
}

stock IsAllDriftPartsInstalled(value)
{
    if(IsDriftPartInstalled(value, 1) &&
       IsDriftPartInstalled(value, 2) &&
       IsDriftPartInstalled(value, 3) &&
       IsDriftPartInstalled(value, 4) &&
       IsDriftPartInstalled(value, 5))
    {
        return 1;
    }
    return 0;
}

CMD:drift1(playerid)
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return 1;
    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == -1) return 1;
    new current = GetOwnableCarData(index, OC_DRIFT);
    if(IsDriftPartInstalled(current, 1)) return 1;
    new new_val = current + 1;
    SetOwnableCarData(index, OC_DRIFT, new_val);
    new query[128];
    mysql_format(mysql, query, sizeof(query), "UPDATE ownable_cars SET drift='%d' WHERE id='%d'", new_val, GetOwnableCarData(index, OC_SQL_ID));
