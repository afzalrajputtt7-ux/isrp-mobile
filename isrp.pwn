CMD:gzcolor(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4) return 1;

	extract params -> new gang_id; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /gzcolor [id รกร รญรครป] (0-รรขรฎรกรฎรครญร รฟ รงรฎรญร , 1-รรฐรงร รฌร รฑรฑรชร รฟ รรร, 2-รร รฒรปรฐรฅรขรฑรชร รฟ รรร, 3-รรปรฒรชร รฐรจรญรฑรชร รฟ รรร)");

	if(!(0 <= gang_id <= 3))
		return SendClientMessage(playerid, 0x999999FF, "รร รญรครป: 0-รรขรฎรกรฎรครญร รฟ รงรฎรญร , 1-รรฐรงร รฌร รฑรฑรชร รฟ รรร, 2-รร รฒรปรฐรฅรขรฑรชร รฟ รรร, 3-รรปรฒรชร รฐรจรญรฑรชร รฟ รรร");

	new gang_zone_id = -1;

	for(new idx; idx < g_gang_zones_loaded; idx ++)
	{
