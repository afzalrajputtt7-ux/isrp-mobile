	return 1;
}

CMD:mute(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 1) return 1;
	

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /mute [id รจรฃรฐรฎรชร ] [รขรฐรฅรฌรฟ รข รฌรจรญรณรฒร รต] [รฏรฐรจรทรจรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]");

	extract params -> new to_player, mute_time, string: reason[30];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(1 <= mute_time <= 360)) return SendClientMessage(playerid, 0xCECECEFF, "รรฐรฅรฌรฟ รครฎรซรฆรญรฎ รกรปรฒรผ รญรฅ รฌรฅรญรผรธรฅ 1 รจ รญรฅ รกรฎรซรผรธรฅ 360 รฌรจรญรณรฒ");
	if(GetPlayerData(to_player, P_MUTE) > 0) return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รณรฆรฅ รฅรฑรฒรผ รฌรณรฒ");
	
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	if(AntiSliv(playerid, "/mute")) return true;
	
	AddAdminStat(playerid, "mutes_total", P_MUTES_TOTAL);
	AddAdminStat(playerid, "mutes_today", P_MUTES_TODAY);

	new fmt_msg[128];
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรปรคร รซ รกรซรฎรชรจรฐรฎรขรชรณ รทร รฒร  รจรฃรฐรฎรชรณ %s รญร  %d รฌรจรญ", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), mute_time);

	if(strlen(reason))
		format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	SetPlayerData(to_player, P_MUTE, mute_time * 60);
	UpdatePlayerDatabaseInt(to_player, "mute", mute_time * 60);

	SendClientMessage(to_player, 0xCECECEFF, "รรฐรฅรฌรฟ รครฎ รฎรชรฎรญรทร รญรจรฟ รกร รญร  รทร รฒร : {CCCC00}/time");

	format(fmt_msg, sizeof fmt_msg, "รรปรคร รซ %s[acc:%d] รกรซรฎรชรจรฐรฎรขรชรณ รทร รฒร  รญร  %d รฌรจรญ. รรฐรจรทรจรญร : %s",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), mute_time, reason);

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

