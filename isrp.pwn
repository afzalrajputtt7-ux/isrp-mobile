		Dialog
		(
			playerid, DIALOG_OWNABLE_CAR_LOAD_LUT, DIALOG_STYLE_LIST,
			"{FFCD00}รรจรฑรฒรฅรฌร  รณรฏรฐร รขรซรฅรญรจรฟ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ",
			w_str,
			"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
		);
	}
	else
	{
