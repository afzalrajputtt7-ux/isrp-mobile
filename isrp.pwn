CMD:pos(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) == 0) return 1;

	new Float: x, Float: y, Float: z, interior, virtual_world;

	if(sscanf(params, "P<,>fff", x, y, z))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /pos [x y z]");

	sscanf(params, "P<,>{fff}dd", interior, virtual_world);

	return SetPlayerPosEx(playerid, x, y, z, interior, virtual_world);
}

CMD:d(playerid, params[])
{
	if(!GetPlayerTeamEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฎรฐรฃร รญรจรงร รถรจรฟรต");
	else if(TEAM_OPG_ARZAMASKAYA <= GetPlayerTeamEx(playerid) <= TEAM_OPG_LYTKARINSKAYA) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รครซรฟ รฑรฎรฒรฐรณรครญรจรชรฎรข รฃรฎรฑ. รฎรฐรฃร รญรจรงร รถรจรฉ");
	else if(IsPlayerMuted(playerid) > 0) return SendClientMessage(playerid, 0xFF6600FF, "รรฎรฑรฒรณรฏ รข รทร รฒ รงร รกรซรฎรชรจรฐรฎรขร รญ. รรฐรฅรฌรฟ รครฎ รฐร รงรกรซรฎรชรจรฐรฎรขรชรจ: {66CC33}/time");	
	if(!IsWorkDayStarted(playerid)) return 1;
	else if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /d [รฒรฅรชรฑรฒ]");


	new fmt_msg[144];

	format(fmt_msg, sizeof fmt_msg, "[D] %s %s[%d]: %s", GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), playerid, params);

	if(IsAIP(params))
	{
      	SendClientMessage(playerid, -1, "รรฎรครฎรงรฐรฅรญรจรฟ รข รฐรฅรชรซร รฌรฅ!");
       	return false;
    }

	for(new i; i < MAX_PLAYERS; i ++)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!IsPlayerLogged(i)) continue;
		if(!GetPlayerTeamEx(i)) continue;
		if(GetPlayerData(i, P_ADVISOR_BLOCK_CHAT)) continue;

		SendClientMessage(i, 0xFF9999FF, fmt_msg);
	}

	SetPlayerChatBubble(playerid, "รฑรชร รงร รซ(ร ) รทรฒรฎ-รฒรฎ รข รฐร รถรจรพ รฎรฐรฃร รญรจรงร รถรจรฉ", 0xDD99FFAA, 10.0, 4000);

	return 1;
}

