		SetPlayerListitemValue(playerid, count ++, idx);
	}
	Dialog(playerid, DIALOG_HOTEL_FLOOR_LIFT, DIALOG_STYLE_LIST, "{FFCD00}รรปรกรฅรฐรจรฒรฅ รฝรฒร รฆ", string, "รรปรกรฐร รฒรผ", "รรฒรฌรฅรญร ");
}

stock ShowPlayerHotelFloorInfo(playerid, hotel_id, floor_id)
{
	if(0 <= hotel_id <= MAX_HOTELS-1)
	{
		if(0 <= floor_id <= MAX_HOTEL_FLOORS-1)
		{
			new string[512];
			new fmt_str[45 + 1];

			new rent_time;
			new time = gettime();

			new s_idx = floor_id * 12;
			new e_idx = s_idx + 12;

			string = "รรฎรฌรฅรฐ\t\tรรฒร รฒรณรฑ\t\tรรฏรซร รทรฅรญรญรปรฅ รครญรจ\tรรฎรฑรฒรฎรฟรซรฅรถ\n\n{FFFFFF}";
			while(s_idx < e_idx)
			{
				if(IsHotelRoomOwned(hotel_id, s_idx))
				{
					rent_time = GetElapsedTime(GetHotelData(hotel_id, s_idx, H_RENT_DATE), time, CONVERT_TIME_TO_DAYS);
					if(rent_time < 0)
						rent_time = 0;

					format(fmt_str, sizeof fmt_str, "%d\t\t%s\t\t%d\t\t%s\n", (s_idx % 12) + 1, rent_time > 0 ? ("รร รญรฟรฒ\t") : ("รรปรฑรฅรซรฅรญรจรฅ"), rent_time, GetHotelData(hotel_id, s_idx, H_OWNER_NAME));
				}
				else format(fmt_str, sizeof fmt_str, "%d\t\tรรขรฎรกรฎรครฅรญ\n", (s_idx % 12) + 1);
				strcat(string, fmt_str);

				s_idx ++;
			}

			format(fmt_str, sizeof fmt_str, "{66CC99}รรฏรจรฑรฎรช รญรฎรฌรฅรฐรฎรข รญร  %d รฝรฒร รฆรฅ", floor_id + 1);
			Dialog(playerid, DIALOG_HOTEL_FLOOR_INFO, DIALOG_STYLE_MSGBOX, fmt_str, string, "รร รงร รค", "รร รชรฐรปรฒรผ");
		}
	}
}

