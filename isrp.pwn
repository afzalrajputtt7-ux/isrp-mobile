CMD:radial(playerid)
{
    if(!IsPlayerInAnyVehicle(playerid))
        return SendClientMessage(playerid, 0xCECECE, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรฑรฟ รข รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

    new vehicleid = GetPlayerVehicleID(playerid);
    if(vehicleid == INVALID_VEHICLE_ID || vehicleid >= MAX_VEHICLES)
        return SendClientMessage(playerid, 0xCECECE, "รรธรจรกรชร : 0001. รรฑรซรจ รข รขรจรครจรฒรฅ รฝรฒรฎ รฒรฎ รญร รฏรจรธรจรฒรฅ รฐร รงรฐร รกรฎรฒรทรจรชร รฌ");

    new Node:JSONObject = JSON_Object();
    new Node:Info = JSON_Array();

    if(vehicleid < MAX_VEHICLES)
    {
        Info = JSON_Append(Info, JSON_Array(JSON_Int(1))); // ????????
        if(GetVehicleParam(vehicleid, V_LOCK)) Info = JSON_Append(Info, JSON_Array(JSON_Int(3))); // ?????
        if(vInfo[vehicleid][vLaunchControl]) Info = JSON_Append(Info, JSON_Array(JSON_Int(5))); // ?????
        if(GetVehicleParam(vehicleid, V_ENGINE)) Info = JSON_Append(Info, JSON_Array(JSON_Int(6))); // ?????????
        if(vInfo[vehicleid][vEnableNeon]) Info = JSON_Append(Info, JSON_Array(JSON_Int(12))); // ?????????
        if(vInfo[vehicleid][vEnableHighLights]) Info = JSON_Append(Info, JSON_Array(JSON_Int(13))); // ??????? ????
        if(GetVehicleParam(vehicleid, V_LIGHTS)) Info = JSON_Append(Info, JSON_Array(JSON_Int(14))); // ????
        if(vInfo[vehicleid][vEnableStrob]) Info = JSON_Append(Info, JSON_Array(JSON_Int(15))); // ??????????
        if(vInfo[vehicleid][vEnableHydraulics]) Info = JSON_Append(Info, JSON_Array(JSON_Int(19))); // ??????????
    }

    JSON_SetArray(JSONObject, "s", Info);
    ShowPlayerGUI(playerid, 27, JSONObject);

    return true;
}


stock SetVehicleSpeedometerInfo(vehicleid, Float:fuel = 0.0, Float:mileage = 0.0)
{
	vInfo[vehicleid][vFuel] = fuel;
	vInfo[vehicleid][vMileage] = mileage;

	foreach(new playerid: Player)
	{	
		if(GetPlayerVehicleID(playerid) == vehicleid && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) SetVehicleSpeedometerInfoFP(playerid, vehicleid, fuel, mileage); 
		else continue;
	}
} 

stock SetVehicleSpeedometerInfoFP(playerid, vehicleid, Float:fuel = 0.0, Float:mileage = 0.0)
{
	new BitStream:bitstream = BS_New();
	BS_WriteValue(bitstream, PR_UINT16, vehicleid);
	BS_WriteValue(bitstream, PR_UINT8, 14);

	BS_WriteValue(bitstream, PR_UINT32, fuel);
	BS_WriteValue(bitstream, PR_UINT32, mileage); 

	PR_SendRPC(bitstream, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
	BS_Delete(bitstream);
}
stock SetVehicleTonerForPlayer(playerid, vehicleid, front, rear, front_side, back_side)
{
	new BitStream:bitstream = BS_New();
	BS_WriteValue(bitstream, PR_UINT16, vehicleid);
	BS_WriteValue(bitstream, PR_UINT8, 0);

	BS_WriteValue(bitstream, PR_UINT32, front);
	BS_WriteValue(bitstream, PR_UINT32, rear);
	BS_WriteValue(bitstream, PR_UINT32, front_side);
	BS_WriteValue(bitstream, PR_UINT32, back_side); 

	PR_SendRPC(bitstream, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
	BS_Delete(bitstream);
}





