					else { GivePlayerMoneyEx(BlackJackLobby[lobby][Table3Id], -pBJInfo[BlackJackLobby[lobby][Table3Id]][pBJBet]); format(str, sizeof str, "%d รฐรณb", playermoney(BlackJackLobby[lobby][Table3Id])); PlayerTextDrawSetString(BlackJackLobby[lobby][Table3Id], bj_money[BlackJackLobby[lobby][Table3Id]], str); }
