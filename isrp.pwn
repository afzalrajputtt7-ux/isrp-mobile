CMD:givemic(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_RADIO) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givemic [id รจรฃรฐรฎรชร ]");


	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!GetPVarInt(to_player, "radio_mic"))
		SendPlayerOffer(playerid, to_player, OFFER_TYPE_GIVE_MIC);

	else
	{
		new fmt_text[128];

		format(fmt_text, sizeof fmt_text, "%s %s[%d] รฎรฒรชรซรพรทรจรซ รร รฑ รฎรฒ รฐร รครจรฎ-รฝรดรจรฐร ",
		GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), playerid);

		SendClientMessage(to_player, 0xFF5533FF, fmt_text);

		format(fmt_text, sizeof fmt_text, "รรป รฎรฒรชรซรพรทรจรซรจ %s[%d] รฎรฒ รฐร รครจรฎ-รฝรดรจรฐร ", GetPlayerNameEx(to_player), to_player);
		SendClientMessage(playerid, 0x3399FFFF, fmt_text);

		format(fmt_text, sizeof fmt_text, "[รรร] %s %s[%d] รฎรฒรชรซรพรทรจรซ %s[%d] รฎรฒ รฐร รครจรฎ-รฝรดรจรฐร ",
		GetPlayerJobAndRankName(playerid), GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);

		SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_text, 0x99CC99FF, playerid);

		SetPVarInt(to_player, "radio_mic", 0);
	}

	return 1;
}

