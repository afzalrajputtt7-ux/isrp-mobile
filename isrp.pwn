					else { GivePlayerMoneyEx(BlackJackLobby[lobby][Table4Id], -pBJInfo[BlackJackLobby[lobby][Table4Id]][pBJBet]); format(str, sizeof str, "%d รฐรณb", playermoney(BlackJackLobby[lobby][Table4Id])); PlayerTextDrawSetString(BlackJackLobby[lobby][Table4Id], bj_money[BlackJackLobby[lobby][Table4Id]], str); }
