CMD:setprods(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return 1;

	extract params -> new biz_id, amount; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /setprods [id รกรจรงรญรฅรฑร ] [รชรฎรซ-รขรฎ]");

	if(!(0 <= amount <= 10000))
		return SendClientMessage(playerid, 0x999999FF, "รรฎรซรจรทรฅรฑรฒรขรฎ รฏรฐรฎรครณรชรฒรฎรข รฎรฒ 0 รครฎ 10000");

	if(!(0 <= biz_id <= g_business_loaded - 1))
		return SendClientMessage(playerid, 0x999999FF, "รร รญรญรฎรฃรฎ รกรจรงรญรฅรฑร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

	SetBusinessData(biz_id, B_PRODS, amount);

	new fmt_text[90];

	format(fmt_text, sizeof fmt_text, "UPDATE business SET products=%d WHERE id=%d", GetBusinessData(biz_id, B_PRODS), GetBusinessData(biz_id, B_SQL_ID));
	mysql_query(mysql, fmt_text, false);

	format(fmt_text, sizeof fmt_text, "รรป รณรฑรฒร รญรฎรขรจรซรจ %d รฏรฐรฎรครณรชรฒรฎรข รข รกรจรงรญรฅรฑรฅ ยน%d", amount, biz_id);
	SendClientMessage(playerid, 0x66CC33FF, fmt_text);

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รณรฑรฒร รญรฎรขรจรซ %d รฏรฐรฎรครณรชรฒรฎรข รข รกรจรงรญรฅรฑรฅ ยน%d", GetPlayerNameEx(playerid), playerid, amount, biz_id);
	SendMessageToAdmins(fmt_text, 0x999999FF);

	return 1;
}

