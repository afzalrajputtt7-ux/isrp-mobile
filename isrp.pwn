		Dialog
		(
			playerid, DIALOG_OPEN_HOOD_OR_TRUNK, DIALOG_STYLE_MSGBOX,
			" ",
			"\t{CC9900}รรฏรฐร รขรซรฅรญรจรฟ ร รขรฒรฎ",
			"รร รฏรฎรฒ", "รร รฃร รฆรญรจรช"
		);
	}
	return 1;
}

CMD:i(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);

	if(!IsABike(vehicleid))
	{
		if(!IsPlayerDriver(playerid))
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รงร  รฐรณรซรฅรฌ");

		new stationid = GetNearestFuelStation(playerid, 10.0);
		if(stationid != -1)
		{
			FuelStationFillCar(playerid, vehicleid, stationid);
		}
		else SendClientMessage(playerid, 0xCECECEFF, "รรฎรกรซรจรงรฎรฑรฒรจ รญรฅรฒ รงร รฏรฐร รขรฎรทรญรปรต รฑรฒร รญรถรจรฉ");
	}
	return 1;
}

CMD:alarm(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);

	if(!IsABike(vehicleid))
	{
		if(!IsPlayerDriver(playerid))
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รงร  รฐรณรซรฅรฌ");

		alarm = (GetVehicleData(vehicleid, V_ALARM) ^ VEHICLE_PARAM_ON);
		SetVehicleData(vehicleid, V_ALARM, alarm);
	}
	return 1;
}

CMD:charity(playerid, params[])
{
	new Cache: result;
	new rows;
	new money;
	new fmt_str[75];
	new string[1024];

	cache_set_active(charity_cache_data);
	rows = cache_num_rows();

	string = "รรณรฌรฌร \t\tรรฌรฟ\n\n{FFFFFF}";
	for(new idx; idx < rows; idx ++)
	{
		cache_get_row(idx, 0, fmt_str);
		money = cache_get_row_int(idx, 1);

		format(fmt_str, sizeof fmt_str, "%d รฐรณรก\t\t%s\n", money, fmt_str);
		strcat(string, fmt_str);
	}
	cache_set_active(Cache:0); //unset active cache

	format(fmt_str, sizeof fmt_str, "SELECT SUM(money) as money FROM charity WHERE uid=%d LIMIT 1", GetPlayerAccountID(playerid));
	result = mysql_query(mysql, fmt_str, true);

	money = cache_get_row_int(0, 0);
	cache_delete(result);

	format(fmt_str, sizeof fmt_str, "\n{999999}รรณรฌรฌร  รร รธรจรต รฏรฎรฆรฅรฐรฒรขรฎรขร รญรจรฉ: %d รฐรณรก", money);
	strcat(string, fmt_str);

	return Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "{00CC00}รรฎรฏ 25 รกรซร รฃรฎรฒรขรฎรฐรจรฒรฅรซรฅรฉ", string, "รร รชรฐรปรฒรผ", "");
}

