				format(fmt_str, sizeof fmt_str, "%s รฏรฐรฅรครซร รฃร รฅรฒ รร รฌ รชรณรฏรจรฒรผ รงร รฏรฐร รขรฎรทรญรณรพ รฑรฒร รญรถรจรพ ยน%d \"%s\" รฏรฎ รถรฅรญรฅ %d รฐรณรก", GetPlayerNameEx(playerid), value_1, GetFuelStationData(value_1, FS_NAME), value_2);
