stock utf8_to_cp1251(string[]) {
    new len = strlen(string);
    for (new i = 0; i < len; i++) {
        if (string[i] == 0xD0 && i + 1 < len) {
            if (string[i + 1] >= 0x90 && string[i + 1] <= 0xBF) {
                string[i] = string[i + 1] + 0x30;
                strdel(string, i + 1, i + 2);
                len--;
            }
        }
        else if (string[i] == 0xD1 && i + 1 < len) {
            if (string[i + 1] >= 0x80 && string[i + 1] <= 0x8F) {
                string[i] = string[i + 1] + 0x70;
                strdel(string, i + 1, i + 2);
                len--;
            }
        }
    }
    return 1;
}

stock cp1251_to_utf8(string[]) {
    new len = strlen(string);
    new result[128];
    new i = 0, j = 0;
    while (i < len && j < sizeof(result) - 2) {
        if (string[i] >= 0xC0) {
            result[j++] = 0xD0 + (string[i] >= 0xF0);
            result[j++] = string[i++] - (string[i] >= 0xF0 ? 0x70 : 0x30);
        } else {
            result[j++] = string[i++];
        }
    }
    result[j] = 0;
    format(string, 128, "%s", result);
}

CMD:pr(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_FSIN)
		return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฒรฐรณรครญรจรช รรรร");

	if(GetPlayerJob(playerid) < 5)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร !");

	if(gettime() - g_last_pr[playerid] < 600)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรครฎรฆรครจรฒรฅ, รฏรฎรฎรนรฐรฅรญรจรฟ รฌรฎรฆรญรฎ รขรปรคร รขร รฒรผ รฒรฎรซรผรชรฎ รฐร รง รข 10 รฌรจรญรณรฒ. ");

	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	new targetid, reason[64];
	if(sscanf(params, "us[64]", targetid, reason))
		return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /pr [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");


	if(!IsPlayerConnected(targetid) || !IsPlayerLogged(targetid))
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ รญร รฉรครฅรญ");

	if(GetPlayerData(targetid, P_FJAIL) <= 0)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรฎรนรฐรฅรญรจรฅ รฌรฎรฆรญรฎ รขรปรคร รขร รฒรผ รฒรฎรซรผรชรฎ รงร รชรซรพรทยธรญรญรปรฌ รรรร.");

	if(GetPlayerData(targetid, P_PR) >= 1)
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รณรฆรฅ รจรฌรฅรฅรฒ รฌร รชรฑรจรฌร รซรผรญรฎรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รฏรฎรฎรนรฐรฅรญรจรฉ.");

	SetPlayerData(targetid, P_PR, GetPlayerData(targetid, P_PR) + 1);
	UpdatePlayerDatabaseInt(targetid, "pr", GetPlayerData(targetid, P_PR));

	AddPlayerData(targetid, P_FJAIL, -, 600);
	UpdatePlayerDatabaseInt(targetid, "fjail", GetPlayerData(targetid, P_FJAIL));

	new msg[144];
	format(msg, sizeof msg, "รรฎรฒรฐรณรครญรจรช รรรร %s[%d] รขรปรคร รซ รขร รฌ รฏรฎรฎรนรฐรฅรญรจรฅ รฏรฎ รฏรฐรจรทรจรญรฅ: %s.", GetPlayerNameEx(playerid), playerid, reason);
	SendClientMessage(targetid, COLOR_BLUE, msg);

