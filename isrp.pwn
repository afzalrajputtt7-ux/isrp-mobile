CMD:home(playerid, params[])
{
	new houseid = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);
	if(houseid != -1)
	{
		new fmt_str[1024];
		new entranceid = GetHouseData(houseid, H_ENTRACE);
		new city[MAX_ZONES_NAME + 1], area[MAX_ZONES_NAME + 1];

		format(fmt_str, sizeof fmt_str, "{FFFFFF}รรจรฏ / รญร รงรขร รญรจรฅ:\t\t\t{339999}%s\n", GetHouseData(houseid, H_NAME));
		if(entranceid != -1)
		{
			GetCityName(GetEntranceData(entranceid, E_POS_X), GetEntranceData(entranceid, E_POS_Y), city);
			GetAreaName(GetEntranceData(entranceid, E_POS_X), GetEntranceData(entranceid, E_POS_Y), area);
			format
			(
				fmt_str, sizeof fmt_str,
				"%s{FFFFFF}รรฎรฌรฅรฐ รฏรฎรครบรฅรงรคร :\t\t\t%d\n"\
				"รรฎรฌรฅรฐ รชรขร รฐรฒรจรฐรป:\t\t\t%d\n"\
				"รรฎรฐรฎรค / รฎรกรซร รฑรฒรผ:\t\t\t%s\n"\
				"รร รฉรฎรญ:\t\t\t\t\t%s\n",
				fmt_str,
				entranceid + 1,
				GetHouseData(houseid, H_FLAT_ID) + 1,
				city,
				area
			);
		}
		else
		{
			GetCityName(GetHouseData(houseid, H_POS_X), GetHouseData(houseid, H_POS_Y), city);
			GetAreaName(GetHouseData(houseid, H_POS_X), GetHouseData(houseid, H_POS_Y), area);
			format
			(
				fmt_str, sizeof fmt_str,
				"%s{FFFFFF}รรฎรฌรฅรฐ รครฎรฌร :\t\t\t\t%d\n"\
				"รรฎรฐรฎรค / รฎรกรซร รฑรฒรผ:\t\t\t%s\n"\
				"รร รฉรฎรญ:\t\t\t\t\t%s\n",
				fmt_str,
				houseid,
				city,
				area
			);
		}

		format
		(
			fmt_str, sizeof fmt_str,
			"%sรรฒรฎรจรฌรฎรฑรฒรผ:\t\t\t\t{888888}%d {FFFFFF}รฐรณรก\n"\
			"รรฎรฌ รฎรฏรซร รทรฅรญ รญร :\t\t\t{E0584B}%d {FFFFFF}รจรง {66CC00}30 {FFFFFF}รครญรฅรฉ\n"\
			"รรฎรซรจรทรฅรฑรฒรขรฎ รชรฎรฌรญร รฒ:\t\t\t%d\n"\
			"รรฐรฎรขรฅรญรผ รณรซรณรทรธรฅรญรจรฉ:\t\t\t%d\n"\
			"รรฎรครฅรซรผ รครฎรฌร รธรญรฅรฃรฎ ร รขรฒรฎ:\t\t{FF3333}รรฅรฒ\n"\
			"{FFFFFF}รรขร รฐรฒรฏรซร รฒร :\t\t\t\t%d รฐรณรก รข รครฅรญรผ\n"\
			"รรจรฏ รชรขร รฐรฒรฏรซร รฒรป:\t\t\t%s\n"\
			"รรฒร รฒรณรฑ:\t\t\t\t\t%s\n\n"\
			"{669966}รรซรฟ รฎรฒรชรฐรปรฒรจรฟ รฏร รญรฅรซรจ รณรฏรฐร รขรซรฅรญรจรฟ รขร รธรจรฌ รครฎรฌรฎรฌ\n"\
			"รญร รฆรฌรจรฒรฅ รชรญรฎรฏรชรณ \"รรงรฌรฅรญรจรฒรผ\"",
			fmt_str,
			GetHouseData(houseid, H_PRICE),
			GetHouseData(houseid, H_RENT_DATE) <= gettime() ? 0 :
			GetElapsedTime(GetHouseData(houseid, H_RENT_DATE), gettime(), CONVERT_TIME_TO_DAYS),
			GetHouseTypeInfo(GetHouseData(houseid, H_TYPE), HT_ROOMS),
			GetHouseData(houseid, H_IMPROVEMENTS),
			GetHouseData(houseid, H_IMPROVEMENTS) < 4 ? (GetHouseData(houseid, H_RENT_PRICE)) : (GetHouseData(houseid, H_RENT_PRICE) / 2),
			GetHouseData(houseid, H_IMPROVEMENTS) < 4 ? ("รรกรปรทรญร รฟ") : ("รรฎรญรจรฆรฅรญรญร รฟ"),
			GetHouseData(houseid, H_LOCK_STATUS) ? ("{CC3333}รรฎรฌ รงร รชรฐรปรฒ") : ("{66CC33}รรฎรฌ รฎรฒรชรฐรปรฒ")
		);
		Dialog(playerid, DIALOG_HOUSE_INFO, DIALOG_STYLE_LIST, "{ff4a4a}"SERVER_NAME"{ffffff} -> รรญรดรฎรฐรฌร รถรจรฟ รฎ รครฎรฌรฅ", fmt_str, "รรงรฌรฅรญรจรฒรผ", "รรฒรฌรฅรญร ");
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รครฎรฌร ");

	return 1;
}

CMD:sellhome(playerid, params[])
{
	new houseid = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);
	if(houseid != -1)
	{
		Dialog
		(
			playerid, DIALOG_HOUSE_SELL, DIALOG_STYLE_MSGBOX,
			"{ff4a4a}"SERVER_NAME" -> {ffffff}  รรฐรฎรคร รฆร  รครฎรฌร ",
			"{FFFFFF}รรป รณรขรฅรฐรฅรญรป รทรฒรฎ รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ รฑรขรฎรฉ รครฎรฌ รฃรฎรฑรณรคร รฐรฑรฒรขรณ?\n\n"\
			"{ffffff}รร รฌ รกรณรครฅรฒ รขรฎรงรขรฐร รนรฅรญรฎ {32CD32} 70 {ffffff}รฏรฐรฎรถรฅรญรฒรฎรข รฎรฒ รฑรฒรฎรจรฌรฎรฑรฒรจ รญรฅรครขรจรฆรจรฌรฎรฑรฒรจ.\n"\
			"{ffffff}รร รฌ รกรณรครฅรฒ รขรฎรงรขรฐร รนรฅรญรฎ {32CD32} 60 {ffffff}รฏรฐรฎรถรฅรญรฒรฎรข รฎรฒ รชรณรฏรซรฅรญรญรปรต รฐร รญรฅรฅ รณรซรณรทรธรฅรญรจรฉ.\n\n"\
			"{ffffff}รรฑรซรจ รรป รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ รกรจรงรญรฅรฑ รครฐรณรฃรฎรฌรณ รจรฃรฐรฎรชรณ,\n"\
			"{ffffff}รจรฑรฏรฎรซรผรงรณรฉรฒรฅ รชรฎรฌร รญรครณ {1E90FF} /sellmyhome",
			"รร ", "รรฅรฒ"
		);
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รครฎรฌร ");

	return 1;
}

CMD:sellmyhome(playerid, params[])
{
	new houseid = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);
	if(houseid != -1)
	{
		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellmyhome [id รจรฃรฐรฎรชร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

		extract params -> new to_player, price;

		new house_price = GetHouseData(houseid, H_PRICE);

		if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
			return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

		if(GetPlayerHouse(to_player) != -1)
			return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รณรฆรฅ รฅรฑรฒรผ รครฎรฌ");

		if(!((house_price / 3) <= price <= (house_price * 3)))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รญรฅ รครฎรซรฆรญร  รกรปรฒรผ รครฎรฐรฎรฆรฅ รจรซรจ รครฅรธรฅรขรซรฅ รข 3 รฐร รงร  รฎรฒ รฑรฒรฎรจรฌรฎรฑรฒรจ รครฎรฌร ");

		if(GetPlayerMoneyEx(to_player) < price)
			return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฒร รชรฎรฉ รฑรณรฌรฌรป");

		if(!(IsPlayerInRangeOfHouse(playerid, houseid, 10.0) && IsPlayerInRangeOfHouse(to_player, houseid, 10.0)))
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รจ รฏรฎรชรณรฏร รฒรฅรซรผ รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฎรชรฎรซรฎ รครฎรฌร  รชรฎรฒรฎรฐรปรฉ รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ");

		SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_HOME, houseid, price);
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รครฎรฌร ");

	return 1;
}

CMD:live(playerid, params[])
{
	new houseid = GetPlayerHouse(playerid, HOUSE_TYPE_HOME);
	if(houseid != -1)
	{
		new type = GetHouseData(houseid, H_TYPE);
		new rooms = GetHouseTypeInfo(type, HT_ROOMS);

		if(GetHouseRentersCount(houseid) >= rooms)
			return SendClientMessage(playerid, 0x999999FF, "รรฑรฅ รชรฎรฌรญร รฒรป รร รธรฅรฃรฎ รครฎรฌร  รณรฆรฅ รงร รญรฟรฒรป");

		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /live [id รจรฃรฐรฎรชร ]"); // [รชรฎรซ-รขรฎ รครญรฅรฉ] [รถรฅรญร  (รญรฅรฎรกรฟรงร รฒรฅรซรผรญรฎ)]

		extract params -> new to_player, days, price;

		if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
			return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

		if(GetPlayerHouse(to_player) != -1)
			return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รณรฆรฅ รฅรฑรฒรผ รครฎรฌ");

		if(!(300 <= price <= 10_000))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฅรญร  ร รฐรฅรญรครป รครฎรซรฆรญร  รกรปรฒรผ รฎรฒ 300 รครฎ 10000 รฐรณรก");

		else if(!(1 <= days <= 30))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฎรซ-รขรฎ รครญรฅรฉ ร รฐรฅรญรครป รครฎรซรฆรญรฎ รกรปรฒรผ รฎรฒ 0 รครฎ 30");

		if(GetPlayerMoneyEx(to_player) < price)
			return SendClientMessage(playerid, 0xCECECEFF, "ร รฝรฒรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ รฒร รชรฎรฉ รฑรณรฌรฌรป");
		
		if(!(IsPlayerInRangeOfHouse(playerid, houseid, 10.0) && IsPlayerInRangeOfHouse(to_player, houseid, 10.0)))
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รจ ร รฐรฅรญรคร รฒรฎรฐ รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฎรชรฎรซรฎ รครฎรฌร  รชรฎรฒรฎรฐรปรฉ รตรฎรฒรจรฒรฅ รฑรคร รฒรผ รข ร รฐรฅรญรครณ");

		SendPlayerOffer(playerid, to_player, OFFER_TYPE_HOME_RENT_ROOM, houseid);
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รครฎรฌร ");

	return 1;
}

