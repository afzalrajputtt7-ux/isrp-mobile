alias:goto("g")
CMD:goto(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 2) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /goto [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");

    if(GetPlayerSecretEx(to_player) >= 1)
	    return SendClientMessage(playerid, 0xCECECEFF, "ร รจรฃรฐรฎรชร  รฅรฑรฒรผ รฏรฐรจรขรฅรซรฅรฃรจรฟ รฑรชรฐรปรฒรญรฎรฑรฒรผ");

	new Float: x, Float: y, Float: z, interior, virtual_world;
	GetPlayerPos(to_player, x, y, z);
	interior = GetPlayerInterior(to_player);
	virtual_world = GetPlayerVirtualWorld(to_player);

	SetPlayerPosEx(playerid, x + 1, y + 1, z, 0.0, interior, virtual_world, false);
   player_state_pickup[playerid] = 0;
	SetPlayerInHouse(playerid, GetPlayerInHouse(to_player));
	SetPlayerInBiz(playerid, GetPlayerInBiz(to_player));

	new fmt_msg[999];
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฒรฅรซรฅรฏรฎรฐรฒรจรฐรฎรขร รซรฑรฟ รช %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);
    
	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรป รณรฑรฏรฅรธรญรฎ รฒรฅรซรฅรฏรฎรฐรฒรจรฐรฎรขร รซรจรฑรผ รช รจรฃรฐรฎรชรณ %s[%d]", GetPlayerNameEx(to_player), to_player);
	SendClientMessage(playerid, 0x66CC00FF, fmt_msg);    
	
	format(fmt_msg, sizeof fmt_msg, "{1E90FF}รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รณรฑรฏรฅรธรญรฎ รช รร รฌ รฒรฅรซรฅรฏรฎรฐรฒรจรฐรฎรขร รซรฑรฟ.", GetPlayerNameEx(playerid), playerid);
	SendClientMessage(to_player, 0x66CC00FF, fmt_msg);	

	format(fmt_msg, sizeof fmt_msg, "รรฅรซรฅรฏรฎรฐรฒรจรฐรฎรขร รซรฑรฟ รช %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}

alias:gethere("gh")

CMD:gethere(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 2) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

