CMD:topmoney(playerid)
{
	new string[256];
	format(string, 256, "SELECT * FROM `accounts` ORDER BY money DESC LIMIT 10");
	mysql_tquery(mysql, string, "TopMoney", "d",playerid);

	return 1;
}

public: TopMoney(playerid)
{
	new name[24], cash,rows,fields, string[2000];
	cache_get_data(rows, fields);
	if(rows)
	{
		for(new i; i < rows; i++)
		{
			name[0] = EOS;
			cash = 0;
			cache_get_field_content(i, "name", name, mysql);
			cash = cache_get_field_content_int(i, "money", mysql);
			format(string, sizeof(string), "%s\n"c_b"รรจรช: "c_server"%s\t "c_b"| \t"c_b"รรฅรญรฅรฃ: "c_server"%d", string, name, cash);
			strcat(string, string, 0);
		}
	}

	Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "รรฎรฏ 10 รจรฃรฐรฎรชรฎรข รฏรฎ รครฅรญรผรฃร รฌ", string, "รร รชรฐรปรฒรผ", "");

	return 1;
}

CMD:history(playerid, params[])
{
	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /history [รจรฌรฟ รจรฃรฐรฎรชร ]");

	if(!(3 <= strlen(params) <= 20))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");

	extract params -> new string: name[21];

	new query[128];
	new Cache: result, user_id;

	mysql_format(mysql, query, sizeof query, "SELECT id FROM accounts WHERE name='%e' LIMIT 1", name);
	result = mysql_query(mysql, query);

	if(cache_num_rows())
		user_id = cache_get_row_int(0, 0);

	cache_delete(result);

	if(!user_id)
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");

	format(query, sizeof query, "SELECT name FROM change_names WHERE owner_id=%d ORDER BY id DESC LIMIT 45", user_id);
	mysql_tquery(mysql, query, "ShowChangeNameHistory", "is", playerid, name);

	return 1;
}

CMD:call(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร . รรฃรฎ รฌรฎรฆรญรฎ รชรณรฏรจรฒรผ รข รฑรฎรฒรฎรขรฎรฌ รฑร รซรฎรญรฅ");

	if(GetPlayerPhoneCall(playerid, PC_INCOMING_PLAYER) != INVALID_PLAYER_ID || GetPlayerPhoneCall(playerid, PC_OUTCOMING_PLAYER) != INVALID_PLAYER_ID)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรญรทรจรฒรฅ รฒรฅรชรณรนรจรฉ รฐร รงรฃรฎรขรฎรฐ");

	if(!GetPlayerPhoneCall(playerid, PC_ENABLED))
		return SendClientMessage(playerid, 0x999999FF, "รร รธ รฒรฅรซรฅรดรฎรญ รฎรฒรชรซรพรทรฅรญ");

	if(GetPlayerData(playerid, P_PHONE_BALANCE) >= 5)
	{
		new number;
		if(sscanf(params, "d", number))
		{
			Dialog
			(
				playerid, DIALOG_PHONE_CALL, DIALOG_STYLE_INPUT,
				"{FFCD00}รร รกรฅรฐรจรฒรฅ รญรฎรฌรฅรฐ",
				"{6699CC}รรฎรฌรฅรฐร  รฃรฎรฑรณรคร รฐรฑรฒรขรฅรญรญรปรต รฑรซรณรฆรก:\n\n\
				{FFFFFF}รรฎรซรจรถรจรฟ\t\t\t{66CC00}02\n\
				{FFFFFF}รรชรฎรฐร รฟ รฏรฎรฌรฎรนรผ\t\t{66CC00}03\n\
				{FFFFFF}รร รชรฑรจ\t\t\t\t{66CC00}555\n\
				{FFFFFF}รรฅรตร รญรจรช\t\t\t{66CC00}090\n\
				{FFFFFF}รรฏรฅรฐร รฒรฎรฐ รฑรขรฟรงรจ\t\t{66CC00}111",
				"รรฎรงรขรฎรญรจรฒรผ", "รรฒรฌรฅรญร "
			);
			return 1; // (TODO)
		}

		switch(number)
		{
			case 02: return 1;
			case 03: return 1;
			case 555: return 1;
			case 090: return 1;
			case 111:
			{
				new fmt_str[175];
				SetPlayerPhoneUseState(playerid, true);

				format
				(
					fmt_str, sizeof fmt_str,
					"{FFFFFF}รรครฐร รขรฑรฒรขรณรฉรฒรฅ! รรป รฏรฎรงรขรฎรญรจรซรจ รฎรฏรฅรฐร รฒรฎรฐรณ.\n"\
					"รร  รฑรทรฅรฒรณ รร รธรฅรฃรฎ รฌรฎรกรจรซรผรญรฎรฃรฎ รฒรฅรซรฅรดรฎรญร  {00FF00}%d รฐรณรก\n\n"\
					"{FFFFFF}รรฎรฏรฎรซรญรจรฒรผ รฅรฃรฎ รฌรฎรฆรญรฎ รข รซรพรกรฎรฌ รกร รญรชรฎรฌร รฒรฅ.\n"\
					"รรฑรฅรฃรฎ รครฎรกรฐรฎรฃรฎ!",
					GetPlayerData(playerid, P_PHONE_BALANCE)
				);
				Dialog(playerid, DIALOG_PHONE_CALL_BALANCE, DIALOG_STYLE_MSGBOX, "{FFCD00}รรฏรฅรฐร รฒรฎรฐ รฑรฎรฒรฎรขรฎรฉ รฑรขรฟรงรจ", fmt_str, "รรช", "รรฒรฌรฅรญร ");
			}

			default:
			{
				new subscriber = GetPlayerIDByPhone(number);

				if(number < 1)
					return SendClientMessage(playerid, 0x999999FF, "รร รญรญรปรฉ รญรฎรฌรฅรฐ รญรฅ รฎรกรฑรซรณรฆรจรขร รฅรฒรฑรฟ");

				if(subscriber == INVALID_PLAYER_ID)
					return SendClientMessage(playerid, 0xCECECEFF, "รร รกรฐร รญรญรปรฉ รร รฌรจ รญรฎรฌรฅรฐ รญรฅ รฎรกรฑรซรณรฆรจรขร รฅรฒรฑรฟ");

				if(subscriber == playerid || GetPlayerPhoneCall(subscriber, PC_INCOMING_PLAYER) != INVALID_PLAYER_ID || GetPlayerPhoneCall(subscriber, PC_OUTCOMING_PLAYER) != INVALID_PLAYER_ID)
					return SendClientMessage(playerid, 0x999999FF, "รรกรฎรญรฅรญรฒ รงร รญรฟรฒ");

				if(!GetPlayerPhoneCall(subscriber, PC_ENABLED))
					return SendClientMessage(playerid, 0x999999FF, "รรฅรซรฅรดรฎรญ ร รกรฎรญรฅรญรฒร  รขรญรฅ รงรฎรญรป รครฎรฑรฒรณรฏร ");

				SetPlayerPhoneCall(playerid, PC_OUTCOMING_PLAYER, subscriber);
				SetPlayerPhoneCall(subscriber, PC_INCOMING_PLAYER, playerid);

				new fmt_str[90];

				format(fmt_str, sizeof fmt_str, "{FFFFFF}รรฑรตรฎรครฟรนรจรฉ รงรขรฎรญรฎรช | รรฎรฌรฅรฐ:{ffff00}%d {FFFFFF}| รรฆรจรคร รญรจรฅ รฎรฒรขรฅรฒร  รฎรฒ %s", number, GetPlayerNameEx(subscriber));
				SendClientMessage(playerid, 0x66CC00FF, fmt_str);

				format(fmt_str, sizeof fmt_str, "{FFFFFF}รรตรฎรครฟรนรจรฉ รงรขรฎรญรฎรช | รรฎรฌรฅรฐ:{ffff00}%d {FFFFFF}| รรปรงรปรขร รฅรฒ{ffff00} %s", GetPlayerPhone(playerid), GetPlayerNameEx(playerid));
				SendClientMessage(subscriber, 0x3399FFFF, fmt_str);

				SendClientMessage(subscriber, 0xFFFFFFFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {ffff00}/p {FFFFFF}รทรฒรฎรกรป รฎรฒรขรฅรฒรจรฒรผ รจรซรจ {ffff00}/h {FFFFFF}รทรฒรฎรกรป รฎรฒรชรซรฎรญรจรฒรผ รขรปรงรฎรข.");
				SetPlayerPhoneUseState(playerid, true);
			}
		}
	}
	else
	{
		SendClientMessage(playerid, 0xCECECEFF, "รร  รฑรทรฅรฒรณ รญรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฑรฐรฅรครฑรฒรข");
		SendClientMessage(playerid, 0xCECECEFF, "รรฎรฏรฎรซรญรจรฒรผ รฌรฎรกรจรซรผรญรปรฉ รฒรฅรซรฅรดรฎรญ รฌรฎรฆรญรฎ รข รซรพรกรฎรฌ รกร รญรชรฎรฌร รฒรฅ");
	}

	return 1;
}
alias:call("c")

CMD:p(playerid, params[])
{
	if(GetPlayerPhoneCall(playerid, PC_TIME) != -1) return 1;

	new caller = GetPlayerPhoneCall(playerid, PC_INCOMING_PLAYER);
	if(caller != INVALID_PLAYER_ID)
	{
		SetPlayerPhoneCall(caller, PC_TIME, 0);
		SetPlayerPhoneCall(playerid, PC_TIME, 0);

		new fmt_str[64];
		format(fmt_str, sizeof fmt_str, "{FFFFFF}รรป รฎรฒรขรฅรฒรจรซรจ รญร  รงรขรฎรญรฎรช {ffff00} %s", GetPlayerNameEx(caller));
		SendClientMessage(playerid, 0xDD90FFFF, fmt_str);

		format(fmt_str, sizeof fmt_str, "{ffff00} %s {FFFFFF}รฎรฒรขรฅรฒรจรซ รญร  รร รธ รงรขรฎรญรฎรช", GetPlayerNameEx(playerid));
		SendClientMessage(caller, 0xDD90FFFF, fmt_str);

		SetPlayerPhoneUseState(playerid, true, false);
	}
	else SendClientMessage(playerid, 0xCECECEFF, "รรฅรฒ รขรตรฎรครฟรนรจรต รขรปรงรฎรขรฎรข");

	return 1;
}

CMD:h(playerid, params[])
{
	new caller = GetPlayerPhoneCall(playerid, PC_INCOMING_PLAYER);
	new call_to = GetPlayerPhoneCall(playerid, PC_OUTCOMING_PLAYER);

	if(call_to != INVALID_PLAYER_ID)
	{
		if(GetPlayerPhoneCall(call_to, PC_INCOMING_PLAYER) == playerid)
		{
			ClearPlayerPhoneCall(call_to);
			SendClientMessage(call_to, 0xFF9944FF, "{ffff00}| {FFFFFF}รรขรฎรญรฎรช รฎรชรฎรญรทรฅรญ");

			SetPlayerPhoneUseState(call_to, false);
		}
		SendClientMessage(playerid, 0xFF9944FF, "{ffff00}| {FFFFFF}รรขรฎรญรฎรช รฎรชรฎรญรทรฅรญ");
	}
	else if(caller != INVALID_PLAYER_ID)
	{
		if(GetPlayerPhoneCall(caller, PC_OUTCOMING_PLAYER) == playerid)
		{
			ClearPlayerPhoneCall(caller);
			SendClientMessage(caller, 0xFF9944FF, "{ffff00}| {FFFFFF}รรขรฎรญรฎรช รฎรชรฎรญรทรฅรญ");

			SetPlayerPhoneUseState(caller, false);
		}
		if(GetPlayerPhoneCall(playerid, PC_TIME) != -1)
		{
			SendClientMessage(playerid, 0xFF9944FF, "{ffff00}| {FFFFFF}รรขรฎรญรฎรช รฎรชรฎรญรทรฅรญ");
		}
		else SendClientMessage(playerid, 0xFF9944FF, "{ffff00}| {FFFFFF}รรป รฎรฒรชรซรฎรญรจรซรจ รขรตรฎรครฟรนรจรฉ รขรปรงรฎรข");
	}
	else return 1;

	ClearPlayerPhoneCall(playerid);
	SetPlayerPhoneUseState(playerid, false);

	return 1;
}

CMD:sms(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร . รรฃรฎ รฌรฎรฆรญรฎ รชรณรฏรจรฒรผ รข รฑรฎรฒรฎรขรฎรฌ รฑร รซรฎรญรฅ");

	if(!GetPlayerPhoneCall(playerid, PC_ENABLED))
		return SendClientMessage(playerid, 0x999999FF, "รร รธ รฒรฅรซรฅรดรฎรญ รฎรฒรชรซรพรทรฅรญ");

	if(GetPlayerData(playerid, P_PHONE_BALANCE) >= 5)
	{
		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sms [รญรฎรฌรฅรฐ รฒรฅรซรฅรดรฎรญร ] [รฑรฎรฎรกรนรฅรญรจรฅ]");

		extract params -> new number, string:message[66];

		if(IsAIP(message))
		{
	   		SendClientMessage(playerid, -1, "รรฎรครฎรงรฐรฅรญรจรฟ รข รฐรฅรชรซร รฌรฅ!");
	       	return false;
	    }

		if(number < 550)
			return SendClientMessage(playerid, 0x999999FF, "รร รญรญรปรฉ รญรฎรฌรฅรฐ รญรฅ รฎรกรฑรซรณรฆรจรขร รฅรฒรฑรฟ");

		new subscriber = GetPlayerIDByPhone(number);

		if(subscriber != INVALID_PLAYER_ID)
		{
			if(!GetPlayerPhoneCall(subscriber, PC_ENABLED))
				return SendClientMessage(playerid, 0x999999FF, "รรฅ รณรคร รฅรฒรฑรฟ รฎรฒรฏรฐร รขรจรฒรผ รฑรฎรฎรกรนรฅรญรจรฅ. รรฅรซรฅรดรฎรญ ร รกรฎรญรฅรญรฒร  รญรฅรครฎรฑรฒรณรฏรฅรญ");

			if(!strlen(message))
				return SendClientMessage(playerid, 0xCECECEFF, "รรขรฅรครจรฒรฅ รฑรฎรฎรกรนรฅรญรจรฅ รครซรฟ รฎรฒรฏรฐร รขรชรจ");

			if(strlen(message) > 64)
				return SendClientMessage(playerid, 0xCECECEFF, "รรซรจรธรชรฎรฌ รครซรจรญรญรฎรฅ รฑรฎรฎรกรนรฅรญรจรฅ");

			AddPlayerData(playerid, P_PHONE_BALANCE, -, 5);
			GameTextForPlayer(playerid, "SMS ~n~~y~-5 rub", 4000, 1);

			new fmt_str[128];

			format(fmt_str, sizeof fmt_str, "SMS: %s | รรฒรฏรฐร รขรจรฒรฅรซรผ: %s [รฒ.%d]", message, GetPlayerNameEx(playerid), GetPlayerPhone(playerid));
			SendClientMessage(subscriber, 0xFFFF00FF, fmt_str);
			SetPlayerChatBubble(subscriber, "SMS <<", 0xFFFF00FF, 5.0, 1500);

			format(fmt_str, sizeof fmt_str, "SMS: %s | รรฎรซรณรทร รฒรฅรซรผ: %s [รฒ.%d]", message, GetPlayerNameEx(subscriber), GetPlayerPhone(subscriber));
			SendClientMessage(playerid, 0xFFFF00FF, fmt_str);
			SetPlayerChatBubble(playerid, "SMS >>", 0xFFFF00FF, 5.0, 1500);

			format(fmt_str, sizeof fmt_str, "UPDATE accounts SET phone_balance=%d WHERE id=%d LIMIT 1", GetPlayerData(playerid, P_PHONE_BALANCE), GetPlayerAccountID(playerid));
			mysql_tquery(mysql, fmt_str, "", "");

			if(g_admin_ears)
			{
				format(fmt_str, sizeof fmt_str, "[A] SMS: %s | รฎรฒ %s[%d] รช %s[%d]", message, GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(subscriber), subscriber);
				SendMessageToAdmins(fmt_str, 0xFFFF00FF);
			}

			format(fmt_str, sizeof fmt_str, "รรซรฟ %s[acc:%d]: %s", GetPlayerNameEx(subscriber), GetPlayerAccountID(subscriber), message);
			SendLog(playerid, LOG_TYPE_SMS_CHAT, fmt_str);
		}
		else SendClientMessage(playerid, 0x999999FF, "รรฅรซรฅรดรฎรญ รญร รตรฎรครจรฒรฑรฟ รขรญรฅ รงรฎรญรป รครฎรฑรฒรณรฏร ");
	}
	else
	{
		SendClientMessage(playerid, 0xCECECEFF, "รร  รฑรทรฅรฒรณ รญรฅรครฎรฑรฒร รฒรฎรทรญรฎ รฑรฐรฅรครฑรฒรข");
		SendClientMessage(playerid, 0xCECECEFF, "รรฎรฏรฎรซรญรจรฒรผ รฌรฎรกรจรซรผรญรปรฉ รฒรฅรซรฅรดรฎรญ รฌรฎรฆรญรฎ รข รซรพรกรฎรฌ รกร รญรชรฎรฌร รฒรฅ");
	}
	return 1;
}

CMD:eject(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);

	if(!vehicleid || !IsPlayerDriver(playerid))
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รฑรจรครฅรฒรผ รงร  รฐรณรซรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒร ");

	if(!strlen(params))
		return SendClientMessage(playerid, 0x999999FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /eject [id รจรฃรฐรฎรชร ]");

	extract params -> new to_player;

	if(vehicleid != GetPlayerVehicleID(to_player) || playerid == to_player)
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รครฎรซรฆรฅรญ รฑรจรครฅรฒรผ รข รร รธรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	RemovePlayerFromVehicle(to_player);

	new fmt_str[64];
	format(fmt_str, sizeof fmt_str, "%s รขรปรชรจรญรณรซ รร รฑ รจรง รฑรขรฎรฅรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ", GetPlayerNameEx(playerid));
	SendClientMessage(to_player, 0x3399FFFF, fmt_str);

	format(fmt_str, sizeof fmt_str, "รรป รขรปรชรจรญรณรซรจ %s รจรง รฑรขรฎรฅรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ", GetPlayerNameEx(to_player));
	SendClientMessage(playerid, 0x3399FFFF, fmt_str);

	return 1;
}

CMD:book(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร . รรฃรฎ รฌรฎรฆรญรฎ รชรณรฏรจรฒรผ รข รฑรฎรฒรฎรขรฎรฌ รฑร รซรฎรญรฅ");

	return ShowPlayerPhoneBook(playerid);
}

CMD:add(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร . รรฃรฎ รฌรฎรฆรญรฎ รชรณรฏรจรฒรผ รข รฑรฎรฒรฎรขรฎรฌ รฑร รซรฎรญรฅ");

	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /add [id รจรฃรฐรฎรชร ] [รญรฎรฌรฅรฐ รฒรฅรซรฅรดรฎรญร ]");

	extract params -> new to_player, string: number[10];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerPhoneBookInit(playerid))
		InitPlayerPhoneBook(playerid);

	if(GetPlayerPhoneBookContacts(playerid) >= MAX_PHONE_BOOK_CONTACTS)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รฏรจรฑรญร รฟ รชรญรจรฆรชร  รงร รฏรฎรซรญรฅรญร . รรคร รซรจรฒรฅ รญรฅรญรณรฆรญรปรฅ รชรฎรญรฒร รชรฒรป");

	if((3 <= strlen(number) <= 9) && IsNumeric(number) && strval(number) > 0)
		return AddPhoneBookContact(playerid, GetPlayerNameEx(to_player), number);

	SetPVarString(playerid, "add_contact_name", GetPlayerNameEx(to_player));
	new fmt_str[64 + 1];

	format(fmt_str, sizeof fmt_str, "{FFFFFF}รรขรฅรครจรฒรฅ รญรฎรฌรฅรฐ รฒรฅรซรฅรดรฎรญร  รครซรฟ รชรฎรญรฒร รชรฒร  %s", GetPlayerNameEx(to_player));
	return Dialog(playerid, DIALOG_PHONE_BOOK_ADD_CONTACT, DIALOG_STYLE_INPUT, "{FFCD00}รรฎรกร รขรซรฅรญรจรฅ รญรฎรขรฎรฃรฎ รชรฎรญรฒร รชรฒร ", fmt_str, "รรฎรกร รขรจรฒรผ", "รรฒรฌรฅรญร ");
}

