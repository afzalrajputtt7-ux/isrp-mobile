CMD:sendcmd(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return 1;

	extract params -> new to_player, string:c_command[20], string:c_params[128]; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sendcmd [id รจรฃรฐรฎรชร ] [รชรฎรฌร รญรคร ] [รฏร รฐร รฌรฅรฒรฐรป]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new fmt_text[144];

	if(strfind(c_command, "w        	") != -1
	|| strfind(c_command, "ban") != -1
	|| strfind(c_command, "offban") != -1
	|| strfind(c_command, "unban") != -1
	|| strfind(c_command, "unwarn") != -1
	|| strfind(c_command, "permban") != -1
	|| strfind(c_command, "jail") != -1
	|| strfind(c_command, "unjail") != -1
	|| strfind(c_command, "mute") != -1
	|| strfind(c_command, "unmute") != -1
	|| strfind(c_command, "warn") != -1)
	{
		//format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฏรฎรฏรปรฒร รซรฑรฟ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฎรฒ รจรฌรฅรญรจ %s[%d] รชรฌรค: /%s %s",
		//GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, c_command, c_params);

		SendMessageToAdmins(fmt_text, 0x999999FF, 5);

		return 1;
	}

	format(fmt_text, sizeof fmt_text, "cmd_%s", c_command);

	CallLocalFunction(fmt_text, "is", to_player, c_params);

	format(fmt_text, sizeof fmt_text, "รรฒรฏรฐร รขรจรซ รฎรฒ รจรฌรฅรญรจ %s[acc:%d] รชรฌรค: /%s %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), c_command, c_params);
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

	return 1;
}


CMD:givecash(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 4) return 1;

	extract params -> new to_player, cash; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givecash [id รจรฃรฐรฎรชร ] [cรณรฌรฌร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(-10_000_000 <= cash <= 10_000_000)) return SendClientMessage(playerid, 0xCECECEFF, "รรฎรฆรญรฎ รขรปรคร รขร รฒรผ รครฎ 10.000.000 รฐรณรกรซรฅรฉ รงร  รฎรครจรญ รฐร รง");

	new reason[144];
	format(reason, sizeof reason, "รรปรคร รทร  รครฅรญรฅรฃ รฎรฒ ร รครฌรจรญร  %s", GetPlayerNameEx(playerid));
	GivePlayerMoneyEx(to_player, cash, reason, true, true);

	format(reason, sizeof reason, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รขรปรคร รซ รร รฌ %d รฐรณรกรซรฅรฉ", GetPlayerNameEx(playerid), cash);
	SendClientMessage(to_player, 0xFFFFFFFF, reason);

	format(reason, sizeof reason, "[A] %s[%d] รขรปรคร รซ รครฅรญรผรฃรจ %s[%d] รชรฎรซ-รขรฎ %d รฐรณรก, รข รจรฒรฎรฃรฅ รณ รจรฃรฐรฎรชร  %d รฐรณรก", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, cash, GetPlayerMoneyEx(to_player));
	SendMessageToAdmins(reason, 0x999999FF);

	format(reason, sizeof reason, "รรปรคร รซ %s[acc:%d] %d รฐรณรก", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), cash);
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, reason);

	return 1;
}
alias:givecash("givemoney")


CMD:givedonate(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return 1;

	extract params -> new to_player, donate; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /givedonate [id รจรฃรฐรฎรชร ] [cรณรฌรฌร ]");

