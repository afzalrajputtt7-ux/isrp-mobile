forward LoadOrgTotals(playerid);
public LoadOrgTotals(playerid)
{
    new org_names[11][64] = {
        "รรฐร รขรจรฒรฅรซรผรฑรฒรขรฎ รฎรกรซร รฑรฒรจ",
        "รรฎรจรญรฑรชร รฟ รทร รฑรฒรผ",
        "รรฎรฐรฎรครฑรชร รฟ รกรฎรซรผรญรจรถร ",
        "รรร",
        "รรรรร",
        "รรรร",
        "รรร",
        "รรรร",
        "รรฐรงร รฌร รฑรฑรชรฎรฅ รรร",
        "รร รฒรปรฐรฅรขรฑรชรฎรฅ รรร",
        "รรปรฒรชร รฐรจรญรฑรชรฎรฅ รรร"
    };

    new org_colors[11] = {
        0xFFFF00, // รรฐร รขรจรฒรฅรซรผรฑรฒรขรฎ โ รฆยธรซรฒรปรฉ
        0x8B4513, // รรฎรจรญรฑรชร รฟ รทร รฑรฒรผ โ รชรฎรฐรจรทรญรฅรขรปรฉ
        0xFF3366, // รรฎรซรผรญรจรถร  โ รฐรฎรงรฎรขรฎ-รชรฐร รฑรญรปรฉ
        0xFFA500, // รรร โ รฎรฐร รญรฆรฅรขรปรฉ
        0x00008B, // รรรรร โ รฒยธรฌรญรฎ-รฑรจรญรจรฉ
        0x00008B, // รรรร โ รฒยธรฌรญรฎ-รฑรจรญรจรฉ
        0x00008B, // รรร โ รฒยธรฌรญรฎ-รฑรจรญรจรฉ
        0xAFEEEE, // รรรร โ #AFEEEE
        0x00FF00, // รรฐรงร รฌร รฑรฑรชร รฟ รรร โ รงรฅรซยธรญรปรฉ
        0x483D8B, // รร รฒรปรฐรฅรขรฑรชร รฟ รรร โ #483D8B
        0xFFD700  // รรปรฒรชร รฐรจรญรฑรชรฎรฅ รรร โ รงรฎรซรฎรฒรฎรฉ
    };

    new org_total[11];
    new org_online[11];
    new fmt_text[160], list[2048];

    new rows = cache_get_row_count();
    for (new i = 0; i < rows; i++)
    {
        new team = cache_get_field_content_int(i, "team");
        new total = cache_get_field_content_int(i, "total");

        if (1 <= team <= 11)
            org_total[team - 1] = total;
    }

    for (new i = 0; i < MAX_PLAYERS; i++)
    {
        if (!IsPlayerConnected(i)) continue;

        new team = GetPlayerTeamEx(i);
        if (1 <= team <= 11 && IsPlayerLogged(i))
            org_online[team - 1]++;
    }

    strcat(list, "{E0584B}รรฎรฌรฅรฐ\t{E0584B}รร รจรฌรฅรญรฎรขร รญรจรฅ รดรฐร รชรถรจรจ\t{E0584B}รรฎรซ-รขรฎ รจรฃรฐรฎรชรฎรข รข รฑรฅรฒรจ\t{E0584B}รรกรนรฅรฅ รชรฎรซ-รขรฎ รจรฃรฐรฎรชรฎรข\n");

    for (new i = 0; i < 11; i++)
    {
        format(fmt_text, sizeof fmt_text,
            "{E0584B}%d\t{%06x}%s\t{E0584B}%d{FFFFFF} รทรฅรซ.\t{E0584B}%d{FFFFFF} รทรฅรซ.\n",
            i + 1,
            org_colors[i] & 0xFFFFFF,
            org_names[i],
            org_online[i],
            org_total[i]
        );
        strcat(list, fmt_text);
    }

    Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_TABLIST_HEADERS, "{ff4a4a}"SERVER_NAME"{FFFFFF} | รรฒร รฒรจรฑรฒรจรชร  รฎรฐรฃร รญรจรงร รถรจรฉ", list, "รร รชรฐรปรฒรผ", "");
    return 1;
}

stock UnixToDate(unix, &year, &month, &day, &hour, &minute, &second)
{
    new timestamp = unix;
    new days = timestamp / 86400;
    new rem = timestamp % 86400;

    hour = rem / 3600;
    rem %= 3600;
    minute = rem / 60;
    second = rem % 60;

    year = 1970;
    while (true)
    {
        new leap = ((year % 4 == 0 && year % 100 != 0) || year % 400 == 0);
        new days_in_year = leap ? 366 : 365;
        if (days >= days_in_year)
        {
            days -= days_in_year;
            year++;
        }
        else break;
    }

    static const month_days[12] = { 31,28,31,30,31,30,31,31,30,31,30,31 };
    month = 0;
    while (month < 12)
    {
        new mdays = month_days[month];
        if (month == 1 && ((year % 4 == 0 && year % 100 != 0) || year % 400 == 0)) mdays++;
        if (days >= mdays)
        {
            days -= mdays;
            month++;
        }
        else break;
    }
    month++;
    day = days + 1;

}

stock ShowSpawnSelectionDialog(playerid)
{
    new dialogText[1024];

    strcat(dialogText, "{E0584B}KRANIN STUDIO RolePlay{FFFFFF} | รรปรกรฅรฐรจรฒรฅ รฌรฅรฑรฒรฎ รฏรฎรฟรขรซรฅรญรจรฟ\n");

    strcat(dialogText, "รรฎรชรงร รซ\t{00AA00}รรฎรฑรฒรณรฏรญรฎ\t{999999}รร รฆรฌรจรฒรฅ รครซรฟ รขรปรกรฎรฐร \n");

