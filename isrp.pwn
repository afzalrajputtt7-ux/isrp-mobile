				}
				else
				{
					SetBusinessData(businessid, B_LOCK_STATUS, true);
					SendClientMessage(playerid, 0xFF6600FF, "รรจรงรญรฅรฑ รงร รชรฐรปรฒ");
				}
				UpdateBusinessLabel(businessid);

				new query[75];
				mysql_format(mysql, query, sizeof query, "UPDATE business SET `lock`=%d WHERE `id`=%d LIMIT 1", GetBusinessData(businessid, B_LOCK_STATUS), GetBusinessData(businessid, B_SQL_ID));
				mysql_query(mysql, query, false);

				CallLocalFunction("ShowPlayerBusinessDialog", "ii", playerid, BIZ_OPERATION_PARAMS);
			}			
			case BIZ_OPERATION_PROD_PRICE: // รณรฑรฒร รญรฎรขรจรฒรผ รฑรฒรฎรจรฌรฎรฑรฒรผ รฏรฐรฎรครณรชรฒร 
			{
				Dialog
				(
					playerid, DIALOG_BIZ_PROD_PRICE, DIALOG_STYLE_INPUT,
					"{33AACC}รรฒรฎรจรฌรฎรฑรฒรผ รฏรฐรฎรครณรชรฒร ",
					"{FFFFFF}รรณรฒ รขรป รฌรฎรฆรฅรฒรฅ รจรงรฌรฅรญรจรฒรผ รฑรฒรฎรจรฌรฎรฑรฒรผ รฏรฐรฎรครณรชรฒร  รครซรฟ รกรจรงรญรฅรฑร \n"\
					"รรชร รฆรจรฒรฅ รถรฅรญรณ รข รฏรฐรฅรครฅรซร รต รฎรฒ 25 รครฎ 200 รฐรณรกรซรฅรฉ",
					"รรฌรฅรญรจรฒรผ", "รร รงร รค"
				);
			}
			case BIZ_OPERATION_PROD_ORDER: // รงร รชร รงร รฒรผ รฏรฐรฎรครณรชรฒรป
			{
				Dialog
				(
					playerid, DIALOG_BIZ_ORDER_PRODS, DIALOG_STYLE_INPUT,
					"{33AACC}รร รชร รง รฏรฐรฎรครณรชรฒรฎรข",
					"{FFFFFF}รรชรฎรซรผรชรฎ รฏรฐรฎรครณรชรฒรฎรข รรป รตรฎรฒรจรฒรฅ รงร รชร รงร รฒรผ?",
					"รร รชร รงร รฒรผ", "รร รงร รค"
				);
			}
			case BIZ_OPERATION_PROD_ORDER_CANCEL: // รฎรฒรฌรฅรญรจรฒรผ รงร รชร รง
			{
				new order_id = GetBusinessData(businessid, B_ORDER_ID);
				if(order_id != -1)
				{
					new fmt_str[128];
					format
					(
						fmt_str, sizeof fmt_str,
						"{FFFFFF}รรป รครฅรฉรฑรฒรขรจรฒรฅรซรผรญรฎ รตรฎรฒรจรฒรฅ รฎรฒรฌรฅรญรจรฒรผ รงร รชร รง?\n"\
						"รร  รฑรทรฅรฒ รกรจรงรญรฅรฑร  รกรณรครฅรฒ รขรฎรงรขรฐร รนรฅรญรฎ {FFCD00}%d รฐรณรก",
						GetOrderData(order_id, O_AMOUNT) * GetOrderData(order_id, O_PRICE)
					);
					Dialog(playerid, DIALOG_BIZ_ORDER_CANCEL, DIALOG_STYLE_MSGBOX, "{33AADD}รรฒรฌรฅรญร  รงร รชร รงร ", fmt_str, "รร ", "รรฅรฒ");
				}
				else
				{
					SendClientMessage(playerid, 0xFF6600FF, "รรป รญรฅ รฎรดรฎรฐรฌรซรฟรซรจ รงร รชร รง รฏรฐรฎรครณรชรฒรฎรข รครซรฟ รฑรขรฎรฅรฃรฎ รกรจรงรญรฅรฑร ");
					CallLocalFunction("ShowPlayerBusinessDialog", "ii", playerid, BIZ_OPERATION_PARAMS);
				}
			}
			case BIZ_OPERATION_PROFIT_STATS: // รดรจรญร รญรฑรฎรขร รฟ รฑรฒร รฒรจรฑรฒรจรชร 
			{
				new query[256];

				new time = gettime();
				new cur_day = time - (time % 86400);
				new start_day = cur_day - (86400 * 20);

				mysql_format(mysql, query, sizeof query, "SELECT FROM_UNIXTIME(time, '%%Y-%%m-%%d') AS date, SUM(money) as total FROM business_profit WHERE bid=%d AND view=1 AND time >= %d AND time < %d GROUP BY time ORDER BY time DESC LIMIT 20", GetBusinessData(businessid, B_SQL_ID), start_day, cur_day);
				mysql_tquery(mysql, query, "ShowBusinessProfit", "ii", playerid, ++ mysql_race[playerid]);
			}
			case BIZ_OPERATION_IMPROVEMENTS: // รรซรณรทรธรฅรญรจรฟ
			{
				new fmt_str[80];
				new string[512];

				new buffer[14 + 1];
				new i_level = GetBusinessData(businessid, B_IMPROVEMENTS);

				for(new idx; idx < sizeof(g_business_improvements); idx ++)
				{
					format(fmt_str, sizeof fmt_str, "%d รณรฐรฎรขรฅรญรผ:\t%s\t", idx + 1, g_business_improvements[idx][I_NAME]);

					switch(idx)
					{
						case 0,1,4:
							buffer = "\t";

						case 5:
							buffer = "\t\t";

						default:
							buffer[0] = 0;
					}
					if(buffer[0] != EOS)
						strcat(fmt_str, buffer);

					if(i_level > idx)
					{
						strins(fmt_str, "{2277AA}", 0, sizeof fmt_str);
						strcat(fmt_str, "รรณรฏรซรฅรญรฎ");
					}
					else
					{
						if(i_level < idx)
						{
							strins(fmt_str, "{CC3344}", 0, sizeof fmt_str);
						}
						strcat(string, fmt_str);

						valfmt(buffer, g_business_improvements[idx][I_PRICE]);
						format(fmt_str, sizeof fmt_str, "%s รฐรณรก", buffer);

						if(i_level == idx)
							strins(fmt_str, "{66CC33}", 0, sizeof fmt_str);
					}
					strcat(fmt_str, "\n");
					strcat(string, fmt_str);
				}
				Dialog(playerid, DIALOG_BIZ_IMPROVEMENT, DIALOG_STYLE_LIST, "{33AADD}รรฎรฑรฒรณรฏรญรปรฅ รณรซรณรทรธรฅรญรจรฟ", string, "รรณรฏรจรฒรผ", "รร รงร รค");
			}
		}
	}

	return 1;
}

AntiDeAMX()
{
        new a[][] =
        {
                "Unarmed (Fist)",
                "Brass K"
        };
        #pragma unused a
}

public: ShowBusinessProfit(playerid, race)
{
	if(race != mysql_race[playerid])
	{
		new string[600];
		new fmt_str[32];
		new rows = cache_num_rows();

		if(rows)
		{
			string = "รร รฒร \t\t\tรรฐรจรกรปรซรผ\n\n{FFFFFF}";
		}
		else string = "{FFFFFF}รรจรญร รญรฑรฎรขร รฟ รฑรฒร รฒรจรฑรฒรจรชร  รร รธรฅรฃรฎ รกรจรงรญรฅรฑร  รฅรนรฅ รญรฅ รฑรดรฎรฐรฌรจรฐรฎรขร รญร ";

		for(new idx; idx < rows; idx ++)
		{
			cache_get_row(idx, 0, fmt_str, mysql, sizeof fmt_str);
			strcat(string, fmt_str);

			format(fmt_str, sizeof fmt_str, "\t\t%d รฐรณรก\n", cache_get_row_int(idx, 1));
			strcat(string, fmt_str);
		}
		Dialog(playerid, DIALOG_BIZ_INFO, DIALOG_STYLE_MSGBOX, "{33AADD}รรฎรตรฎรค รกรจรงรญรฅรฑร  รงร  20 รครญรฅรฉ", string, "<< รร รงร รค", "รร รชรฐรปรฒรผ");
	}
}

