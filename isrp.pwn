public: UpdateFactoryDesk(deskid)
{
	new fmt_str[64];

	format(fmt_str, sizeof fmt_str, "รร รกรฎรทรฅรฅ รฌรฅรฑรฒรฎ ยน%d\n%s", deskid + 1, factory_desk[deskid][FD_USED] ? ("{FF6600}รร รญรฟรฒรฎ") : ("{33CC00}รรขรฎรกรฎรครญรฎ"));
	UpdateDynamic3DTextLabelText(factory_desk[deskid][FD_LABEl], 0xFFFFFFEE, fmt_str);
