}

stock IsBusinessNoEnter(action_id) //ร รขรฒรฎรฑร รซรฎรญรป
{
if(GetBusinessData(action_id, B_TYPE) == 20) return 1;
	switch(GetBusinessData(action_id, B_SQL_ID))
	{
		case 31, 32, 33:
		{
			return 1;
		}
	}
	return 0;
}

