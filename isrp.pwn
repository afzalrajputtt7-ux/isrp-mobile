public spawningwerton(playerid)
{
	SendClientMessage(playerid, 0xFFFFFFFF, "{5e8720}| {FFFFFF}รรฎรกรฐรฎ รฏรฎรฆร รซรฎรขร รฒรผ รญร  {FF6347}KRANIN STUDIO{FF6347}!");
	// รรขรฅรครฎรฌรซรฅรญรจรฟ รฎ รกรฅรงรฎรฏร รฑรญรฎรฑรฒรจ
	SendClientMessage(playerid, 0xFFFFFFFF, "{FFFF00}| {FFFFFF}รรซรฟ รกรฅรงรฎรฏร รฑรญรฎรฑรฒรจ, รณรฑรฒร รญรฎรขรจรฒรฅ รฎรฒรฏรฅรทร รฒรฎรช รฏร รซรผรถร  รฏรฐรจ รขรตรฎรครฅ รข รจรฃรฐรณ.");
	SendClientMessage(playerid, 0xFFFFFFFF, "{FFFF00}| {FFFFFF}รรฑรฒร รญรฎรขรจรข รฎรฒรฏรฅรทร รฒรฎรช, รขรป รฑรฌรฎรฆรฅรฒรฅ รขรตรฎรครจรฒรผ รข รจรฃรฐรณ รกรฅรง รขรขรฎรคร  รฏร รฐรฎรซรฟ.");

	// รรขรฅรครฎรฌรซรฅรญรจรฅ รครซรฟ รญรฎรขรจรทรชรฎรข
	if (GetPlayerLevel(playerid) < 3)
	{
		SendClientMessage(playerid, 0xFFFFFFFF, "{FFFF00}| {FFFFFF}รรฎรชร  รรป {FFFF00}รฌร รซรฎรจรฌรณรนรจรฉ (รครฎ 3-รฃรฎ รณรฐรฎรขรญรฟ){FFFFFF}, รญร  รณรซรจรถรฅ รรป รฌรฎรฆรฅรฒรฅ รฏรฎรฏรฐรฎรธร รฉรญรจรทร รฒรผ รครฅรญรผรฃรจ.");
		SendClientMessage(playerid, 0xFFFFFFFF, "{FFFF00}| {FFFFFF}รรฑรฏรฎรซรผรงรณรฉรฒรฅ รชรฎรฌร รญรครณ {ffff00}/bg{ffffff}, รทรฒรฎรกรป รญร รทร รฒรผ รฏรฎรฏรฐรฎรธร รฉรญรจรทร รฒรผ!");
	}
	
	if(!GetPlayerData(playerid, P_ADMIN)) SendClientMessage(playerid, 0xFF0000FF, "ร รขร รฑ รญรฅรฒ ร รครฌรจรญรชรจ, รจรฑรฏรฎรซรผรงรณรฉรฒรฅ /goadm");

}

