CMD:fill(playerid, params[])
{
	if(GetPlayerJob(playerid) != JOB_MECHANIC)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ ร รขรฒรฎรฌรฅรตร รญรจรช");

	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /fill [id รจรฃรฐรฎรชร ] [รชรฎรซ-รขรฎ รฒรฎรฏรซรจรขร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

	extract params -> new to_player, fill_fuel_count, fill_price;

	if(!IsPlayerConnected(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 15.0))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(!IsPlayerDriver(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รรซรจรฅรญรฒ รครฎรซรฆรฅรญ รญร รตรฎรครจรฒรผรฑรฟ รงร  รฐรณรซรฅรฌ");

	if(1 <= GetPlayerJobLoadItems(playerid) <= fill_fuel_count)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฒรฎรฏรซรจรขร ");

	if(!(1 <= fill_price <= 1500))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รครฎรซรฆรญร  รกรปรฒรผ รครฎ 1500 รฐรณรกรซรฅรฉ");

	if(GetPlayerMoneyEx(to_player) < fill_price)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รชรซรจรฅรญรฒร  รญรฅรฒ รฑ รฑรฎรกรฎรฉ รฑรฒรฎรซรผรชรฎ รครฅรญรฅรฃ");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_FILL_CAR, fill_fuel_count, fill_price);
	return 1;
}

CMD:repair(playerid, params[])
{
	if(GetPlayerJob(playerid) != JOB_MECHANIC)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ ร รขรฒรฎรฌรฅรตร รญรจรช");

	if(!IsPlayerInJob(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รฐร รกรฎรฒร รฒรผ ร รขรฒรฎรฌรฅรตร รญรจรชรฎรฌ");

	new job_car = GetPlayerJobCar(playerid);
	if(!IsPlayerInVehicle(playerid, job_car) || GetVehicleData(job_car, V_ACTION_ID) == VEHICLE_ACTION_ID_NONE)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รฐร รกรฎรฒร รฒรผ ร รขรฒรฎรฌรฅรตร รญรจรชรฎรฌ รจ รญร รตรฎรครจรฒรผรฑรฟ รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /repair [id รจรฃรฐรฎรชร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

	extract params -> new to_player, repair_price;

	if(!IsPlayerConnected(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 15.0))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(!IsPlayerDriver(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รรซรจรฅรญรฒ รครฎรซรฆรฅรญ รญร รตรฎรครจรฒรผรฑรฟ รงร  รฐรณรซรฅรฌ");

	new Float: vehicle_health;
	GetVehicleHealth(GetPlayerVehicleID(to_player), vehicle_health);
	if(vehicle_health < 350.0 && !IsPlayerInRangeOfPoint(playerid, 80.0, 1180.0962,2500.5166,12.4769)) return SendClientMessage(playerid, 0xCECECEFF, "รรฐร รญรฑรฏรฎรฐรฒ รชรซรจรฅรญรฒร  รฎรทรฅรญรผ รฑรจรซรผรญรฎ รฏรฎรขรฐรฅรฆรครฅรญ, รฎรฒรขรฅรงรจรฒรฅ รฅรฃรฎ รญร  รฑรฒรฎรฟรญรชรณ ร รขรฒรฎรฌรฅรตร รญรจรชรฎรข {CCCC00}(/gps)");

	if(!(1 <= repair_price <= 8000))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รครฎรซรฆรญร  รกรปรฒรผ รครฎ 8000 รฐรณรกรซรฅรฉ");

	if(GetPlayerMoneyEx(to_player) < repair_price)
		return SendClientMessage(playerid, 0xCECECEFF, "ร รชรซรจรฅรญรฒร  รญรฅรฒ รฑ รฑรฎรกรฎรฉ รฑรฒรฎรซรผรชรฎ รครฅรญรฅรฃ");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_REPAIR_CAR, repair_price);
	return 1;
}

CMD:getfuel(playerid, params[])
{
	if(GetPlayerJob(playerid) != JOB_MECHANIC)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ ร รขรฒรฎรฌรฅรตร รญรจรช");

	if(!IsPlayerInJob(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รฐร รกรฎรฒร รฒรผ ร รขรฒรฎรฌรฅรตร รญรจรชรฎรฌ");

	new job_car = GetPlayerJobCar(playerid);
	if(!IsPlayerInVehicle(playerid, job_car) || GetVehicleData(job_car, V_ACTION_ID) == VEHICLE_ACTION_ID_NONE)
		return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รฐร รกรฎรฒร รฒรผ ร รขรฒรฎรฌรฅรตร รญรจรชรฎรฌ รจ รญร รตรฎรครจรฒรผรฑรฟ รข รฐร รกรฎรทรฅรฌ รฒรฐร รญรฑรฏรฎรฐรฒรฅ");

	new stationid = GetNearestFuelStation(playerid, 10.0);
	if(stationid != -1)
	{
		SetPVarInt(playerid, "nearest_fuel_st", stationid);

		if(IsFuelStationOwned(stationid))
		{
			if(GetFuelStationData(stationid, FS_FUELS) < 10)
				return SendClientMessage(playerid, 0xFF6600FF, "รรฐร รญรจรซรจรนรฅ รฝรฒรฎรฉ รรร รฏรณรฑรฒรฎ");
		}

		new fmt_str[150];
		format
		(
			fmt_str, sizeof fmt_str,
			"{FFFFFF}รรฎรฏรซรจรขรฎ รญร  รรร:\t\t%d/10000 รซ\n"\
			"รรฒรฎรจรฌรฎรฑรฒรผ 1 รซรจรฒรฐร :\t%d รฐรณรก\n\n"\
			"รรขรฅรครจรฒรฅ รชรฎรซ-รขรฎ รกรฅรญรงรจรญร , รชรฎรฒรฎรฐรฎรฅ รตรฎรฒรจรฒรฅ รงร รชรณรฏรจรฒรผ\n"\
			"(รทรจรฑรซรฎ รครฎรซรฆรญรฎ รกรปรฒรผ รชรฐร รฒรญรปรฌ 10)",
			GetFuelStationData(stationid, FS_FUELS),
			GetFuelStationData(stationid, FS_FUEL_PRICE)
		);
		Dialog(playerid, DIALOG_FUEL_STATION_BUY_FUEL_M, DIALOG_STYLE_INPUT, "{FFCD00}รร รชรณรฏรชร  รฒรฎรฏรซรจรขร ", fmt_str, "รรณรฏรจรฒรผ", "รรฒรฌรฅรญร ");
	}
	else SendClientMessage(playerid, 0xCECECEFF, "รรฎรกรซรจรงรฎรฑรฒรจ รญรฅรฒ รงร รฏรฐร รขรฎรทรญรปรต รฑรฒร รญรถรจรฉ");

	return 1;
}

CMD:rentcar(playerid, params[])
{
	if(GetPlayerRentCar(playerid) != INVALID_VEHICLE_ID && playerid == rent_cars_data[GetPlayerRentCar(playerid) - first_rent_car_id][rent_car_tenant_id])
		return SendClientMessage(playerid, 0xFF6600FF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ /unrent รทรฒรฎรกรป รฐร รงรฎรฐรขร รฒรผ รฒรฅรชรณรนรจรฉ รครฎรฃรฎรขรฎรฐ ร รฐรฅรญรครป");

	new vehicleid = GetPlayerVehicleID(playerid);
	if(GetVehicleData(vehicleid, V_ACTION_TYPE) != VEHICLE_ACTION_TYPE_RENT_CAR)
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รกรปรฒรผ รข รฌร รธรจรญรฅ, รชรฎรฒรฎรฐรณรพ รฌรฎรฆรญรฎ ร รฐรฅรญรครฎรขร รฒรผ");

	SetPlayerData(playerid, P_RENT_CAR, vehicleid);
	rent_cars_data[vehicleid - first_rent_car_id][rent_car_tenant_id] = playerid;

	Dialog(playerid, -1, DIALOG_STYLE_MSGBOX, " ", " ", " ", " ");

	SendClientMessage(playerid, 0x66CC00FF, "รรป รขรงรฟรซรจ รฒรฐร รญรฑรฏรฎรฐรฒ รข ร รฐรฅรญรครณ");
	SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {00CC66}/lock 2 {FFFFFF}รครซรฟ รฎรฒรชรฐรปรฒรจรฟ รจ รงร รชรฐรปรฒรจรฟ รครขรฅรฐรฅรฉ");
	SendClientMessage(playerid, -1, "รรฒรฎรกรป รฐร รงรฎรฐรขร รฒรผ รครฎรฃรฎรขรฎรฐ ร รฐรฅรญรครป รขรขรฅรครจรฒรฅ {00CC66}/unrent");
	SendClientMessage(playerid, 0x999999FF, "รรฑรซรจ รรป รฏรฎรฏร รครฅรฒรฅ รข รกรฎรซรผรญรจรถรณ รจรซรจ รฐร รงรฎรกรผรฅรฒรฅ รฒรฐร รญรฑรฏรฎรฐรฒ");
	SendClientMessage(playerid, 0x999999FF, "รรฎ รครฎรฃรฎรขรฎรฐ รกรณรครฅรฒ รฐร รฑรฒรฎรฐรฃรญรณรฒ. รรฑรซรจ รรป รญรฅ รงร รชรฐรฎรฅรฒรฅ รฒรฐร รญรฑรฏรฎรฐรฒ");
	SendClientMessage(playerid, 0x999999FF, "รรฎ รฅรฃรฎ รฌรฎรฆรฅรฒ ร รฐรฅรญรครฎรขร รฒรผ รครฐรณรฃรฎรฉ รจรฃรฐรฎรช รจ รรป รฏรฎรฒรฅรฐรฟรฅรฒรฅ รฅรฃรฎ");

	TogglePlayerControllable(playerid, true);

	return 1;
}

CMD:unrent(playerid, params[])
{
	new vehicleid = GetPlayerRentCar(playerid);
	if(!(vehicleid != INVALID_VEHICLE_ID && playerid == rent_cars_data[vehicleid - first_rent_car_id][rent_car_tenant_id]))
		return SendClientMessage(playerid, 0xCECECEFF, "ร รร รฑ รญรฅรฒ รครฎรฃรฎรขรฎรฐร  ร รฐรฅรญรครป รฒรฐร รญรฑรฏรฎรฐรฒร ");

	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		RemovePlayerFromVehicle(playerid);

	SetPlayerData(playerid, P_RENT_CAR, INVALID_VEHICLE_ID);
	rent_cars_data[vehicleid - first_rent_car_id][rent_car_tenant_id] = INVALID_PLAYER_ID;

	SendClientMessage(playerid, 0xFFFF00FF, "รรฎรฃรฎรขรฎรฐ ร รฐรฅรญรครป รฒรฐร รญรฑรฏรฎรฐรฒร  รฐร รฑรฒรฎรฐรฃรญรณรฒ");
	return 1;
}

CMD:unfcar(playerid)
{
    new vehicleid = GetPlayerData(playerid, P_FRACTION_CAR);
	if (vehicleid == INVALID_VEHICLE_ID) {
		return;
	}
    if(GetVehicleData(vehicleid, V_ACTION_TYPE) == VEHICLE_ACTION_ORG_CAR)
    {
        SetPlayerData(playerid, P_FRACTION_CAR, INVALID_VEHICLE_ID);
        DestroyDeliveryVehicle(vehicleid);
        SendClientMessage(playerid, -1, ""SC"รรป รณรคร รซรจรซรจ รฒรฐร รญรฑรฏรฎรฐรฒ!");
    }
    else
    	SendClientMessage(playerid, -1, ""USC"รรป รญรฅ รกรฐร รซรจ รฒรฐร รญรฑรฏรฎรฐรฒ");
}

CMD:business(playerid, params[])
{
	new businessid = GetPlayerBusiness(playerid);
	if(businessid != -1)
	{
		static const
			music_name[6][9] = {"รรฒรชรซรพรทรฅรญ", "รรขรณรช 1", "รรขรณรช 2", "รรขรณรช 3", "รรขรณรช 4", "รรขรณรช 5"};

		if(GetBusinessData(businessid, B_ENTER_MUSIC) > sizeof music_name - 1)
		{
			SetBusinessData(businessid, B_ENTER_MUSIC, sizeof music_name - 1);
		}

		new fmt_str[1024];
		new city[MAX_ZONES_NAME + 1], area[MAX_ZONES_NAME + 1];
		GetCityName(GetBusinessData(businessid, B_POS_X), GetBusinessData(businessid, B_POS_Y), city);
		GetAreaName(GetBusinessData(businessid, B_POS_X), GetBusinessData(businessid, B_POS_Y), area);
		format
		(
			fmt_str, sizeof fmt_str,
			"{FFFFFF}รร รงรขร รญรจรฅ:\t\t\t\t{339999}%s\n"\
			"{FFFFFF}รรฎรฌรฅรฐ รกรจรงรญรฅรฑร :\t\t\t%d\n"\
			"รรซร รครฅรซรฅรถ:\t\t\t\t%s\n"\
			"รรฎรฐรฎรค / รฎรกรซร รฑรฒรผ:\t\t\t%s\n"\
			"รร รฉรฎรญ:\t\t\t\t\t%s\n"\
			"รรซร รฒร  รงร  รขรตรฎรค:\t\t\t%d รฐรณรก\n"\
			"รรฎรซรจรทรฅรฑรฒรขรฎ รฏรฐรฎรครณรชรฒรฎรข:\t\t{66CC00}%d {FFFFFF}รจรง {E0584B}%d\n"\
			"รรฒรฎรจรฌรฎรฑรฒรผ 1 รฏรฐรฎรครณรชรฒร :\t\t%d รฐรณรก\n"\
			"รรฐรฎรขรฅรญรผ รณรซรณรทรธรฅรญรจรฉ:\t\t\t%d\n"\
			"รร รซร รญรฑ รฏรฐรฅรครฏรฐรจรฟรฒรจรฟ:\t\t\t%d รฐรณรก\n"\
			"รรจรงรญรฅรฑ ร รฐรฅรญรครฎรขร รญ รญร :\t\t{66CC00}%d {FFFFFF}รจรง {E0584B}30 {FFFFFF}รครญรฅรฉ\n"\
			"{FFFFFF}รรขรณรช รฏรฐรจ รขรตรฎรครฅ:{E0584B}\t\t\t{%s}%s\n"\
			"{FFFFFF}รรฎรฑ. รฑรฒรฎรจรฌรฎรฑรฒรผ:\t\t\t%d รฐรณรก\n"\
			"รรฐรฅรญรคร  รฏรฎรฌรฅรนรฅรญรจรฟ:\t\t\t%d รฐรณรก รข รครฅรญรผ\n"\
			"รรจรฏ ร รฐรฅรญรครป:\t\t\t\t%s\n"\
			"รรฒร รฒรณรฑ:\t\t\t\t\t%s\n\n"\
			"{669966}รรซรฟ รฎรฒรชรฐรปรฒรจรฟ รฏร รญรฅรซรจ รณรฏรฐร รขรซรฅรญรจรฟ รขร รธรจรฌ รกรจรงรญรฅรฑรฎรฌ\n"\
			"รญร รฆรฌรจรฒรฅ รชรญรฎรฏรชรณ \"รรงรฌรฅรญรจรฒรผ\"",
			GetBusinessData(businessid, B_NAME),
			businessid,
			GetBusinessData(businessid, B_OWNER_NAME),
			city,
			area,
			GetBusinessData(businessid, B_ENTER_PRICE),
			GetBusinessData(businessid, B_PRODS),
			GetBusinessMaxProd(businessid),
			GetBusinessData(businessid, B_PROD_PRICE),
			GetBusinessData(businessid, B_IMPROVEMENTS),
			GetBusinessData(businessid, B_BALANCE),
			GetBusinessData(businessid, B_RENT_DATE) <= gettime() ? 0 :
			GetElapsedTime(GetBusinessData(businessid, B_RENT_DATE), gettime(), CONVERT_TIME_TO_DAYS),
			!GetBusinessData(businessid, B_ENTER_MUSIC) ? ("FF3333") : ("33CC00"),
			music_name[GetBusinessData(businessid, B_ENTER_MUSIC)],
			GetBusinessData(businessid, B_PRICE),
			GetBusinessData(businessid, B_IMPROVEMENTS) < 3 ? (GetBusinessData(businessid, B_RENT_PRICE)) : (GetBusinessData(businessid, B_RENT_PRICE) / 2),
			GetBusinessData(businessid, B_IMPROVEMENTS) < 3 ? ("รรฎรซรญร รฟ") : ("รรผรฃรฎรฒรญร รฟ"),
