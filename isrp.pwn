	if(!(0 <= biz_id <= g_business_loaded - 1)) return SendClientMessage(playerid, 0x999999FF, "รร รญรญรฎรฃรฎ รกรจรงรญรฅรฑร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

