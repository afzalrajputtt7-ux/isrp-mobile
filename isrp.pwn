	}

	if(gang_zone_id == -1)
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รญร  รญรณรฆรญรฎรฉ รฒรฅรฐรฐรจรฒรฎรฐรจรจ");

	//SetGangZoneData(gang_zone_id, GZ_GANG, gang_id);
	//SaveGangZone(gang_zone_id);

	//GangZoneShowForAll(GetGangZoneData(gang_zone_id, GZ_ZONE), gang_zone_colors[ GetGangZoneData(gang_zone_id, GZ_GANG) ]);

	new fmt_text[75];

	SendClientMessage(playerid, -1, "รรป รจรงรฌรฅรญรจรซรจ รกร รญรครณ, รขรซร รครฅรพรนรณรพ รคร รญรญรฎรฉ รฒรฅรฐรฐรจรฒรฎรฐรจรฅรฉ");

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รจรงรฌรฅรญรจรซ รกร รญรครณ รณ รฒรฅรฐรฐรจรฒรฎรฐรจรจ ยน%d รญร  %d", GetPlayerNameEx(playerid), playerid, gang_zone_id, gang_id);
	SendMessageToAdmins(fmt_text, 0x999999FF);

	format(fmt_text, sizeof fmt_text, "รรงรฌรฅรญรจรซ รกร รญรครณ รณ รฒรฅรฐรฐรจรฒรฎรฐรจรจ ยน%d รญร  %d", gang_zone_id, gang_id);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

