{
	if(GetPlayerAdminEx(playerid)< 12) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
    new fmt_msg[999];
    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รฏรฐรฎรจรญรดรฎรฐรฌรจรฐรฎรขร รซ รฑรฅรฐรขรฅรฐ รงร รฟรขรซรฅรญรจรฅรฌ \"รรทร รฑรซรจรขรปรฌรจ รทร รฑร รฌรจ\".", GetPlayerNameEx(playerid), playerid);

	 SendClientMessageToAll(0xFFFFFFFF, "{FA8072}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป | {32CD32}รรฐรจ รฏรฎรซรณรทรฅรญรจรจ รงร รฐรฏรซร รฒรป รญร  รชร รฆรครฎรฉ รจรง รครฎรฑรฒรณรฏรญรปรต รฐร รกรฎรฒ รฎรญร  รกรณรครฅรฒ รณรฌรญรฎรฆร รฒรผรฑรฟ รข{00FA9A} X2{32CD32} รฐร รงร .");
     SendClientMessageToAll(0xFFFFFFFF, "{FA8072}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป | {32CD32}รร รฆรครปรฉ 'PayDay' รญร  รฑรฅรฐรขรฅรฐรฅ รรป รกรณรครฅรฒรฅ รฏรฎรซรณรทร รฒรผ รข{00FA9A} X2{32CD32} รฐร รงร  รกรฎรซรผรธรฅ รฎรทรชรฎรข รฎรฏรปรฒร  (EXP).");
     SendClientMessageToAll(0xFFFFFFFF, "{FA8072}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป | {32CD32}รรฐรจ รฏรฎรฏรฎรซรญรฅรญรจรจ รกร รซร รญรฑร  ร รชรชร รณรญรฒร  (Black Coin)- รฑรณรฌรฌร  รฏรฎรฏรฎรซรญรฅรญรจรฟ รกรณรครฅรฒ รณรฌรญรฎรฆร รฒรผรฑรฟ รข{00FA9A} X2{32CD32} รฐร รงร !");
     SendClientMessageToAll(0xFFFFFFFF, "{FA8072}รรทร รฑรฒรซรจรขรปรฅ รทร รฑรป | {32CD32}รรฎรฏรฎรซรญรจรฒรผ รฑรทรฅรฒ รฑรขรฎรฅรฃรฎ รจรฃรฐรฎรขรฎรฃรฎ ร รชรชร รณรญรฒร  รฌรฎรฆรญรฎ รฏรฐรฟรฌรฎ รข รซร รณรญรทรฅรฐรฅ, รจรซรจ รทรฅรฐรฅรง รฑร รฉรฒ: {00FA9A}none.online");
return 1;
}

