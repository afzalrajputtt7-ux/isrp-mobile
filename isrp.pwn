CMD:sethelper(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
    if(GetPlayerAdminEx(playerid) < 3) return 1;

    extract params -> new to_player, level; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sethelper [id รจรฃรฐรฎรชร ] [รณรฐรฎรขรฅรญรผ: 1 รจรซรจ 2]");

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if(level < 1 || level > 2)
        return SendClientMessage(playerid, 0x999999FF, "รรฐรฎรขรฅรญรผ รครฎรซรฆรฅรญ รกรปรฒรผ 1 รจรซรจ 2");

    if(GetPlayerHelperEx(to_player))
        return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รณรฆรฅ รฟรขรซรฟรฅรฒรฑรฟ รรฃรฅรญรฒรฎรฌ รรฎรครครฅรฐรฆรชรจ");

    SetPlayerData(to_player, P_HELPER, level);
    UpdatePlayerDatabaseInt(to_player, "helper", level);

    new fmt_text[128], rank_text[32];
    rank_text = (level == 1) ? "รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจ 1-รฃรฎ รณรฐรฎรขรญรฟ" : "รรฒร รฐรธรจรฉ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจ";

    format(fmt_text, sizeof fmt_text, "{1E90FF}รรป รกรปรซรจ รญร รงรญร รทรฅรญรป รญร  รฏรฎรฑรฒ %s ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฎรฌ %s[%d]", rank_text, GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, 0x999999FF, fmt_text);

    format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฏรฎรฑรฒร รขรจรซ %s[%d] รญร  รฏรฎรฑรฒ %s",
        GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, rank_text);
    SendMessageToAdmins(fmt_text, 0x999999FF);

    format(fmt_text, sizeof fmt_text, "รรฎรฑรฒร รขรจรซ %s[acc:%d] รญร  รฏรฎรฑรฒ %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), rank_text);
    SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

    return 1;
}

CMD:delhelper(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 3 ) return 1;

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /delhelper [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!GetPlayerHelperEx(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญรฅ รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจ");
		
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

	SetPlayerData(to_player, P_HELPER, 0);
	UpdatePlayerDatabaseInt(to_player, "helper", 0);

	new fmt_text[128];

	format(fmt_text, sizeof fmt_text, "รรซร รขรญรปรฉ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฑรญรฟรซ รร รฑ รฑ รฏรฎรฑรฒร  รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ", GetPlayerNameEx(playerid), playerid);
	SendClientMessage(to_player, 0xFF5533FF, fmt_text);

	format(fmt_text, sizeof fmt_text, "[A] รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s[%d] รฑรญรฟรซ %s[%d] รฑ รฏรฎรฑรฒร  รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ",
	GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);

	SendMessageToAdmins(fmt_text, 0xFF5533FF);

	format(fmt_text, sizeof fmt_text, "รรญรฟรซ %s[acc:%d] รฑ รฏรฎรฑรฒร  รรฃรฅรญรฒ รรฎรครครฅรฐรฆรชรจร ", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_text);

	return 1;
}

CMD:offdeladmin(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 5) return 1;

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /offdeladmin [รญรจรช รจรฃรฐรฎรชร ]");

	extract params -> new string: player_name[21];

	if(IsPlayerConnected(GetPlayerID(player_name))) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญร รตรฎรครจรฒรฑรฟ รญร  รฑรฅรฐรขรฅรฐรฅ");

	new query[144],
		Cache: result,
		rows,
		uid,
		//admin,
		uip[16];

	mysql_format(mysql, query, sizeof query, "SELECT id, admin, last_ip FROM accounts WHERE name='%s'", player_name);
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	if(rows)
	{
		uid = cache_get_row_int(0, 0);
	//	admin = cache_get_row_int(0, 1);
		cache_get_row(0, 2, uip);
	}

	cache_delete(result);

	if(!rows || !uid) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รฑ รฒร รชรจรฌ รจรฌรฅรญรฅรฌ รญรฅ รญร รฉรครฅรญ");


	cache_delete(result);


	format(query, sizeof query, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รฑรญรฟรซ %s รฑ รฏรฎรฑรฒร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร [รรดรซร รฉรญ]", GetPlayerNameEx(playerid), player_name);

	SendMessageToAdmins(query, 0xFF5533FF);

	new id = GetPlayerID(player_name);
	if (id != INVALID_PLAYER_ID) {
		SetPlayerData(id, P_ADMIN, 0);
		UpdatePlayerDatabaseInt(id, "admin", 0);
	}
	mysql_format(mysql, query, sizeof query, "UPDATE `accounts` SER `admin`=0 WHERE `id`=%i LIMIT 1", uid);
	mysql_query(mysql, query, false);
	return 1;
}

