	ApplyAnimationEx(playerid, "SHOP", "ROB_Shifty", 4.0, 0, 0, 0, 0, 0, 0);
	SetPlayerChatBubble(playerid, "รร รครฅรขร รฅรฒ รฌร รฑรชรณ", 0xFF9900FF, 15.0, 5000);

	GameTextForPlayer(playerid, "~b~~h~invisible on", 2500, 4);
	SendClientMessage(playerid, 0x3399FFFF, "รร รธรฅ รฌรฅรฑรฒรฎรฐร รฑรฏรฎรซรฎรฆรฅรญรจรฅ รญร  GPS รฑรชรฐรปรฒรฎ รญร  10 รฌรจรญรณรฒ");

