CMD:admfly(playerid, params[])
{
	if (GetPlayerAdminEx(playerid) < 7)
		return ShowNotificationNew(playerid, 0, 5, 0, 0, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร รฌ 7 รณรฐรฎรขรญรฟ รจ รขรปรธรฅ", ">");

	TogglePlayerControllable(playerid, false);
	ShowPlayerDialog(playerid, DIALOG_ADMFLY, DIALOG_STYLE_LIST, "รรฅรฆรจรฌ รฏรฎรซยธรฒร ",
		"รรฏรฅรฐยธรค\nรร รงร รค\nรรซรฅรขรฎ\nรรฏรฐร รขรฎ\nรรปรฉรฒรจ รจรง รฏรฎรซยธรฒร ", "รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ");

	return 1;
}

CMD:groom(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_FSIN)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรฌร รญรคร  รครฎรฑรฒรณรฏรญร  รฒรฎรซรผรชรฎ รฑรฎรฒรฐรณรครญรจรชร รฌ รรรร");

	if(GetPlayerJob(playerid) < 5)
		return SendClientMessage(playerid, COLOR_GREY, "รรฎรฌร รญรคร  รครฎรฑรฒรณรฏรญร  รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร ");

	if(!IsWorkDayStarted(playerid)) return 1;

	new targetid;
	if(sscanf(params, "d", targetid))
		return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /groom [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(targetid) || !IsPlayerLogged(targetid) || targetid == playerid)
		return SendClientMessage(playerid, COLOR_GREY, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, targetid, 5.0))
		return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(GetPlayerData(targetid, P_JAIL) > 0 || GetPlayerData(targetid, P_FJAIL) > 0)
		return SendClientMessage(playerid, COLOR_GREY, "รรฅรซรผรงรฟ รขรปรคร รฒรผ รฏรฐรฎรฏรณรฑรช รงร รชรซรพรทยธรญรญรฎรฌรณ");

	new pname[24], tname[24];
	GetPlayerName(playerid, pname, sizeof pname);
	GetPlayerName(targetid, tname, sizeof tname);

	if(GetPVarInt(targetid, "groomaccess") == 1)
	{
		DeletePVar(targetid, "groomaccess");

		new fmt_msg[144];
		format(fmt_msg, sizeof fmt_msg, "[R] %s %s[%d] รจรงรบรฟรซ รฏรฐรฎรฏรณรฑรช รข รชรฎรฌรญร รฒรณ รครซรฟ รฑรขรจรคร รญรจรฉ รณ รจรฃรฐรฎรชร  %s[%d]",
			GetPlayerJobAndRankName(playerid),
			pname,
			playerid,
			tname,
			targetid);
		SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, COLOR_RADIO);

		format(fmt_msg, sizeof fmt_msg, "รรฎรฒรฐรณรครญรจรช รรรร %s รจรงรบรฟรซ รร รธ รฏรฐรฎรฏรณรฑรช รข รชรฎรฌรญร รฒรณ รครซรฟ รฑรขรจรคร รญรจรฉ", pname);
		SendClientMessage(targetid, COLOR_BLUE, fmt_msg);

		format(fmt_msg, sizeof fmt_msg, "รรป รจรงรบรฟรซรจ รฏรฐรฎรฏรณรฑรช รณ รจรฃรฐรฎรชร  %s", tname);
		SendClientMessage(playerid, COLOR_BLUE, fmt_msg);
	}
	else
	{
		SetPVarInt(targetid, "groomaccess", 1);

		new fmt_msg[144];
		format(fmt_msg, sizeof fmt_msg, "[R] %s %s[%d] รขรปรคร รซ รฏรฐรฎรฏรณรฑรช รข รชรฎรฌรญร รฒรณ รครซรฟ รฑรขรจรคร รญรจรฉ รจรฃรฐรฎรชรณ %s[%d]",
			GetPlayerJobAndRankName(playerid),
			pname,
			playerid,
			tname,
			targetid);
		SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, COLOR_RADIO);

		format(fmt_msg, sizeof fmt_msg, "รรฎรฒรฐรณรครญรจรช รรรร %s รขรปรคร รซ รร รฌ รฏรฐรฎรฏรณรฑรช รข รชรฎรฌรญร รฒรณ รครซรฟ รฑรขรจรคร รญรจรฉ", pname);
		SendClientMessage(targetid, COLOR_BLUE, fmt_msg);

		format(fmt_msg, sizeof fmt_msg, "รรป รขรปรคร รซรจ รฏรฐรฎรฏรณรฑรช รจรฃรฐรฎรชรณ %s", tname);
		SendClientMessage(playerid, COLOR_BLUE, fmt_msg);
	}

	return 1;
}

stock CreateFSINRoomLabel(roomid)
{
    new Float:x, Float:y, Float:z;
    switch (roomid)
    {
        case 0: { x = -2019.02; y = -1790.33; z = 1501.18; }
        case 1: { x = -2022.37; y = -1790.36; z = 1501.18; }
        case 2: { x = -2019.02; y = -1793.88; z = 1501.18; }
        case 3: { x = -2022.37; y = -1793.92; z = 1501.18; }
        case 4: { x = -2019.02; y = -1806.09; z = 1501.18; }
        case 5: { x = -2022.37; y = -1806.13; z = 1501.18; }
        case 6: { x = -2019.02; y = -1809.62; z = 1501.18; }
        case 7: { x = -2022.37; y = -1809.64; z = 1501.18; }
        default: return;
    }

    if (doorSvidanieLabel[roomid] != Text3D:INVALID_3DTEXT_ID)
        DestroyDynamic3DTextLabel(doorSvidanieLabel[roomid]);

    doorSvidanieLabel[roomid] = CreateDynamic3DTextLabel("รรญรจรถรจร รซรจรงร รถรจรฟ รชรฎรฌรญร รฒรป...", 0xFFFF00FF, x, y, z, 5.0, INVALID_PLAYER_ID, INVALID_VEHICLE_ID, 0, 1, 1);
}

stock UpdateFSINRoomText(roomid)
{
    new label[160];
    new status[32];

    if (!g_fsinRooms[roomid][isBusy])
        format(status, sizeof status, "{FFFF00}รฑรขรฎรกรฎรครญร ");
    else
        format(status, sizeof status, "{FFFF00}รจรคยธรฒ รฑรขรจรคร รญรจรฅ");

    format(label, sizeof label,
        "{FFFF00} << รรฎรฌรญร รฒร  รครซรฟ รฑรขรจรคร รญรจรฉ >>\n\
        {FFFF00}|{FFFFFF} รรฎรฌรฅรฐ:{FFFF00} %d\n\
        {FFFF00}|{FFFFFF} รรฒร รฒรณรฑ:{FFFFFF} %s",
        roomid + 1,
        status);

    if (doorSvidanieLabel[roomid] != Text3D:INVALID_3DTEXT_ID)
        UpdateDynamic3DTextLabelText(doorSvidanieLabel[roomid], 0xFFFF00FF, label);
}

stock StartMeetFSIN(prisonerid, visitorid, roomid, duration)
{
    g_fsinRooms[roomid][isBusy] = true;
    g_fsinRooms[roomid][roomTimer] = duration * 60;
    g_fsinRooms[roomid][roomPrisonerID] = prisonerid;
    g_fsinRooms[roomid][roomVisitorID] = visitorid;

    SetPlayerPos(prisonerid, -1994.25, -1821.57, 1501.18);
    SetPlayerFacingAngle(prisonerid, 89.32);
    SetPlayerVirtualWorld(prisonerid, roomid + 2);
    SetPlayerInterior(prisonerid, 1);
    TogglePlayerControllable(prisonerid, false);
    SetPlayerCameraPos(prisonerid, -1994.26, -1821.60, 1501.45); // +0.2
    SetPlayerCameraLookAt(prisonerid, -1996.65, -1821.63, 1501.18);

    SetPlayerPos(visitorid, -1996.65, -1821.63, 1501.18);
    SetPlayerFacingAngle(visitorid, 267.94);
    SetPlayerVirtualWorld(visitorid, roomid + 2);
    SetPlayerInterior(visitorid, 1);
    SetPVarInt(visitorid, "groomaccess", 1);

    UpdateFSINRoomText(roomid);
    g_fsinRoomTimerID[roomid] = SetTimerEx("FSINMeetTick", 1000, true, "i", roomid);
}

stock StopMeetFSIN(roomid, bool:manual = false, fsinid = INVALID_PLAYER_ID)
{
    if (g_fsinRoomTimerID[roomid]) KillTimer(g_fsinRoomTimerID[roomid]);
    g_fsinRoomTimerID[roomid] = 0;

    new prisonerid = g_fsinRooms[roomid][roomPrisonerID];
    new visitorid = g_fsinRooms[roomid][roomVisitorID];

    if (IsPlayerConnected(prisonerid))
    {
        SetPlayerPos(prisonerid, -1744.28, -2681.35, 7.59);
        SetPlayerFacingAngle(prisonerid, 230.05);
        SetPlayerVirtualWorld(prisonerid, 0);
        SetPlayerInterior(prisonerid, 0);
        TogglePlayerControllable(prisonerid, true);
        SetCameraBehindPlayer(prisonerid);
        SendClientMessage(prisonerid, COLOR_BLUE, "รรขรจรคร รญรจรฅ รฎรชรฎรญรทรฅรญรฎ.");
    }

    if (IsPlayerConnected(visitorid))
    {
        SetPlayerPos(visitorid, -1815.31, -2620.62, 7.73);
        SetPlayerFacingAngle(visitorid, 0.0);
        SetPlayerVirtualWorld(visitorid, 0);
        SetPlayerInterior(visitorid, 0);
        TogglePlayerControllable(visitorid, true);
        DeletePVar(visitorid, "groomaccess");
        SendClientMessage(visitorid, COLOR_BLUE, "รรขรจรคร รญรจรฅ รฎรชรฎรญรทรฅรญรฎ.");
    }

    if (manual && IsPlayerConnected(fsinid))
    {
        new msg[64];
        format(msg, sizeof msg, "รรฎรฒรฐรณรครญรจรช รรรร %s รงร รขรฅรฐรธรจรซ รขร รธรฅ รฑรขรจรคร รญรจรฅ.", GetPlayerNameEx(fsinid));
        if (IsPlayerConnected(prisonerid)) SendClientMessage(prisonerid, -1, msg);
        if (IsPlayerConnected(visitorid)) SendClientMessage(visitorid, -1, msg);
    }

    g_fsinRooms[roomid][isBusy] = false;
    g_fsinRooms[roomid][roomTimer] = 0;
    g_fsinRooms[roomid][roomPrisonerID] = INVALID_PLAYER_ID;
    g_fsinRooms[roomid][roomVisitorID] = INVALID_PLAYER_ID;

    UpdateFSINRoomText(roomid);
}

CMD:startmeet(playerid, params[])
{
    if (GetPlayerTeamEx(playerid) != TEAM_FSIN)
        return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฒรฐรณรครญรจรช รรรร");

    if (GetPlayerJob(playerid) < 5)
        return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร !");

    if(!IsWorkDayStarted(playerid)) return 1;

    new prisonerid, visitorid, minutes;
    if (sscanf(params, "iii", prisonerid, visitorid, minutes))
        return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ /startmeet [id รงร รชรซรพรทรฅรญรญรฎรฃรฎ] [id รฏรฎรฑรฅรฒรจรฒรฅรซรฟ] [รขรฐรฅรฌรฟ รข รฌรจรญรณรฒร รต]");

    if (!IsPlayerConnected(prisonerid) || !IsPlayerConnected(visitorid))
        return SendClientMessage(playerid, COLOR_GREY, "รรครจรญ รจรง รณรชร รงร รญรญรปรต รจรฃรฐรฎรชรฎรข รญรฅ รข รฑรฅรฒรจ");

    if (prisonerid == visitorid || prisonerid == playerid || visitorid == playerid)
        return SendClientMessage(playerid, COLOR_GREY, "รรฅรชรฎรฐรฐรฅรชรฒรญรปรฅ ID รจรฃรฐรฎรชรฎรข");

    if (GetPlayerData(prisonerid, P_FJAIL) <= 0)
        return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรช รญรฅ รฟรขรซรฟรฅรฒรฑรฟ รงร รชรซรพรทยธรญรญรปรฌ");

    if (GetPlayerDistanceFromPlayer(playerid, prisonerid) > 5.0 || GetPlayerDistanceFromPlayer(playerid, visitorid) > 5.0)
        return SendClientMessage(playerid, COLOR_GREY, "รรฃรฐรฎรชรจ รครฎรซรฆรญรป รกรปรฒรผ รฐรฟรครฎรฌ รฑ รขร รฌรจ");

    if (!IsPlayerInRangeOfPoint(playerid, 20.0, -2023.11, -1799.98, 1501.18))
    return SendClientMessage(playerid, COLOR_GREY, "รรป รครฎรซรฆรญรป รกรปรฒรผ รข รชรฎรฌรญร รฒรฅ รครซรฟ รฑรขรจรคร รญรจรฉ");

    if (minutes < 5 || minutes > 15)
        return SendClientMessage(playerid, COLOR_GREY, "รรฐรฅรฌรฟ รครฎรซรฆรญรฎ รกรปรฒรผ รฎรฒ 5 รครฎ 15 รฌรจรญรณรฒ");

    new roomid = -1;
    for (new i = 0; i < sizeof g_fsinRooms; i++)
    {
        if (!g_fsinRooms[i][isBusy])
        {
            roomid = i;
            break;
        }
    }

    if (roomid == -1)
        return SendClientMessage(playerid, COLOR_GREY, "รรฅรฒ รฑรขรฎรกรฎรครญรปรต รชรฎรฌรญร รฒ รครซรฟ รฑรขรจรคร รญรจรฉ");

    StartMeetFSIN(prisonerid, visitorid, roomid, minutes);

    new fmt_msg[144];
    format(fmt_msg, sizeof fmt_msg, "[R] %s %s รญร รทร รซ รฑรขรจรคร รญรจรฅ รครซรฟ รงร รชรซรพรทรฅรญรญรฎรฃรฎ %s รจ รฏรฎรฑรฅรฒรจรฒรฅรซรฟ %s รข รชรฎรฌรญร รฒรฅ ยน%d รญร  %d รฌรจรญรณรฒ.",
        GetPlayerJobAndRankName(playerid),
        GetPlayerNameEx(playerid),
        GetPlayerNameEx(prisonerid),
        GetPlayerNameEx(visitorid),
        roomid + 1,
        minutes);

    if (!GetPlayerTeamEx(playerid))
    {
        SendMessageToJob(GetPlayerJob(playerid), fmt_msg);
        SendClientMessage(playerid, -1, "รร รกรฎรฒร รฅรฒ");
    }
    else
    {
        SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, 0x33CC66FF);
    }

    new info_msg[64];
    format(info_msg, sizeof info_msg, "รร รทร รซรฎ รฑรขรจรคร รญรจรฟ: รรป รญร รทร รซรจ รฑรขรจรคร รญรจรฅ รข รชรฎรฌรญร รฒรฅ ยน%d", roomid + 1);
    SendClientMessage(playerid, COLOR_BLUE, info_msg);
    return 1;
}

CMD:stopmeet(playerid, params[])
{
    if (GetPlayerTeamEx(playerid) != TEAM_FSIN)
        return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฒรฐรณรครญรจรช รรรร");

    if (GetPlayerJob(playerid) < 5)
        return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร !");

    if (!IsWorkDayStarted(playerid)) return 1;

    if (!IsPlayerInRangeOfPoint(playerid, 20.0, -2023.11, -1799.98, 1501.18))
        return SendClientMessage(playerid, COLOR_GREY, "รรป รครฎรซรฆรญรป รกรปรฒรผ รข รชรฎรฌรญร รฒรฅ รครซรฟ รฑรขรจรคร รญรจรฉ");

    new inputRoom;
    if (sscanf(params, "i", inputRoom))
        return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ /stopmeet [รญรฎรฌรฅรฐ รชรฎรฌรญร รฒรป รฎรฒ 1 รครฎ 8]");

    new roomid = inputRoom - 1;

    if (roomid < 0 || roomid >= sizeof g_fsinRooms)
        return SendClientMessage(playerid, COLOR_GREY, "รรฅรขรฅรฐรญรปรฉ รญรฎรฌรฅรฐ รชรฎรฌรญร รฒรป");

    if (!g_fsinRooms[roomid][isBusy])
        return SendClientMessage(playerid, COLOR_GREY, "ร รฝรฒรฎรฉ รชรฎรฌรญร รฒรฅ รญรฅ รจรคยธรฒ รฑรขรจรคร รญรจรฅ");

    StopMeetFSIN(roomid, true, playerid);

    new fmt_msg[144];
    format(fmt_msg, sizeof fmt_msg, "[R] %s %s รงร รขรฅรฐรธรจรซ รฑรขรจรคร รญรจรฅ รข รชรฎรฌรญร รฒรฅ ยน%d.",
        GetPlayerJobAndRankName(playerid),
        GetPlayerNameEx(playerid),
        inputRoom);

    if (!GetPlayerTeamEx(playerid))
    {
        SendMessageToJob(GetPlayerJob(playerid), fmt_msg);
        SendClientMessage(playerid, -1, "รร รกรฎรฒร รฅรฒ");
    }
    else
    {
        SendMessageToTeam(GetPlayerTeamEx(playerid), fmt_msg, 0x33CC66FF);
    }

    new info_msg[64];
    format(info_msg, sizeof info_msg, "รร รขรฅรฐรธรฅรญรจรฅ รฑรขรจรคร รญรจรฟ: รรป รงร รขรฅรฐรธรจรซรจ รฑรขรจรคร รญรจรฅ รข รชรฎรฌรญร รฒรฅ ยน%d", inputRoom);
    SendClientMessage(playerid, COLOR_BLUE, info_msg);
    return 1;
}

CMD:startmeettest(playerid, params[])
{
    if (GetPlayerTeamEx(playerid) != TEAM_FSIN)
        return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฒรฐรณรครญรจรช รรรร");

    if (GetPlayerJob(playerid) < 5)
        return SendClientMessage(playerid, COLOR_GREY, "รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ รฑ 5-รฃรฎ รฐร รญรฃร !");

