		);
		Dialog(playerid, DIALOG_BIZ_INFO, DIALOG_STYLE_LIST, "{ff4a4a}"SERVER_NAME"{ffffff} -> รรญรดรฎรฐรฌร รถรจรฟ รฎ รกรจรงรญรฅรฑรฅ", fmt_str, "รรงรฌรฅรญรจรฒรผ", "รรฒรฌรฅรญร ");
		
		//CreateBusinessMenuTextDraws(playerid);
