    new Float:x, Float:y, Float:z;
    GetPlayerPos(playerid, x, y, z);
    EnablePlayerGPS(playerid, x, y, z, "รรฅรฒรชร  รญร  รฒรฅรชรณรนรฅรฌ รฌรฅรฑรฒรฅ");
