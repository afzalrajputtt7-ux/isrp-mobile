							case 2: // รรญรดรฎรฐรฌร รถรจรฟ รฎ รฒรฐร รญรฑรฏรฎรฐรฒรฅ
							{
								new vehicleid = GetPlayerOwnableCar(playerid);
								if(vehicleid != INVALID_VEHICLE_ID)
								{
									new model_id = GetVehicleData(vehicleid, V_MODELID);
									if(model_id)
									{
										new fmt_str[64];
										new index = GetVehicleData(vehicleid, V_ACTION_ID);

										format(fmt_str, sizeof fmt_str, "รรฎรครฅรซรผ: %s (รญรฎรฌรฅรฐ รฌรฎรครฅรซรจ %d)", GetVehicleName(vehicleid), model_id);
										SendClientMessage(playerid, 0x99FF66FF, fmt_str);

										if(!(GetOwnableCarData(index, OC_COLOR_1) == -1 || GetOwnableCarData(index, OC_COLOR_2) == -1))
										{
											format(fmt_str, sizeof fmt_str, "รรขรฅรฒ 1: ID %d   รรขรฅรฒ 2: ID %d", GetOwnableCarData(index, OC_COLOR_1), GetOwnableCarData(index, OC_COLOR_2));
											SendClientMessage(playerid, 0x99FF66FF, fmt_str);
										}
										else SendClientMessage(playerid, 0x99FF66FF, "รรขรฅรฒร  รฒรฐร รญรฑรฏรฎรฐรฒร : รฑรซรณรทร รฉรญรปรฅ");

										format(fmt_str, sizeof fmt_str, "รรฎรฑ. รฑรฒรฎรจรฌรฎรฑรฒรผ: %d รฐรณรก", GetVehicleInfo(model_id - 400, VI_PRICE));
										SendClientMessage(playerid, 0x99FF66FF, fmt_str);
									}
								}
								else
