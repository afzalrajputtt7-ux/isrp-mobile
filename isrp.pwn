CMD:re(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1) return 1;

    extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /re [id รจรฃรฐรฎรชร ]");

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");

    if(GetPlayerSecretEx(to_player) >= 1)
        return SendClientMessage(playerid, 0xCECECEFF, "ร รจรฃรฐรฎรชร  รฅรฑรฒรผ รฏรฐรจรขรฅรซรฅรฃรจรฟ รฑรชรฐรปรฒรญรฎรฑรฒรผ");
        
    if(playerid == to_player)
        return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

    if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
        return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");

    if(GetPlayerSpectateData(playerid, S_PLAYER) == -1)
    {
        new Float: x, Float: y, Float: z, Float: a;

        GetPlayerPos(playerid, x, y, z);
        GetPlayerFacingAngle(playerid, a);

        SetPlayerSpectateData(playerid, S_START_POS_X, x);
        SetPlayerSpectateData(playerid, S_START_POS_Y, y);
        SetPlayerSpectateData(playerid, S_START_POS_Z, z);
        SetPlayerSpectateData(playerid, S_START_ANGLE, a);

        SetPlayerSpectateData(playerid, S_START_INTERIOR, GetPlayerInterior(playerid));
        SetPlayerSpectateData(playerid, S_START_VIRTUAL_WORLD, GetPlayerVirtualWorld(playerid));
    }

    StartSpectate(playerid, to_player);
    ShowSpectateGUI(playerid, to_player);

    new fmt_text[999];
    format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฑรซรฅรครจรฒ รงร  %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_text, 0x999999FF);
    
    SendClientMessage(playerid, 0x999999FF, "[A] รรฑรฏรฎรซรผรงรณรฉรฒรฅ รชรฎรฌร รญรครณ \"/reoff\", รทรฒรฎรกรป รฏรฐรฅรชรฐร รฒรจรฒรผ รฑรซรฅรฆรชรณ รงร  รจรฃรฐรฎรชรฎรฌ.");

    format(fmt_text, sizeof fmt_text, "รรซรฅรครจรฒ รงร  %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

    return 1;
}
alias:re("sp")

CMD:reoff(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1) return 1;

    if(GetPlayerSpectateData(playerid, S_PLAYER) != -1)
    {
        HidePlayerGUI(playerid, 66);
     //   StopSpectate(playerid);

        new Float:x, Float:y, Float:z, Float:a;
        x = GetPlayerSpectateData(playerid, S_START_POS_X);
        y = GetPlayerSpectateData(playerid, S_START_POS_Y);
        z = GetPlayerSpectateData(playerid, S_START_POS_Z);
        a = GetPlayerSpectateData(playerid, S_START_ANGLE);

        SetPlayerPos(playerid, x, y, z);
        SetPlayerFacingAngle(playerid, a);

        SetPlayerInterior(playerid, GetPlayerSpectateData(playerid, S_START_INTERIOR));
        SetPlayerVirtualWorld(playerid, GetPlayerSpectateData(playerid, S_START_VIRTUAL_WORLD));

        SetPlayerSpectateData(playerid, S_PLAYER, -1);
    }

    return 1;
}

stock HidePlayerGUI(playerid, guiid)
{
    new Node:json = JSON_Object();
    JSON_SetInt(json, "c", 1);
    OnPacketIncoming(playerid, guiid, json);
    JSON_Cleanup(json);
}

CMD:weap(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 2) return 1;

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /weap [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new fmt_text[625],
		text[45];

	format
	(
		fmt_text,
		sizeof fmt_text,
		"\
		รรซรฎรฒ\tรรฐรณรฆรจรฅ\t\tรร รฒรฐรฎรญรป\n{FFFFFF}\
		"
	);

	for(new i = 0; i < 13; i++)
	{
		new weapon_id, weapon_ammo;

		GetPlayerWeaponData(to_player, i, weapon_id, weapon_ammo);

		format(text, sizeof text, "\n%d\t%s%s%d", i+1, GetWeaponName(weapon_id), weapon_dialog_tabulation[weapon_id], weapon_ammo);
		strcat(fmt_text, text);
	}

	Dialog
	(
		playerid,
		INVALID_DIALOG_ID,
		DIALOG_STYLE_LIST,
		"{FFCC00}รรฐรณรฆรจรฟ รณ รจรฃรฐรฎรชร ",
		fmt_text,
		"รร รชรฐรปรฒรผ",
		""
	);

	format(fmt_text, sizeof fmt_text, "รรฌรฎรฒรฐรจรฒ รฎรฐรณรฆรจรฅ %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

	return 1;
}

CMD:stats(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 1) return 1;

	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /stats [id รจรฃรฐรฎรชร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	ShowPlayerStatsAdmin(to_player, playerid);

	new fmt_text[55];

	format(fmt_text, sizeof fmt_text, "รรฌรฎรฒรฐรจรฒ รฑรฒร รฒรจรฑรฒรจรชรณ %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_text);

