	new fmt_text[75],
		list[sizeof fmt_text * 10 + 50] = "รรฐรฃร รญรจรงร รถรจรฟ - รรฎรซรฆรญรฎรฑรฒรผ - รรฌรฟ - รรฅรซรฅรดรฎรญ{FFFFFF}\n";

