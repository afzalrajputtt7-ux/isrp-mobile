 			  g_delivery_vehicle[veh] = false;
  			 g_delivery_target[veh] = -1;
 			  g_delivery_boxes[veh] = 0;
			   g_delivery_target_name[veh][0] = EOS;

 			  SendClientMessage(playerid, COLOR_GREY, "รรป รฐร รงรฃรฐรณรงรจรซรจ รขรฑรฅ รฟรนรจรชรจ, รฏรฎรฑรฒร รขรชร  รฎรชรฎรญรทรฅรญร .");
			}

            return 1;
        }
    }
for (new veh = 0; veh < MAX_VEHICLES; veh++)
    {
        if (areaid == g_delivery_load_area[veh])
        {
            if (!IsValidVehicle(veh)) return 1;
            if (!g_delivery_vehicle[veh]) return 1;

            if (!GetPVarInt(playerid, "box_in_hard_delivery"))
                return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒรณ รฟรนรจรชร  รฑ รฌร รฒรฅรฐรจร รซร รฌรจ รข รฐรณรชร รต, รขรฎรงรผรฌรจรฒรฅ รฅรฃรฎ รญร  รฑรชรซร รครฅ.");

            if (g_delivery_boxes[veh] >= MAX_DELIVERY_BOXES)
                return SendClientMessage(playerid, COLOR_GREY, "รรขรฒรฎรฌรฎรกรจรซรผ รฏรฎรซรญรฎรฑรฒรผรพ รงร รฃรฐรณรฆรฅรญ.");

            RemovePlayerAttachedObject(playerid, 2);
            DeletePVar(playerid, "box_in_hard_delivery");
            DeletePVar(playerid, "box_in_hard_delivery_frac");

            ApplyAnimation(playerid, "CARRY", "putdwn", 4.1, 0, 1, 1, 1, 0, 0);
            SetTimerEx("StopPlayerAnimation", 1000, false, "i", playerid);

            g_delivery_boxes[veh]++;
            UpdateDeliveryLabel(veh, g_delivery_target[veh]);

            SendClientMessage(playerid, COLOR_GREY, "รรป รงร รฃรฐรณรงรจรซรจ รฟรนรจรช รฑ รฌร รฒรฅรฐรจร รซร รฌรจ รข รดรณรฐรณ, รฎรฒรฏรฐร รขรซรฟรฉรฒรฅรฑรผ รงร  รญรฎรขรปรฌ.");

            if (g_delivery_boxes[veh] >= MAX_DELIVERY_BOXES)
            {
                DestroyDynamicPickup(g_delivery_load_pickup[veh]);
                DestroyDynamicArea(g_delivery_load_area[veh]);

                g_delivery_load_pickup[veh] = -1;
                g_delivery_load_area[veh] = -1;

                new msg[128];
                format(msg, sizeof(msg), "รร รฃรฐรณรงรชร  รฎรชรฎรญรทรฅรญร . รรฒรฏรฐร รขรซรฟรฉรฒรฅรฑรผ รข รฎรฐรฃร รญรจรงร รถรจรพ: %s {FFFFFF}รครซรฟ รฐร รงรฃรฐรณรงรชรจ.", g_delivery_target_name[veh]);
                SendClientMessage(playerid, -1, msg);
                SendClientMessage(playerid, -1, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {FFFF00}/unloadboxes {FFFFFF}รครซรฟ รญร รทร รซร  รฐร รงรฃรฐรณรงรชรจ");
            }
        }
    }
