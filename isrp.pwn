stock ShowPlayerBuyCommandDialog(playerid)
{
	if(GetPlayerAdminEx(playerid) < 9)
		return SendClientMessage(playerid, -1, "รรฎรชรณรฏรชร  รฏรซร รฒรญรปรต รชรฎรฌร รญรค รครฎรฑรฒรณรฏรญร  รฑ 9-รฎรฃรฎ รณรฐรฎรขรญรฟ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร ");

	new big_fmt[568], description[64];
	for(new i; i < sizeof(g_admin_cmd_buy); i ++)
	{
		if(g_player[playerid][CMD_ACCESS][i] != '1') description = "{dd2e13}รรฅ รชรณรฏรซรฅรญรฎ";
            else description = "{23dc1b}รรณรฏรซรฅรญรฎ";

		format(big_fmt, sizeof(big_fmt), "%s[%d] %s\t\t%s\t%d รรณรก\n",big_fmt, i+1, g_admin_cmd_buy[i][CMD_NAME], description, g_admin_cmd_buy[i][CMD_PRICE]);
	}
	Dialog
	(
		playerid, DIALOG_BUY_CMD, DIALOG_STYLE_LIST,
		"รรฎรชรณรฏรชร  รฏรซร รฒรญรปรต รชรฎรฌรฌร รญรค",
		big_fmt,
		"รร รซรฅรฅ", "รรฒรฌรฅรญร "
	);
	return 1;
}
stock GetPlayerAdminCMDAllow(playerid, CMD_id)
{
	if(GetPlayerAdminEx(playerid) < 1) return false;
	
