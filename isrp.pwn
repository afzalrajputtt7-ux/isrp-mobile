					else { GivePlayerMoneyEx(BlackJackLobby[lobby][Table1Id], -pBJInfo[BlackJackLobby[lobby][Table1Id]][pBJBet]); format(str, sizeof str, "%d รฐรณb", playermoney(BlackJackLobby[lobby][Table1Id])); PlayerTextDrawSetString(BlackJackLobby[lobby][Table1Id], bj_money[BlackJackLobby[lobby][Table1Id]], str); }
