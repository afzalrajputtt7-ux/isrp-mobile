	if(!(0 <= house_id <= g_house_loaded - 1)) return SendClientMessage(playerid, 0x999999FF, "รร รญรญรฎรฃรฎ รครฎรฌร  รญรฅ รฑรณรนรฅรฑรฒรขรณรฅรฒ รญร  รฑรฅรฐรขรฅรฐรฅ");

