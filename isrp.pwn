CMD:testpos(playerid, params[])
{
    new Float:x, Float:y, Float:z;
    new Float:rot; // รฒรฎรซรผรชรฎ yaw
    new vehicleid;

    if(IsPlayerInAnyVehicle(playerid))
    {
        vehicleid = GetPlayerVehicleID(playerid);
        GetVehiclePos(vehicleid, x, y, z);
        rot = GetVehicleZAngle(vehicleid); // รฏรฎรขรฎรฐรฎรฒ รฏรฎ Z
        printf("รรฃรฐรฎรช %d รข รฒรฐร รญรฑรฏรฎรฐรฒรฅ %d | รรฎรงรจรถรจรฟ: X: %.3f Y: %.3f Z: %.3f | รรฃรฎรซ Z: %.3f",
            playerid, vehicleid, x, y, z, rot);
    }
    else
    {
        GetPlayerPos(playerid, x, y, z);
        GetPlayerFacingAngle(playerid, rot);
        printf("รรฃรฐรฎรช %d รญร  รงรฅรฌรซรฅ | รรฎรงรจรถรจรฟ: X: %.3f Y: %.3f Z: %.3f | รรฃรฎรซ Z: %.3f",
            playerid, x, y, z, rot);
    }

    return 1;
}


stock SaveOwnableCarNitro(index)
{
    new query[128];
    mysql_format(mysql, query, sizeof(query), "UPDATE ownable_cars SET nitro='%d' WHERE id='%d'", GetOwnableCarData(index, OC_NITRO), GetOwnableCarData(index, OC_SQL_ID));
    mysql_query(mysql, query);
}

stock SaveOwnableCarFirmware(index)
{
    new query[256];

    mysql_format(
        mysql,
        query,
        sizeof(query),
        "UPDATE ownable_cars SET \
            comfort_pl = '%d', \
            sport = '%d', \
            sport_pl = '%d', \
            drift = '%d' \
        WHERE id = '%d'",

        GetOwnableCarData(index, OC_COMFORT_PL),
        GetOwnableCarData(index, OC_SPORT),
        GetOwnableCarData(index, OC_SPORT_PL),
        GetOwnableCarData(index, OC_DRIFT),
        GetOwnableCarData(index, OC_SQL_ID)
    );

    mysql_query(mysql, query);
    return 1;
}

stock SetVehicleAcceleration(vehicleid, Float:accel, setvalue=0)
{
    if(setvalue)
    {
        vInfo[vehicleid][vAccel] = accel;
    }
    foreach(new playerid: Player) SetVehicleAccelerationForPlayer(playerid, vehicleid, accel);
}

stock SetVehicleAccelerationForPlayer(playerid, vehicleid, Float:accel)
{
    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT16, vehicleid);
    BS_WriteValue(bs, PR_UINT8, 5);

    BS_WriteValue(bs, PR_FLOAT, accel);

    PR_SendRPC(bs, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
}

CMD:accel1(playerid, params[])
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return SendClientMessage(playerid, -1, !"รญรฅ รข รฌร รธรจรญรฅ!");

    new Float:value;
    if(sscanf(params, "f", value)) return SendClientMessage(playerid, -1, !"รจรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /accel [รงรญร รทรฅรญรจรฅ]");

    SetVehicleAcceleration(vehicleid, value, 1);
    return 1;
}

stock IsSportPartInstalled(current_value, part_digit)
{
    new s_val[12];
    format(s_val, sizeof(s_val), "%d", current_value);
    new char_digit = part_digit + '0';
    for(new i = 0; i < strlen(s_val); i++) {
        if(s_val[i] == char_digit) return 1;
    }
    return 0;
}

CMD:sport1(playerid)
{
    new vehicleid = GetPlayerVehicleID(playerid);
    if(!vehicleid) return 1;
    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == -1) return 1;

    new current = GetOwnableCarData(index, OC_SPORT);
    if(IsSportPartInstalled(current, 1)) return SendClientMessage(playerid, -1, "รรฅรฒร รซรผ #1 รณรฆรฅ รฑรฒรฎรจรฒ!");

    new new_val = current + 1; // รรฎรกร รขรซรฟรฅรฌ 1 รข รฐร รงรฐรฟรค รฅรครจรญรจรถ
    SetOwnableCarData(index, OC_SPORT, new_val);

    new query[128];
    mysql_format(mysql, query, sizeof(query), "UPDATE ownable_cars SET sport='%d' WHERE id='%d'", new_val, GetOwnableCarData(index, OC_SQL_ID));
    mysql_query(mysql, query);
    return 1;
}

