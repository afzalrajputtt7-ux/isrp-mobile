	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รร รถรจรฅรญรฒ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");
	if(GetPlayerData(to_player, P_OCCUPIED_BED) == -1) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รซรฅรฆรจรฒ รข รกรฎรซรผรญรจรถรฅ");
	if(!(100 <= price <= 5000)) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รซรฅรทรฅรญรจรฟ รครฎรซรฆรญร  รกรปรฒรผ รฎรฒ 100 รครฎ 5000 รฐรณรกรซรฅรฉ");
	if(GetPlayerMoneyEx(to_player) < price) return SendClientMessage(playerid, 0x999999FF, "ร รฏร รถรจรฅรญรฒร  รญรฅรฒ รฑ รฑรฎรกรฎรฉ รฑรฒรฎรซรผรชรฎ รครฅรญรฅรฃ");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_MEDHELP, price);
	return 1;
}

CMD:medbed(playerid, params[])
{
    if(IsPlayerInRangeOfPoint(playerid, 100.0, 1484.458862,2494.261474,2501.000000))
    {
        if(GetPlayerHealthEx(playerid) >= 75)
        {
            return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รญรณรฆรคร รฅรฒรฅรฑรผ รข รซรฅรทรฅรญรจรจ");
        }
        new bedid = -1;

        for(new i; i < sizeof g_med_bed_pos; i++)
        {
            if(!IsPlayerInRangeOfPoint(playerid, 2.5, g_med_bed_pos[i][0], g_med_bed_pos[i][1], g_med_bed_pos[i][2])) continue;
            bedid = i;
            break;
        }

        if(bedid == -1) return 1;
        else if(GetPlayerData(playerid, P_OCCUPIED_BED) != -1) return SendClientMessage(playerid, 0xCECECEFF, "รรป รณรฆรฅ รงร รญรฟรซรจ รชรฎรฉรชรณ");
        else if(g_med_bed_used[bedid]) return SendClientMessage(playerid, 0xCECECEFF, "รรฒร  รชรฎรฉรชร  รงร รญรฟรฒร ");

        else
        {
            SetPlayerData(playerid, P_OCCUPIED_BED, bedid);

            g_med_bed_used[bedid] = true;
           
           gPlayerInMedBed[playerid] = true;

            new fmt_msg[200];

            format(fmt_msg, sizeof fmt_msg, "{ffff00}ยซ รร รญรฟรฒร รฟ รกรฎรซรผรญรจรทรญร รฟ รชรฎรฉรชร  ยป\n \n{ffff00}|{ffffff}รรฎรฌรฅรฐ รชรฎรฉรชรจ: {ffff00}%d\n{ffffff}รร รถรจรฅรญรฒ: {ffff00}%s\n \n{ffffff}รรฎรครฎรฉรครจรฒรฅ รกรซรจรฆรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\nรฑ รกรฎรซรผรญรจรทรญรฎรฉ รชรฎรฉรชรฎรฉ", bedid + 1, GetPlayerNameEx(playerid));
            UpdateDynamic3DTextLabelText(g_med_bed_label[bedid], 0xFFFFFFFF, fmt_msg);

            format(fmt_msg, sizeof fmt_msg, "รรป รงร รญรฟรซรจ รชรฎรฉรชรณ ยน%d. ร รงร รขรจรฑรจรฌรฎรฑรฒรจ รฎรฒ รฑรฎรฑรฒรฎรฟรญรจรฟ รงรครฎรฐรฎรขรผรฟ รซรฅรทรฅรญรจรฅ รฌรฎรฆรฅรฒ รงร รญรฟรฒรผ รขรฐรฅรฌรฟ", bedid + 1);
            SendClientMessage(playerid, 0x32a44bFF, fmt_msg);

            SendClientMessage(playerid, -1, "รรฒรฎรกรป รขรปรฏรจรฑร รฒรผรฑรฟ รฏรฎรครฎรฉรครจรฒรฅ รช รขรฐร รทรณ รจรซรจ รขรปรฉรครจรฒรฅ รงร  รฏรฐรฅรครฅรซรป รกรฎรซรผรญรจรถรป");
        }
        SetTimer("HospitalTreatment", (random(5) + 1) * 1000, false);
    }

    return 1;
}

CMD:out(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_HOSPITAL) return SendClientMessage(playerid, 0x999999FF, "รรป รญรฅ รฌรฅรครจรถรจรญรฑรชรจรฉ รฐร รกรฎรฒรญรจรช");
	if(!IsPlayerInRangeOfPoint(playerid, 99.0, 2038.0170,1419.8960,999.1563)) return SendClientMessage(playerid, 0xCECECEFF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รกรฎรซรผรญรจรถรฅ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	extract params -> new to_player; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /out [id รจรฃรฐรฎรชร ]");


	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");
	if(GetPlayerData(to_player, P_OCCUPIED_BED) == -1) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รครฎรซรฆรฅรญ รญร รตรฎรครจรฒรผรฑรฟ รญร  รซรฅรทรฅรญรจรจ");

	ClearMedBed(to_player, GetPlayerData(playerid, P_OCCUPIED_BED));
	SetPlayerData(to_player, P_HOSPITAL, false);

	SetPlayerChatBubble(to_player, "รรปรฏรจรฑร รญ", 0x66CC00FF, 10.0, 2000);

	new fmt_msg[60];
	format(fmt_msg, sizeof fmt_msg, "รรฅรครจรถรจรญรฑรชรจรฉ รฐร รกรฎรฒรญรจรช %s รขรปรฏรจรฑร รซ รร รฑ รจรง รกรฎรซรผรญรจรถรป", GetPlayerNameEx(playerid));
	SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "รรป รขรปรฏรจรฑร รซรจ %s รจรง รกรฎรซรผรญรจรถรป", GetPlayerNameEx(to_player));
	SendClientMessage(playerid, 0x3399FFFF, fmt_msg);
	return 1;
}

