alias:e("en")
CMD:e(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);

	if(!IsABike(vehicleid))
	{
		if(!IsPlayerDriver(playerid))
			return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รงร  รฐรณรซรฅรฌ");

		
		if(GetVehicleData(vehicleid, V_FUEL) <= 0.0)
			return ShowNotificationNew(playerid, 0, 5, 0, 0, "ร รคร รญรญรฎรฌ ร รขรฒรฎ รญรฅรฒ รฒรฎรฏรซรจรขร ", "");

	    engine = (GetVehicleParam(vehicleid, V_ENGINE) ^ VEHICLE_PARAM_ON);
		SetVehicleParam(vehicleid, V_ENGINE, engine);
	}
	return 1;
}
alias:l("lights")
CMD:l(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);

	if(!IsABike(vehicleid))
