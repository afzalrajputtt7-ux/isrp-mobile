				(
					playerid, DIALOG_CONTENER1, DIALOG_STYLE_MSGBOX,
					"{FFCD00}รรฎรฆรฅรฒ รขรปรฏร รฑรฒรผ:",
					"- รรฏรฒรฅรทรชรจ\n"\
					"- รรฅรฌรฎรญรฒรญรปรฅ รชรฎรฌรซรฅรชรฒรป\n"\
					"- รรชรฑรฅรฑรฑรณร รฐ รญร  รฑรฏรจรญรณ\n"\
					"- รร รทรชร  รครฅรญรฅรฃ\n"\
					"- รรฅรฐรฒรจรดรจรชร รฒ รญร  รฎรฏรปรฒ\n"\
					"- รรพรกรฎรฅ รฎรฐรณรฆรจรฅ",
					"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
				);
				
				//return 1;
			}
			if(IsPlayerInRangeOfPoint(playerid, 3.0, 617.468688,1729.151977,12.078809))
			{
				Dialog
				(
					playerid, DIALOG_CONTENER2, DIALOG_STYLE_MSGBOX,
					"{FFCD00}รรฎรฆรฅรฒ รขรปรฏร รฑรฒรผ:",
					"- รรครฅรฆรคร  รฐร รกรฎรฒรญรจรชร  รรร\n"\
					"- รรครฅรฆรคร  รฃรฅรญรจรฐร รซร  ร รฐรฌรจรจ\n"\
					"- รรครฅรฆรคร  รฑรญรฅรฃรณรฐรฎรทรชรจ\n"\
					"- รรครฅรฆรคร  'รรซรผรฟ'\n"\
					"- รรครฅรฆรคร  รฃรฅรญรจรฐร รซร  รรร\n"\
					"- รรครฅรฆรคร  รฐร รกรฎรฒรญรจรชร  รฌรฅรครจรถรจรญรฑรชรฎรฉ รฑรซรณรฆรกรป",
					"รรฎรญรฟรฒรญรฎ", "รร รชรฐรปรฒรผ"
				);
				//return 1;
			}
			if(IsPlayerInRangeOfPoint(playerid, 100.0, 2035.7643,1416.3625,999.7344))
			{
				new bedid = -1;

				for(new i; i < sizeof g_med_bed_pos; i++)
				{
					if(!IsPlayerInRangeOfPoint(playerid, 1.5, g_med_bed_pos[i][0], g_med_bed_pos[i][1], g_med_bed_pos[i][2])) continue;
					bedid = i;
					break;
				}

				if(bedid == -1) return 1;
				else if(GetPlayerData(playerid, P_OCCUPIED_BED) != -1) return SendClientMessage(playerid, 0xCECECEFF, "รรป รณรฆรฅ รงร รญรฟรซรจ รชรฎรฉรชรณ");
				else if(GetPlayerHealthEx(playerid) >= 95.0)
				{
					return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรฅ รญรณรฆรคร รฅรฒรฅรฑรผ รข รซรฅรทรฅรญรจรจ");
				}
				else if(g_med_bed_used[bedid]) return SendClientMessage(playerid, 0xCECECEFF, "รรฒร  รชรฎรฉรชร  รงร รญรฟรฒร ");

				else
				{
					SetPlayerData(playerid, P_OCCUPIED_BED, bedid);

					g_med_bed_used[bedid] = true;

					new fmt_msg[200];

					format(fmt_msg, sizeof fmt_msg, "{ffff00}ยซ รร รญรฟรฒร รฟ รกรฎรซรผรญรจรทรญร รฟ รชรฎรฉรชร  ยป\n{ffff00}|{ffffff}รรฎรฌรฅรฐ รชรฎรฉรชรจ: %d\n{ffffff}รร รถรจรฅรญรฒ: {ffff00} %s\n{ffffff}รรฎรครฎรฉรครจรฒรฅ รกรซรจรฆรฅ รครซรฟ รขรงร รจรฌรฎรครฅรฉรฑรฒรขรจรฟ\nรฑ รกรฎรซรผรญรจรทรญรฎรฉ รชรฎรฉรชรฎรฉ", bedid + 1, GetPlayerNameEx(playerid));
					UpdateDynamic3DTextLabelText(g_med_bed_label[bedid], 0xFFFFFFEE, fmt_msg);

					format(fmt_msg, sizeof fmt_msg, "รรป รงร รญรฟรซรจ รชรฎรฉรชรณ ยน%d. ร รงร รขรจรฑรจรฌรฎรฑรฒรจ รฎรฒ รฑรฎรฑรฒรฎรฟรญรจรฟ รงรครฎรฐรฎรขรผรฟ รซรฅรทรฅรญรจรฅ รฌรฎรฆรฅรฒ รงร รญรฟรฒรผ รขรฐรฅรฌรฟ", bedid + 1);
					SendClientMessage(playerid, 0x66CC00FF, fmt_msg);

					SendClientMessage(playerid, -1, "รรฒรฎรกรป รขรปรฏรจรฑร รฒรผรฑรฟ รฏรฎรครฎรฉรครจรฒรฅ รช รขรฐร รทรณ รจรซรจ รขรปรฉรครจรฒรฅ รงร  รฏรฐรฅรครฅรซรป รกรฎรซรผรญรจรถรป");
				}
			}
			if(GetPlayerInHouse(playerid) != -1)
			{
				new houseid = GetPlayerInHouse(playerid);
				if(GetHouseData(houseid, H_IMPROVEMENTS) >= 1)
				{
					ExitPlayerFromHouse(playerid, 1.1);
				}
			}
			if(GetPlayerData(playerid, P_IN_HOTEL_ROOM) != -1)
			{
				ExitPlayerFromHotelRoom(playerid);
			}
		}
		if(PRESSED(KEY_HANDBRAKE | KEY_WALK))
		{
			new targetid = GetPlayerTargetPlayer(playerid);
			//new targetid = playerid;

			if(targetid != INVALID_PLAYER_ID && !GetPlayerWeapon(playerid))
			{
				SetPlayerData(playerid, P_TARGET_ID, targetid);

				new fmt_str[64];
				format(fmt_str, sizeof fmt_str, "{FFCD00}รรฅรฉรฑรฒรขรจรฟ (%s)", GetPlayerNameEx(targetid));

				Dialog
				(
					playerid, DIALOG_ACTION, DIALOG_STYLE_LIST,
					fmt_str,
					"1. รรฐรจรขรฅรฒรฑรฒรขรจรฅ\n\
					2. รรฎรชร รงร รฒรผ รฏร รฑรฏรฎรฐรฒ\n\
					3. รรฎรชร รงร รฒรผ รซรจรถรฅรญรงรจรจ\n\
					4. รรฎรชร รงร รฒรผ รญร รขรปรชรจ",
					"รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ"
				);
			}
		}
		if(PRESSED(KEY_HANDBRAKE))
		{
			if(GetPVarInt(playerid, "have_jerrican") == 1 && GetPlayerSpeed(playerid) == 0.0)
			{
				new vehicleid = GetNearestVehicleID(playerid, 2.3);
				if(vehicleid != INVALID_VEHICLE_ID)
				{
					SetPVarInt(playerid, "jerrican_fill_car", vehicleid);

					Dialog
					(
						playerid, DIALOG_JERRICAN_FILL_CAR, DIALOG_STYLE_MSGBOX,
						"{6699FF}รร รญรจรฑรฒรฐร ",
						"{FFFFFF}รรป รตรฎรฒรจรฒรฅ รงร รฏรฐร รขรจรฒรผ รฝรฒรฎรฒ รฒรฐร รญรฑรฏรฎรฐรฒ รฑ รชร รญรจรฑรฒรฐรป?",
						"รร ", "รรฅรฒ"
					);
				}
			}
		}
		if(PRESSED(KEY_CTRL_BACK | KEY_HANDBRAKE))
		{
			if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
			{
				callcmd::car(playerid, "");
			}
		}
		else if(PRESSED(KEY_CTRL_BACK))
		{
			CallLocalFunction("cmd_trunk", "i", playerid);
		}
	}
	return 1;
}


public OnRconLoginAttempt(ip[], password[], success)
