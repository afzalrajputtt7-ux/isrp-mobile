						format(fmt_text, sizeof fmt_text, "รรป รคร รซรจ รจรฃรฐรฎรชรณ %s รครฎรฑรฒรณรฏ รช รฐร รครจรฎ-รฝรดรจรฐรณ", GetPlayerNameEx(playerid));
						SendClientMessage(offer_id, 0x66CC33FF, fmt_text);

						format(fmt_text, sizeof fmt_text, "[รรร] %s %s[%d] รฏรฎรครชรซรพรทรจรซ %s[%d] รช รฐร รครจรฎ-รฝรดรจรฐรณ",
						GetPlayerJobAndRankName(offer_id), GetPlayerNameEx(offer_id), offer_id, GetPlayerNameEx(playerid), playerid);

