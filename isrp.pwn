                if(idx < 0 || idx >= sizeof(spawnPos)) idx = 0;

                new vehicleid = CreateVehicle(462, spawnPos[idx][0], spawnPos[idx][1], spawnPos[idx][2], spawnPos[idx][3], 0, 0, 300, 0, VEHICLE_ACTION_TYPE_RENT_BIKE_LUT);

                if(vehicleid == INVALID_VEHICLE_ID)
                {
                    ShowNotificationDefault(playerid, 2, 5, 2, 0, "รรธรจรกรชร : รญรฅ รณรคร รซรฎรฑรผ รฑรฎรงรคร รฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ!");
                    return 1;
