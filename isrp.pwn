	OFFER_TYPE_REPAIR_CAR,		// รฏรฎรทรจรญรชร  ร รขรฒรฎ (รฌรฅรตร รญรจรช)
	OFFER_TYPE_SELL_BUSINESS,	// รฏรฐรฎรคร รฆร  รกรจรงรญรฅรฑร 
	OFFER_TYPE_BUSINESS_MANAGER,// รฏรฐรจรฃรซร รฑรจรฒรผ รฑรฎรฒรฐรณรครญรจรชร  รฑรฅรกรฅ รญร  รฏรฐรฅรครฏรฐรจรฟรฒรจรฅ
	OFFER_TYPE_SELL_HOME,		// รฏรฐรฎรคร รฒรผ รครฎรฌ รจรฃรฐรฎรชรณ
	OFFER_TYPE_HOME_RENT_ROOM,	// รฏรฐรฅรครซรฎรฆรจรฒรผ รฏรฎรฑรฅรซรจรฒรผรฑรฟ รข รชรฎรฌรญร รฒรฅ รฑรขรฎรฅรฃรฎ รครฎรฌร 
	OFFER_TYPE_SELL_OWNABLE_CAR,// รฏรฐรฎรคร รฒรผ รซรจรทรญรปรฉ รร
	OFFER_TYPE_SELL_OWNABLE_CAR2,// รฏรฐรฎรคร รฒรผ รซรจรทรญรปรฉ รร 2
	OFFER_TYPE_INVITE,			// รฏรฐรฅรครซรฎรฆรจรฒรผ รขรฑรฒรณรฏรจรฒรผ รข รฎรฐรฃร รญรจรงร รถรจรพ
	OFFER_TYPE_FINVITE,         // รฏรฐรฅรครซรฎรฆรฅรญรจรฅ รขรฑรฒรณรฏรจรฒรผ รข รฑรฅรฌรผรพ
	OFFER_TYPE_MEDHELP,			// รซรฅรทรฅรญรจรฅ
	OFFER_TYPE_HEAL,			// รซรฅรทรฅรญรจรฅ รข รฌร รธรจรญรฅ รฑรชรฎรฐรฎรฉ รฏรฎรฌรฎรนรจ
	OFFER_TYPE_CHANGE_SEX,		// รฑรฌรฅรญร  รฏรฎรซร 
	OFFER_TYPE_SHOW_SKILL,		// รฏรฐรฎรฑรฌรฎรฒรฐ รญร รขรปรชรฎรข รขรซร รครฅรญรจรฟ รฎรฐรณรฆรจรฅรฌ
	OFFER_TYPE_GIVE_CAR_KEY,	// รคร รฒรผ รชรซรพรทรจ รฎรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร 
	OFFER_TYPE_CASINO_DICE,		// รกรฐรฎรฑรจรฒรผ รชรฎรฑรฒรจ รข รชร รงรจรญรฎ
	OFFER_TYPE_GETHERE,			// รฒรฅรซรฅรฏรฎรฐรฒ รช รฑรฅรกรฅ ร รครฌรจรญร  รขรปรธรฅ รฐร รญรฃรฎรฌ
	OFFER_TYPE_GIVE_MIC,		// รครฎรฑรฒรณรฏ รข รฐร รครจรฎรฝรดรจรฐ
	OFFER_TYPE_GIVE_LIC,		// รฏรฐรฎรคร รฆร  รซรจรถรฅรญรงรจรฉ
	OFFER_TYPE_SELL_SKIN,		// รฏรฐรฎรคร รฆร  รฑรชรจรญร 
	OFFER_TYPE_JAIL_FREE,		// รขรปรฏรณรฑรฒรจรฒรผ รจรง รฒรพรฐรผรฌรป (รครซรฟ ร รครขรฎรชร รฒรฎรข)
	OFFER_TYPE_SELL_COINS_MONEY,
	OFFER_TYPE_SELL_COINS_RUB,
	OFFER_TYPE_ACCESSORY,
	OFFER_TYPE_SHOWVB,
	OFFER_TYPE_SHOWMED,
	OFFER_TYPE_MEDCARD,
	OFFER_TYPE_SHOWPASS,
	OFFER_TYPE_SHOWLIC, 
};

