CMD:starthalloween(playerid)
{
    if(g_HalloweenQuestActive == 0)
    {
        g_HalloweenQuestActive = 1;
        g_PlayerQuestStatus[playerid] = 0;

        // รรกรบรฟรขรซรฟรฅรฌ รฑรฒรฐรฎรชรณ
        new message[128];
        format(message, sizeof(message), "รรป รณรฑรฏรฅรธรญรฎ รญร รทร รซรจ Halloween รชรขรฅรฑรฒ");
        SendClientMessage(playerid, COLOR_WHITE, message); // รรฎรกร รขรผรฒรฅ รถรขรฅรฒ รครซรฟ รฑรฎรฎรกรนรฅรญรจรฟ
        CreateVehicle(466, -707.802062,101.233436,16.304492, 0.0);
        SetPlayerCheckpoint(playerid, -707.802062,101.233436,16.304492);
        if(!IsPlayerPassenger(playerid))
        {
        SetPlayerCheckpoint(playerid, -226.964385,452.922241,12.885372);
        Dialog
        (
        playerid, 12459, DIALOG_STYLE_MSGBOX, "รรฒร รฐรจรช",
        "รรครฐร รขรฑรฒรขรณรฉ %s! รร รครจรฑรผ รข รฌร รธรจรญรณ รจ รฎรฒรฏรฐร รขรซรฟรฉ รญร  รฌรฅรฒรชรณ!",
        "รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ" );
        
       } 
        
    }
    else
    {
        new message[128];
        format(message, sizeof(message), "รรป รณรฆรฅ รญร รทร รซรจ รชรขรฅรฑรฒ");
