									if(GetPlayerOwnableCars(playerid) == 0)
										SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
									else
										SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
								}
							}
							case 3: // รรฒรฌรฅรฒรจรฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ รญร  GPS
							{
								callcmd::getmycar(playerid, "");
							}
							case 4: // รรฎรครฎรฃรญร รฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ รช รฎรฒรฅรซรพ (1000 รฐรณรก)
							{
								new vehicleid = GetPlayerOwnableCar(playerid);
								if(vehicleid != INVALID_VEHICLE_ID)
								{
									if(!SetVehicleToHotelRespawn(hotel_id, vehicleid))
									{
										SendClientMessage(playerid, 0xCECECEFF, "ร รคร รญรญรปรฉ รฌรฎรฌรฅรญรฒ รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรณ รดรณรญรชรถรจรพ");
									}
								}
								else
								{
									if(GetPlayerOwnableCars(playerid) == 0)
										SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
									else
										SendClientMessage(playerid, 0x999999FF, "รร รธ รซรจรทรญรปรฉ รฒรฐร รญรฑรฏรฎรฐรฒ รญรฅ รงร รฃรฐรณรฆรฅรญ รญร  รฑรฅรฐรขรฅรฐ");
								}
							}
							case 5: // รรฐรฎรคร รฒรผ รฒรฐร รญรฑรฏรฎรฐรฒ
							{
								callcmd::sellcar(playerid, "");
