CMD:repaircar(playerid, params[])
{
	if(GetPlayerRepCar(playerid) < 1) return Send(playerid, -1,"ร รขร รฑ รญรฅรฒ รฐรฅรฌ. รชรฎรฌรฏรซรฅรชรฑร , รชรณรฏรจรฒรผ รฅรฃรฎ รฌรฎรฆรญรฎ รญร  รรร");
	
	if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid,-1, !"[รรธรจรกรชร ] {FFFFFF}รรป รครฎรซรฆรญรป รกรปรฒรผ รงร  รฐรณรซยธรฌ");
	
	SendClientMessage(playerid,-1, !"[รรญรดรฎรฐรฌร รถรจรฟ] {FFFFFF}รรป รณรฑรฏรฅรธรญรฎ รฏรฎรทรจรญรจรซรจ รฑรขรฎรฉ รฒรฐร รญรฑรฏรฎรฐรฒ");
	new vehicleid = GetPlayerVehicleID(playerid);
	
	SetVehicleHealth(vehicleid,1000);
	PlayerPlaySound(playerid, 1133, 0.0,0.0,0.0);
	

	RepairVehicle(vehicleid);
	
	AddPlayerData(playerid, P_REPCARID, -, 1);
	UpdatePlayerDatabaseInt(playerid, "repcarid",GetPlayerData(playerid, P_REPCARID));
	return 1;
}
