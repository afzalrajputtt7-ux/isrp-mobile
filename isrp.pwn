			name[0] = EOS;
			cash = 0;
			cache_get_field_content(i, "name", name, mysql);
			cash = cache_get_field_content_int(i, "capt_kills", mysql);
			format(string, sizeof(string), "%s\n"c_b"รรจรช: "c_server"%s "c_b"Kills: "c_server"%d", string, name, cash);
			strcat(string, string, 0);
		}
	}

	Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "รรฎรฏ 5 รจรฃรฐรฎรชรฎรข", string, "รร รชรฐรปรฒรผ", "");

	return 1;
}


