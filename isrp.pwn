		}
		else
		{
		    SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รรป รณรฆรฅ รฏรฎรซรณรทรจรซรจ ร รครฌรจรญรชรณ!");
			return true;
		}
	}
	else
	{
	    return 1;
	}
	return true;
}

