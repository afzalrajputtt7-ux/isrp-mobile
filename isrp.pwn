    strcat(dialog, "{FF6666}#1\t{FFFFFF}รรณรฐรญร รซ รฏรฎรฑรฒร \t{FF6666}รญร รฆรฌรจรฒรฅ รครซรฟ รฏรฎรครฐรฎรกรญรฎรฑรฒรฅรฉ\n");
    strcat(dialog, "{FF6666}#2\t{FFFFFF}รร รฑรฒรณรฏรจรฒรผ รญร  รฏรฎรฑรฒ\t{FF6666}รญร รฆรฌรจรฒรฅ รครซรฟ รขรปรฏรฎรซรญรฅรญรจรฟ รครฅรฉรฑรฒรขรจรฟ\n");
    strcat(dialog, "{FF6666}#3\t{FFFFFF}รรฎรชรจรญรณรฒรผ รฏรฎรฑรฒ\t{FF6666}รญร รฆรฌรจรฒรฅ รครซรฟ รขรปรฏรฎรซรญรฅรญรจรฟ รครฅรฉรฑรฒรขรจรฟ");

    Dialog(playerid, DIALOG_POST, DIALOG_STYLE_TABLIST_HEADERS,
        "{FF6666}KRANIN STUDIO RolePlay {FFFFFF}| รรฐรฌรฅรฉรฑรชรจรฉ รฏรฎรฑรฒ", dialog, "รรปรกรฐร รฒรผ", "รร รชรฐรปรฒรผ");

