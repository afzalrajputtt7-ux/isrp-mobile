alias:gnews("gov")

CMD:invite(playerid, params[])
{
    if (!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG))
        return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

    if (!(9 <= GetPlayerJob(playerid) <= 10))
        return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");	
        
	if(!IsWorkDayStarted(playerid)) return 1;

    if (!strlen(params))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /invite [id รจรฃรฐรฎรชร ]");

    extract params -> new to_player;
    if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
        return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if (1 <= GetPlayerTeamEx(to_player) < MAX_ORG)
        return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รณรฆรฅ รฑรฎรฑรฒรฎรจรฒ รข รฎรฐรฃร รญรจรงร รถรจรจ");

    if (GetPlayerData(to_player, P_WARN))
        return SendClientMessage(playerid, 0xCECECEFF, "ร รจรฃรฐรฎรชร  รฅรฑรฒรผ รฏรฐรฅรครณรฏรฐรฅรฆรครฅรญรจรฟ");

    if (!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");
       
    if (GetPlayerData(to_player, P_MEDCARD) != 1)
	    return SendClientMessage(playerid, COLOR_GREY, "ร รจรฃรฐรฎรชร  รญรฅรฒ รฌรฅรครจรถรจรญรฑรชรฎรฉ รชร รฐรฒรป.");

    new team = GetPlayerTeamEx(playerid);
    if (team == TEAM_PPS || team == TEAM_FBI || team == TEAM_DPS || team == TEAM_FSIN)
    {
        if (GetPlayerData(to_player, P_VOENBILET_NUM) == 0)
            return SendClientMessage(playerid, 0x999999FF, "ร รจรฃรฐรฎรชร  รญรฅรฒรณ รขรฎรฅรญรญรฎรฃรฎ รกรจรซรฅรฒร ");
    }

    SendPlayerOffer(playerid, to_player, OFFER_TYPE_INVITE);
    return 1;
}

CMD:uninvite(playerid, params[])
{
	if(!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG)) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	if(!(9 <= GetPlayerJob(playerid) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /uninvite [id รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");


	extract params -> new to_player, string:reason[32];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!(1 <= strlen(reason) <= 32))
		return SendClientMessage(playerid, 0xCECECEFF, "รรขรฅรครจรฒรฅ รฏรฐรจรทรจรญรณ รณรขรฎรซรผรญรฅรญรจรฟ");

	if(GetPlayerTeamEx(to_player) != GetPlayerTeamEx(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฎรฐรฃร รญรจรงร รถรจรจ");

	if(GetPlayerJob(to_player) >= GetPlayerJob(playerid))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฅรซรผรงรฟ รณรขรฎรซรจรฒรผ รณรขรฎรซรจรฒรผ รงร รฌรฅรฑรฒรจรฒรฅรซรฟ/รซรจรครฅรฐร  รฎรฐรฃร รญรจรงร รถรจรจ");

	// }

	EndWorkDayUval(to_player);
	UnInvite(playerid, to_player, reason);

	return 1;
}

CMD:rang(playerid, params[])
{
	if(!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG)) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	if(!(9 <= GetPlayerJob(playerid) <= 10)) return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /rang [id รจรฃรฐรฎรชร ] [+/-]");

	
	extract params -> new to_player, string:give_rang[2];
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");
	if(GetPlayerTeamEx(to_player) != GetPlayerTeamEx(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฎรฐรฃร รญรจรงร รถรจรจ");
	if(GetPlayerJob(to_player) >= 10) return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รฏรฎรขรปรฑรจรฒรผ รจรซรจ รฏรฎรญรจรงรจรฒรผ รซรจรครฅรฐร  รฎรฐรฃร รญรจรงร รถรจรจ");

	new current_rang = GetPlayerJob(to_player);

	new fmt_msg[75];
	if(give_rang[0] == '+')
	{
		if((current_rang + 1) >= GetPlayerJob(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รฏรฎรขรปรฑรจรฒรผ รกรฎรซรผรธรฅ รฑรขรฎรฅรฃรฎ รฐร รญรฃร ");

		GetPlayerJob(to_player)++;
		format(fmt_msg, sizeof fmt_msg, "รร รธ รฐร รญรฃ รข รฎรฐรฃร รญรจรงร รถรจรจ รกรปรซ รฏรฎรขรปรธรฅรญ รครฎ %d (%s)", GetPlayerJob(to_player), GetPlayerJobAndRankName(to_player));
		SendClientMessage(to_player, 0x3399FFFF, fmt_msg);
	}
	else if(give_rang[0] == '-')
	{
		if((current_rang - 1) < 1) return SendClientMessage(playerid, 0x999999FF, "รรฅรซรผรงรฟ รฏรฎรญรจรงรจรฒรผ รญรจรฆรฅ 1 รฐร รญรฃร ");

		GetPlayerJob(to_player)--;
		format(fmt_msg, sizeof fmt_msg, "รร รธ รฐร รญรฃ รข รฎรฐรฃร รญรจรงร รถรจรจ รกรปรซ รฏรฎรญรจรฆรฅรญ รครฎ %d (%s)", GetPlayerJob(to_player), GetPlayerJobAndRankName(to_player));
		SendClientMessage(to_player, 0x3399FFFF, fmt_msg);
	}
	else return SendClientMessage(playerid, 0xCECECEFF, "รรขรฅรครจรฒรฅ รครฅรฉรฑรฒรขรจรฅ: '+' รทรฒรฎรกรป รฏรฎรขรปรฑรจรฒรผ รจรซรจ '-' รทรฒรฎรกรป รฏรฎรญรจรงรจรฒรผ");

	if(GetPlayerTeamEx(to_player) == TEAM_GOVERNMENT && IsValidDynamic3DTextLabel(GetPlayerData(to_player, P_ADVISOR_LABEL)))
	{
		DestroyDynamic3DTextLabel(GetPlayerData(to_player, P_ADVISOR_LABEL));
		SetPlayerData(to_player, P_ADVISOR_LABEL, Text3D: -1);
	}

	if(!GetPlayerSex(to_player))
	{
		SetPlayerData(playerid, P_OSKIN, GetTeamData(GetPlayerTeamEx(to_player), O_SKINS)[GetPlayerJob(to_player)-1]);
		ResetSkin(to_player);
	}

	format(fmt_msg, sizeof fmt_msg, "รรป %s รฐร รญรฃ %s[%d] รครฎ %d (%s)", (give_rang[0] == '+') ? ("รฏรฎรขรปรฑรจรซรจ") : ("รฏรฎรญรจรงรจรซรจ"),  GetPlayerNameEx(to_player), to_player, GetPlayerJob(to_player), GetPlayerJobAndRankName(to_player));
	SendClientMessage(playerid, 0x3399FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "UPDATE accounts SET org_skin=%d,job=%d WHERE id=%d", GetPlayerData(to_player, P_OSKIN), GetPlayerJob(to_player), GetPlayerAccountID(to_player));
	mysql_query(mysql, fmt_msg, false);

	format(fmt_msg, sizeof fmt_msg, "%s %s[acc:%d] รครฎ %d (%s)", (give_rang[0] == '+') ? ("รรฎรขรปรฑรจรซ") : ("รรฎรญรจรงรจรซ"),  GetPlayerNameEx(to_player), to_player, GetPlayerJob(to_player), GetPlayerJobAndRankName(to_player));

	SendLog(playerid, LOG_TYPE_FRACTION, fmt_msg);

	return 1;
}

CMD:changeskin(playerid, params[])
{
    if (!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG))
        return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");

    if (!(9 <= GetPlayerJob(playerid) <= 10))
        return SendClientMessage(playerid, 0x999999FF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");

	
	if(!IsWorkDayStarted(playerid)) return 1;

    if (!strlen(params))
        return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /changeskin [id รจรฃรฐรฎรชร ]");


    extract params -> new to_player;

    if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

    if (GetPlayerTeamEx(to_player) != GetPlayerTeamEx(playerid))
        return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรฒ รจรฃรฐรฎรช รญรฅ รฑรฎรฑรฒรฎรจรฒ รข รร รธรฅรฉ รฎรฐรฃร รญรจรงร รถรจรจ");


    new team_id = GetPlayerTeamEx(playerid);
    new fmt_str[64], text[1024];
    new old_skin = -1, count;

    SetPVarInt(playerid, "change_team_skin_playerid", to_player);

    // รร รฃรฎรซรฎรขรฎรช
    strcat(text, "{E0584B}รรฎรฌรฅรฐ | {FFFFFF}ID รฑรชรจรญร \t\tรรฎรซ\n");

    for (new i = 0; i < 9; i++)
    {
        new skin = GetTeamData(team_id, O_SKINS)[i];

        if (skin == old_skin) continue;
        old_skin = skin;

        SetPlayerListitemValue(playerid, count, i);
        count++;

        new gender_tag[24];
        if (i < 5)
            format(gender_tag, sizeof gender_tag, "{E0584B}[ รรณรฆ ]");
        else
            format(gender_tag, sizeof gender_tag, "{00FF00}[ รรฅรญ ]");

        format(fmt_str, sizeof fmt_str, "{E0584B}%d | {FFFFFF}%d\t\t%s\n", count, skin, gender_tag);
        strcat(text, fmt_str);
    }

    Dialog(playerid, DIALOG_TEAM_CHANGE_SKIN, DIALOG_STYLE_TABLIST_HEADERS, "{E0584B}รรปรกรฅรฐรจรฒรฅ รขรญรฅรธรญรฎรฑรฒรผ รครซรฟ รจรฃรฐรฎรชร :", text, "รรช", "รรฒรฌรฅรญร ");
    return 1;
}

CMD:showall(playerid, params[])
{
    if (!(1 <= GetPlayerTeamEx(playerid) < MAX_ORG))
        return SendClientMessage(playerid, 0xCECECEFF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	
	if(!IsWorkDayStarted(playerid)) return 1;
	
    if (!(9 <= GetPlayerJob(playerid) <= 10))
        return SendClientMessage(playerid, 0xCECECEFF, "รรณรญรชรถรจรฟ รครฎรฑรฒรณรฏรญร  รซรจรครฅรฐร รฌ รฎรฐรฃร รญรจรงร รถรจรจ รจ รจรต รงร รฌรฅรฑรฒรจรฒรฅรซรฟรฌ");


    new query[128];
    format(query, sizeof query,
        "SELECT name, job, owarn, last_login FROM accounts WHERE team = %d ORDER BY job DESC",
        GetPlayerTeamEx(playerid)
    );

    mysql_tquery(mysql, query, "ShowOrgAllPlayers", "i", playerid);
    return 1;
}

forward ShowOrgAllPlayers(playerid);
public ShowOrgAllPlayers(playerid)
{
    new rows = cache_get_row_count();
    if (rows == 0)
        return SendClientMessage(playerid, COLOR_GREY, "รรฎรฒรฐรณรครญรจรชรฎรข รญรฅรฒ รข รกร รงรฅ รคร รญรญรปรต.");

    new fmt_text[160], list[4096] = "รรจรชรญรฅรฉรฌ\tรร รญรฃ\tรรปรฃรฎรขรฎรฐรป\tรรฎรฑรซรฅรครญรจรฉ รขรตรฎรค\n";

    for (new i = 0; i < rows; i++)
    {
        new name[24];
        new rank = cache_get_field_content_int(i, "job");
        new owarn = cache_get_field_content_int(i, "owarn");
        new last_login = cache_get_field_content_int(i, "last_login");

        cache_get_field_content(i, "name", name, sizeof name);

        new year, month, day, hour, minute, second;
        UnixToDate(last_login, year, month, day, hour, minute, second);

        new date_str[32];
        format(date_str, sizeof date_str, "%02d-%02d-%d", day, month, year);

        format(fmt_text, sizeof fmt_text,
            "%s\t%d\t%d/3\t%s\n",
            name,
            rank,
            owarn,
            date_str
        );

        strcat(list, fmt_text);
    }

    new org_id = GetPlayerTeamEx(playerid);
    new header[64];
    format(header, sizeof header, "{%06x}%s{FFFFFF} | รรฎรฑรฒร รข รฎรฐรฃร รญรจรงร รถรจรจ",
        g_organization[org_id][O_COLOR] & 0xFFFFFF,
        g_organization[org_id][O_NAME]
    );

    ShowPlayerDialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_TABLIST_HEADERS, header, list, "รร รชรฐรปรฒรผ", "");
    return 1;
}

CMD:find(playerid, params[])
{
	if(!(GetPlayerTeamEx(playerid) || GetPlayerJob(playerid))) return SendClientMessage(playerid, 0xCECECEFF, "รรป รญรจรฃรครฅ รญรฅ รฐร รกรฎรฒร รฅรฒรฅ/รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฎรฐรฃร รญรจรงร รถรจรฟรต");

	ShowTeamStructureDialog(playerid, GetPlayerTeamEx(playerid));
	return 1;
}

stock ShowTeamStructureDialog(playerid, teamid)
{
	new string[1500];
	new fmt_str[40];

	if(teamid)
	{
		string = "รรฐรฎรขรฅรญรผ\tรร รญรฃ\tรรฅรซรฅรดรฎรญ\tรรฌรฟ\n\n{FFFFFF}";

		for(new i; i < MAX_PLAYERS; i ++)
		{
			if(!IsPlayerConnected(i)) continue;
			else if(!IsPlayerLogged(i)) continue;
			else if(GetPlayerTeamEx(i) != teamid) continue;

			format(fmt_str, sizeof fmt_str, "%d\t\t%d\t%d\t\t%s", GetPlayerLevel(i), GetPlayerJob(i), GetPlayerPhone(i), GetPlayerNameEx(i));
			strcat(string, fmt_str);

			if(IsPlayerAFK(i))
				strcat(string, "-AFK");

			strcat(string, "\n");
		}

		if(IsTeamSubdivision(teamid))
			Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "{FFCC00}รรซรฅรญรป รฏรฎรครฐร รงรครฅรซรฅรญรจรฟ online", string, "รร รชรฐรปรฒรผ", "");
		else
			Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "{FFCC00}รรซรฅรญรป รฎรฐรฃร รญรจรงร รถรจรจ online", string, "รร รชรฐรปรฒรผ", "");
	}
	else
	{
		string = "รรฐรฎรขรฅรญรผ\tรรฅรซรฅรดรฎรญ\tรรฌรฟ\n\n{FFFFFF}";

		for(new i; i < MAX_PLAYERS; i ++)
		{
			if(!IsPlayerConnected(i)) continue;
			else if(!IsPlayerLogged(i)) continue;
			else if(GetPlayerJob(i) != GetPlayerJob(playerid)) continue;

			format(fmt_str, sizeof fmt_str, "%d\t%d%s%s", GetPlayerLevel(i), GetPlayerPhone(i), GetPlayerPhone(i) > 0 ? ("\t") : ("\t\t"), GetPlayerNameEx(i));
			strcat(string, fmt_str);

			if(IsPlayerAFK(i))
				strcat(string, "-AFK");

			if(IsPlayerInJob(i))
				strcat(string, " *");

			strcat(string, "\n");
		}

		Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, "{FFCC00}รรฎรฒรฐรณรครญรจรชรจ online", string, "รร รชรฐรปรฒรผ", "");
	}
	return 1;
}

