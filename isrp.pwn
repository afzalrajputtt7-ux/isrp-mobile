	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0)) return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");
	if(GetPlayerData(to_player, P_OCCUPIED_BED) == -1) return SendClientMessage(playerid, 0xCECECEFF, "รรฃรฐรฎรช รครฎรซรฆรฅรญ รญร รตรฎรครจรฒรผรฑรฟ รญร  รฑรฒร รถรจรฎรญร รฐรญรฎรฌ รซรฅรทรฅรญรจรจ");
