					Dialog(playerid, DIALOG_FUEL_STATION_ORDER_CANCE, DIALOG_STYLE_MSGBOX, "{33AADD}รรฒรฌรฅรญร  รงร รชร รงร ", fmt_str, "รร ", "รรฅรฒ");
