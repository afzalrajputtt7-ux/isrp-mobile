forward LoadOwnableCarRentLut(playerid, oc_id);
public LoadOwnableCarRentLut(playerid, oc_id)
{
    if(g_ownable_car_loaded + 1 > MAX_OWNABLE_CARS)
    {
        print("[OwnableCars]: รรธรจรกรชร  รข รงร รฃรฐรณรงรชรฅ. รรฐรฅรขรปรธรฅรญ รซรจรฌรจรฒ รซรจรทรญรฎรฃรฎ รฒรฐร รญรฑรฏรฎรฐรฒร ");
        return -1;
    }

    new query[128],
        Cache:result,
        vehicleid;

    mysql_format(mysql, query, sizeof query,
        "SELECT * FROM ownable_cars WHERE id='%d' LIMIT 1", oc_id);
    result = mysql_query(mysql, query, true);

    if(!cache_num_rows())
    {
        cache_delete(result);
        return -1;
    }

    new idx = GetFreeOwnableCarID();

    SetOwnableCarData(idx, OC_SQL_ID,      cache_get_field_content_int(0, "id"));
    SetOwnableCarData(idx, OC_OWNER_ID,    cache_get_field_content_int(0, "owner_id"));
    SetOwnableCarData(idx, OC_MODEL_ID,    cache_get_field_content_int(0, "model_id"));
    SetOwnableCarData(idx, OC_COLOR_1,     cache_get_field_content_int(0, "color_1"));
    SetOwnableCarData(idx, OC_COLOR_2,     cache_get_field_content_int(0, "color_2"));

    cache_get_field_content(0, "number",
        g_ownable_car[idx][OC_NUMBER], mysql, 8);

    // ================== รรรยจร รรรรรรรรร รรรรรร รร PVAR ==================
    new Float:x = GetPVarFloat(playerid, "rent_x");
    new Float:y = GetPVarFloat(playerid, "rent_y");
    new Float:z = GetPVarFloat(playerid, "rent_z");
    new Float:a = GetPVarFloat(playerid, "rent_a");

    DeletePVar(playerid, "rent_x");
    DeletePVar(playerid, "rent_y");
    DeletePVar(playerid, "rent_z");
    DeletePVar(playerid, "rent_a");

    // ================== รรรรรรรรร ร รรรรรรรรร ==================
    SetOwnableCarData(idx, OC_POS_X, x);
    SetOwnableCarData(idx, OC_POS_Y, y);
    SetOwnableCarData(idx, OC_POS_Z, z);
    SetOwnableCarData(idx, OC_ANGLE, a);

    vehicleid = CreateVehicle
    (
        GetOwnableCarData(idx, OC_MODEL_ID),
        x, y, z, a,
        GetOwnableCarData(idx, OC_COLOR_1),
        GetOwnableCarData(idx, OC_COLOR_2),
        -1,
        0,
        VEHICLE_ACTION_TYPE_OWNABLE_CAR,
        idx
    );

    if(vehicleid == INVALID_VEHICLE_ID)
    {
        cache_delete(result);
        return -1;
    }

    format(g_ownable_car[idx][OC_NUMBER], 12, g_ownable_car[idx][OC_NUMBER]);
    SetVehicleRuNumberPlate(vehicleid, g_ownable_car[idx][OC_NUMBER], "17");

    SetVehicleData(vehicleid, V_HEALTH, 1000);
    SetVehicleHealth(vehicleid, 1000);
    SetVehicleData(vehicleid, V_LAST_LOAD_TIME, gettime());

    ownable_car_sell_status[vehicleid] = false;

    cache_delete(result);

    LoadOwnableCarTrunk(vehicleid);

    return vehicleid;
}
stock bool:IsAllPartsPurchased(vehicleid, const parts[], count)
{
    for(new i = 0; i < count; i++)
    {
        if(parts[i] == 0) // รฅรฑรซรจ รครฅรฒร รซรผ รญรฅ รชรณรฏรซรฅรญร 
            return false;
    }
    return true;
}

stock BuyPart(vehicleid, detal_id, type)
{
    new str_query[256];

    // รร รตรฎรครจรฌ รฏรฅรฐรขรปรฉ รฏรณรฑรฒรฎรฉ รฑรซรฎรฒ
    for(new i = 0; i < 5; i++)
    {
        if(VehicleTuning[vehicleid][type][i] == 0)
        {
            VehicleTuning[vehicleid][type][i] = detal_id;

            // รรฎรตรฐร รญรฟรฅรฌ รข รกร รงรณ โ รจรฑรฏรฎรซรผรงรณรฅรฌ รฎรครญรณ รชรฎรซรฎรญรชรณ
            switch(type)
            {
                case TUNING_COMFORT:
                    mysql_format(mysql, str_query, sizeof(str_query),
                        "UPDATE ownable_cars SET OC_COMFORT_PL=%d WHERE id=%d", detal_id, vehicleid);
                case TUNING_SPORT:
                    mysql_format(mysql, str_query, sizeof(str_query),
                        "UPDATE ownable_cars SET OC_SPORT=%d WHERE id=%d", detal_id, vehicleid);
                case TUNING_SPORT_PL:
                    mysql_format(mysql, str_query, sizeof(str_query),
                        "UPDATE ownable_cars SET OC_SPORT_PL=%d WHERE id=%d", detal_id, vehicleid);
                case TUNING_DRIFT:
                    mysql_format(mysql, str_query, sizeof(str_query),
                        "UPDATE ownable_cars SET OC_DRIFT=%d WHERE id=%d", detal_id, vehicleid);
            }

            mysql_query(mysql, str_query, false);

            break; // รฒรฎรซรผรชรฎ รฎรครจรญ รฑรซรฎรฒ รงร  รฐร รง
        }
    }

    // รรฐรจรฌรฅรญรฟรฅรฌ รฏรฐรฎรธรจรขรชรณ
    ApplyTuning(vehicleid);
}

// ร รฐรฅรญรซร  รฒรจรฏรฎ รฏรจรชร รฏ
stock CreateRentBikeLut()
{
    for(new idx; idx < sizeof rent_bikelut; idx ++)
    {
        CreatePickup(19131, 23, rent_bikelut[idx][0], rent_bikelut[idx][1], rent_bikelut[idx][2], -1, PICKUP_ACTION_RENT_BIKE_LUT, idx);//19134
        CreateDynamic3DTextLabel("{ffff00}รรฏรฐร รขรซรฅรญรจรฅ รฒรฐร รญรฑรฏรฎรฐรฒรฎรฌ", 0x3399FFFF, rent_bikelut[idx][0], rent_bikelut[idx][1], rent_bikelut[idx][2]  + 1.4, 10.0);
    }
    return 1;
}



