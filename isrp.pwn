CMD:addfuelst(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 7) return 1;

	extract params -> new price, rent_price; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /addfuelst [รฑรฒรฎรจรฌรฎรฑรฒรผ] [รถรฅรญร  ร รฐรฅรญรครป]");

	if(price < 1) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รกรฅรญรงรฎรชรฎรซรฎรญรชรจ รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");

	if(rent_price < 1) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรจรฌรฎรฑรฒรผ รกรฅรญรงรฎรชรฎรซรฎรญรชรจ รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");

	new Cache: result,
		idx = g_fuel_station_loaded;

	GetPlayerPos(playerid, g_fuel_station[idx][FS_POS_X], g_fuel_station[idx][FS_POS_Y], g_fuel_station[idx][FS_POS_Z]);

	new fmt_text[256];

	format
	(

		fmt_text, sizeof fmt_text,
		"INSERT INTO `fuel_stations`\
		(`price`,`rent_price`,`fuels`, `fuel_price`, `buy_fuel_price`, `balance`, `x`, `y`, `z`)\
		VALUES('%d','%d','100','50','50','100000','%f','%f','%f')",
		price, rent_price,
		GetFuelStationData(idx, FS_POS_X),
		GetFuelStationData(idx, FS_POS_Y),
		GetFuelStationData(idx, FS_POS_Z)
	);


	result = mysql_query(mysql, fmt_text, true);

	SetFuelStationData(idx, FS_SQL_ID, 		cache_insert_id());

	cache_delete(result);

	g_fuel_station_loaded ++;

	SetFuelStationData(idx, FS_LABEL, CreateDynamic3DTextLabel("รกรฅรญรงรฎรชรฎรซรฎรญรชร ", 0xFFFF00FF, GetFuelStationData(idx, FS_POS_X), GetFuelStationData(idx, FS_POS_Y), GetFuelStationData(idx, FS_POS_Z) + 0.3, 6.50));

	UpdateFuelStationLabel(idx);

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฑรฎรงรคร รซ รงร รฏรฐร รขรชรณ ยน%d", GetPlayerNameEx(playerid), playerid, idx);

	SendMessageToAdmins(fmt_text, 0x66CC33FF);
	return 1;
}

CMD:addhouse(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 7) return 1;

	extract params -> new type, price, rent_price; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /addhouse [รฒรจรฏ] [รฑรฒรฎรจรฌรฎรฑรฒรผ] [รถรฅรญร  ร รฐรฅรญรครป]");

	new fmt_text[300];

	if(!(0 <= type <= sizeof g_house_type - 1))
	{
		SendClientMessage(playerid, 0x999999FF, "รรจรฏรป รครฎรฌรฎรข:");

		for(new i; i < sizeof g_house_type; i ++)
		{
			format(fmt_text, sizeof fmt_text, "%d. %s", i, GetHouseTypeInfo(i, HT_NAME));

			SendClientMessage(playerid, 0xCECECEFF, fmt_text);
		}

		return 1;
	}

	if(price < 1) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรจรฌรฎรฑรฒรผ รครฎรฌร  รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");

	if(rent_price < 1) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรจรฌรฎรฑรฒรผ ร รฐรฅรญรครป รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");

	new Cache: result,
		idx = g_house_loaded;

	GetPlayerPos(playerid, g_house[idx][H_POS_X], g_house[idx][H_POS_Y], g_house[idx][H_POS_Z]);

	SetHouseData(idx, H_PRICE,			price);
	SetHouseData(idx, H_RENT_PRICE,		rent_price);
	SetHouseData(idx, H_TYPE,			type);

	SetHouseData(idx, H_ENTRACE,		-1);

	format
	(
		fmt_text, sizeof fmt_text,
		"INSERT INTO houses \
		(type, price, rent_price, x, y, z)\
		VALUES ('%d', '%d', '%f', '%f', '%f', '%f')",
		type, price, rent_price,
		GetHouseData(idx, H_POS_X),
		GetHouseData(idx, H_POS_Y),
		GetHouseData(idx, H_POS_Z)
	);

	result = mysql_query(mysql, fmt_text, true);

	SetHouseData(idx, H_SQL_ID, 		cache_insert_id());

	cache_delete(result);

	g_house_loaded ++;

	UpdateHouse(idx);

	new city[MAX_ZONES_NAME + 1], area[MAX_ZONES_NAME + 1];
	GetCityName(GetHouseData(idx, H_POS_X), GetHouseData(idx, H_POS_Y), city);
	GetAreaName(GetHouseData(idx, H_POS_X), GetHouseData(idx, H_POS_Y), area);
	format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฑรฎรงรคร รซ รครฎรฌ ยน%d (%s / %s)", GetPlayerNameEx(playerid), playerid, idx, city, area);

	SendMessageToAdmins(fmt_text, 0x66CC33FF);

	SendClientMessage(playerid, 0x3399FFFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ {FFFF00}/setexitpos รจ /setcarpos{3399FF}, รทรฒรฎรกรป รงร รขรฅรฐรธรจรฒรผ รฑรฎรงรคร รญรจรฅ รครฎรฌร ");

	return 1;
}

CMD:edithousedata(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
    if(GetPlayerAdminEx(playerid) < 7) return 1;

    extract params -> new houseid, type, price, rent_price;  else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /edithousedata [ID รครฎรฌร ] [รฒรจรฏ] [รฑรฒรฎรจรฌรฎรฑรฒรผ] [รถรฅรญร  ร รฐรฅรญรครป]");

    if(!(0 <= houseid < g_house_loaded))
        return SendClientMessage(playerid, 0x999999FF, "รรฎรฌ รฑ รฒร รชรจรฌ ID รญรฅ รญร รฉรครฅรญ");

    if(!(0 <= type < sizeof g_house_type))
    {
        SendClientMessage(playerid, 0x999999FF, "รรฅรขรฅรฐรญรปรฉ รฒรจรฏ รครฎรฌร . รรฎรฑรฒรณรฏรญรปรฅ รฒรจรฏรป:");

        new fmt_text[128];
        for(new i; i < sizeof g_house_type; i++)
        {
            format(fmt_text, sizeof fmt_text, "%d. %s", i, GetHouseTypeInfo(i, HT_NAME));
            SendClientMessage(playerid, 0xCECECEFF, fmt_text);
        }

        return 1;
    }

    if(price < 1) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรจรฌรฎรฑรฒรผ รครฎรฌร  รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");
    if(rent_price < 1) return SendClientMessage(playerid, 0x999999FF, "รรฒรฎรจรฌรฎรฑรฒรผ ร รฐรฅรญรครป รญรฅ รฌรฎรฆรฅรฒ รกรปรฒรผ รฌรฅรญรผรธรฅ 1");

    SetHouseData(houseid, H_TYPE, type);
    SetHouseData(houseid, H_PRICE, price);
    SetHouseData(houseid, H_RENT_PRICE, rent_price);

    new fmt_text[300];
    format(fmt_text, sizeof fmt_text,
        "UPDATE houses SET type = '%d', price = '%d', rent_price = '%d' WHERE id = '%d'",
        type, price, rent_price, GetHouseData(houseid, H_SQL_ID)
    );

    new Cache: result = mysql_query(mysql, fmt_text, true);
    cache_delete(result);

    UpdateHouse(houseid);

    format(fmt_text, sizeof fmt_text, "[A] %s[%d] รจรงรฌรฅรญรจรซ รฏร รฐร รฌรฅรฒรฐรป รครฎรฌร  ยน%d (รฒรจรฏ: %d, รถรฅรญร : %d, ร รฐรฅรญรคร : %d)",
        GetPlayerNameEx(playerid), playerid, houseid, type, price, rent_price);

    SendMessageToAdmins(fmt_text, 0x66CC33FF);
    SendClientMessage(playerid, 0x3399FFFF, "รร รฐร รฌรฅรฒรฐรป รครฎรฌร  รณรฑรฏรฅรธรญรฎ รฎรกรญรฎรขรซรฅรญรป");

    return 1;
}

CMD:sethousepos(playerid, params[])
{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
    if(GetPlayerAdminEx(playerid) < 7) return 1;

    extract params -> new houseid; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sethousepos [ID รครฎรฌร ]");

    if(!(0 <= houseid < g_house_loaded))
        return SendClientMessage(playerid, 0x999999FF, "รรฎรฌ รฑ รฒร รชรจรฌ ID รญรฅ รญร รฉรครฅรญ");

    new Float:x, Float:y, Float:z;
    GetPlayerPos(playerid, x, y, z);

    SetHouseData(houseid, H_POS_X, x);
    SetHouseData(houseid, H_POS_Y, y);
    SetHouseData(houseid, H_POS_Z, z);

    new fmt_text[300];
    format(fmt_text, sizeof fmt_text,
        "UPDATE houses SET x = '%f', y = '%f', z = '%f' WHERE id = '%d'",
        x, y, z, GetHouseData(houseid, H_SQL_ID)
    );

    new Cache: result = mysql_query(mysql, fmt_text, true);
    cache_delete(result);

    UpdateHouse(houseid);

    format(fmt_text, sizeof fmt_text, "[A] %s[%d] รฎรกรญรฎรขรจรซ รฏรฎรงรจรถรจรพ รครฎรฌร  ยน%d", GetPlayerNameEx(playerid), playerid, houseid);
    SendMessageToAdmins(fmt_text, 0x66CC33FF);

    SendClientMessage(playerid, 0x3399FFFF, "รรฎรงรจรถรจรฟ รครฎรฌร  รณรฑรฏรฅรธรญรฎ รฎรกรญรฎรขรซรฅรญร ");

    return 1;
}

