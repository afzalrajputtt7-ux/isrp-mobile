public: GetPlayerPrise(playerid)
{
	new fmt_text[256];
	
	AddPlayerData(playerid, P_DONATE_CASE, -, 1);
	UpdatePlayerDatabaseInt(playerid, "case", GetPlayerData(playerid, P_DONATE_CASE));
	
    switch(random(15))
	{
		case 0..6:
		{
			new rand = random(10000000);

			GivePlayerMoneyEx(playerid, rand,"รรฒรชรฐรปรฒรจรฅ รชรฅรฉรฑร ", true, true);
			format(fmt_text, sizeof fmt_text, "รรฎรงรครฐร รขรซรฟรฅรฌ! รรป รขรปรจรฃรฐร รซรจ: %d$", rand);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);
			return 1;
		}
		case 7..8:
		{
		    new rand = random(15);
		    
		    GivePlayerDonateRub(playerid, rand,"รรฒรชรฐรปรฒรจรฅ รชรฅรฉรฑร ", true, true);
			format(fmt_text, sizeof fmt_text, "รรฎรงรครฐร รขรซรฟรฅรฌ! รรป รขรปรจรฃรฐร รซรจ: %d DONATE-RUB", rand);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);
			return 1;
		}
		case 9:
		{
		    AddPlayerData(playerid, P_CAR_SLOTS, +, 1);
			UpdatePlayerDatabaseInt(playerid, "car_slots", GetPlayerData(playerid, P_CAR_SLOTS));
			
			format(fmt_text, sizeof fmt_text, "รรป รขรปรจรฃรฐร รซรจ รฑรซรฎรฒ รครซรฟ รฒรฐร รญรฑรฏรฎรฐรฒร . รรฅรชรณรนรฅรฅ รชรฎรซรจรทรฅรฑรฒรขรฎ รฑรซรฎรฒรฎรข: %d",
			GetPlayerData(playerid, P_CAR_SLOTS));
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);
			return 1;
		}
		case 10..13:
		{
		    new rand = random(500) + 300;

		    GivePlayerDonate(playerid, rand,"รรฒรชรฐรปรฒรจรฅ รชรฅรฉรฑร ", true);
			format(fmt_text, sizeof fmt_text, "รรฎรงรครฐร รขรซรฟรฅรฌ! รรป รขรปรจรฃรฐร รซรจ: %d DONATE-COINS", rand);
			SendClientMessage(playerid, 0x66CC00FF, fmt_text);
		}
		case 14..15:
		{
		    new premium = GetPlayerPremium(playerid);
      		if(!premium)
        	{
         		SetPlayerData(playerid, P_PREMIUM, 1);
         		SetPlayerData(playerid, P_PREMIUM_DATE, gettime() + 3 * 86400);
			}
			else
			{
   				AddPlayerData(playerid, P_PREMIUM_DATE, +, 3 * 86400);
			}

			new prem_day,
   			prem_month,
   			prem_year;

			timestamp_to_date(GetPlayerData(playerid, P_PREMIUM_DATE), prem_year, prem_month, prem_day);

			format(fmt_text, sizeof fmt_text, "รรป รณรฑรฏรฅรธรญรฎ รขรปรจรฃรฐร รซรจ {EC174F} VIP {FFFFFF}รครฎ {EC174F}%02d.%02d.%d", prem_day, prem_month, prem_year);
			SendClientMessage(playerid, -1, fmt_text);
			UpdatePlayerDatabaseInt(playerid, "premium_date", GetPlayerData(playerid, P_PREMIUM_DATE));
			UpdatePlayerDatabaseInt(playerid, "premium", 1);
			return 1;
		}
 	}
	return false;
}

