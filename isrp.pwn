}


CMD:rep(playerid, params[])
{
	if(!GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xFFFFFFFF, "{FF0000}| {FFFFFF}รรฎรฑรฒรณรฏรญรฎ รฒรฎรซรผรชรฎ ร รครฌรจรญรจรฑรฒรฐร รถรจรจ รฏรฐรฎรฅรชรฒร !");

	if(!g_report_created) return SendClientMessage(playerid, 0xCECECEFF, "{FF0000}| {FFFFFF}รรฅรฒ รฎรกรฐร รนรฅรญรจรฉ รครซรฟ รฏรฐรฎรขรฅรฐรชรจ!");

	new fmt_text[360],
		bool: rep_is_found;

	for(new idx; idx < g_report_created; idx ++)
	{
		if(GetReportData(idx, REP_EDIT) || GetReportData(idx, REP_CREATOR) == INVALID_PLAYER_ID) continue;

		format
		(
			fmt_text, sizeof fmt_text,
			"{FFFF00}| {FFFFFF}รรฒรฏรฐร รขรจรฒรฅรซรผ: {FFFF00}%s[%d]\n\n{FFFF00}| {FFFFFF}รรฎรครฅรฐรฆรจรฌรฎรฅ: {FFFF00}%s \n\n"\
			"{FFFFFF}รร รฌ รญรฅรฎรกรตรฎรครจรฌรฎ รฑรดรฎรฐรฌรณรซรจรฐรฎรขร รฒรผ, ร  รงร รฒรฅรฌ รขรขรฅรฑรฒรจ รฎรฒรขรฅรฒ รญร \n"\
			"รฆร รซรฎรกรณ รจรฃรฐรฎรชร  รข รครจร รซรฎรฃรฎรขรฎรฅ รฏรฎรซรฅ รญรจรฆรฅ.",
			GetPlayerNameEx(GetReportData(idx, REP_CREATOR)), GetReportData(idx, REP_CREATOR), GetReportData(idx, REP_TEXT)
		);

		Dialog(playerid, DIALOG_REPORT_EDIT, DIALOG_STYLE_INPUT, "{FF6347}"SERVER_NAME" {FFFFFF}| รร รซรฎรกรป", fmt_text, "รร รซรฅรฅรฅ", "รรฒรฌรฅรญร ");

		SetReportData(idx, REP_EDIT, true);

		SetPVarInt(playerid, "report_id", idx);

		rep_is_found = true;

		break;
	}

	if(!rep_is_found) return SendClientMessage(playerid, 0xCECECEFF, "{FF0000}| {FFFFFF}รรฅรฒ ร รชรฒรณร รซรผรญรปรต รฎรกรฐร รนรฅรญรจรฉ รครซรฟ รฐร รฑรฑรฌรฎรฒรฐรฅรญรจรฟ!");

	return 1;
}
alias:reps("reps")
alias:ans("pm")
CMD:ans(playerid, params[])
{
    if(GetPlayerAdminEx(playerid))
    {
		new targetid, text[81];

		if (sscanf(params, "is[81]", targetid, text) || targetid < 0 ) {
			if (!report_Show(playerid) && strlen(params) > 2) {
				SendClientMessage(playerid, COLOR_WHITE, !"{afafaf}รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /ans [playerid / reportid] [รฒรฅรชรฑรฒ / รฎรฒรขรฅรฒ]");
			}
			return true;
		}
		if (targetid >= MAX_PLAYERS) {

			new report_id = targetid, status = REPORT_STATUS_ANSWERED, Cache:result;

			mysql_query_[0] = EOS;

			mysql_format(mysql, mysql_query_, sizeof (mysql_query_), "SELECT * FROM "TABLE_REPORTS" \
				WHERE status=0 AND id=%i", report_id
			);
			result = mysql_query(mysql, mysql_query_, true);

			targetid = cache_get_field_content_int(0, "player_id");
			cache_get_field_content(0, "text", TempReportInfo[playerid][reportText], mysql, 144);
			cache_get_field_content(0, "date", TempReportInfo[playerid][reportDate], mysql, 20);

			mysql_query_[0] = EOS;
			new rows = cache_num_rows();

			if(!rows) {
				cache_delete(result);
				SendClientMessage(playerid, COLOR_WHITE, !"{afafaf}รร  รคร รญรญรปรฉ รงร รฏรฐรฎรฑ รณรฆรฅ รกรปรซ รคร รญ รฎรฒรขรฅรฒ!");
				return true;
			}
			mysql_format(mysql, mysql_query_, sizeof (mysql_query_), "UPDATE "TABLE_REPORTS" SET \
				status=%d, answer='%s' WHERE status=0 AND id=%d", status, text, report_id
			);
			mysql_query(mysql, mysql_query_);

			format(stringer1, sizeof (stringer1), "\
				{FFFFFF}รร รฒร  รงร รฏรฐรฎรฑร : {afafaf}%s\n \n\
				{FFFFFF}รร รธ รงร รฏรฐรฎรฑ ยน%d:\n\
				{afafaf}| {afafaf}%s\n \n\
				{FFFFFF}รรฒรขรฅรฒ รฎรฒ ร รครฌรจรญรจรฑรฒรฐร รถรจรจ:\n\
				{afafaf}| "c_server"%s",
				TempReportInfo[playerid][reportDate], report_id, TempReportInfo[playerid][reportText], text
			);
			Dialog(targetid, 0000, DIALOG_STYLE_MSGBOX, ""c_server"รรฒรขรฅรฒ ร รครฌรจรญรจรฑรฒรฐร รถรจรจ", stringer1, !"รรฏร รฑรจรกรฎ", !"");

			format(stringer1, sizeof (stringer1), ""c_server"รร รธ รงร รฏรฐรฎรฑ ยน%d: {FFFFFF}%s", report_id, TempReportInfo[playerid][reportText]);
			SendClientMessage(targetid, COLOR_YELLOW, stringer1);
			format(stringer1, sizeof (stringer1), ""c_server"{8B4513}รรฒรขรฅรฒ รฎรฒ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s[%d]: {CD853F}%s", GetPlayerNameEx(playerid), playerid, text);
			SendClientMessage(targetid, COLOR_YELLOW, stringer1), stringer1[0] = EOS;

			format(stringer1, sizeof(stringer1), "{CC6633}[A] %s[%d] รฎรฒรขรฅรฒรจรซ รจรฃรฐรฎรชรณ %s[%i]: %s",
				GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(targetid), targetid, text
			);
			SendMessageToAdmins(stringer1,0xFfa500AA);

            /*if(PlayerInfo[playerid][pAdmin]) PlayerInfo[playerid][pRepAdm]++;
            else PlayerInfo[playerid][pHotvet] ++;*/

			cache_delete(result);

		} else {
			if (!IsPlayerConnected(targetid))
				return SendClientMessage(playerid, COLOR_WHITE, !"{afafaf}รรฃรฐรฎรช รญรฅ รญร รฉรครฅรญ");

			if (strlen(text) > 80)
				return SendClientMessage(playerid, COLOR_WHITE, !"{afafaf}รรฅรซรผรงรฟ รฏรจรฑร รฒรผ รกรฎรซรผรธรฅ 80 รฑรจรฌรขรฎรซรฎรข!");

			if (targetid == playerid)
				return SendClientMessage(playerid, COLOR_WHITE, !"{afafaf}รรฅรซรผรงรฟ รฎรฒรขรฅรฒรจรฒรผ รฑร รฌรฎรฌรณ รฑรฅรกรฅ");

			format(stringer1, sizeof(stringer1), ""c_server"{8B4513}รรฒรขรฅรฒ รฎรฒ ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %s[%d]: {CD853F}%s",
				GetPlayerNameEx(playerid), playerid, text
			);
			SendClientMessage(targetid, 0xffa141FF, stringer1);

			format(stringer1, sizeof(stringer1), "{afafaf}[A] %s[%d] รฎรฒรขรฅรฒรจรซ รจรฃรฐรฎรชรณ %s[%d]: %s",
				GetPlayerNameEx(playerid), playerid, GetPlayerData(targetid, P_NAME), targetid, text
			);
			SendMessageToAdmins(stringer1,0xFfa500AA);

            /*if(PlayerInfo[playerid][pAdmin]) PlayerInfo[playerid][pRepAdm]++;
            else PlayerInfo[playerid][pHotvet] ++;*/

			stringer1[0] = EOS;
		}
	}
	return true;
}



CMD:addfamcar(playerid, params[])
{
    new database_car;
    if(sscanf(params, "d", database_car))
        return SendClientMessage(playerid, COLOR_GREY, "รรฑรฏรฎรซรผรงรฎรขร รญรจรฅ: /addfamcar [ID ร รขรฒรฎ]");

    new fam_id = GetPlayerIdFamily(playerid);
    if(fam_id == -1)
        return SendClientMessage(playerid, COLOR_GREY, "รรป รญรฅ รฑรฎรฑรฒรฎรจรฒรฅ รข รฑรฅรฌรผรฅ.");

    MoveOwnableCar(playerid, database_car, fam_id);
    return 1;
}

CMD:testf(playerid)
{
new fam_id = GetPlayerIdFamily(playerid);

new msg[64];
format(msg, sizeof(msg), "รรฉรครจ รฑรฅรฌรผรจ: %d", fam_id);
SendClientMessage(playerid, COLOR_GREY, msg);
}



stock ShowAdminCommandsByLevel(playerid, level)
{
    new dialogStr[2048];
    format(dialogStr, sizeof(dialogStr), "รรฎรฌร รญรครป ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร  %d รณรฐรฎรขรญรฟ:\n\n", level);

    switch(level)
    {
        case 1:
        {
            strcat(dialogStr, "/re โ รญร รทร รฒรผ รฑรซรฅรฆรชรณ รงร  รจรฃรฐรฎรชรฎรฌ\n");
            strcat(dialogStr, "/reoff โ รฏรฐรฅรชรฐร รฒรจรฒรผ รฑรซรฅรฆรชรณ\n");
            strcat(dialogStr, "/epoints โ รฎรฒรชรฐรปรฒรผ รฌร รฃร รงรจรญ epoints\n");
            strcat(dialogStr, "/askin โ รญร รครฅรฒรผ ร รครฌรจรญ-รฑรชรจรญ\n");
            strcat(dialogStr, "/jail โ รฏรฎรฑร รครจรฒรผ รจรฃรฐรฎรชร  รข รฒรพรฐรผรฌรณ\n");
            strcat(dialogStr, "/unjail โ รฎรฑรขรฎรกรฎรครจรฒรผ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/mute โ รงร รกรซรฎรชรจรฐรฎรขร รฒรผ รทร รฒ\n");
            strcat(dialogStr, "/unmute โ รฑรญรฟรฒรผ รกรซรฎรชรจรฐรฎรขรชรณ รทร รฒร \n");
            strcat(dialogStr, "/flip โ รฏรฅรฐรฅรขรฅรฐรญรณรฒรผ ร รขรฒรฎ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/vtp โ รฒรฅรซรฅรฏรฎรฐรฒ รช ร รขรฒรฎ\n");
            strcat(dialogStr, "/getv โ รฒรฅรซรฅรฏรฎรฐรฒ ร รขรฒรฎ รช รจรฃรฐรฎรชรณ\n");
            strcat(dialogStr, "/vget โ รฒรฅรซรฅรฏรฎรฐรฒ ร รขรฒรฎ รช รฑรฅรกรฅ\n");
            strcat(dialogStr, "/freeze โ รงร รฌรฎรฐรฎรงรจรฒรผ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/unfreeze โ รฐร รงรฌรฎรฐรฎรงรจรฒรผ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/astats โ รฑรฒร รฒรจรฑรฒรจรชร  ร รครฌรจรญรจรฑรฒรฐร รฒรฎรฐร \n");
            strcat(dialogStr, "/stats โ รฑรฒร รฒรจรฑรฒรจรชร  รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/slap โ รฏรฎรครกรฐรฎรฑรจรฒรผ รจรฃรฐรฎรชร \n");
            strcat(dialogStr, "/agm โ ร รครฌรจรญรจรฑรฒรฐร รฒรจรขรญรฎรฅ รกรฅรฑรฑรฌรฅรฐรฒรจรฅ\n");
            strcat(dialogStr, "/tp โ รฒรฅรซรฅรฏรฎรฐรฒ-รซรจรฑรฒ\n");
            strcat(dialogStr, "/af โ ร รครฌรจรญ-รดรฎรฐรฌรป\n");
            strcat(dialogStr, "/dl โ รจรญรดรฎรฐรฌร รถรจรฟ รฎรก ร รขรฒรฎ\n");
            strcat(dialogStr, "/az โ รฒรฅรซรฅรฏรฎรฐรฒ รข ร รครฌรจรญ-รงรฎรญรณ\n");
        }
        case 2:
