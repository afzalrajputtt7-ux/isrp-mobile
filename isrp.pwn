		SendClientMessage(playerid, 0xCECECEFF, "รรฎรค: 1 - รรฐรฎรขรฅรญรผ | 2 - รร รกรฎรฒร ");

		return 1;
	}

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player)) return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	new fmt_msg[128];

	switch(set_code)
	{
		case 1:
		{
			if(!(1 <= set_value <= 25)) return SendClientMessage(playerid, 0xFF6600FF, "รรฐรฎรขรฅรญรผ รฎรฒ 1 รครฎ 25");

			SetPlayerData(to_player, P_LEVEL, set_value);

			SetPlayerScore(to_player, set_value);

			format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รจรงรฌรฅรญรจรซ รร รฌ รณรฐรฎรขรฅรญรผ รญร  %d", GetPlayerNameEx(playerid), set_value);
			SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

			format(fmt_msg, sizeof fmt_msg, "รรป รจรงรฌรฅรญรจรซรจ รจรฃรฐรฎรชรณ %s รณรฐรฎรขรฅรญรผ รญร  %d", GetPlayerNameEx(to_player), set_value);
			SendClientMessage(playerid, 0x3399FFFF, fmt_msg);
		}
		case 2:
		{
			//if(!(0 <= set_value <= 6)) return SendClientMessage(playerid, 0xFF6600FF, "รรค รฐร รกรฎรฒรป รฎรฒ 0 รครฎ 6");
			SetPlayerData(to_player, P_JOB, set_value);

			format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รณรฑรฒร รญรฎรขรจรซ รร รฌ รฐร รกรฎรฒรณ %s", GetPlayerNameEx(playerid), GetPlayerJobAndRankName(to_player));
			SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

			format(fmt_msg, sizeof fmt_msg, "รรป รณรฑรฒร รญรฎรขรจรซรจ รจรฃรฐรฎรชรณ %s รฐร รกรฎรฒรณ %s", GetPlayerNameEx(to_player), GetPlayerJobAndRankName(to_player));
			SendClientMessage(playerid, 0x66CC00FF, fmt_msg);
		}
		default: return SendClientMessage(playerid, 0xFF6600FF, "รรธรจรกรชร : รรฅรขรฅรฐรญรฎ รขรขรฅรครฅรญ รชรฎรค");
	}

	mysql_format(mysql, fmt_msg, sizeof fmt_msg, "UPDATE accounts SET level=%d,job=%d WHERE id=%d", GetPlayerLevel(to_player), GetPlayerJob(to_player), GetPlayerAccountID(to_player));
	mysql_query(mysql, fmt_msg, false);

	return 1;
}

CMD:pay(playerid, params[])
{
	extract params -> new to_player, cash; else return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /pay [id รจรฃรฐรฎรชร ] [รฑรณรฌรฌร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 6.0))
		return SendClientMessage(playerid, 0x999999FF, ""USC"รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รคร รซรฅรชรฎ รฎรฒ รร รฑ");

	new fmt_text[75],
		max_money = 50000;

	if(!(1 <= cash <= max_money))
	{
		format(fmt_text, sizeof fmt_text, ""USC"รรณรฌรฌร  รครฎรซรฆรญร  รกรปรฒรผ รฎรฒ 1 รครฎ %d รฐรณรกรซรฅรฉ", max_money);

		SendClientMessage(playerid, 0xCECECEFF, fmt_text);
		return 1;
	}

	format(fmt_text, sizeof fmt_text, "+%d", cash);
	SetPlayerChatBubble(to_player, fmt_text, 0x00CC00FF, 10.0, 5000);

	format(fmt_text, sizeof fmt_text, "-%d", cash);
	SetPlayerChatBubble(playerid, fmt_text, 0xFF6600FF, 10.0, 5000);

	format(fmt_text, sizeof fmt_text, "รรฅรฐรฅรคร รทร  รครฅรญรฅรฃ รฎรฒ %s", GetPlayerNameEx(playerid));
	GivePlayerMoneyEx(to_player, cash, fmt_text, true, true);

	format(fmt_text, sizeof fmt_text, "รรฅรฐรฅรคร รทร  รครฅรญรฅรฃ รจรฃรฐรฎรชรณ %s", GetPlayerNameEx(to_player));
	GivePlayerMoneyEx(playerid, -cash, fmt_text, true, true);

	format(fmt_text, sizeof fmt_text, "%s รฏรฅรฐรฅรคร รซ รร รฌ รครฅรญรผรฃรจ %d รฐรณรก", GetPlayerNameEx(playerid), cash);
	SendClientMessage(to_player, 0x3399FFFF, fmt_text);

	format(fmt_text, sizeof fmt_text, "รรป รฏรฅรฐรฅรคร รซรจ รจรฃรฐรฎรชรณ %s รครฅรญรผรฃรจ %d รฐรณรก", GetPlayerNameEx(to_player), cash);
	SendClientMessage(playerid, 0x3399FFFF, fmt_text);

	Action(playerid, "รครฎรฑรฒร รซ รชรฎรธรฅรซยธรช รจ รฏรฅรฐรฅรคร รซ รครฅรญรผรฃรจ", _, false);

	return 1;
}

CMD:agm(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1)
        return ShowNotificationDefault(playerid, 2, 5, 2, 0, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");

    new fmt_msg[128];
    if(GetPVarInt(playerid, "agm") == 0)
    {
        SetPVarInt(playerid, "agm", 1);
        SetPlayerHealth(playerid, 1000.0); // รรฐรฎรฑรฒรฎ รกรฎรซรผรธรฎรฅ รงรครฎรฐรฎรขรผรฅ

        // รร รฏรณรฑรชร รฅรฌ รฒร รฉรฌรฅรฐ ร รขรฒรฎ-รฐรฅรฃรฅรญรฅรฐร รถรจรจ
        new timerid = SetTimerEx("AGM_HealthRestore", 500, true, "i", playerid);
        SetPVarInt(playerid, "agm_timer", timerid);

        SendClientMessage(playerid, -1, ""SC"รรป รณรฑรฏรฅรธรญรฎ {FFFF00}รขรชรซรพรทรจรซรจ {FFFFFF}ร รครฌรจรญรจรฑรฒรฐร รฒรจรขรญรฎรฅ รกรฅรฑรฑรฌรฅรฐรฒรจรฅ");
        format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รขรชรซรพรทรจรซ ร รครฌรจรญรจรฑรฒรฐร รฒรจรขรญรฎรฅ รกรฅรฑรฑรฌรฅรฐรฒรจรฅ", GetPlayerNameEx(playerid), playerid);
        SendMessageToAdmins(fmt_msg, 0x999999FF);
    }
    else
    {
        SetPVarInt(playerid, "agm", 0);
        SetPlayerHealth(playerid, 100.0);

        KillTimer(GetPVarInt(playerid, "agm_timer"));
        DeletePVar(playerid, "agm_timer");

        SendClientMessage(playerid, -1, ""SC"รรป รณรฑรฏรฅรธรญรฎ {FFFF00}รขรปรชรซรพรทรจรซรจ {FFFFFF}ร รครฌรจรญรจรฑรฒรฐร รฒรจรขรญรฎรฅ รกรฅรฑรฑรฌรฅรฐรฒรจรฅ");
        format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] รขรปรชรซรพรทรจรซ ร รครฌรจรญรจรฑรฒรฐร รฒรจรขรญรฎรฅ รกรฅรฑรฑรฌรฅรฐรฒรจรฅ", GetPlayerNameEx(playerid), playerid);
        SendMessageToAdmins(fmt_msg, 0x999999FF);
    }
    return 1;
}

forward AGM_HealthRestore(playerid);
public AGM_HealthRestore(playerid)
{
    if(!IsPlayerConnected(playerid)) return;

    if(GetPVarInt(playerid, "agm") == 1)
    {
        new Float:hp;
        GetPlayerHealth(playerid, hp);

        if(hp < 100.0)
        {
            SetPlayerHealth(playerid, 100.0);
        }
    }
}

