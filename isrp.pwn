	if(GetPlayerData(to_player, P_JAIL) > 0) return SendClientMessage(playerid, 0xCECECEFF, "รรฒรฎรฒ รจรฃรฐรฎรช รณรฆรฅ รฑรจรครจรฒ รข รฒรพรฐรผรฌรฅ");
