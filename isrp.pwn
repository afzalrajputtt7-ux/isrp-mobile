CMD:permban(playerid, params[])

{
    if(TEST_SERVER == 1) return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}รร รญรญร รฟ รชรฎรฌร รญรคร  รญรฅ รครฎรฑรฒรณรฏรญร  รญร  รรรร รรรรรรร!");
	if(GetPlayerAdminEx(playerid) < 7) return SendClientMessage(playerid, COLOR_GREY, "ร รขร รฑ รญรฅรฒ รครฎรฑรฒรณรฏร  รช รจรฑรฏรฎรซรผรงรฎรขร รญรจรพ รคร รญรญรฎรฉ รชรฎรฌร รญรครป");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /permban [ID รจรฃรฐรฎรชร ] [รฏรฐรจรทรจรญร ]");
	extract params -> new to_player, string:reason[30];
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
	return ShowNotificationDefault(playerid, 2, 5, 2, 0, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ. ");
	new ban_time = 9999;
	new fmt_msg[999];
	if(playerid == to_player)
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รฑร รฌรฎรฌ รฑรฅรกรฅ");

	if(GetPlayerAdminEx(playerid) < GetPlayerAdminEx(to_player))
    return SendClientMessage(playerid, 0xFF5533FF, "รรป รญรฅ รฌรฎรฆรฅรฒรฅ รจรฑรฏรฎรซรผรงรฎรขร รฒรผ รฝรฒรฎ รญร  รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐรฅ รขรปรธรฅ รขร รฑ รฏรฎ รณรฐรฎรขรญรพ");
	if(AntiSliv(playerid, "/permban")) return true;
	format(fmt_msg, sizeof fmt_msg, "รรครฌรจรญรจรฑรฒรฐร รฒรฎรฐ %s รญร รขรฑรฅรฃรคร  รงร รกรซรฎรชรจรฐรฎรขร รซ รจรฃรฐรฎรชร  %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
	if(strlen(reason) > 0)
	format(fmt_msg, sizeof fmt_msg, "%s. รรฐรจรทรจรญร : %s", fmt_msg, reason);
	SendClientMessageToAll(0xFF5533FF, fmt_msg);
	if(!strlen(reason)) reason = "None";
	format(fmt_msg, sizeof fmt_msg, "รร รกร รญรจรซ %s[acc:%d] รญร รขรฑรฅรฃรคร . รรฐรจรทรจรญร  %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);
	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);
	
    AddAdminStat(playerid, "bans_total", P_BANS_TOTAL);
	AddAdminStat(playerid, "bans_today", P_BANS_TODAY);
	
	AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, reason, GetPlayerNameEx(playerid));

	return 1;

}


stock LoadSvetfor()
{
    for(new i; i < sizeof SvetforsPos; i++)
    {
        CreateObject(931, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
        
        if(SvetforsType[i] == 1)
        {
            SvetforsColor[i] = CreateObject(930, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
            SetTimerEx("SvetforsChangeColor", 25000, false, "ddd", i, 1, 0);
        }
        else
        {
            SvetforsColor[i] = CreateObject(928, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
            SetTimerEx("SvetforsChangeColor", 25000, false, "ddd", i, 3, 0);
        }
    }
}

forward SvetforsChangeColor(i, type, step);
public SvetforsChangeColor(i, type, step)
{
    switch(type)
    {
        case 1:
        {
            DestroyObject(SvetforsColor[i]);
            SvetforsColor[i] = CreateObject(929, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
            SetTimerEx("SvetforsChangeColor", 3000, false, "ddd", i, 2, 1);
        }
        case 2:
        {
            DestroyObject(SvetforsColor[i]);
            if(step == 1)
            {
                SvetforsColor[i] = CreateObject(928, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
                SetTimerEx("SvetforsChangeColor", 25000, false, "ddd", i, 3, 0);
            }
            else
            {
                SvetforsColor[i] = CreateObject(930, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
                SetTimerEx("SvetforsChangeColor", 25000, false, "ddd", i, 1, 0);
            }
        }
        case 3:
        {
            DestroyObject(SvetforsColor[i]);
            SvetforsColor[i] = CreateObject(929, SvetforsPos[i][0], SvetforsPos[i][1], SvetforsPos[i][2], 0,0,SvetforsPos[i][3]);
            SetTimerEx("SvetforsChangeColor", 3000, false, "ddd", i, 2, 2);
        }
    }
}


