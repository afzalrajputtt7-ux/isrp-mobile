			"{FFFFFF}รรป รณรขรฅรฐรฅรญรป รทรฒรฎ รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ รฑรขรฎรพ รงร รฏรฐร รขรฎรทรญรณรพ รฑรฒร รญรถรจรพ รฃรฎรฑรณรคร รฐรฑรฒรขรณ?\n\n"\
			"รร รฌ รกรณรครฅรฒ รขรฎรงรขรฐร รนรฅรญร  รฅรฅ รฑรฒรฎรจรฌรฎรฑรฒรผ รงร  รขรปรทรจรฒรฎรฌ 30%\n"\
			"รร รชรฆรฅ รกรณรครฅรฒ รขรฎรงรขรฐร รนรฅรญรฎ 60% รฎรฒ รฑรฒรฎรจรฌรฎรฑรฒรจ รชรณรฏรซรฅรญรญรปรต รณรซรณรทรธรฅรญรจรฉ\n\n"\
			"รรฑรซรจ รรป รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ รงร รฏรฐร รขรฎรทรญรณรพ รฑรฒร รญรถรจรพ รครฐรณรฃรฎรฌรณ รจรฃรฐรฎรชรณ,\n"\
			"รจรฑรฏรฎรซรผรงรณรฉรฒรฅ รชรฎรฌร รญรครณ /sellmyfuelst",
			"รร ", "รรฅรฒ"
		);
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รงร รฏรฐร รขรชรจ");

	return 1;
}

CMD:sellmyfuelst(playerid, params[])
{
	new stationid = GetPlayerFuelStation(playerid);
	if(stationid != -1)
	{
		if(!strlen(params))
			return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /sellmyfuelst [id รจรฃรฐรฎรชร ] [รฑรฒรฎรจรฌรฎรฑรฒรผ]");

		extract params -> new to_player, price;

		if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
			return SendClientMessage(playerid, 0xCECECEFF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

		if(price < 1)
			return SendClientMessage(playerid, 0xCECECEFF, "รรชร รฆรจรฒรฅ รฑรฒรฎรจรฌรฎรฑรฒรผ รฏรฐรฎรคร รฆรจ");

		new Float: f_pos_x = GetFuelStationData(stationid, FS_POS_X);
		new Float: f_pos_y = GetFuelStationData(stationid, FS_POS_Y);
		new Float: f_pos_z = GetFuelStationData(stationid, FS_POS_Z);

		if(GetPlayerMoneyEx(to_player) < price)
			return SendClientMessage(playerid, 0xCECECEFF, "ร รฏรฎรชรณรฏร รฒรฅรซรฟ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รฑรฐรฅรครฑรฒรข");

		if(!(IsPlayerInRangeOfPoint(playerid, 10.0, f_pos_x, f_pos_y, f_pos_z) && IsPlayerInRangeOfPoint(to_player, 10.0, f_pos_x, f_pos_y, f_pos_z)))
			SendClientMessage(playerid, 0xCECECEFF, "รรป รจ รฏรฎรชรณรฏร รฒรฅรซรผ รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รฐรฟรครฎรฌ รฑ รงร รฏรฐร รขรชรฎรฉ รชรฎรฒรฎรฐรณรพ รตรฎรฒรจรฒรฅ รฏรฐรฎรคร รฒรผ");

		SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_FUEL_ST, stationid);
	}
	else SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รงร รฏรฐร รขรชรจ");

	return 1;
}

CMD:fuel(playerid, params[])
{
	new fmt_str[41];
	new string[40 * (MAX_FUEL_STATIONS+2) + 1] = "ยน รรร\t\tรรฒรฎรจรฌรฎรฑรฒรผ 1 รซ\t\tร รญร รซรจรทรจรจ\t\tรร รงรขร รญรจรฅ รรร\n\n{FFFFFF}";

	for(new idx; idx < g_fuel_station_loaded; idx ++)
	{
		format(fmt_str, sizeof fmt_str, "%d\t\t\t%d รฐรณรก\t\t%d รซ\t\t%s\n", idx, GetFuelStationData(idx, FS_FUEL_PRICE), GetFuelStationData(idx, FS_FUELS), GetFuelStationData(idx, FS_NAME));
		strcat(string, fmt_str);
	}
	return Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_LIST, "{FFCD00}รร รฏรฐร รขรฎรทรญรปรฅ รฑรฒร รญรถรจรจ", string, "รร รชรฐรปรฒรผ", "");
}

