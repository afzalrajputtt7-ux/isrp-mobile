#define TUNING_COMFORT 0
#define TUNING_SPORT   1
#define TUNING_SPORT_PL 2
#define TUNING_DRIFT   3

// รร รฑรฑรจรข รครซรฟ รตรฐร รญรฅรญรจรฟ รครฅรฒร รซรฅรฉ รชร รฆรครฎรฉ รฌร รธรจรญรป
// รร รฑรฑรจรข รครซรฟ รตรฐร รญรฅรญรจรฟ รครฅรฒร รซรฅรฉ รชร รฆรครฎรฉ รฌร รธรจรญรป
new VehicleTuning[MAX_VEHICLES][4][5]; // [vehicleid][รฒรจรฏ][รจรญรครฅรชรฑ รครฅรฒร รซรจ]

stock IsPartPurchased(vehicleid, detal_id, type)
{
    for(new i = 0; i < 5; i++)
    {
        if(VehicleTuning[vehicleid][type][i] == detal_id)
            return 1; // true
    }
    return 0; // false
}



stock ApplyTuning(vehicleid)
{
    // COMFORT โ รฅรฑรซรจ รขรฑรฅ 5 รครฅรฒร รซรฅรฉ รชรณรฏรซรฅรญรป, รณรฑรชรฎรฐรฅรญรจรฅ 33
    if(IsAllPartsPurchased(vehicleid, VehicleTuning[vehicleid][TUNING_COMFORT], 5))
        SetVehicleAcceleration(vehicleid, 33.0, 1);

    // SPORT โ รขรฑรฅ 5 รครฅรฒร รซรฅรฉ > รณรฑรชรฎรฐรฅรญรจรฅ 35
    if(IsAllPartsPurchased(vehicleid, VehicleTuning[vehicleid][TUNING_SPORT], 5))
        SetVehicleAcceleration(vehicleid, 35.0, 1);

    // SPORT+ โ รขรฑรฅ 5 รครฅรฒร รซรฅรฉ > รณรฑรชรฎรฐรฅรญรจรฅ 38
    if(IsAllPartsPurchased(vehicleid, VehicleTuning[vehicleid][TUNING_SPORT_PL], 5))
        SetVehicleAcceleration(vehicleid, 38.0, 1);

    // DRIFT โ รฅรฑรซรจ รฅรฑรฒรผ รตรฎรฒรฟ รกรป รฎรครญร  รครฅรฒร รซรผ, รขรชรซรพรทร รฅรฌ รครฐรจรดรฒ
    if(IsAllPartsPurchased(vehicleid, VehicleTuning[vehicleid][TUNING_DRIFT], 5))
        SetVehicleDrift(vehicleid, true);
}


stock SetVehicleDrift(vehicleid, bool:enable)
{
    if (!IsValidVehicle(vehicleid))
        return 0;

    foreach(new playerid : Player)
    {
        SetVehicleDriftForPlayer(playerid, vehicleid, enable);
    }
    return 1;
}

stock SetVehicleDriftForPlayer(playerid, vehicleid, bool:enable)
{
    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT8, 5); // รรครฅรญรฒรจรดรจรชร รฒรฎรฐ รฏร รชรฅรฒร  รครซรฟ รครฐรจรดรฒ-รฐรฅรฆรจรฌร  (case 5u)
    BS_WriteValue(bs, PR_UINT16, vehicleid); // ID รฒรฐร รญรฑรฏรฎรฐรฒรญรฎรฃรฎ รฑรฐรฅรครฑรฒรขร 
    BS_WriteValue(bs, PR_UINT8, enable); // รรชรซรพรทรฅรญรจรฅ/รขรปรชรซรพรทรฅรญรจรฅ รครฐรจรดรฒ-รฐรฅรฆรจรฌร  (0 รจรซรจ 1)

    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
    return 1;
}

stock GetTuningTypeByCase(detal_id)
{
    switch(detal_id)
    {
        case 4, 9, 14, 19, 24: return 0; // COMFORT
        case 5, 10, 15, 20, 25: return 1; // SPORT
        case 6, 11, 16, 21, 26: return 3; // DRIFT
        case 7, 12, 17, 22, 27: return 2; // SPORT+
    }
    return -1; // รญรฅ รญร รฉรครฅรญรฎ
}

