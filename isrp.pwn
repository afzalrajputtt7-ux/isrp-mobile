CMD:dice(playerid, params[])
{
	if(GetPlayerInBiz(playerid) == -1)
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รชร รงรจรญรฎ");

	if(GetBusinessData(GetPlayerInBiz(playerid), B_TYPE) != BUSINESS_TYPE_CASINO)
		return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รข รชร รงรจรญรฎ");

	if(!IsPlayerInRangeOfAnyCasinoTable(playerid)) return SendClientMessage(playerid, 0x999999FF, "รรป รครฎรซรฆรญรป รญร รตรฎรครจรฒรผรฑรฟ รขรฎรงรซรฅ รจรฃรฐร รซรผรญรฎรฃรฎ รฑรฒรฎรซร ");

	extract params -> new to_player, money; else return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /dice [id รจรฃรฐรฎรชร ] [รฑรณรฌรฌร ]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
		return SendClientMessage(playerid, 0x999999FF, "รร รชรฎรฃรฎ รจรฃรฐรฎรชร  รญรฅรฒ");

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 4.0))
		return SendClientMessage(playerid, 0x999999FF, "รรฃรฐรฎรช รญร รตรฎรครจรฒรฑรฟ รฑรซรจรธรชรฎรฌ รคร รซรฅรชรฎ");

	if(!(1 <= money <= 1_000_000))
		return SendClientMessage(playerid, 0x999999FF, "รรณรฌรฌร  รครฎรซรฆรญร  รกรปรฒรผ รญรฅ รกรฎรซรฅรฅ 1.000.000 รฐรณรกรซรฅรฉ");

	if(GetPlayerMoneyEx(playerid) < money)
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รครฅรญรฅรฃ");

	if(GetPlayerMoneyEx(to_player) < money)
		return SendClientMessage(playerid, 0x999999FF, "ร รจรฃรฐรฎรชร  รญรฅรฒ รฒร รชรฎรฃรฎ รชรฎรซรจรทรฅรฑรฒรขร  รครฅรญรฅรฃ");

	SendPlayerOffer(playerid, to_player, OFFER_TYPE_CASINO_DICE, money);

	return 1;
}

CMD:ad(playerid, params[])
{
	if(!GetPlayerPhone(playerid))
		return SendClientMessage(playerid, 0x999999FF, "ร รร รฑ รญรฅรฒ รฒรฅรซรฅรดรฎรญร , รฏรฎ รชรฎรฒรฎรฐรฎรฌรณ รฌรฎรฃรณรฒ รฑ รร รฌรจ รฑรขรฟรงร รฒรผรฑรฟ");

	new fmt_text[144];

	if(IsAIP(params))
	{
   		SendClientMessage(playerid, -1, "รรฎรครฎรงรฐรฅรญรจรฟ รข รฐรฅรชรซร รฌรฅ!");
       	return false;
    }

	for(new idx; idx < g_advert_created; idx ++)
	{
		if(GetAdvertData(idx, A_CREATOR) != playerid) continue;

		format(fmt_text, sizeof fmt_text, "รร รธรฅ รฎรกรบรฟรขรซรฅรญรจรฅ รณรฆรฅ รญร รตรฎรครจรฒรฑรฟ รข รฎรทรฅรฐรฅรครจ รฏรฎรค {00CC99}รญรฎรฌรฅรฐรฎรฌ %d", GetAdvertIndexInQueue(idx));
		SendClientMessage(playerid, 0xCECECEFF, fmt_text);

		
		if(idx)
			SendClientMessage(playerid, 0xCECECEFF, "รรป รฌรฎรฆรฅรฒรฅ รณรฑรชรฎรฐรจรฒรผ รฅรฃรฎ รฏรณรกรซรจรชร รถรจรพ {FF9900}รฑ รฏรฎรฌรฎรนรผรพ รชรฎรฌร รญรครป /up. {CECECE}รรฑรซรณรฃร  รฑรฒรฎรจรฒ {33CCFF}2000 รฐรณรก");
		

		return 1;
	}

	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "รรฑรฏรฎรซรผรงรณรฉรฒรฅ: /ad [รฒรฅรชรฑรฒ รฎรกรบรฟรขรซรฅรญรจรฟ]");

	if(GetPlayerMoneyEx(playerid) < ADVERT_SEND_PRICE)
		return SendClientMessage(playerid, 0x999999FF, "รรซรฟ รฎรฒรฏรฐร รขรชรจ รฎรกรบรฟรขรซรฅรญรจรฟ รญรฅรฎรกรตรฎรครจรฌรฎ รจรฌรฅรฒรผ 250 รฐรณรก");

	SendAdvert(playerid, params);

	GivePlayerMoneyEx(playerid, -250, "รรฒรฏรฐร รขรชร  รฎรกรบรฟรขรซรฅรญรจรฟ", true, true);

	format(fmt_text, sizeof fmt_text, "รรฅรชรฑรฒ: %s", params);
	SendClientMessage(playerid, 0x00CC99FF, fmt_text);

	SendClientMessage(playerid, -1, "รร รธรฅ รฎรกรบรฟรขรซรฅรญรจรฅ รกรปรซรฎ รครฎรกร รขรซรฅรญรฎ รข รฎรทรฅรฐรฅรครผ รครซรฟ รฏรณรกรซรจรชร รถรจรจ");
	SendClientMessage(playerid, -1, "รรฑรฒร รขร รฉรฒรฅรฑรผ รญร  รฑรขรฟรงรจ, รข รฏรฐรฎรฒรจรขรญรฎรฌ รฑรซรณรทร รฅ รฎรกรบรฟรขรซรฅรญรจรฅ รกรณรครฅรฒ รณรคร รซรฅรญรฎ รจรง รฎรทรฅรฐรฅรครจ");
	// SendClientMessage(playerid, -1, "รรป รฌรฎรฆรฅรฒรฅ รณรฑรชรฎรฐรจรฒรผ รฅรฃรฎ รฏรณรกรซรจรชร รถรจรพ {FF9900}รฑ รฏรฎรฌรฎรนรผรพ รชรฎรฌร รญรครป /up. {FFFFFF}รรฑรซรณรฃร  รฑรฒรฎรจรฒ {33CCFF}2000 รฐรณรก");

	return 1;
}

CMD:edit(playerid, params[])
{
	if(GetPlayerTeamEx(playerid) != TEAM_RADIO) return SendClientMessage(playerid, 0x999999FF, "รร รฌ รญรฅรครฎรฑรฒรณรฏรญร  รคร รญรญร รฟ รดรณรญรชรถรจรฟ");
	
	if(!IsWorkDayStarted(playerid)) return 1;

	if(!g_advert_created) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรฒ รฎรกรบรฟรขรซรฅรญรจรฉ รครซรฟ รฐรฅรคร รชรฒรจรฐรฎรขร รญรจรฟ");

	new fmt_text[360],
		bool: ad_is_found;

	for(new idx; idx < g_advert_created; idx ++)
	{
		if(GetAdvertData(idx, A_EDIT) || GetAdvertData(idx, A_CREATOR) == INVALID_PLAYER_ID) continue;

		format
		(
			fmt_text, sizeof fmt_text,
			"{FFFFFF}รรฒรฏรฐร รขรจรฒรฅรซรผ: %s\n\nรรฅรชรฑรฒ:\n{FFCD00}%s\n\n"\
			"{FFFFFF}รรซรฟ รฐรฅรคร รชรฒรจรฐรฎรขร รญรจรฟ รฎรกรบรฟรขรซรฅรญรจรฟ รขรขรฅรครจรฒรฅ รญรฎรขรปรฉ รฒรฅรชรฑรฒ รจ รญร รฆรฌรจรฒรฅ 'รรฒรฏรฐร รขรจรฒรผ'.\n"\
			"รรฑรซรจ รฐรฅรคร รชรฒรจรฐรฎรขร รญรจรฅ รฎรกรบรฟรขรซรฅรญรจรพ รญรฅ รญรณรฆรญรฎ, รฎรฑรฒร รขรผรฒรฅ รฏรฎรซรฅ รฏรณรฑรฒรปรฌ.",
			GetPlayerNameEx(GetAdvertData(idx, A_CREATOR)), GetAdvertData(idx, A_TEXT)
		);

		Dialog(playerid, DIALOG_ADVERT_EDIT, DIALOG_STYLE_INPUT, "{00CC00}รรณรกรซรจรชร รถรจรฟ รฎรกรบรฟรขรซรฅรญรจรฟ", fmt_text, "รรฒรฏรฐร รขรจรฒรผ", "รรฒรชรซรฎรญรจรฒรผ");

		SetAdvertData(idx, A_EDIT, true);

		SetPVarInt(playerid, "advert_id", idx);

		ad_is_found = true;

		break;
	}

	if(!ad_is_found) return SendClientMessage(playerid, 0xCECECEFF, "รรฅรฒ รฎรกรบรฟรขรซรฅรญรจรฉ รครซรฟ รฐรฅรคร รชรฒรจรฐรฎรขร รญรจรฟ");

	return 1;
}

